# HDA
HDA_URL=https://helpdeskgbs.luxottica.com/HDAPortal_GBS/#/Page/APOperator
HDA_USERNAME=
HDA_PASSWORD=
BROWSER_HEADLESS=false
BROWSER_KEEP_OPEN=true
BROWSER_SLOW_MO_MS=0
BROWSER_WINDOW_WIDTH=1600
BROWSER_WINDOW_HEIGHT=1200
BROWSER_BINARY_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
EVIDENCE_ENABLED=false

# Runtime
TIMEZONE=America/Mexico_City
DOWNLOAD_DIR=runtime/downloads
OUTPUT_DIR=runtime/outputs
LOG_DIR=runtime/logs
EVIDENCE_DIR=runtime/evidence
TEMPLATE_PATH=templates/template.xlsx

# Schedule reference
PROCESS_1_RUN_TIME=03:00
PROCESS_2_DELAY_MINUTES=90

# Mail testing
MAIL_TEST_RECIPIENT=your-test-email@example.com
MAIL_PRIMARY_RECIPIENT=
MAIL_SECONDARY_RECIPIENT=
MAIL_FMS_RECIPIENT=
MAIL_AFS_RECIPIENT=
MAIL_USD_RECIPIENT=
MAIL_CAD_RECIPIENT=
MAIL_SUMMARY_RECIPIENT=
MAIL_ERROR_RECIPIENT=
MAIL_BCC_RECIPIENT=
MAIL_SUBJECT_PREFIX=[TEST]

# Mail transport
SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# SAP access
SAP_USERNAME_FMS=
SAP_PASSWORD_FMS=
SAP_USERNAME_AFS=
SAP_PASSWORD_AFS=
SAP_CONNECTION_NAME_FMS=
SAP_CONNECTION_NAME_AFS=
SAP_CLIENT_FMS=500
SAP_CLIENT_AFS=400
SAP_LANGUAGE=EN
SAP_TCODE_FMS=ZFIN_AP_NONPO_LUCY4
SAP_TCODE_AFS=ZFIN_AP_NONPO_LUCY4
SAP_EXECUTABLE_PATH=C:\Program Files (x86)\SAP\FrontEnd\SAPgui\saplogon.exe
