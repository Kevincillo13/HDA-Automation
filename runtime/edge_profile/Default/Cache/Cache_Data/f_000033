Ext.namespace('Portal.Controls');

Ext.define('Portal.Controls.TreeField', {
    extend: 'Ext.net.DropDownField',
    alias: 'widget.treefield',
    requires: ['Ext.selection.Model', 'Ext.data.Store', 'Ext.tree.Panel'],
    entity: null,
    expandOnlySelected: false,
    objectDescriptionUrl: "~/WSCView/GetMultiObjectAndDescription",
    displayOnlyLeafNode: true,
    enableInnerNodeChecking: false,
    enableChildSelectionByParent: true,
    singleSelection: false,

    fieldTypeCls: 'tree-field',

    // tells if component is doing data resolution
    loading: false,

    // tells if is there a pending reset request (it happens when 'formload' event arrives while initla component loading operation is still running)
    resetDirtyPending: false,

    // keeps current value while data resolution is running
    pendingValue: null,

    constructor: function (config) {
        /*
        this.addEvents({
            'checkchanged': true
        });
        */
        this.callParent(arguments);
    },

    initComponent: function () {
        var me = this;

        me.callParent(arguments);

        // set value + text 
        me.mode = "ValueText";
        me.arraySeparator = '|';
      
        this.mon(this, "blur", function () {
            this.refreshPredefinedSolutions();
        });

        this.on('triggerclick', function (item, trigger, index, tag, e) {
            
            if (tag === 'clear') {
                var oldVal = this.getValue();
                this.clear();
                if (this.component.rendered) {
                    this.component.suspendEvents();
                    this.component.clearChecked();
                    this.component.resumeEvents();
                }
                if (oldVal != this.getValue()) {
                    this.fireEvent('select', this);
                }
            }

        });

        me.setComponentReadOnly(me.readOnly);
        
        this.mon(this, 'writeablechange', function (field, read, eOpts) {
            me.setComponentReadOnly(read);
        });

        this.mon(this, 'formload', function () {
            if (this.loading) {
                this.resetDirtyPending = true; // keep track of resetDirty request
            } else {
                this.resetDirty();
            }
        });

        Ext.apply(this.component, {
            //"clearFilter": me.clearFilter,
            "filterTree": me.filterTree
        });

    },

    setupTree: function (tree) {
        var view = tree.getView();

        Ext.apply(view, {
            // disable node checking when node is disabled
            // if our function returns false, the original function is not called
            onCheckChange: Ext.Function.createInterceptor(
                view.onCheckChange,
                function (record) {
                    if (record.get('disabled')) {                        
                        return false;
                    }
                },
                tree)
        });
    },

    getRowClass: function (record, index, rowParams, ds) {
        return record.get('disabled') ? this.disabledCls : '';
    },

    setReadOnly: function (readOnly) {

        this.setComponentReadOnly(readOnly);
        this.callParent([readOnly]);
    },

    setComponentReadOnly: function (readOnly) {
        var me = this,
            configureComponent = function () {
                me.setDisableAllTreeNodes(readOnly);
                //me.component.disabled = !readOnly;
                me.component.getTopToolbar().setDisabled(readOnly);
                me.component.getView().refresh();
                //Workaround: if tree field has no data the drop down is shown wrongly
                if (me.component.getStore().data.length == 0) {
                    me.collapse();
                    me.expand();
                }
            };

        if (me.component.rendered) {
            // if component is ready then configure it immediately
            configureComponent();
            me.getTrigger(0)[readOnly ? 'hide' : 'show']();
        } else {

            // if component isn't ready then configure it when dropdown expands and renders it
            me.addListener('expand', function () {
               
                // wait for store loading in order to get all nodes ready to be disabled
                me.component.getStore().addListener('load', function () {
                    configureComponent();

                    me.component.getView().refresh();
                });
            }, me, { single: true });
        }
        
    },

    setDisableAllTreeNodes: function (disable) {
        // set the "disabled" attribute for all nodes
        this.component.getRootNode().cascadeBy(function (n) { n.data.disabled = disable; });
    },

    treeCheckChange: function (node, checked) {
        var tree = this.component;
        var control = tree.dropDownField;
        var root = node;

        tree.suspendEvents();

        if (control.singleSelection) {
            tree.clearChecked(tree.getRootNode());
            Portal.Controls.TreeField.prototype.toggleCheck(node, checked);
        } else {
            if (control.enableChildSelectionByParent) {
                tree.toggleChecked(node, checked);
            } else {
                Portal.Controls.TreeField.prototype.toggleCheck(node, checked);
            }
        }

        this.fireEvent('checkchanged', this, tree, node, checked);

        tree.resumeEvents();
    },
    toggleCheck: function (node, value) {
        if (node.getUI && node.getUI().rendered) {
            node.getUI().toggleChecked(value);
        } else {
            node.set('checked', value)
        }
    },
    refreshSelection: function () {
        var tree = this.component;
        var me = this;

        if (!tree) return;

        // obtain all checked nodes.
        var checkedNodes = tree.getChecked()/*tree.getCheckedNodes()*/;
        var nodeValue = [];
        var nodeText = [];

        Ext.each(checkedNodes, function (node) {
            // add the Id.
            nodeValue.push(node.getId());
            var text = me.getComboDisplayValue(me.displayOnlyLeafNode, node);

            nodeText.push(text);
        });

        me.setValueBase(nodeValue.join(this.arraySeparator), nodeText, false);

        if (this.getValue() != '')
            this.getTrigger(0).show();
        else
            this.getTrigger(0).hide();

        this.validate();
    },

    onCustomTriggerClick: function (trigger, evt) {
        this.fireEvent("triggerclick", this, trigger, trigger.id, trigger.tag, evt);
    },

    getSelectedID: function () {
        return this.getValue();
    },

    updateTreeSelection: function (val, nodeFn) {
        var me = this,
            tree = me.component,
            store = tree.getStore(),
            value = val || '',
            currentValues = [];

        Ext.each(value.split(me.arraySeparator), function (id) {
            var node = store.getNodeById(id);
            if (node) {
                currentValues.push(id);
                if (Ext.isFunction(nodeFn)) {
                    nodeFn(node);
                }
                tree.expandPath(node.getPath());
            }
        });

        tree.suspendEvents();
        tree.clearChecked();
        tree.setChecked({ ids: currentValues });
        tree.resumeEvents();
    },

    isDirty: function () {
        var originalValue = this.originalValue || '',
            value = this.getValue() || '',
            originalArr = originalValue.toString().split(this.arraySeparator).sort(),
            valueArr = value.toString().split(this.arraySeparator).sort();

        return !Ext.Array.equals(originalArr, valueArr);
    },

    setValueBase: function (value, text, collapse) {
        Portal.Controls.TreeField.superclass.setValue.apply(this, [value, text, false]);
    },

    setValue: function (value, text, collapse) {

        var tree = this.component;
        var me = this;
        value = value || '';

        // Ensure to deal with strings
        if (Ext.isArray(value))
            value = value.join(me.arraySeparator);

        if (!text && value && value != '') {
            me.loadObjectData(value);
            return;
        }
        var values = [];
        if (value && Ext.isDefined(value)) {
            values = value.split(me.arraySeparator);
        }

        var currentValues = [], currentDisplayValues = [];

        if (tree && tree.rendered) {
            if (value && value != '') {

                me.updateTreeSelection(value, function (node) {
                    var text = me.getComboDisplayValue(me.displayOnlyLeafNode, node);
                    currentValues.push(node.getId());
                    currentDisplayValues.push(text);
                });

            } else {
                
                if (!Ext.isEmpty(tree.getSelectedNodes())) {
                    tree.suspendEvents();
                    tree.clearChecked();
                    tree.resumeEvents();
                }
            }

            Portal.Controls.TreeField.superclass.setValue.apply(me,
                [currentValues.join(this.arraySeparator), currentDisplayValues, false]);
        } else {
            Portal.Controls.TreeField.superclass.setValue.apply(me,
                [value, text, false]);
        }

        this.validate();
    },

    getValue: function () {
        if (this.loading) {
            return this.pendingValue;
        }
        return this.callParent();
    },

    getComboDisplayValue: function (displayOnlyLeafNode, node) {
        if (displayOnlyLeafNode)
            return Portal.Util.htmlDecode(node.data.text);
        else {
            return this.getHierarchyDescription(node, "", 1);
        }
    },

    getHierarchyDescription: function (node, description, depth) {
        if (depth == 1)
            description = Portal.Util.htmlDecode(node.data.text);
        else
            description = Portal.Util.htmlDecode(node.data.text) + " > " + description;

        if (node.parentNode && node.parentNode.data && node.parentNode.data.id != "#ROOT#") {
            if (depth >= 4)
                description = "... > " + description;
            else
                return this.getHierarchyDescription(node.parentNode, description, depth + 1);
        }

        return description;
    },

    loadObjectData: function (newValue, callback) {

        var rec = {}, oldValue = this.getValue();
        var me = this;

        me.loading = true;
        me.pendingValue = newValue;

        Ext.Ajax.request({
            url: Portal.Util.Url.buildAbsolutePath(me.objectDescriptionUrl),
            method: 'POST',
            scope: this,
            params: {
                ids: newValue,
                entity: this.entity
            },
            success: function (response, options) {
                me.loading = false;
                me.pendingValue = null;

                // Ajax request OK
                var responseObj = Ext.decode(response.responseText);
                if (responseObj.success) {

                    var values = me.extractValuesFromLoadResults(responseObj.data, newValue.toString().split(me.arraySeparator));

                    me.setValue(values.ids.join(this.arraySeparator), values.displayValues);

                    me.refreshPredefinedSolutions();

                    if (me.resetDirtyPending) {
                        me.resetDirty();
                        me.resetDirtyPending = false;
                    }

                    if (Ext.isFunction(callback)) callback(responseObj);

                    //me.setDisabled(me.disabled);
                } else {
                    Portal.Console.error('treefield description loading ko: ' + response.data);
                }
            },
            failure: function (response, options) {
                me.loading = false;
                // Ajax request KO
                Portal.Console.error('object link loading call ko: ' + response.status + ' ' + response.statusText);
            }
        });
    },

    extractValuesFromLoadResults: function (results, originalIDs) {
        var values = [];
        var displayValues = [];

        if (!Ext.isArray(results)) results = [results];
        if (!Ext.isArray(originalIDs)) originalIDs = [originalIDs];
        
        // transform data array into dictionary of {ID, Obj} pairs
        var resultsObj = {};
        _.each(results, function (result) {
            resultsObj[result.ID] = result;
        });

        var resultObj;

        // extract ids and values, preserving the original ids order
        // we need this to prevent the tree from returning a different value compared to the previous one
        // when the response items order is different from the original ids one
        _.each(originalIDs, function (originalID) {
            resultObj = resultsObj[originalID];

            if (resultObj) {
                values.push(resultObj.ID);
                displayValues.push(resultObj.ObjectDescription);
            }
        });

        return {
            ids: values,
            displayValues: displayValues
        };
    },

    onTriggerClick: function () {
        if (this.isExpanded) {
            this.collapse();
        } else {
            this.onFocus({});
            this.expand();
        }

        this.el.focus();

        var searchField = this.component.getTopToolbar().getComponent('searchField');
        if (searchField) {
            searchField.clear();
            this.component.clearFilter();
            searchField.focus();
        }
    },

    /**
        Reloads the tree "store".
    */
    reload: function () {
        var tree = this.component;

        if (!tree || !tree.rendered) return;

        this.clearValue();

        // refresh not required.
        if (tree.getRootNode() == null) return;


        tree.getRootNode().reload();
    },

    refreshPredefinedSolutions: function () {
        var tb = Ext.getCmp("tbPredefinedSolutions");

        if (!tb) return;

        var button = tb.items.get(0);

        if (!button) return;

        button.setDisabled(true);

        var form = this.findParentByType('form').getForm();

        Ext.Ajax.request({
            url: Portal.Const.Url.BASE_APP_URL + "Ticket/AvailableTicketCategorySolutions",
            method: 'POST',
            params: {
                TicketCategoryID: this.getUnderlyingValueField().value
            },
            success: function (response, opts) {
                // refresh solutions.
                var json = Portal.Util.Json.decode(response.responseText, true);

                if (json != null && json.data != null && json.data.length > 0) {
                    button.setDisabled(false);
                    button.setIconClass("icon-lightbulb");
                    button.getEl().frame();

                    // add items...
                    button.menu.removeAll();

                    Ext.each(json.data, function (itm) {
                        button.menu.addMenuItem({ text: itm.Subject, customData: itm });
                    });


                    button.menu.on("click", function (menu, item, b) {
                        // setup subject/prolem/sol
                        var customData = item.customData;

                        var problem = form.findField('Problem');
                        var solution = form.findField('Solution');
                        var subject = form.findField('Subject');

                        if (problem && Ext.isEmpty(problem.getValue()) && !Ext.isEmpty(customData.Problem)) problem.setValue(customData.Problem);
                        if (solution && Ext.isEmpty(solution.getValue()) && !Ext.isEmpty(customData.Solution)) solution.setValue(customData.Solution);
                        if (subject && Ext.isEmpty(subject.getValue()) && !Ext.isEmpty(customData.Subject)) subject.setValue(customData.Subject);
                    });

                }
                else {
                    button.setIconClass("icon-lightbulboff");
                    button.setDisabled(true);
                }
            },
            failure: function (response, opts) {
                // failure code
                Portal.PageManager.showErrorMsg("Errore durante l'operazione");
            }
        });
    },

    filterTree: function (item, e) {
        var tree = item.findParentByType('treepanel'/*'nettreepanel'*/);
        var text = item.getValue();

        tree.clearFilter();

        if (Ext.isEmpty(text, false)) {
            return;
        }

        var re = new RegExp(".*" + text + ".*", "i");
        var selected = {};

        tree.filterBy(function (node) {
            var isSelected = re.test(node.data.text);
            if (!isSelected && node.parentNode) {
                if (!Ext.isEmpty(selected[node.parentNode.data.id])) isSelected = true;
            }

            if (isSelected) selected[node.data.id] = node.data.id;

            return isSelected;
        });

    },

    clearFilter: function (item, trigger, index, tag, e) {
        var tree = item.findParentByType('treepanel');
        item.setValue("");
        tree.clearFilter();
    },

    selectAll: function (item, e) {
        var tree = item.findParentByType('treepanel');
        tree.toggleChecked(tree.getRootNode(), true);
    },

    clearAll: function (item, e) {
        var tree = item.findParentByType('treepanel');
        tree.suspendEvents();
        tree.clearChecked(tree.getRootNode());
        tree.dropDownField.clear();
        tree.resumeEvents();
    },

    isInitializing: function () {
        return this.initializing;
    },

    setSearchFilter: function (newFilter) {
        var me = this;
        Portal.Console.log(['Tree Field', 'Set search filter', this.id, newFilter]);

        if (!Ext.isArray(newFilter)) newFilter = [newFilter];
        var searchFilters = [];
        searchFilters = Portal.Util.mergeFilterArrays(newFilter, searchFilters);

        if (me.component.store && me.component.store.proxy) {
            me.component.store.proxy.url = Portal.Util.Url.applyQSParameter({
                url: me.component.store.proxy.url,
                paramName: "searchFilters",
                paramValue: Ext.isEmpty(searchFilters) ? "" : Portal.Util.Json.encode(searchFilters),
                appendIfNotExists: true
            });
            me.reload();
        }
    },

    autoResolve: function (filter) {
        //do nothing
    }
});

