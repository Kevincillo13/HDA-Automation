// definito qui per fare in modo di scaricare un file unico come risorsa del control TreeFieldAsync a causa di problemi nel caso di risorse multiple
Ext.define('Portal.Controls.TreeFieldAsync', {
    extend: 'Portal.Controls.TreeField',
    requires: ['Portal.Controls.TreeField'],
    alias: 'widget.treefieldasync',

    // tells if tree store is loading
    treeLoading: false,

    setValue: function (value, text, collapse) {
        var tree = this.component;
        var me = this;
        value = value || '';
        
        if (tree && tree.rendered) {
            // update tree and set value
            me.setTreeValue(value, text);

        } else {

            // resolve value by loading object description
            if (!text && value && value != Portal.Const.EMPTY_ID) {
                me.loadObjectData(value);
                return;
            }
            me.setValueBase(value, text, false);
        }

        this.validate();
    },

    setTreeValue: function (value, text) {

        var me = this,
            tree = me.component;

        if (value && value != Portal.Const.EMPTY_ID) {
            if (!me.treeLoading) {

                // reload tree
                tree.suspendEvents();
                tree.clearChecked();
                tree.resumeEvents();

                me.treeLoading = true;
                me.loading = true;
                me.pendingValue = value;

                // reload tree data and then load selected object(s) description(s)

                tree.getStore().reload({
                    callback: function () {
                        if (value && value != Portal.Const.EMPTY_ID) {
                            me.loadObjectData(value, function () { me.treeLoading = false; });
                        } else {
                            me.setValue(Portal.Const.EMPTY_ID);
                            me.treeLoading = false;
                        }
                    }
                });

            } else {
                me.setValueBase(value, text, false);
            }
        } else {

            // empty value
            // set control value and update tree selection (clear checkboxes)

            me.setValueBase(value, text, false);
            me.updateTreeSelection(value);
        }

    },

    getComboDisplayValue: function (displayOnlyLeafNode, node) {
        if (displayOnlyLeafNode)
            return node.data.text;
        else {
            // build hierarchy description
            return this.getNodeHierarchyDescription(node);
        }
    },

    getNodeHierarchyDescription: function (node) {
        var descriptions = [node.get('text')];
        while (node.parentNode && !node.parentNode.isRoot()) {
            node = node.parentNode;
            descriptions.push(node.get('text'));
        }
        return descriptions.reverse().join(' > ');
    },

    treeCheckChange: function (node, checked) {

        var tree = this.component;
        var control = tree.dropDownField;

        if (checked && control.enableChildSelectionByParent && !node.isLeaf() && !node.isLoading() && !node.get('fullyloaded')) {

            node.set('checked', false);

            // load entire node subtree and check its nodes
            tree.getStore().reload({
                node: node,
                params: { Levels: "0" },
                callback: function (nodes) {
                    node.set('fullyloaded', true);

                    if (nodes.length > 0) {

                        Ext.each(nodes, function (n) {
                            n.cascadeBy(function (childNode) { if (!childNode.isLeaf()) { childNode.set('fullyloaded', true); childNode.expand(); } }, this);
                            n.expand();
                        });
                    }

                    tree.toggleChecked(node, true);

                }
            });

            return;
        }

        this.callParent([node, checked]);
    },

    onNodeLoad: function () {
        var store = this.component.getStore(),
            node = store.getById(store.lastOptions.node.id);

        if (node) node.set('fullyloaded', true);
    }
});

Portal.Controls.TreeField.Functions = {

    // ensures that if a node is checked then its parent, ancestors and children are not checked
    exclusiveParentChildrenSelection: function (control, tree, node, checked) {
        if (checked) {
            var currentNode = node;

            // uncheck parent node if current node is selected
            tree.suspendEvents();

            while (currentNode.parentNode) {
                var parentData = currentNode.parentNode.getData();
                if (parentData && parentData.checked) {

                    Portal.Controls.TreeField.prototype.toggleCheck(currentNode.parentNode, false);

                }
                currentNode = currentNode.parentNode;
            }

            tree.resumeEvents();

            // uncheck children nodes if current node is selected
            if (node.childNodes.length > 0) {
                tree.suspendEvents();
                Ext.each(node.childNodes, function (childNode) {
                    tree.toggleChecked(childNode, false);
                });
                tree.resumeEvents();
            }
        }
    }

};