Portal.Date = new function () {

    // Current Date With Time Information
    this.now = function () {
        return new Date();
    };

    // Current Date Without Time Information
    this.currentDate = function () {
        var now = new Date(),
            dd = now.getDate(),
            mm = now.getMonth(),
            yyyy = now.getFullYear();

        return new Date(yyyy, mm, dd, 0, 0, 0, 0);
    };

    this.rangeCheck = function (sourceControl, targetControl, params) {
        var startDate = sourceControl.getValue(),
            endDate = targetControl.getValue()
            ;

        // if one of the values is not a Date instance then clear invalid state and skip date range check
        if (!(startDate instanceof Date) || !(endDate instanceof Date)) {
            return true;
        }

        // Check if the dependency allows the values to be equal
        if (params && params.AllowEquals && params.AllowEquals.Value && params.AllowEquals.Value.toLowerCase() == "true") return (sourceControl.getValue() <= targetControl.getValue());

        return (sourceControl.getValue() < targetControl.getValue());
    };

};

Portal.Util = new function () {

    this.generateUUID = function () {
        var d = new Date().getTime();
        var uuid = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
            var r = (d + Math.random() * 16) % 16 | 0;
            d = Math.floor(d / 16);
            return (c == 'x' ? r : (r & 0x7 | 0x8)).toString(16);
        });
        return uuid;
    };

    /**
     * Clone an object.
     * IMPORTANT: this function makes a SHALLOW COPY of the object, any nested object or array will be copied by reference.
     * @param {any} o - The object to clone
     * @returns {any} - The cloned object
     */
    this.cloneObj = function (o) {
        return _.clone(o);
    };

    this.getDefaultModalViewSize = function () {
        var viewDim = this.getCurrentViewSize();

        var ratio = Portal.Const.UI.DefaultWindowRatio;
        var w, h;
        if (ratio) {
            var a = ratio.split("x").map(function (x) { return parseFloat(x) });
            w = a[0];
            h = a[1];
        } else {
            w = 0.65; //default values
            h = 0.65; //default values
        }

        var dim = { height: viewDim.height * h, width: viewDim.width * w };

        var isTooSmall = (dim.height < 500 || dim.width < 800);

        if (!isTooSmall) return dim;

        // if a popup is too small then take 90% of the viewport size
        return {
            height: viewDim.height * 0.9,
            width: viewDim.width * 0.9
        };
    };

