                        isEmpty = false;
                        return false; // exit for each loop
                    }
                });
            }

            return isEmpty;
        }
    };

    this.areFilterConditionsEmpty = function (conditions) {
        for (var i = 0; i < conditions.length; i++) {
            if (this.filterConditionHasValue(conditions[i])) {
                return false;
            }
        }
        return true;
    };

    this.toArrayFilter = function (filter) {
        if (this.isArrayFilter(filter)) return filter;
        if (this.isEmptyFilter(filter)) return [];

        if (this.isComplexFilter(filter)) {
            if (filter.type == 'AND' && !Ext.isEmpty(filter.conditions) && Ext.isEmpty(filter.subfilters)) {
                return filter.conditions;
            }
        }

        throw new Error('Invalid filter! Complex filters with only 1st level AND conditions can be converted into array filters.');
    };

    this.toComplexFilter = function (filter) {
        if (this.isComplexFilter(filter)) return filter;
        if (this.isEmptyFilter(filter)) return { type: 'AND', conditions: [], subfilters: [] };

        if (this.isArrayFilter(filter)) {
            return { type: 'AND', conditions: filter, subfilters: [] };
        }

        throw new Error('Invalid filter! Only array filters can be converted into complex filters.');
    };

    this.removeEmptyFilters = function (filters) {

        if (this.isArrayFilter(filters)) {

            var result = [];
            filters = filters || [];
            for (var i = 0; i < filters.length; i++) {
                //if (filters[i].value != null && typeof (filters[i].value) != "undefined" && filters[i].value.toString() != '' && filters[i].value.toString() != Portal.Const.EMPTY_ID && /\S/.test(filters[i].value.toString())) {
                if (this.filterConditionHasValue(filters[i])) {
                    result.push(filters[i]);
                }
            }
            return result;

        } else if (this.isComplexFilter(filters)) {

            var result = _.clone(filters);
            var me = this;

            // ...else clear advanced filter object recursively
            var removeEmptyFiltersRecursive = function (filter) {

                // clear empty filters in filter's conditions
                if (filter.conditions) {
                    filter.conditions = me.removeEmptyFilters(filter.conditions);
                }

                // clear subfilters recursive
                if (filter.subfilters) {
                    filter.subfilters.forEach(function (item) {
                        removeEmptyFiltersRecursive(item);
                    });
                }
            }

            removeEmptyFiltersRecursive(result);

            return result;
        }
    };

    this.isArrayFilter = function (filter) {
        return Ext.isArray(filter);
    };

    this.isComplexFilter = function (filter) {
        return Ext.isObject(filter);
    };

    this.sortComplexFilters = function (a, b) {

        var me = this;

        var sortComplexFiltersRecursive = function (a, b) {

            var isAEmpty = me.isEmptyFilter(a),//(Object.keys(a).length == 0),
                isBEmpty = me.isEmptyFilter(b),//(Object.keys(b).length == 0),
                areBothEmpty = (isAEmpty && isBEmpty);

            // check if both empty
            if (areBothEmpty) return 0;

            // check if one empty
            if (isAEmpty) return -1;
            if (isBEmpty) return -1;

            // check types
            var typeSort = a.type.localeCompare(b.type);
            if (typeSort != 0) return typeSort;

            // check conditions
            if (a.conditions.length != b.conditions.length) return (a.conditions.length - b.conditions.length);

            a.conditions.sort(function (a, b) { if (a.property > b.property) return 1; if (a.property < b.property) return -1; return 0; });
            b.conditions.sort(function (a, b) { if (a.property > b.property) return 1; if (a.property < b.property) return -1; return 0; });

            var f1, f2, comparison;
            for (var i = 0, l = a.conditions.length; i < l; i++) {
                f1 = a.conditions[i];
                f2 = b.conditions[i];

                comparison = Portal.Util.compareFilterConditions(f1, f2);
                if (comparison != 0) return comparison;
            }

            // check subfilters
            if (a.subfilters.length != b.subfilters.length) return (a.subfilters.length - b.subfilters.length)

            a.subfilters.sort(function (a, b) { me.sortComplexFilters(a, b); });
            b.subfilters.sort(function (a, b) { me.sortComplexFilters(a, b); });

            var s1, s2;
            for (var i = 0, l = a.subfilters.length; i < l; i++) {
                s1 = a.subfilters[i];
                s2 = b.subfilters[i];

                var sortSubfilters = sortComplexFiltersRecursive(s1, s2);
                if (sortSubfilters != 0) return sortSubfilters;
            }

            return 0;
        }

        return sortComplexFiltersRecursive(a, b);
    };

    this.areFiltersDifferent = function (filter1, filter2) {
        var f1 = _.clone(filter1);
        var f2 = _.clone(filter2);

        if (Ext.isArray(f1) && Ext.isArray(f2)) return this.areFilterArraysDifferent(f1, f2);

        return (this.sortComplexFilters(f1, f2) != 0);
    };

    this.sortFilterArrays = function (filters1, filters2) {
        // check conditions count
        if (filters1.length != filters2.length) return (filters1.length - filters2.length);

        // sort conditions by property name
        filters1.sort(function (a, b) { if (a.property > b.property) return 1; if (a.property < b.property) return -1; return 0; });
        filters2.sort(function (a, b) { if (a.property > b.property) return 1; if (a.property < b.property) return -1; return 0; });

        // compare conditions
        var f1, f2, comparison;
        for (var i = 0, l = filters1.length; i < l; i++) {
            f1 = filters1[i];
            f2 = filters2[i];

            comparison = Portal.Util.compareFilterConditions(f1, f2);
            if (comparison != 0) return comparison;
        }

        return 0;
    };

    this.areFilterArraysDifferent = function (filters1, filters2) {
        return (this.sortFilterArrays(filters1, filters2) != 0);
    };

    this.compareFilterConditions = function (f1, f2) {

        if (f1.property != f2.property) {
            return f1.property.localeCompare(f2.property);
        }

        if (f1.op != f2.op) {
            return f1.op.localeCompare(f2.op);
        }

        if (f1.value != f2.value) {
            return (f1.value > f2.value ? 1 : -1);
        }

        if (f1.extKey || f2.extKey) {
            f1.extKey = f1.extKey || '';
            f2.extKey = f2.extKey || '';

            return f1.extKey.localeCompare(f2.extKey);
        }

        if (f1.parameterControlId || f2.parameterControlId) {
            f1.parameterControlId = f1.parameterControlId || '';
            f2.parameterControlId = f2.parameterControlId || '';

            return f1.parameterControlId.localeCompare(f2.parameterControlId);
        }

        return 0;
    };

    /**
     * Clone a filter
     * This function implements a DEEP COPY, making a copy of all properties and nested objects.
     * @param {Array|Object} filter - The filter to clone
     * @returns {Array|Object} - The cloned filter
     */
    this.cloneFilter = function (filter) {
        var clonedFilter;

        if (Portal.Util.isComplexFilter(filter)) {
            // clone complex filter

            clonedFilter = {};

            clonedFilter.type = filter.type;
            clonedFilter.conditions = Portal.Util.cloneFilter(filter.conditions);

            if (filter.subfilters) {
                clonedFilter.subfilters = [];
                _.each(filter.subfilters, function (subfilter) {
                    clonedFilter.subfilters.push(Portal.Util.cloneFilter(subfilter));
                });
            }

        } else {
            // clone filter array

            clonedFilter = [];

            _.each(filter, function (f) {
                clonedFilter.push(Portal.Util.cloneObj(f));
            });
        }

        return clonedFilter;
    };

    /**
    * Builds a function that evaluates a param value in the specified context.
    */
    this.closureFnFactory = function (context) {
        return function (value) {
            var ctx = context;
            var fs = 'function () { with(this){ return ' + value + ';}; }';
            var f = eval('[' + fs + ']')[0];
            var result = f.call(ctx);
            return result;
        };
    };

    /**
    * Builds the passed in server params, evaluating the "raw" parameters' values.
    * @param {Object} context The context wherein evaluate params values.
    * @return {Object} resultObj An object in the form {"paramName": "paramValue", ...}
    */
    this.buildParams = function (params, context) {
        var resultObj = {},
            paramName,
            paramInfo,
            paramValue,
            paramObj = params || {},
            // Function that evaluates a param value in the specified context.
            evalFn = function (context) {
                return function (value) {
                    var ctx = context;
                    var fs = 'function () { with(this){ return ' + value + ';}; }';
                    var f = eval('[' + fs + ']')[0];
                    var result = f.call(ctx);
                    return result;
                };
            }(context);

        for (paramName in paramObj) {
            paramInfo = paramObj[paramName];
            if (paramInfo.Mode && paramInfo.Mode == 'raw') {

                if (Ext.isFunction(paramInfo.Value)) {
                    paramValue = paramInfo.Value.call();
                } else {
                    // param mode "raw", evaluate param value expression
                    paramValue = evalFn(paramInfo.Value);
                }
            } else {
                // param mode "value", copy value as is
                paramValue = paramInfo.Value;
            }
            resultObj[paramName] = paramValue;
        }
        return resultObj;
    };

