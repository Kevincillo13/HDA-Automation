Portal.Error = new function () {

    var MAX_ERRORS_NUMBER = 50;

    var _flushing = false;

    // Global error handling
    Ext.define('ErrorLog', {
        extend: 'Ext.data.Model',
        fields: ['Username', 'Userid', 'Timestamp', 'ActiveModuleUrl', 'Browser', 'Message', 'Data', 'Stack'],
        proxy: {
            type: 'localstorage',
        }
    });

    var store = Ext.create('Ext.data.Store', {
        id: 'ErrorLogStore',
        model: "ErrorLog",
        autoload: true
    });

    var loadStore = function () {
        store.proxy.id = Portal.Const.Url.APP_VIRTUAL_PATH + "_ErrorLog";
        store.reload();
    };

    return {

        getSyncInterval: function () {
            return (Portal.Const.Diagnostics.ClientErrSyncInterval * 1000);
        },

        isSyncEnabled: function () {
            return (this.getSyncInterval() > 0);
        },

        trace: function (errorMsg, errorData, stack) {

            if (!this.isSyncEnabled()) return;

            if (store.getCount() < MAX_ERRORS_NUMBER) {
                var activeModuleUrl;

                try {

                    if (!stack) {
                        // Try to get current stack 
                        var err = new Error();
                        stack = err.stack;
                    }

                    // get current active tab url
                    var tab = Portal.PageManager.getTabContainer().getActiveTab();
                    if (tab) activeModuleUrl = tab.history.hash;

                } catch (e) {

                }

                // Initialize localstorage store
                loadStore();
                store.sync();

                var now = new Date();
                var log = new Ext.create('ErrorLog', {
                    Timestamp: Ext.Date.format(now, 'Y-m-d G:i:s P'),
                    Message: errorMsg,
                    Data: Portal.Util.Json.encode(errorData),
                    Stack: stack,
                    Userid: Portal.Const.LoggedUser.ID,
                    Username: Portal.Const.LoggedUser.Username,
                    ActiveModuleUrl: activeModuleUrl,
                    Browser: Ext.browser.userAgent
                });

                var logEntry = store.add(log);
                store.sync();

                return logEntry[0];
            }
        },

        traceResponse: function (errorMsg, response, stack) {

            var requestUrl;
            var requestParams;
            var responseStatus = response.status || 0;
            var responseStatusText = response.statusText || '';
            var responseText = (response.responseText ? response.responseText.substring(0, 10000) : '');
            var responseHeaders = (response.getAllResponseHeaders ? response.getAllResponseHeaders() : {});
            var contentType;

            errorMsg = errorMsg || '';

            if (response.request) {
                if (response.request.options) {
                    requestUrl = (response.request.options ? response.request.options.url : '');
                    requestParams = (response.request.options ? response.request.options.params : '');
                }
            }

            if (responseStatus == 0) {
                // connection failure

                if (response.timedout) errorMsg += ' - RESPONSE TIMEOUT';
                if (response.aborted) errorMsg += ' - RESPONSE ABORTED';
            }

            if (responseHeaders) {
                contentType = responseHeaders['content-type'];
            }

            var errorData = {
                RequestUrl: requestUrl,
                RequestParams: requestParams,
                ResponseStatus: responseStatus,
                ResponseStatusText: responseStatusText,
                ResponseText: responseText,
                ResponseContentType: contentType
            };

            var msg = `${errorMsg}\n\n${stack}`
            Portal.Console.error(msg);

            return this.trace(errorMsg, errorData, stack);
        },

        flushQueue: function () {
            if (!this.isSyncEnabled()) return;

            if (!_flushing) {
                _flushing = true;

                try {
                    var i = 0;

                    // Initialize localstorage store
                    loadStore();

                    Ext.each(store.getRange(), function (model) {
                        var log = model.data;
                        //var dataSerialized = JSON.stringify(log, null, 2);

                        Ext.Ajax.request({
                            url: Router.action('Error', 'ClientNotification'),
                            jsonData: { errorData: log },
                            async: false,
                            method: 'POST',
                            success: function (response, options) {
                                store.remove(model);
                                store.sync();
                            },
                            failure: function (response, options) {
                                //  TODO - show error
                                Portal.Util.Console.log("Error during client error notification!");

                            }
                        });

                        i++;

                        // Send 5 exceptions maximum at time.
                        if (i >= Portal.Const.Diagnostics.ClientErrSyncGroupSize)
                            return false;
                    });

                }
                catch (e) {

                }

                _flushing = false;
            }
        }
    };
};

