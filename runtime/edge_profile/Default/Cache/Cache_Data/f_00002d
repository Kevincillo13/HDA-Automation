        var ieMissingDateFormat = /^\d{4}-\d\d-\d\d \d\d:\d\d:\d\d$/i;

        return typeof stringDate === 'string' &&
            stringDate.length === 19 &&
            ieMissingDateFormat.test(stringDate);
    };

    var parseIEMissingDateFormat = function (stringDate) {

        var ieMissingDateFormatSplitter = /^\s*(\d{4})-(\d\d)-(\d\d) (\d\d):(\d\d):(\d\d)\s*$/,
            parts = ieMissingDateFormatSplitter.exec(stringDate),
