    this.Element = new function () {

        /**
        * Navigate the element hierarchy up looking for the specified attribute and return its value
        */
        this.findAttributeValue = function (el, attributeName) {

            var attribute = el.getAttribute(attributeName);

            if (!attribute) {
                var foundEl = el.up("[" + attributeName + "]");

                if (foundEl != null) {
                    attribute = foundEl.getAttribute(attributeName);
                }
            }

            return attribute;
        };

    };

    this.Tree = new function () {

        this.regexClsSplit = new RegExp("\\s+");

        this.getNodeCls = function (node) {

            var nodeCls = node.data.cls || '';

            nodeCls = nodeCls.toLowerCase().trim();

            var classes = nodeCls ? nodeCls.split(this.regexClsSplit) : [];

            return classes;
        };

        this.addNodeCls = function (node, cls) {

            cls = cls.toLowerCase();

            var classes = this.getNodeCls(node);

            if (classes.indexOf(cls) === -1) classes.push(cls);

            if (classes.length > 0) {
                node.data.cls = classes.join(' ');
            }
        };

        this.removeNodeCls = function (node, cls) {

            cls = cls.toLowerCase();

            var classes = this.getNodeCls(node);

            if (classes.length === 0 || classes.indexOf(cls) === -1) return;

            for (var i = classes.length - 1; i >= 0; i--) {
                if (classes[i] === cls) {
                    classes.splice(i, 1);
                }
            }

            node.data.cls = classes.join(' ');
        };

    };

    this.FloatingComponent = new function () {

        this.isCurrentActiveCmp = function (floatingCmp) {
            return (floatingCmp === Ext.WindowManager.getActive());
        };

        /**
         * Checks if the specified floating component (window, floating panel) owns the click event.
         * This is useful to understand if an external click happened, to fire events like auto-close or similar for floating components.
         * 
         * @param {any} floatingCmp The floating component
         * @param {any} clickEvent The click event
         * 
         * @returns {boolean} True if component owns click event, false otherwise.
         */
        this.ownsClick = function (floatingCmp, clickEvent) {

            var clickTargetEl = clickEvent.getTarget();

            var ownClick = floatingCmp.owns(clickTargetEl);

            if (!ownClick) {

                // try to see if click comes from a child "detached" component (eg: a component into a dataview, ...)

                var clickRootCmp = this.findClickOwnerRootCmp(clickTargetEl);

                if (clickRootCmp) {
                    ownClick = Ext.fly(clickRootCmp.el).up('#' + floatingCmp.el.id) !== null;
                }

            }

            // webix compoenent inside ext?
            var webixControl = $$(clickTargetEl);
            if (!ownClick && webixControl) {

                var getExtContainerRecursive = function (control) {
                    // test control
                    if (control.config.getExtContainer) { return control.config.getExtContainer(); }
                    // get top parent
                    var topControl = control.getTopParentView();
                    if (topControl.config.getExtContainer) { return topControl.config.getExtContainer(); }
                    // test master control
                    if (topControl.config.master) {
                        var master = $$(topControl.config.master);
                        if (master) {
                            return getExtContainerRecursive(master);
                        }
                    }
                };

                var extContainer = getExtContainerRecursive(webixControl);
                if (extContainer) {
                    ownClick = floatingCmp.owns(extContainer.el);
                }
            }

            return ownClick;
        };

        /**
         * Tells if the click event must be ignored (for auto-close purposes).
         * 
         * @param {any} clickEvent - The click event
         * @returns {boolean} - True if the click event must be ignored, false otherwise.
         */
        this.autoCloseIgnoreClick = function (clickEvent) {
            var clickTargetEl = clickEvent.getTarget();

            var clickRootCmp = this.findClickOwnerRootCmp(clickTargetEl);

            // ignore toast message clicks
            return (clickRootCmp && (clickRootCmp.xtypesMap['toast'] || clickRootCmp.xtypesMap['infopanel']));
        };

        /**
         * Finds the root owner component for the specified click target element.
         * 
         * @param {Object} clickTargetEl - The click target element (Ext.Element)
         * @returns {Object} - The root owner component.
         */
        this.findClickOwnerRootCmp = function (clickTargetEl) {

            // find the component the click target el belongs to
            var clickTargetCmp = Ext.Component.fromElement(clickTargetEl);

            if (clickTargetCmp) {
                var containerCmp = clickTargetCmp.up();

                // up to the root component
                while (containerCmp) {
                    clickTargetCmp = containerCmp;
                    containerCmp = clickTargetCmp.up();
                }
            } else {
                // try to check if el is somehow a webix component related el (suggest list, ...)
                var clickCmp = $$(clickTargetEl);
                if (clickCmp) {
                    var parentCmp = clickCmp.getTopParentView();
                    if (parentCmp) {
                        var masterCmp = $$(parentCmp.config.master);

                        if (masterCmp) {
                            clickTargetCmp = Ext.Component.fromElement(masterCmp.$view);
                        }
                    }
                }
            }

            return clickTargetCmp;
        };

    };

};

