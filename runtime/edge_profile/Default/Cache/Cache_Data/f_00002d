                        callback.call(cmp, ctx);
                    } catch (e) {
                        Portal.Console.error('onContext ready callback error');
                        if (ctx) Portal.Console.error('Context name: ' + ctx.contextName);
                        if (e.message) Portal.Console.error('Error message: ' + e.message);
