/**
 * Plupload - File Extension to Exclude Filter
 */
if (this.plupload) {

    plupload.addFileFilter('mime_types_exclude', function (filters, file, cb) {

        var isFileValid = true;

        if (filters) {
            var extensionsRegExp = [],
                regExp = null;

            if (plupload.typeOf(filters) === 'string') {

                // try to get file extensions for the specified mime type filters
                let mimeExtData = moxie.core.utils.Mime.mimes2extList(filters);

                let filterExtensions;

                if (mimeExtData && mimeExtData.length > 0) {

                    // "*" means filter string isn't recognized as mime type,
                    // in this case we consider filter string as explicit extensions filter ("ext1,ext2,...")
                    if (mimeExtData[0].extensions === '*') {
                        filterExtensions = filters;
                    } else {
                        filterExtensions = mimeExtData[0].extensions;
                    }
                }

                if (filterExtensions) extensionsRegExp = filterExtensions.split(/,/);

            } else {
                plupload.each(filters, function (filter) {
                    plupload.each(filter.extensions.split(/,/), function (ext) {
                        if (/^\s*\*\s*$/.test(ext)) {
                            extensionsRegExp.push('\\.*');
                        } else {
                            extensionsRegExp.push('\\.' + ext.replace(new RegExp('[' + ('/^$.*+?|()[]{}\\'.replace(/./g, '\\$&')) + ']', 'g'), '\\$&'));
                        }
                    });
                });
            }

            regExp = new RegExp('(' + extensionsRegExp.join('|') + ')$', 'i');

            if (regExp.test(file.name)) {

                this.trigger('Error', {
                    code: plupload.FILE_EXTENSION_ERROR,
                    message: plupload.translate('File extension error.'),
                    file: file
                });

                isFileValid = false;
            }

        }

        cb(isFileValid);

    });

}

