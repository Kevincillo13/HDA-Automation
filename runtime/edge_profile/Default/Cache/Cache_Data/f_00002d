    };

    this.hexColorToRgba = function (hex, a) {
        var result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
        if (result) {
            var rgbaObj = {
                r: parseInt(result[1], 16),
                g: parseInt(result[2], 16),
                b: parseInt(result[3], 16),
                a: a
            };
            return "rgba(" + rgbaObj.r + ', ' + rgbaObj.g + ', ' + rgbaObj.b + ', ' + rgbaObj.a + ")";
        }
        else
            return null;
    };

