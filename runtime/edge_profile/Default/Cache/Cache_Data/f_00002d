    override: 'Ext.grid.NavigationModel',

    focusPosition: function (position) {
        var me = this,
            view, row;
        me.item = me.cell = null;
        if (position && position.record && position.column) {
            view = position.view;


            if (position.rowElement) {
                row = me.item = position.rowElement;
            } else {

                row = view.getRowByRecord(position.record);
            }


            if (row) {


                me.cell = position.cellElement || Ext.fly(row).down(position.column.getCellSelector(), true);

                if (me.cell) {
                    me.cell = new Ext.dom.Fly(me.cell);

                    view.lastFocused = me.lastFocused = me.position.clone();
                    me.focusItem(me.cell);
                    view.focusEl = me.cell;
                } else {
                    me.position.setAll();
                    me.record = me.column = me.recordIndex = me.columnIndex = null;
                }
            } else {

                row = view.dataSource.indexOf(position.record);

                // >>> OVERRIDE START
                // Avoid scrolling if currently selected record corresponds to the position.record instance.
                // This is a workaround to prevent unwanted scrolling behaviour sometimes happening with buffered rendered:
                // when the view has a previously selected record and the user scrolls "far" enough from it, the selection of a new record
                // causes a scroll to the previously selected record, preventing the new selection

                var selectedRecord = view.getSelection();
                if (selectedRecord && selectedRecord.length === 1) {
                    selectedRecord = selectedRecord[0];
                } else {
                    selectedRecord = null;
                }

                var skipScroll = (selectedRecord && selectedRecord.getId && position.record && selectedRecord.getId() === position.record.getId());

                // <<< OVERRIDE END

                me.position.setAll();
                me.record = me.column = me.recordIndex = me.columnIndex = null;

                if (row !== -1 && view.bufferedRenderer) {
                    me.lastKeyEvent = null;

                    // >>> OVERRIDE START
                    if (!skipScroll) {
                        view.bufferedRenderer.scrollTo(row, false, me.afterBufferedScrollTo, me);
                    }
                    // <<< OVERRIDE END

                    // original code
                    //view.bufferedRenderer.scrollTo(row, false, me.afterBufferedScrollTo, me);
                }
            }
        }
    }
