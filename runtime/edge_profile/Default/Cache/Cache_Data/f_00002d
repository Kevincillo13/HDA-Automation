            if (!Error.captureStackTrace) return null;

            var obj = {};
            Error.captureStackTrace(obj, Portal.Console.getStackTrace);
            return obj.stack;
        },
        logStackTrace: function () {
            this.log(this.getStackTrace());
        }
    };
};

