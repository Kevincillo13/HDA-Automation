    // Json convertion utilities
    this.Json = {

        /* MS JSON Date Regex
         * IMPORTANT - This is a "shared" variable, it must NOT be declared using the global modifier /g
         * RegExp objects are stateful and global ones do not reset lastIndex property after a match,
         * so next match call will start from previous lastIndex value.
         * 
         * https://siderite.blogspot.com/2011/11/careful-when-reusing-javascript-regexp.html
         */
        MSDateRegExp: new RegExp(/^\/Date\((.*?)\)\/$/i),

        checkMSDate: function (str) {
            return this.MSDateRegExp.exec(str);
        },

        getDateFromJson: function (str) {
            if (!str || !typeof str == 'string') return null;

            // we expect MS date format, try to build date from MS date string
            var date = this.getMSDate(str);

            if (date) return date;

            // try to build date directly from string (in case of ISO format)
            try {
                return new Date(str);
            } catch (e) {
                Portal.Console.error('Error decoding JSON date ' + str);
            }

            return null;
        },

        getMSDate: function (str) {
            var matches = this.checkMSDate(str);

            if (matches && matches.length == 2) {
                return eval(Ext.String.format('new Date({0})', matches[1]));
            }

            return null;
        },

        getDateToJson: function (d) {
            var t = d.getTime();
            return "\\/Date(" + t + ")\\/";
        },

        decode: function (str, encodeDates) {
            var obj = Ext.decode(str);

            // if we want to create Date instances...
            if (encodeDates) {
                this.prepareDates(obj);
            }

            return obj;
        },

        encode: function (obj, urlEncode) {
            if (obj instanceof Array) {
                // in case of array object do the encoding for each item
                var l = obj.length;
                for (var i = 0; i < l; i++) {
                    this.prepareEncode(obj[i]);
                }
            } else {
                this.prepareEncode(obj);
            }

            var jsonEncoded = Ext.encode(obj);

            return (urlEncode ? jsonEncoded.replace(/'/g, "%27") : jsonEncoded);
