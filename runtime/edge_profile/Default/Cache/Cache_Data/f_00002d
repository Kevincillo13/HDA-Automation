        prepareDates: function (obj) {
            var me = this,
                doDecodeFn = function (decodeObj) {
                    for (var prop in decodeObj) {

                        if (decodeObj[prop] instanceof Array) {
                            var l = decodeObj[prop].length;
                            for (var i = 0; i < l; i++)
                                decodeObj[prop][i] = doDecodeFn(decodeObj[prop][i]);

                            continue;
                        }

                        if (Ext.isObject(decodeObj[prop])) {
                            decodeObj[prop] = doDecodeFn(decodeObj[prop]);
                            continue;
                        }

                        if (typeof decodeObj[prop] === 'string' && me.MSDateRegExp.test(decodeObj[prop])) {
                            decodeObj[prop] = me.getDateFromJson(decodeObj[prop]);
                            continue;
                        }
                    }
                    return decodeObj;
                };

            if (obj instanceof Array) {
                // in case of Array perform decoding for each items
                var l = obj.length;
                for (var i = 0; i < l; i++) {
                    obj[i] = doDecodeFn(obj[i]);
                }
            } else {
                // in case of object perform decoding for object
                obj = doDecodeFn(obj);
            }
