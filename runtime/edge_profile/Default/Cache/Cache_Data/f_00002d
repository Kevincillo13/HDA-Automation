    this.HiddenForm = function (url, fields, target) {
        if (!Ext.isArray(fields))
            return;

        if (Portal.AntiCSRF && Portal.Util.Url.isSameDomainAsCurrentPage(url)) {
            url = Portal.AntiCSRF.getAntiCSRFURL(url);
        }

        target = target || 'iframe';

        var body = Ext.getBody(), frame, form;

        frame = Ext.get('hiddenform-iframe');
        if (frame) frame.destroy();

        form = Ext.get('hiddenform-form');
        if (form) form.destroy();

        frame = body.createChild({
            tag: 'iframe',
            cls: 'x-hidden',
            id: 'hiddenform-iframe',
            name: 'iframe'
        });

        form = body.createChild({
            tag: 'form',
            method: 'POST',
            cls: 'x-hidden',
            id: 'hiddenform-form',
            action: url,
            'target': target
        });

        Ext.each(fields, function (el, i) {
