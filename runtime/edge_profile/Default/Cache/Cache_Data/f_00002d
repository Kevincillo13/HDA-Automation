            // adjusting inner element height in order to match outer height

            var innerHeight = this.calculateInnerHeight(height);
            var minInnerHeight = this.calculateInnerHeight(this.minHeight);

            innerHeight = Math.max(innerHeight, minInnerHeight);

            this.triggerWrap.setHeight(innerHeight);
        },

