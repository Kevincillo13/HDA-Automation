        //this.queue.clear();

        // ADDED this line: is there any item into the queue?
        var isLoading = (this.queue.peek() !== undefined);

        var me = this;

        if (groupCallback) {
            groupCallback = {
                fn: groupCallback,
                counter: config.length || 1,
                config: config,
                step: function () {
                    this.counter--;

                    if (this.counter === 0) {
