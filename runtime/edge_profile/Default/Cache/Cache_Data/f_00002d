/*
    Audio player is used to play an audio stream - when supported, in "single channel".
    
    NOTE: 
    - When Audio is not supported, the class does nothing.
    - Previous audio track will be stopped when playing a new sound.
*/
Portal.AudioPlayer = new function () {

    var me = null,
        audioPlayer = null;

    return {
        init: function () {
            me = this;

            // Determine the correct object to use
            try {
                me.audioPlayer = window.Audio ? new window.Audio() : null;
            }
            catch (err) {
                me.audioPlayer = null;
            }
        },

        /*
            playSound: Plays a sound 

            @soundUrl: URL to the sound resource (MP3)
        */
        playSound: function (soundUrl) {
            var player = me.audioPlayer;

            if (player != null) {
                player.pause();
                player.src = soundUrl;
                player.play();
            }
        },

        /*
            stopSound: Stops the current playing sound (if any).
        */
        stopSound: function () {
            var player = me.audioPlayer;

            if (player != null) {
