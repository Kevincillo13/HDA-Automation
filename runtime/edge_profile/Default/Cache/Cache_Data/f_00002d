    // check if a string contains more than #repetitions of the same character
    // splits same character repetitions by inserting a white space every group of #repetitions of the same character
    // splitCharacterSequence('**********', 5) => '***** *****'
    // splitCharacterSequence('**********', 3) => '*** *** *** *'
    this.splitCharacterSequence = function (val, repetitions, ellipsis) {
        var str = val;

        if (ellipsis) {
            str = Ext.String.ellipsis(str, ellipsis);
        }

        repetitions = repetitions || 20;

        var regEx = new RegExp('(.)\\1{' + repetitions + ',}', 'gi');
        var splitRegEx = new RegExp('(.{1,' + repetitions + '})', 'gi');

        var str = str.replace(regEx, function (match, capture) {
            var tmpArr = match.match(splitRegEx);
            return tmpArr.join('<span style="font-size: 1px;"> </span>');
        });

        return str;
    };

    // calculates days, hours, minutes parts from minutes value
    this.getDurationParts = function (minutes, dayHours) {
        var daysRatio = (dayHours ? (1 / (dayHours * 60)) : Sch.util.Date.getUnitToBaseUnitRatio('d', 'mi')),
            inverseDaysRatio = (dayHours ? (dayHours * 60) : (24 * 60)),
            hoursRatio = Sch.util.Date.getUnitToBaseUnitRatio('h', 'mi'),
            inverseHoursRatio = Sch.util.Date.getUnitToBaseUnitRatio('mi', 'h'),
            daysPart = Math.floor(minutes * daysRatio),
            hoursPart = Math.floor((minutes - daysPart * inverseDaysRatio) * hoursRatio),
            minutesPart = (minutes - daysPart * inverseDaysRatio - hoursPart * inverseHoursRatio);

        return { days: daysPart, hours: hoursPart, minutes: minutesPart };
    };


    this.getDurationReadable = function (minutes, dayHours) {
        var parts = this.getDurationParts(minutes, dayHours);

        var result = [];

        if (parts.days > 0) {
            result.push(Ext.String.format('{0} {1}', parts.days, Sch.util.Date.getReadableNameOfUnit('d', parts.days > 1)));
        }

        if (parts.hours > 0) {
            result.push(Ext.String.format('{0} {1}', parts.hours, Sch.util.Date.getReadableNameOfUnit('h', parts.hours > 1)));
        }

        if (parts.minutes > 0) {
            result.push(Ext.String.format('{0} {1}', parts.minutes, Sch.util.Date.getReadableNameOfUnit('mi', parts.minutes > 1)));
        }

        return result.join(' ');
    };

