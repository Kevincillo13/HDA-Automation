Portal.Console = new function () {
    var isConsole = (typeof console === 'object');

    return {
        isDebugEnabled: true,
        log: function (obj) {
            if (isConsole && this.isDebugEnabled) {
                console.log(obj);
            }
        },
        logObj: function (obj, msg) {
            if (isConsole && this.isDebugEnabled) {
                console.log((obj.self ? obj.self.displayName : obj) + ' > ' + msg);
            }
        },
        error: function (msg) {
            if (isConsole && this.isDebugEnabled) {
                console.error(msg);
            }
        },
        assert: function (assertion, msg) {
            if (isConsole) {
                console.assert(assertion, msg);
            }
