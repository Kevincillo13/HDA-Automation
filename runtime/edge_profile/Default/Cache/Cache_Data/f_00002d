                else {
                    navigator.permissions.query({ name: "clipboard-write" }).then(
                        function (result) {
                            if (result.state == "granted" || result.state == "prompt") {
                                navigator.clipboard.writeText(text).then(function () {
                                    /* clipboard successfully set */
                                }, function () {
                                    /* clipboard write failed */
