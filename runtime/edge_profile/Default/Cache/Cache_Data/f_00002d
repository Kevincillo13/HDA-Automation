            /**
             * Replaces/appends url querystring parameter value.
             * NOTE: parameter name is CASE INSENSITIVE.
             * 
             * @param {Object} params The function parameters.
             * @param {string} params.url The url to parse.
             * @param {string} params.paramName The name of the QS parameter to replace/append.
             * @param {string} params.paramValue The value of the QS parameter to replace/append.
             * @param {boolean} params.appendIfNotExists True if we want to append to querystring the parameter if it doesn't exist.
             *                  Default = true
             *                  
             * @returns {string} The parsed url as url-encoded string.
             */
            applyQSParameter = function (params) {
                var urlObj = getUrlObject(params.url);
                var qsParamName = '';

                params.appendIfNotExists = params.appendIfNotExists === false ? false : true;

                urlObj.searchParams.forEach(function (value, key) {
                    if (key.toLowerCase() === params.paramName.toLowerCase())
                        qsParamName = key;
                });

                if (qsParamName) {
                    urlObj.searchParams.set(qsParamName, params.paramValue);
                } else if (params.appendIfNotExists) {
                    urlObj.searchParams.append(params.paramName, params.paramValue);
                }

                return urlToString(urlObj, isAbsolute(params.url));
            },

            /**
             * Replaces/appends a filter item value on url querystring filters collection.
             * NOTE: parameter name is CASE INSENSITIVE.
             * 
             * @param {Object} params The function parameters.
             * @param {string} params.url The url to parse.
             * @param {string} params.paramName The name of the filter item to replace/append.
             * @param {string} params.paramValue The value of the filter item to replace/append.
             * @param {boolean} params.appendIfNotExists True if we want to append the filter to collection if it doesn't exist.
             *                  Default = true
             * @param {string} params.filterOperator The filter operator.
             *                  Default = eq
             *                  
             * @returns {string} The parsed url as url-encoded string.
             */
            applyQSFilterParameter = function (params) {
                var urlObj = getUrlObject(params.url);
                var filterQSParamName = '';
                var filter = [];
                var filterStr = '';

                params.appendIfNotExists = params.appendIfNotExists === false ? false : true;

                // try to find a "filter" querystring parameter (case insensitive)
                urlObj.searchParams.forEach(function (value, key) {
                    if (key.toLowerCase() === 'filter')
                        filterQSParamName = key;
                });

                if (filterQSParamName) {
                    // filter param found, decode its value
                    filterStr = urlObj.searchParams.get(filterQSParamName);
                    filter = Portal.Util.Json.decode(filterStr);
                } else {
                    // no filter param found, we've to append a new one
                    filterQSParamName = 'filter';
                    filter = [];
                }

                // try to get the required filter item (case insensitive)
                var filterParam = _.find(filter, function (f) { return f.property.toLowerCase() === params.paramName.toLowerCase(); });

                if (filterParam)
                    filterParam.value = params.paramValue; // set filter value
                else if (params.appendIfNotExists)
                    filter.push({ property: params.paramName, op: params.filterOperator || 'eq', value: params.paramValue }); // append a new filter item

                if (_.some(filter)) {
                    filterStr = Portal.Util.Json.encode(filter);

                    urlObj.searchParams.set(filterQSParamName, filterStr);
                }

                return urlToString(urlObj, isAbsolute(params.url));
            },

            /**
             * Replaces/appends an analysis parameter value on url querystring analysis parameters collection.
             * NOTE: parameter name is CASE INSENSITIVE.
             * 
             * @param {Object} params The function parameters.
             * @param {string} params.url The url to parse.
             * @param {string} params.paramName The name of the parameter item to replace/append.
             * @param {string} params.paramValue The value of the parameter item to replace/append.
             * @param {boolean} params.appendIfNotExists True if we want to append the parameter to collection if it doesn't exist.
             *                  Default = true
             *                  
             * @returns {string} The parsed url as url-encoded string.
             */
            applyQSAnalysisParameter = function (params) {
                var urlObj = getUrlObject(params.url);
                var paramsQSParamName = '';
                var analysisParameters = [];
                var paramsStr = '';

                params.appendIfNotExists = params.appendIfNotExists === false ? false : true;

                // try to find a "parameters" querystring parameter (case insensitive)
                urlObj.searchParams.forEach(function (value, key) {
                    if (key.toLowerCase() === 'parameters')
                        paramsQSParamName = key;
                });

                if (paramsQSParamName) {
                    // analysis param found, decode its value
                    paramsStr = urlObj.searchParams.get(paramsQSParamName);
                    analysisParameters = Portal.Util.Json.decode(paramsStr);
                } else {
                    // no analysis param found, we've to append a new one
                    paramsQSParamName = 'parameters';
                    analysisParameters = [];
                }

                // try to get the required param item (case insensitive)
