            return this.msgTarget === 'under' && this.hasActiveError();
        },

        calculateInnerHeight: function (height) {

            if (_.isUndefined(height))
                return -1;

            var innerHeight = height;
            var borderPadding = this.getBorderPadding();

            // remove borders/paddings height
            innerHeight -= (borderPadding.beforeY + borderPadding.afterY);

            // remove label top height
            if (this.labelAlign === 'top' && this.hasVisibleLabel()) {
                innerHeight -= this.labelEl.getHeight();
            }

            // remove footnote height
            if (this.noteEl) {
                var noteMargins = this.noteEl.getMargin();
                innerHeight -= this.noteEl.getHeight() + noteMargins.top + noteMargins.bottom;
            }

            // remove error message height
            if (this.requiresErrorMessageHeight()) {
                var errorMargins = this.errorWrapEl.getMargin();
                innerHeight -= this.errorWrapEl.getHeight() + errorMargins.top + errorMargins.bottom;
            }

            return Math.max(innerHeight, this.minInnerHeight);
