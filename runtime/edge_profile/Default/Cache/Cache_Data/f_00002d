                        closable..: Optional (boolean) Whether the message is closable by the user or not (default: false)
                        
                        PROPERTIES SUPPORTED ONLY ON DN
                        tag.......: Optional (string). Messages with the same tag are considered as a single notification. New messages will replace the previous ones (see below).
                        iconUrl...: Optional (string) Image URL that represents the Icon to display inside the message. Specify only icon OR iconUrl, not both (Supported only on DN)
                        soundUrl..: Optional (string) the URL of the MP3 file to play along with the notification.                        
        */
        showToastMsg: function (cfg) {

            if (Ext.isString(cfg)) {
                cfg = { msg: cfg };
            }

            Ext.apply(cfg, {
                // Desktop notification specific.                
                allowDN: Ext.isDefined(cfg.allowDN) ? cfg.allowDN : true,

                ui: cfg.ui || 'success', /* showToastMsg with no 'ui' specified is used to show success messages */

                // tag is used, when supported, to group messages and to avoid flooding the user with too many messages for the same information.                
                tag: cfg.title || (Portal.Const && Portal.Const.View && Portal.Const.View.PortalTitle ? Portal.Const.View.PortalTitle : 'Portal'),
                delay: cfg.delay || 4000
            });

            var msgType = '';

            if (cfg.type) {

                msgType = cfg.type;

            } else if (cfg.ui) {

                switch (cfg.ui) {

                    case 'danger':
                        msgType = 'negative';
                        break;

                    case 'success':
                        msgType = 'positive';
                        break;

                    case 'warning':
                        msgType = 'warning';
                        break;

                    case 'info':
                        msgType = 'info';
                        break;

                    default:
                        msgType = 'neutral';
                }
            }

            /* Desktop notifications? */
            if (cfg.allowDN && Portal.DesktopNotifications.isEnabled()) {

                // compute icon based on "msgType" (no icon for neutral notifications)
                var uiIcon = (msgType === 'neutral' ? '' : Portal.Const.Url.BASE_APP_URL + "Client/Resources/Img/Notifications/" + msgType + ".png");

                var content = cfg.msg || cfg.text || cfg.html || "";

                // configure display options.
                var options = {
                    // HTML messages are not allowed on Desktop Notifications, so strip HTML and convert <BR> in \n
                    body: content.replace(/<br\/>/g, '\n').replace(/(<([^>]+)>)/ig, ''),

                    // Group messages by messageThread
                    // https://notifications.spec.whatwg.org/#tags-example                    
                    tag: cfg.tag,

                    // default icons.
                    icon: uiIcon,
                    badge: uiIcon
                };

                if (cfg.autoHide != null) {
                    // when autoHide is TRUE, there is NO interaction required.
                    options.requireInteraction = !cfg.autoHide;
                }

                // configure DN to use specific icon, if specified.
                if (cfg.iconUrl != null) {
                    Ext.apply(options, {
                        icon: cfg.iconUrl,
                        badge: cfg.iconUrl
                    });
                }
                // build DN
                var notification = new Notification(cfg.title || (Portal.Const && Portal.Const.View && Portal.Const.View.PortalTitle ? Portal.Const.View.PortalTitle : 'Portal'), options);

                // Play sound if configured and supported.
                if (cfg.soundUrl != null) {
                    Portal.AudioPlayer.playSound(cfg.soundUrl);
                }

                // setup a timeout handler (when required)
                var timeoutHandle = null;

                if (!options.requireInteraction) {
                    timeoutHandle = window.setTimeout(
                        function () {
                            Portal.AudioPlayer.stopSound();

                            notification.close();
                        }, cfg.delay);
                }

                // focus when notification clicked.
                notification.addEventListener("click",
                    function (event) {
                        Portal.AudioPlayer.stopSound();

                        if (timeoutHandle != null) {
                            window.clearTimeout(timeoutHandle);
                        }

                        window.focus();
                        notification.close();
                    });

                notification.addEventListener("close",
                    function (event) {
                        Portal.AudioPlayer.stopSound();
                    });
            }
            else if (Portal.BridgeManager) {
                Portal.BridgeManager.notify(!(msgType === 'negative' || msgType === 'warning'), cfg.msg);
            }
            else {

                // standard toast notification.
                var msgCfg = {
                    xtype: 'notificationtoast',
                    type: msgType,
                    title: cfg.title,
                    textContent: cfg.text,
                    htmlContent: cfg.msg || cfg.html,
                    closable: true,
                    autoHide: Ext.isDefined(cfg.autoHide) ? cfg.autoHide : true,
                    hideDelay: cfg.delay,
