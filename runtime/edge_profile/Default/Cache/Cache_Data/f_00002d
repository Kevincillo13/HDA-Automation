Portal.FiltersUtil = new function () {

    /*
        Builds a filter object from the passed in field (component).
        - field: the field component the filter properties will be extracted from.
    */
    this.buildFilterFromField =  function (field) {

        var fieldValue = (field.getFilterValue ? field.getFilterValue() : field.getValue());
        if (field.xtype == "datefield" && !Ext.isDate(fieldValue))
            fieldValue = null;
        if (field.xtype == "datefield" && field.filterExtensionKey == "DATE_NOW")
            fieldValue = new Date();
       
        fieldValue = this.buildFilterValue(fieldValue, field.filterOperator, true);

        return this.buildFilterFromProperties(
                field.getName(),
                fieldValue,
                field.filterOperator,
                field.filterExtensionKey,
                field.itemId
            );
    },

    /*
        Builds a filter object from the passed in properties.
        - name: property name of the filter condition.
        - value: value of the filter condition.
        - op: filter operator.
        - extKey[optional]: filter extension key.
        - id[optional]: id of the filter condition.
    */
    this.buildFilterFromProperties = function (name, value, op, extKey, id) {
        return {
            property: name,
            value: value,
            op: op,
            'extKey': extKey,
            id: id
        };
    },

    /*
        "Adjusts" the specified value to be used in a filter, according to value type and filter operator.
        - fieldValue: the value of the field.
        - operator: the filter operator.
    */
    this.buildFilterValue = function (fieldValue, operator) {
        if (operator == "nn" || operator == "nl")
            fieldValue = null;
        else {
            // if (Ext.isDate(fieldValue) && (operator === "le" || operator === "gt")) {
            
            if (Ext.isDate(fieldValue) && operator === "le") {
                var dateWithoutTime = Ext.Date.clearTime(fieldValue, true);

                if (dateWithoutTime.getTime() == fieldValue.getTime()) {
                    fieldValue = fieldValue.addDays(1).addSeconds(-1); 
                }   
            }

            // if value is an array build pipe separated string
            if (Ext.isArray(fieldValue)) {
                fieldValue = fieldValue.join('|');
            }
        }
        return fieldValue;
    }
};



