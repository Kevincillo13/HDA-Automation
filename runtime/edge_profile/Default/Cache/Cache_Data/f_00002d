        name = this.getContextInstanceName(name, contextInstanceID);

        // navigate to parent...
        var ctx = null,
            container = null,
            lastModuleCtx = null,
            hasContext = function (cmp) {
                // if current component has a context property with the given name then we found the target!
                if (cmp['Context'] != null) {
                    // keep track of last module context
                    if (cmp.Context.Module) lastModuleCtx = cmp.Context.Module;
                    return (name == null || cmp.Context[name] != null);
                }

                // if current component has a bin owner (in case current component is part of a component bin) start searching from it
                if (cmp.binOwner) return true;

                return false;
            };

        // start from current component
        if (hasContext(this)) {
            // current component has the required context
            container = this;
        } else {
            // otherwise find context in ancestor components
            container = this.findParentBy(hasContext);
        }

        // if a valid container was found return its context object
        if (container != null) {

            if (container.Context) {
                ctx = (name != null ? container.Context[name] : container.Context);
            } else if (container.binOwner) {
                ctx = container.binOwner.getContext(name);
            }

        } else {

            // if a module context instance was found, then search the required context instance starting from it and going up in the module hierarchy through its ancestors
            if (lastModuleCtx) {
                var fn = function (ctx) { return (typeof ctx.component.Context[name] != 'undefined'); };
                for (p = lastModuleCtx.getParentCtx(); p != null && !Ext.isEmptyObj(p) && !fn(p); p = p.getParentCtx()) {
                    // do nothing
                }
                if (p) ctx = p.component.Context[name];
            }

        }

        if (!ctx) {
            Portal.Console.log('Required context "' + name + '" doesn\'t exist!');
            return null;
        }

        if (typeof fn == 'function') {
            try {
                fn.call(ctx, ctx);
            } catch (e) {
                Portal.Console.error('Portal Exception >> GetContext callback error!');
                if (e.message) Portal.Console.error(e.message);
                if (e.stack) Portal.Console.error(e.stack);
            }
