    this.Url = (function () {
        var regexAbsoluteURL = new RegExp('^(?:[a-z]+:)?//', 'i'),
            replaceID = function (url, entityId) {
                return url.replace(Portal.Const.Url.ID_PLACEHOLDER, entityId);
            },
            isAbsolute = function (url) {
                return regexAbsoluteURL.test(url);
            },
            isRelative = function (url) {
                return (url.charAt(0) != '/');
            },
            isSameApplication = function (pathName1, pathName2) {
                return (pathName1.split('/')[1] === pathName2.split('/')[1]);
            },
            isSameDomainAsCurrentPage = function (url) {

                if (url.startsWith('./')) return true;

                if (isAbsolute(url)) {

                    var currentURL = new URL(window.location.href);
                    var targetURL = new URL(url);

                    return (currentURL.hostname === targetURL.hostname && isSameApplication(currentURL.pathname, targetURL.pathname));

                } else {

                    return isSameApplication(url, Router.baseUrl);
                }
            },
            hasProtocol = function (url) {
                return (url.indexOf("http://") == 0);
            },
            /**
             * Builds an absolute path from the specified destination path.
             * Remarks: only 1 level relative path are treated.
             */
            buildAbsolutePath = function (destinationPath) {
                var currentPath, absPath;
                // in case of absolute path return it as is
                if (!isRelative(destinationPath)) return destinationPath;
                if (hasProtocol(destinationPath)) return destinationPath;

                // relative destination path
                Portal.Console.log('destinationPath: ' + destinationPath);

                // get current path
                currentPath = Router.baseUrl;
                Portal.Console.log('currentPath: ' + currentPath);

                if (destinationPath.indexOf("~") == 0) {
                    var idx = currentPath.indexOf('/', 1);

                    if (idx >= 0) {
                        // current url is like "/HDARevolution/...."
                        absPath = currentPath.slice(0, idx); // keep only the first part of the url between the initial "/" and the following "/"
                    } else {
                        // current url is like "/HDARevolution"
                        absPath = currentPath; // currentPath has a single "/" (as first char)
                    }

                    destinationPath = destinationPath.slice(1);
                }
                else {

                    // remove path content after last "/"
                    absPath = currentPath.slice(0, currentPath.lastIndexOf('/') + 1);
                    Portal.Console.log('base abs path: ' + absPath);
                }

                // build absolute path concatenating base abs path and destination path
                absPath = absPath + destinationPath;
                Portal.Console.log('complete abs path: ' + absPath);

                return absPath;
            },

            getUrlObject = function (url) {
                if (isAbsolute(url))
                    return new URL(url);
                else
                    return new URL(url, document.location.origin + Router.baseUrl);
