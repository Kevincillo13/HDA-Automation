Ext.define('Portal.override.layout.component.field.FieldContainer', {

    override: 'Ext.layout.component.field.FieldContainer',

    beginLayoutCycle: function (ownerContext, firstCycle) {

        // telling the field container it has raw content so that it will handle content auto dimensions measuring (like a field component does)
        // otherwise it'll delegate measurement to its layout (and this doesn't work with all layouts when measuring heights).
        ownerContext.hasRawContent = true;

        return this.callParent(arguments);
    },

    publishInnerWidth: function (ownerContext, width) {
        var owner = this.owner;

        if (owner.labelAlign !== 'top' && owner.hasVisibleLabel()) {
            //width -= (owner.labelWidth + (owner.labelPad || 0));
            width -= owner.getLabelWidth();
        }

        if (owner.msgTarget === 'side' && (owner.hasActiveError() || !owner.autoFitErrors)) {
            width -= owner.errorWrapEl.getWidth();
        }

        if (owner.indicatorEl && !owner.indicatorHidden) {
            width -= owner.indicatorEl.parent().getWidth();

            Portal.Console.log(['FIELD CONTAINER', 'INDICATOR WIDTH', owner.indicatorEl.parent().getWidth()]);
        }

        // exclude field body left+right border/padding
        var borderPadding = owner.bodyEl.getBorderPadding();
        width -= (borderPadding.beforeX + borderPadding.afterX);

        // exclude field external wrapper left+right border/padding too...
        borderPadding = owner.el.getBorderPadding();
        width -= (borderPadding.beforeX + borderPadding.afterX);

        ownerContext.containerElContext.setWidth(width);
    },

    publishInnerHeight: function (ownerContext, height) {
        var owner = this.owner;

        if (owner.labelAlign === 'top' && owner.hasVisibleLabel()) {
            height -= owner.labelEl.getHeight();
        }

        if (owner.msgTarget === 'under' && (owner.hasActiveError() || !owner.autoFitErrors)) {
            height -= owner.errorWrapEl.getHeight();
