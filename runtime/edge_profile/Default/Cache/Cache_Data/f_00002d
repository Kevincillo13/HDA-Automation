                            }
                            else
                                Portal.Console.error("Logged user does not have 'clipboard-write' permission!");
                        }
                    );
                }
            },
            pasteValueOnCtl = function (ctl, text) {
                if (text != null && text != "") {
                    if (ctl != null) {
                        if (ctl.getValue() == "")
                            ctl.setValue(text);
                        else {
                            var delimiter = "";
                            if (ctl.xtype == "nettagfield") {
