    /**
     * Public methods
     */
    return {
        getProjectionPromise: getProjectionPromise,
        ajaxGetPromise: ajaxGetPromise,
        ajaxPostPromise: ajaxPostPromise,
        ajaxLongPromise: ajaxLongPromise,
        confirmPromise: confirmPromise
    };
