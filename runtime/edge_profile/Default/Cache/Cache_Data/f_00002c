        contentTpl: null,

        contentData: null,

        contentLayout: null,

        contentItems: null

    },

    privates: {

        afterRenderDone: false,

        afterLayoutDone: false,

        setupFieldContent: function () {

            // --- field content container ---
            var ct = {
                xtype: 'component',
                id: this.id + '_content',
                itemId: 'fieldContentContainer',
                anchor: '100% 100%',
                cls: 'field-content-wrapper field-input-wrapper composite-field-content ' + (this.unstyledContentWrapper ? 'is-unstyled' : ''),
                height: (this.contentHeight ? this.contentHeight : null),
                layout: this.contentLayout || 'auto',
                tpl: this.contentTpl,
