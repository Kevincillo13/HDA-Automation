Ext.define('Portal.ContextFactory', {
    statics: {
        /* Creates a new instance of the given context type, links new instance to the given component and if specified creates a specific scripts instance */
        createInstance: function (contextType, cmp, initCfg, contextInstanceID) {

            Portal.Console.log('CREATING CONTEXT INSTANCE');
            Portal.Console.log(arguments);

            var me = this, ctx;
            ctx = me.ensureModuleContext(cmp, initCfg);

            var ctxDefType = typeof contextType;

            Portal.Console.log('Context creation by ' + ctxDefType);

            if (ctxDefType == 'function' || ctxDefType == 'object') {                
                ctx = me.bindModelToComponent(contextType, cmp, initCfg, contextInstanceID);
                ctx = me.attachContext(contextType, cmp, initCfg);

            } else if (ctxDefType == 'string') {
                
                Portal.Console.log('Context class name: "' + contextType + '"');

                me.ensureContextTypeExistence(contextType, function (ctxConstr) {
                    ctx = me.bindModelToComponent(ctxConstr, cmp, initCfg, contextInstanceID);
                });
            }

            return ctx;
        },
        ensureModuleContext: function (cmp, initCfg) {
            var me = this;

            // ensure Context property existence for the component
            if (!cmp['Context']) cmp.Context = {};

            if (!Ext.isDefined(cmp.Context['Module'])) {
                var depCtx = Ext.create('Portal.ModuleContext', { component: cmp });
                cmp.Context[depCtx.contextName] = depCtx;
                me.initContext(depCtx, initCfg);
            }

            return depCtx;
        },
        
        bindModelToComponent: function (ctxConstructor, cmp, initCfg, contextInstanceID) {

            var me = this;
            var ctx = Portal.ContextFactory.createContextInstance(ctxConstructor, cmp);
            var ctxArr = [];

            // inject init config dependencies
            ctx.dependencies = ctx.dependencies || [];
            if (initCfg.dependencies) {
                ctx.dependencies = ctx.dependencies.concat(initCfg.dependencies);
            }

            // set the context instance as component property (with a specific name or the default one)
            if (ctx.contextName != null) {
                var ctxInstanceName = cmp.getContextInstanceName(ctx.contextName, contextInstanceID);
                cmp.Context[ctxInstanceName] = ctx;
            } else {
                cmp.Context['CustomContext'] = ctx;
            }

            // setup dependencies
            if (ctx.dependencies.length > 0) {

                var ctxDependencies = _.uniq(ctx.dependencies);

                cmp.Context = cmp.Context || {};

                // require all dependencies' resources
                Ext.syncRequire(ctxDependencies, function () {

                    // when all required resources are ready create context instances
                    for (var i = 0, l = ctxDependencies.length; i < l; i++) {

                       try {
                           var depContextType = ctxDependencies[i],
                               depCtx = Portal.ContextFactory.createContextInstance(eval(depContextType), cmp);

                            cmp.Context[depCtx.contextName] = depCtx;
                            ctxArr.push(depCtx);
                        } catch (e) {
                            Portal.Console.error(['Portal Exception', 'ContextFactory encountered an exception during context instantiation', depCtx.contextName]);
                            if (e.message) Portal.Console.error(e.message);
                            if (e.stack) Portal.Console.error(e.stack);
                        }

                    }

                    // add the main context as last one to init
                    ctxArr.push(ctx);

                    initCfg = initCfg || {};

                    // init all context instances
                    for (var i = 0, l = ctxArr.length; i < l; i++) {

                        try {
                            me.initContext(ctxArr[i], initCfg);
                        } catch (e) {
                            Portal.Console.error(['Portal Exception', 'ContextFactory encountered an exception during context initialization', (ctxArr[i] && ctxArr[i].contextName ?  ctxArr[i].contextName : '')]);
                            if (e.message) Portal.Console.error(e.message);
                            if (e.stack) Portal.Console.error(e.stack);
                        }

                    }

                    me.fireContextInitComplete(cmp);
                });

            } else {

                // init single context instance
                initCfg = initCfg || {};
                me.initContext(ctx, initCfg);

                me.fireContextInitComplete(cmp);
            }


            return ctx;
        },

        fireContextInitComplete: function (cmp) {
            cmp.fireEvent('contextinitcomplete', cmp);
        },

        ensureContextTypeExistence: function (contextType, callback) {
            try {
                // if context constructor is defined then pass it to callback fn
                var ctxConstructor = eval(contextType);
                if (Ext.isDefined(ctxConstructor)) {
                    callback(ctxConstructor);
                    return;
                }
            }
            catch (e) {
                Portal.Console.log('WARN - EnsureContextTypeExistence for "' + contextType + '"');
                Portal.Console.log(e);
            }

            // if context constructor is not defined load it through Ext.require call and then pass it to callback fn
            Ext.syncRequire(contextType, function () {
                try {
                    callback(eval(contextType));
                } catch (e) {
                    Portal.Console.error(['Portal Exception', 'ContextFactory encountered an exception during ensureContextTypeExistence call']);
                    if (e.message) Portal.Console.error(e.message);
                    if (e.stack) Portal.Console.error(e.stack);
                }
            });
        },

        createContextInstance: function (ctxConstructor, cmp) {

            if (Ext.isFunction(ctxConstructor)) {
                ctxConstructor = ctxConstructor();
            } else {
                ctxConstructor = ctxConstructor;
            }

            Ext.apply(ctxConstructor, { component: cmp });

            if (ctxConstructor['dependencies'] == null) {
                ctxConstructor.dependencies = [];
            }

            // create context instance
            var ctx = Ext.create('Portal.ContextBase', ctxConstructor);
            return ctx;
        },

        initContext: function (ctx, initCfg) {
            Portal.Console.log('INIT CONTEXT ' + ctx.contextName);
            ctx.init(initCfg);
            ctx.ready = true;
            ctx.component.fireEvent('contextReady', ctx);
            Portal.MessageBus.publish('Portal.Context.Ready', ctx, ctx);
        }
    }
});
