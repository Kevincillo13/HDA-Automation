        addRelation: function (params) {
            /**
            * Standard create new related record handler.
            * @param {Object}. Properties expected:
            *      - filter: the filter array to pass towards the new record view;
            *      - relatedEntityCollectionID: the related entity collection type;
            *      - relatedEntityID: the related entity type;
            *      - isTarget: boolean, indicate if the new created object is source or target.
            *      - precompileForm: boolean, indicate if precompile the new record form
            *      - relationTypeID: relation type
            *      - type: adding type (1 = create new 2 = search 3 = search by id)
            *      - viewID: id of search view
            *      - recordViewID: id of detail view
            */
            var workingStatus = workingCtx.currentStatus();
            var objId = workingCtx.getContext('Detail').currentStatus().id;
            var decodedParams = Portal.Util.buildParams(params, workingStatus);
            var currParams;
            var topic = "";
            var messageFilter = '';
            var listCtx = me.getContext('List');

            if (!workingCtx.messageListeners)
                workingCtx.messageListeners = [];

            var addRelationSingle = function (currentObjID, relatedId) {
                var sourceID = relatedId;
                var targetID = currentObjID;

                if (decodedParams.isTarget == "True") {
                    sourceID = currentObjID;
                    targetID = relatedId;
                }

                Ext.Ajax.request({
                    url: Router.action("WSCView", "AddRelation"),
                    method: 'POST',
                    params: {
                        "sourceID": sourceID,
                        "targetID": targetID,
                        "relationTypeID": decodedParams.relationTypeID
                    },
                    success: function (response, opts) {
                        // check the response data.
                        var json = Portal.Util.Json.decode(response.responseText, true);
                        if (json != null) {
                            if (json.success) {
                                if (listCtx)
                                    listCtx.refreshList();

                                Portal.MessageBus.publish('Portal.ObjectRelation.Insert', {
                                    sourceID: sourceID,
                                    targetID: targetID,
                                    relationTypeID: decodedParams.relationTypeID
                                }, me);

                            } else {
                                if (listCtx)
                                    listCtx.refreshList();
                                Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION + "<br/><br/>" + (json.result.desc || ""));
                            }
                        }
                    },
                    failure: function (response, opts) {
                        // failure code
                        Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION);
                    }
                });
            };

            var addRelationMultiple = function (currentObjID, relatedIDs) {
                var sourceID = relatedIDs;
                var targetID = currentObjID;

                if (decodedParams.isTarget == "True") {
                    sourceID = currentObjID;
                    targetID = relatedIDs;
                }

                Ext.Ajax.request({
                    url: Portal.Const.Url.BASE_APP_URL + "WSCView/AddRelationMultiple",
                    method: 'POST',
                    params: {
                        "sourceID": sourceID,
                        "targetID": targetID,
                        "relationTypeID": decodedParams.relationTypeID
                    },
                    success: function (response, opts) {
                        // check the response data.
                        var json = Portal.Util.Json.decode(response.responseText, true);
                        if (json != null) {
                            if (json.success) {
                                if (listCtx)
                                    listCtx.refreshList();

                                Portal.MessageBus.publish('Portal.ObjectRelation.Insert', {
                                    sourceID: sourceID,
                                    targetID: targetID,
                                    relationTypeID: decodedParams.relationTypeID
                                }, me);

                            } else {
                                if (listCtx)
                                    listCtx.refreshList();
                                Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION + "<br/><br/>" + (json.result.desc || ""));
                            }
                        }
                    },
                    failure: function (response, opts) {
                        // failure code
                        Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION);
                    }
                });
            };

            var addRelationByFilter = function (currentObjID, filter) {
                var sourceID = "";
                var targetID = currentObjID;

                if (decodedParams.isTarget == "True") {
                    sourceID = currentObjID;
                    targetID = "";
                }

                Ext.Ajax.request({
                    url: Portal.Const.Url.BASE_APP_URL + "WSCView/AddRelationByFilter",
                    method: 'POST',
                    params: {
                        "sourceID": sourceID,
                        "targetID": targetID,
                        "filter": JSON.stringify(filter),
                        "relationTypeID": decodedParams.relationTypeID
                    },
                    success: function (response, opts) {
                        // check the response data.
                        var json = Portal.Util.Json.decode(response.responseText, true);
                        if (json != null) {
                            if (json.success) {
                                if (listCtx)
                                    listCtx.refreshList();

                                Portal.MessageBus.publish('Portal.ObjectRelation.Insert', {
                                    sourceID: sourceID,
                                    targetID: targetID,
                                    relationTypeID: decodedParams.relationTypeID
                                }, me);

                            } else {
                                if (listCtx)
                                    listCtx.refreshList();
                                Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION + "<br/><br/>" + (json.result.desc || ""));
                            }
                        }
                    },
                    failure: function (response, opts) {
                        // failure code
                        Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION);
                    }
                });
            };

            if (decodedParams.type == "1") {  //create new

                if (decodedParams.precompileForm == "True") {
                    var filter = Portal.Util.Json.decode(decodedParams.filter);
                    currParams = {
                        filter: Portal.Util.Json.encode([
                            {
                                property: filter.property,
                                value: filter.value,
                                op: filter.op
                            },
                            {
                                property: "CopyFromID",
                                value: objId,
                                op: "eq"
                            },
                            {
                                property: "CopyFromEntity",
                                value: workingCtx.getContext('Detail').currentStatus().recordType,
                                op: "eq"
                            }

                        ])
                    };
                }
                else {
                    currParams = decodedParams;
                }

                var url = Router.action("WSCView", "Detail", { entity: decodedParams.relatedEntityCollectionID });
                Portal.PageManager.openModule({
                    mode: "tab",
                    url: url,
                    params: currParams,
                    parentContainer: this.getContext('Module'),
                    recordViewID: decodedParams.recordViewID
                });

                topic = 'Portal.' + decodedParams.relatedEntityID + '.Insert';
                messageFilter = 'child';
            }
            else {

                currParams = decodedParams;

                if (decodedParams.type == "2") { //search
                    var urlParams = {
                        entity: decodedParams.relatedEntityCollectionID,
                        allowMultiSelection: true
                    };
                    if (decodedParams.viewID)
                        urlParams.viewID = decodedParams.viewID;
                    var url = Router.action(
                        'WSCView',
                        'List',
                        urlParams
                    );

                    // message topic for single selection
                    topic = 'Portal.' + decodedParams.relatedEntityID + '.ObjectLink.ValueSelected';
                    messageFilter = 'child';

                    // catch multi selection message and handle multiple relation adding
                    var multiSelectionTopic = 'Portal.' + decodedParams.relatedEntityID + '.RecordSelection';

                    if (workingCtx.messageListeners.indexOf(multiSelectionTopic) == -1) {
                        workingCtx.messageListeners.push(multiSelectionTopic);

                        me.listenToMessage({
                            topic: multiSelectionTopic,
                            messageFilter: 'child',
                            listenerFn: function (msg) {
                                if (!Ext.isEmpty(msg.objectIDs)) {
                                    addRelationMultiple(objId, msg.objectIDs);
                                }
                            }
                        });
                    }

                    var filterSelectionTopic = 'Portal.' + decodedParams.relatedEntityID + '.AllRecordSelection';

                    if (workingCtx.messageListeners.indexOf(filterSelectionTopic) == -1) {
                        workingCtx.messageListeners.push(filterSelectionTopic);

                        me.listenToMessage({
                            topic: filterSelectionTopic,
                            messageFilter: 'child',
                            listenerFn: function (msg) {
                                if (!Ext.isEmpty(msg.filter)) {
                                    addRelationByFilter(objId, msg.filter);
                                }
                            }
                        });
                    }

                    // open search view
                    Portal.PageManager.openModule({
                        mode: "objectLink",
                        url: url,
                        params: currParams,
                        parentContainer: me.getContext('Module')
                    });
                }

                if (decodedParams.type == "3") {
                    var cfg = {
                        entity: decodedParams.relatedEntityID
                    };

                    me.doFindObjectById(cfg).then(function (relatedId) {
                        addRelationSingle(objId, relatedId);
                    });
                }
            }

            // add single selection listener
            if (workingCtx.messageListeners.indexOf(topic) == -1) {
                workingCtx.messageListeners.push(topic);

                me.listenToMessage({
                    topic: topic,
                    messageFilter: messageFilter,
                    listenerFn: function (msg) {

                        var relatedId;
                        Portal.Console.log(msg);

                        switch (decodedParams.type) {
                            case "1":
                                relatedId = msg.ID;
                                break;
                            case "2":
                                relatedId = msg.value;
                                break;
                        }

                        addRelationSingle(objId, relatedId);
                    }
                });
            }
        },

        /*
          findObjectById: Opens a find window to search an item by ID. When found displays the Detail, when not found shows an error message.
         
          params:
           - entity: Optional. The entity to open (eg. Incident), inherited from the "workingStatus"
           - recordViewID: Optional. ID of a custom view to use for this command when opening the detail.
         */
        findObjectById: function (params) {
