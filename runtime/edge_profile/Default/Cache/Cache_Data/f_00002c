Ext.define('Portal.Validation.FormErrorsViewer', {

    config: {

        expandContainerOnFieldErrors: true,

        defaultErrorMessage: 'WSC_Msg_FormIvalid'

    },

    privates: {

        getContainersWithErrors: function (fieldsWithErrors) {
            var containersWithErrors = {};

            _.each(fieldsWithErrors, function (field) {
                var container = field.up('container[collapsed]');
                if (container && !containersWithErrors[container.id])
                    containersWithErrors[container.id] = container;
            });

            return containersWithErrors;
        },

        expandContainersWithFieldErrors: function (errors) {
            var fieldsWithErrors =
                _.chain(errors)
                    .filter(function (error) { return Ext.getClassName(error) == 'Portal.Validation.FieldError' && error.getField(); })
                    .map(function (fieldError) { return fieldError.getField(); })
                    .value();

            var containersWithErrors = this.getContainersWithErrors(fieldsWithErrors);

            _.each(containersWithErrors, function (containerWithErrors) {
                if (containerWithErrors.collapsible && containerWithErrors.collapsed)
                    containerWithErrors.expand();
            });
        }
    },

    constructor: function (config) {
        this.initConfig(config);
    },

    showErrors: function (errors) {
        var errorMsg = this.buildErrorMessage(errors);

        Portal.Util.Msg.showErrorToastMsg({ title: translations.WSC_Msg_FormIvalid, html: errorMsg });

        if (this.getExpandContainerOnFieldErrors())
            this.expandContainersWithFieldErrors(errors);
    },

    buildErrorMessage: function (errors) {
        var errorMsg;

        if (errors.length > 0) {
            var errorsToShow = _.map(errors, function (error) { return { name: error.getTitle(), msg: error.getMessage() }; });
            errorMsg = Portal.Util.buildFormErrorsHtml(errorsToShow);
        } else {
            errorMsg = translations[this.getDefaultErrorMessage()];
        }

        return errorMsg;
    }

});
Ext.ns('Portal.Validation');

Ext.define('Portal.Validation.PromiseValidator', {

    config: {
        validators: []
    },

    constructor: function (config) {
        this.initConfig(config);
    },

    addValidator: function(validator){
        this.getValidators().push(validator);
    },

    validate: function (params) {
        var me = this;

        return new Promise(function (resolve, reject) {
            
            // create validator promises
            var promises = _.map(me.getValidators(), function (validator) { return validator(params); });

            // wait for all validations to complete (even those failing)
            RSVP.allSettled(promises)
                .then(function (results) {

                    // collect promise rejections
                    var validationErrors =
                        _.chain(results)
                            .where({ state: 'rejected' })
                            .pluck('reason')
                            .value();

                    if (validationErrors.length > 0) {

                        // each promise can reject with multiple errors (array of errors)
                        // we need to ensure a final "flat" array collecting all errors from each promise rejection result
                        var errors = _.reduce(validationErrors, function (memo, val) { return memo.concat(val) }, []);

                        reject(errors);

                    } else {

                        // collect promise results
                        var results =
                            _.chain(results)
                                .where({ state: 'fulfilled' })
                                .pluck('value')
                                .value();

                        resolve(results);
                    }
                });
        });
    }

});
Ext.define('Portal.Notification.NotificationUtils', {

    singleton: true,

    NEUTRAL: 'neutral',

    INFO: 'info',

    POSITIVE: 'positive',

