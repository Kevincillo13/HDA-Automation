        // workaround to make combo picker always hidden even when field writable status changes (readonly/editable)
        triggers = me.getTriggers();
        if (triggers.picker) triggers.picker.hideOnReadOnly = false;

        var detailTrigger = me.getTrigger('detail');
        if (detailTrigger)
            Ext.override(detailTrigger, { onCustomClick: me.triggerOnCustomClick });

        // apply default configs 
