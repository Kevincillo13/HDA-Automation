Ext.define('Portal.Validation.FormValidator', {

    config: {

        form: null

    },

    constructor: function (config) {
        this.initConfig(config);
    },

    isValid: function () {
        return this.getForm().isValid();
    },

    getErrors: function () {
        var fields = this.getForm().getFields();

        var errors = [];
        fields.each(function (field) {
            var fieldError = field.getActiveError();
            /*
             * fieldError check must be executed before isValid check because there is a bug that reset activeError on field if
             * isValid return true, it happens when there is a disabled field with a remote validation (for example webusername in Contact)
             */
            if (fieldError && fieldError.length > 0)
                errors.push(Ext.create('Portal.Validation.FieldError', { field: field }));
            else if (!field.isValid())
                errors.push(Ext.create('Portal.Validation.FieldError', { field: field }));

        });

        return errors;
    }
});
