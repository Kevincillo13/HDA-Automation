            return ui;
        };

        init() {
            var me = this;
            super.init();
            me.minEventHeight = 40;
        };

        urlChange() {
            super.urlChange();

            if (_configuration.workingHourEnabled && this.Day) {
                var day = this.Day;
                var weekDay = day.getDay();
                var list = this.List;

                var dayConfiguration = _.filter(_configuration.workingHourConfig, (x) => { return x.DayOfWeek == weekDay });

                list.data.each(slot => {
                    var h = slot.id * 1;
                    var availableHour = true;

                    if (dayConfiguration && dayConfiguration.length > 0) {
                        if (dayConfiguration[0].TimeSpan.length == 0) {
                            list.addCss(slot.id, "hour_disabled", true);
                        } else {
                            _.each(dayConfiguration[0].TimeSpan, (time) => {
                                var start = parseInt(time.StartHour.split(":")[0]);
                                var end = parseInt(time.EndHour.split(":")[0]);
                                if ((h < start || h > end) && availableHour) {
                                    list.addCss(slot.id, "hour_disabled", true);
                                } else {
                                    availableHour = false;
                                    list.removeCss(slot.id, "hour_disabled", true);
                                    if (h === start && parseInt(time.StartHour.split(":")[1]) > 0) {
                                        list.addCss(slot.id, "hour_half_disabled_top", true);
                                    } else if (h === end && parseInt(time.EndHour.split(":")[1]) > 0) {
                                        list.addCss(slot.id, "hour_half_disabled_bottom", true);
                                    }
                                }
                            });
                        }
                    }
                });
                this.List.refresh();
            }
        };
    };

