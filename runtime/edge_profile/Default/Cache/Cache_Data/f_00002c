// requires: ['Portal.MessageBus'],
Ext.define('Portal.MessageBusHelper', {

    constructor: function (cfg) {

        var me = this,

            msg = cfg.data || {},

            ctx = cfg.ctx || {},

            result = true,

            applyCondition = function (checkFn, resultFn) {
                if (typeof resultFn == 'function' || result) {
                    result = checkFn.call(this, msg, ctx);
                    if (result && typeof resultFn == 'function') {
                        resultFn.call(this, msg);
                    }   
                }
                return me;
            },

            isAnonymousMsg = function () {
                return (!msg.sourceCtx);
            },

            isMsgFromDescendantsOrSelf = function () {
                if (!msg || !msg.sourceCtx) return false;

                var msgPath = msg.sourceCtx.path,
                    ctxPath = ctx.path(),
                    currentModulePath = getModulePath(ctxPath),
                    msgModulePath = getModulePath(msgPath);

                // if msg has a source path, then test if it starts with module path
                return msgModulePath.indexOf(currentModulePath) == 0;
            },

            isMsgFromAncestorsOrSelf = function () {
                if (!msg || !msg.sourceCtx) return false;

                return ctx.path().indexOf(msg.sourceCtx.path) == 0;
            },

            isMsgFromParent = function () {
                if(!isMsgFromAncestorsOrSelf()) return false;

                return (ctx.path() == (msg.sourceCtx.path + '/' + ctx.id));
            },

            isMsgFromChild = function () {
                var msgPath = msg.sourceCtx.path,
                    ctxPath = ctx.path(),
                    currentModulePath = getModulePath(ctxPath),
                    msgModulePath = getModulePath(msgPath);

                // if message path is shorter than current module path, then we're not in a child module
                if (msgModulePath.length <= currentModulePath.length) return false;

                // if message path doesn't start with current module path, then we're not in a child moule
                if (msgModulePath.indexOf(currentModulePath) != 0) return false;

                var childPath = msgModulePath.substring(currentModulePath.length + 1),
                    childPathItems = childPath.split('/');

                return (childPath && childPathItems.length == 1);
            },

            isMsgFromActiveTab = function (cfg) {

                var activeTab = Portal.PageManager.getTabContainer().getActiveTab(),
                    tab = cfg.portalTab;

                return (tab === activeTab);
            },

            isPrivateMsg = function () {

                // TODO - return isMsgFromAncestorsOrSelf OR isMsgFromDescendantsOrSelf ?

                if (!msg || !msg.sourceCtx) return false;

                var msgPath = msg.sourceCtx.path,
                    modulePath = ctx.path(),
                    msgPathArr = msgPath.split('/'),
                    modulePathArr = modulePath.split('/'),
                    cnt = 0;

                // check if the two paths (message one and context one) have some common items
                for (var i = 0, l = Math.min(msgPathArr.length, modulePathArr.length) ; i < l; i++) {
                    if (msgPathArr[i] != modulePathArr[i])
                        break;
                    cnt++;
                }

                return cnt > 1;
            },

            isSameModuleMsg = function () {
                if (!msg || !msg.sourceCtx) return false;

                var ctxPath = ctx.path(),
                    msgPath = msg.sourceCtx.path;

                return (ctxPath.substring(0, ctxPath.lastIndexOf('/')) === msgPath.substring(0, msgPath.lastIndexOf('/')));
            },

            isSamePageMsg = function () {
                if (!msg || !msg.sourceCtx) return false;

                var moduleCtx = ctx.getContext('Module'),
                    msgModuleCtx = Ext.getCmp(msg.sourceCtx.componentId).getContext('Module'),
                    modulePageCmp,
                    msgPageCmp;

                if (moduleCtx && msgModuleCtx) {
                    modulePageCmp = moduleCtx.pageComponent();
                    msgPageCmp = msgModuleCtx.pageComponent();
                    
                    return (modulePageCmp && msgPageCmp && modulePageCmp.id === msgPageCmp.id);
                }
                return false;
            },

            getModulePath = function (path) {
                // remove first '/'
                if (Ext.String.startsWith(path, '/')) path = path.substring(1);

                // single level path
                if (path.indexOf('/') == -1) return '/' + path;

                // split path items
                var pathItems = path.split('/');

                // extract module path items
                var modulePathItems = [];
                Ext.each(pathItems, function (itm) {
                    if (Ext.String.endsWith(itm, '_Module')) {
                        modulePathItems.push(itm);
                    } else {
                        // break;
                        return false;
                    }
                });

                return '/' + modulePathItems.join('/');
            };

        me.check = function () {
            return result;
        };

        me.isAnonymous = function (fn) {
            return applyCondition(isAnonymousMsg, fn);
        };

        me.isParent = function (fn) {
            return applyCondition(isMsgFromParent, fn);
        };

        me.isChild = function (fn) {
            return applyCondition(isMsgFromChild, fn);
        };

        me.isPrivate = function (fn) {
            return applyCondition(isPrivateMsg, fn);
        };

        me.getModulePath = getModulePath;

        me.isValidMessage = function (cfg) {
            var me = this;
            return applyCondition.call(
                me,
                function () {
                    var valid = true, filterType = typeof cfg.messageFilter;
                    if (filterType == 'string') {
                        switch (cfg.messageFilter) {
                            case 'private':
                                // is message private (having same root path?)
                                valid = isPrivateMsg();
                                break;
                            case 'samemodule':
                                // is message from same module?
                                valid = isSameModuleMsg();
                                break;
                            case 'samepage':
                                valid = isSamePageMsg();
                                break;
                            case 'descendant-or-self':
                                valid = isMsgFromDescendantsOrSelf();
                                break;
                            case 'ancestor-or-self':
                                valid = isMsgFromAncestorsOrSelf();
                                break;
                            case 'child':
                                valid = isMsgFromChild();
                                break;
                            case 'activetab':
                                valid = isMsgFromActiveTab(cfg);
                                break;
                            default:
                                // do nothing
                        }
                    } else if (filterType == 'function') {
                        valid = cfg.messageFilter(msg);
                    }

                    if (valid) {
                        // check context name filter if specified
                        if (cfg.contextName) {
                            if (!msg.sourceCtx || !msg.sourceCtx.contextName || msg.sourceCtx.contextName !== cfg.contextName) valid = false;
                        }
                    }

                    return valid;
                },
                cfg.listenerFn);
        };
    }
});

