    /**
     * Webix Sidebar extension (to better handle sidebar popup positioning when scrollbar is visible)
     */
    webix.protoUI({

        name: "portalsidebar",

        $init: function (config) {
            // instantiate custom popup and pass sidebar ref
            config.popup = config.popup || {};
            config.popup.view = 'portalsidebarpopup';
            config.popup.sidebar = this;
        }

    }, webix.ui.sidebar);

    /**
     * Webix Popup extension (to better handle sidebar popup positioning when scrollbar is visible)
     */
    webix.protoUI({

        name: 'portalsidebarpopup',

        // override
        show: function (node, position, point) {

            // scrollbar issue workaround
            // calculate horizontal offset to make the popup overlap the scrollbar

            let sidebar = this.config.sidebar;
            let sidebarNode = sidebar.getNode();
            let hasContentScroll = sidebarNode.clientHeight < sidebarNode.scrollHeight;
            let xOffset = hasContentScroll ? -webix.env.scrollSize : 0;

            position.x += xOffset;

            return webix.ui.popup.prototype.show.call(this, node, position, point);
        }

    }, webix.ui.popup);

}
