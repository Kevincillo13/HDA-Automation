Ext.ns('Portal.Filters');

Portal.Filters.FilterAreaContext = function () {

    // self reference
    var me = null;

    // delayed tasks 
    var invalidFilterTask = null;

    // consts
    var ADV_FILTER_TYPE = 'advanced',
        STD_FILTER_TYPE = 'standard',
        FILTER_AREA_TYPE = "FILTERAREA",
        IMMEDIATE_DELAY = 10,   // milliseconds
        DEFAULT_DELAY = 1500;   // milliseconds

    // panels
    var advancedFiltersPanel = null,    // dynamic panel to show advanced filter's controls
        infoPanel = null,               // current filter's infos
        warningPanel = null;            // current filter's warnings

    // filters
    var originalFilter = null,
        initialAdvancedFilter = {},
        initialParameters = [];

    var toolbarContainer = null;

    var _filterToggleCmp = null;

    // an object that keeps references to all areas declared for current filter area
    //  {
    //    [** areaID **]: {
    //      areaCmp: [** areaContainerComponent **],
    //      defaultFilterCmp: [** default filter component **],
    //      task: [** delayed task called when filter area values change **]
    //    }
    //  }
    var areas = {},
        activeAreaID = null;

    // starting server configuration
    var contextConfig = null;

    // configurations
    var filtersChangeDelay = DEFAULT_DELAY,
        enableFilterStoring = false,
        viewMode = null,    // inline|window
        filtersInitialized = false;

    var _filterMatcher = null;

    /**
     * Filter indicator visualization mode:
     * - 'none': no filter indicator is shown;
     * - 'removable_filters': show filter indicator when there is at least one removable filter applied (excludes visible locked filters);
     * - 'visibile_filters': show filter indicator when there is at least one visible filter applied (includes visible locked filters);
     * 
     * Note: implicit filters are always excluded.s
     */
    var _filterIndicatorMode = null;

    var _filterIndicatorActive = false;

    var _fixedFilters = null;

    /****************************************************************************
    *                               SYSTEM INIT
    ****************************************************************************/

    var _init = function (initCfg) {

        me = this;

        _filterMatcher = Portal.Filters.FilterAreaContext.Utils.getFilterMatcher();
        _filterIndicatorMode = Portal.Filters.FilterAreaContext.Utils.getFilterIndicatorMode();

        infoPanel = me.component.down('infopanel#listinfo');
        warningPanel = me.component.down('infopanel#listwarning');

        initCfg = initCfg || {};

        // loading state
        var initialState = {};

        var moduleCtx = me.getContext('Module');

        contextConfig = me.getConfiguration('FilterAreaContextConfig');

        invalidFilterTask = new Ext.util.DelayedTask(function () {
            _sendInvalidFilterMessage();
        });

        if (contextConfig) {

            me.recordType = contextConfig.recordType;

            if (contextConfig.toolbarContainerID) {
                toolbarContainer = Ext.net.ResourceMgr.getCmp(contextConfig.toolbarContainerID);
                _filterToggleCmp = toolbarContainer.getComponent('filterToggle');
            }

            if (!Ext.isEmpty(moduleCtx.getModuleParams().EnableFilterStoring)) {
                enableFilterStoring = moduleCtx.getModuleParams().EnableFilterStoring === 'true';
            }

            if (contextConfig.areasConfig)
                _setupAreas(Portal.Util.Json.decode(contextConfig.areasConfig, true));

            if (contextConfig.filter) {
                // setFilters and send init message
                me.initialFilters = Portal.Util.Json.decode(contextConfig.filter, true);

                initialState.stdFilter = me.initialFilters;
                //me.lastFilters = me.getFilter();

                // reset dirty flag for all active area filters
                _getActiveArea().getForm().resetDirty();
            }

            viewMode = contextConfig.viewMode ? contextConfig.viewMode : "inline";

            if (contextConfig.filtersChangeDelay * 1 >= 0)
                filtersChangeDelay = contextConfig.filtersChangeDelay;
        }

        if (contextConfig.useAdvancedFilters) _initAdvancedFilters(initialState);

        _setupInfoPanel();

        // set initial filter state
        me.setFilterState(initialState, _isExpanded());

        _setupFilterIndicatorManagement();

        filtersInitialized = true;

        _sendFilterInitMessage();
        me.fireEvent('filtersinit', me, me.lastFilters);

        Ext.syncRequire('Portal.Filters.QuickFilterHelper', function () {
            var config = {
                type: FILTER_AREA_TYPE,
                getFilterSettings: function () { return me.filterSettings; },
                getFilterAreaID: _getFilterAreaID,
                getFilterEntity: function () { return me.recordType; },
                getFilterEntityCollection: function () { return me.collectionType; },
                getFilterState: _getFilterState,
                getFilterFields: _getFilterFields,
                loadFilterButtonHandler: _loadFilter,
                reloadAdvancedFilterArea: _reloadAdvancedFilterArea,
                saveFilterHandler: function (success, filterName, filterDescription, filterId) {
                    if (success) {
                        _showInfoPanel(
                            filterName,
                            filterDescription,
                            infoPanel && infoPanel.getData() ? infoPanel.getData().readonly : false);
                    }
                }
            };
            me.quickFilter = Portal.Filters.QuickFilterHelper(me, config);
        });

        originalFilter = _getFilterState();

        // add info panel listener


        // listen to filter set messages sent from Analysis
        if (me.recordType) {
            me.listenToMessage({
                topic: 'Portal.FilterArea.' + me.recordType + '.SetFilter',
                messageFilter: 'samepage',
                listenerFn: function (msg) {

                    var filterObj = msg,
                        filters = msg.filters,
                        keepLockedFilters = false;

                    if (Ext.isString(msg.filters)) {
                        filters = Portal.Util.Json.decode(msg.filters, true);
                    }

                    if (Ext.isDefined(msg.keepLockedFilters)) {
                        keepLockedFilters = msg.keepLockedFilters ? true : false;
                    }

                    // apply defaults
                    Ext.applyIf(filterObj, {
                        canEdit: true
                    });

                    _clearFilters(false, false, true);

                    if (Ext.isArray(filters)) {
                        var filtersToKeep = [];

                        if (keepLockedFilters) {
                            // keep only LOCKED filters.
                            filtersToKeep = _.filter(me.initialFilters, function (f) { return Ext.isDefined(f.lock) && f.lock; });
                        }

                        me.initialFilters = filtersToKeep.concat(filters);
                        filterObj.stdFilter = filters;
                    }

                    me.setFilterState(filterObj);

                    me.lastFilters = me.getFilter();
                    _saveLocalStoredFilter();
                }
            });
        }

    };

    var _setupInfoPanel = function () {
        if (!infoPanel) return;

        infoPanel.on('click', function () {
            me.openFilterEditor();
        });

        infoPanel.on('close', function () {
            me.backToOriginalFilter();
        });
    };

    // register filter areas
    // each filter area configuration is an array with [area id, container component id, (optional) default filter id]
    var _setupAreas = function (areasCfg) {
        if (!areasCfg || areasCfg.length === 0) return;
        var areaCmp, defaultFilterCmp;

        Ext.each(areasCfg, function (cfg) {
            areaCmp = null;
            defaultFilterCmp = null;

            if (!cfg || cfg.length < 2) return;
            areaCmp = Ext.net.ResourceMgr.getCmp(cfg[1]);

            if (cfg[2])
                defaultFilterCmp = toolbarContainer.down('#' + cfg[2]);

            areas['filterArea_' + cfg[0]] = { areaCmp: areaCmp, defaultFilterCmp: defaultFilterCmp, task: null };
        });

        // set first area as active by default
        activeAreaID = 'filterArea_' + areasCfg[0][0];

        //me.lastFilters = me.getFilter();

        if (me.component.rendered) {
            _restoreLocalStoredFilter();
        } else {
            me.component.mon(me.component, 'afterrender', _restoreLocalStoredFilter);
        }

    };

    var _initAdvancedFilters = function (initialState) {

        // save ref to advanced filters panel
        advancedFiltersPanel = me.component.down('#AdvancedFilters');

        if (advancedFiltersPanel) {
            initialState.advFilter = advancedFiltersPanel.advancedFilter;
            initialState.parameters = advancedFiltersPanel.parameters;
        }
    };

    /****************************************************************************
    *                                 EVENTS
    ****************************************************************************/

    var _advancedFilterAreaLoadComplete = function (advFilter, parameters) {
        var getParamFilterRecursive = function (controlId, filter) {
            var result = null;

            if (filter.conditions) {
                for (var f = 0; f < filter.conditions.length; f++) {
                    if (filter.conditions[f].parameterControlId && filter.conditions[f].parameterControlId === controlId) {
                        result = filter.conditions[f];
                        break;
                    }
                }
            }

            if (!result && filter.subfilters) {

                for (var sf = 0; sf < filter.subfilters.length; sf++) {
                    result = getParamFilterRecursive(controlId, filter.subfilters[sf]);

                    if (result) break;
                }
            }

            return result;
        };

        // update filter value
        var controls = _getAdvancedFilterFields();

        controls.forEach(function (item) {
            item.suspendEvent('change');
            var filter = getParamFilterRecursive(item.itemId, advFilter);
            if (filter) Portal.Filters.FilterAreaContext.Utils.setFieldValueFromFilter(item, filter);
            item.resumeEvent('change');
        });

        // update status
        initialAdvancedFilter = advFilter;
        initialParameters = parameters;
        //me.lastFilters = me.getFilter();

        // highlight advanced filter area
        _highlightAdvancedFilters();

        advancedFiltersPanel.show();

        // notify changes
        me.filtersChanged(true, true);
    };

    var _highlightAdvancedFilters = function (filters) {

        // highlight advanced filter panel
        if (contextConfig.useAdvancedFilters && advancedFiltersPanel && _isExpanded())
            if (advancedFiltersPanel.getEl()) advancedFiltersPanel.getEl().frame();

        _highlightFilters(filters);
    };

    var _highlightFilters = function (filters) {
        if (!filters || filters.length === 0 || !_isExpanded()) return;

        //  highlight standard filters
        var filterAreaForm = _getActiveArea().getForm(),
            filterItems = filterAreaForm.getFields();

        Ext.each(filters, function (item, index, all) {
            var control = filterItems.findBy(function (f) {
                return f.getName() === item.property && f.filterOperator === item.op;
            });
            if (control && !Ext.isEmptyObj(control) && !control.hidden) {
                var element = control.getEl();
                if (element) { element.frame(); }
            }
        });
    };

    var _filtersChanged = function (immediateNotification, force) {

        if (!force && !filtersInitialized)
            return;

        // send "immediate" message? call task with a small delay in order to buffer other concurrent calls
        // send "delayed" message? use standard delay
        var delay = immediateNotification ? IMMEDIATE_DELAY : filtersChangeDelay;

        if (!_isValid()) {
            me.lastFilters = {};
            invalidFilterTask.delay(delay);
            return;
        }

        var filters = me.getFilter() || {},
            lastFilters = me.lastFilters || {},
            changed = Portal.Util.areFiltersDifferent(filters, lastFilters);

        if (!changed) return;

        me.lastFilters = filters;

        var areaTask = _getActiveAreaTask(function () {
            _sendFilterChangedMessage(me.lastFilters);
            me.fireEvent('filterschanged', me, me.lastFilters);
        });

        areaTask.delay(delay);
    };

