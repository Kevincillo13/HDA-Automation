Ext.apply(Portal.CommandContext, { Utils: {} });
Ext.apply(Portal.CommandContext.Utils, {
    prepareOperationParams: function (status, params, encodeValues) {

        var currentParams = Portal.Util.buildParams(params, status),
            filterArr = status.filter || [];

        if (currentParams.filter) {
            filterArr = this.mergeOperationFilters(status.filter, currentParams.filter);
        }
        currentParams.filter = filterArr;

        if (encodeValues) {
            for (var p in currentParams) {
                if (Ext.isString(currentParams[p])) {
                    // do nothing for strings
                } else if (Ext.isDate(currentParams[p])) {
                    // date encoding
                    currentParams[p] = Portal.Util.Json.getDateToJson(currentParams[p]);
                } else {
                    // numeric/bool/object/array encoding
                    currentParams[p] = Portal.Util.Json.encode(currentParams[p]);
                }
            }
        }

        return currentParams;
    },
    // Merges context filter with operation specific filter.
    mergeOperationFilters: function (ctxFilter, operationFilter) {
        var filterArr = [],
            operationFilter;

        if (ctxFilter) {
            filterArr = filterArr.concat(ctxFilter);
        }

        if (operationFilter) {
            if (typeof operationFilter === 'string') {
                operationFilter = Portal.Util.Json.decode(operationFilter);
            }

            if (!Ext.isArray(operationFilter)) {
                operationFilter = [operationFilter];
            }

            filterArr = Portal.Util.mergeFilterArrays(operationFilter, filterArr);
        }

        return filterArr;

    }
});
Portal.Actions = new function () {
    
    function onClick(el) {

        var args = {},
            arg = null,
            action = null,
            context = null;

        for (var att, i = 0, atts = el.attributes, n = atts.length; i < n; i++) {

            att = atts[i];

            if (att.nodeName.startsWith('data-')) {

                arg = att.nodeName.replace('data-', '');

                switch (arg) {

                    case 'action':
                        action = att.nodeValue;
                        break;

                    case 'context':
                        context = att.nodeValue;
                        break;

                    default:
                        args[arg] = att.nodeValue;
                }

            }
        }

        if (context) {

            var cmp = Ext.Component.fromElement(Ext.fly(el));

            if (cmp) {
                var ctx = cmp.getContext(context);
                if (ctx) {
                    var ctxFn = ctx[action];
                    ctxFn.call(ctx, args);
                }
            }

        } else {

            if (action) {

                var fn = eval(action);

                if (fn) fn.call(el, args);
            }
        }

    };
    
    return {

        //configureComponentClick: configureComponentClick,
        onClick: onClick

    };
};
