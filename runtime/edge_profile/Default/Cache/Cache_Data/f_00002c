Ext.define('Portal.UI.LayoutManager', {

    singleton: true,

    privates: {

        _viewport: null,

        _sortedBreakpoints: [],

        _currentSize: null,

        _checkSizeTask: null,

        _initialized: false,

        _calcSize: function () {

            var windowWidth = window.innerWidth;
            var size = _.find(this._sortedBreakpoints, function (bp) { return bp.value >= windowWidth; });

            return (size ? size.name : '');
        },

        _updateHtmlClass: function (newSize) {
            if (this._currentSize) {
                document.documentElement.classList.remove(this._getSizeClsName(this._currentSize));
                document.documentElement.classList.remove(this._getSizeAndDeviceClsName(this._currentSize));
            }

            if (newSize) {
                document.documentElement.classList.add(this._getSizeClsName(newSize));
                document.documentElement.classList.add(this._getSizeAndDeviceClsName(newSize));
            }
        },

        _checkSize: function () {
            var oldSize = this._currentSize;

            var newSize = this._calcSize();

            if (newSize !== this._currentSize) {
                
                this._updateHtmlClass(newSize);
                this._currentSize = newSize;

                if (this._initialized) {

                    var vp = this.getViewport();
                    if (vp) vp.doLayout();

                    Portal.MessageBus.publish('Portal.UI.Layout.Change', { oldSize: oldSize, newSize: newSize });
                }
            }
        },

        _getSizeClsName: function (size) {
            return (size ? 'layout-' + size.toLowerCase() : '');
        },

        _getSizeAndDeviceClsName: function (size) {
            if (!size) return '';

            var sizeCls = this._getSizeClsName(size);

            var deviceCls = Portal.Const.Device.IsMobile ? 'mobile' : 'desktop';

            return sizeCls + '-' + deviceCls;
        }

    },

    setup: function () {

        var me = this;

        document.addEventListener("DOMContentLoaded", function () {

            me._sortedBreakpoints = _
                .chain(Portal.Const.UI.LayoutBreakPoints)
                .map(function (value, name) { return { name: name, value: value * 1 }; })
                .sortBy('value')
                .value();

            if (_.any(me._sortedBreakpoints)) {

                me._checkSizeTask = new Ext.util.DelayedTask(function () {
                    me._checkSize();
                });

                window.addEventListener("resize", function () {
                    me._checkSizeTask.delay(100);
                });

                me._checkSize();
            }

            me._initialized = true;

            Portal.MessageBus.publish('Portal.UI.Layout.Init', { size: me._currentSize });

        });

    },

    getCurrentSize: function () {
        return this._currentSize;
    },

    getViewport: function () {
        if (!this._viewport) {
            this._viewport = Ext.ComponentQuery.query('netviewport')[0];
        }

        // TODO - PLUS - CONTROLLARE PERCHE' VIENE GENERATO VIEWPORT NON EXT.NET
        if (!this._viewport) {
            this._viewport = Ext.ComponentQuery.query('viewport')[0];
        }

        return this._viewport;
    }

});
