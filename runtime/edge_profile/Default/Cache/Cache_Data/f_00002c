        /*
          doFindObjectById: returns a PROMISE that performs the actual search by id, checks object existence           
         
          cfg:
          - entity: The entity to open (eg. Incident)
         */
        doFindObjectById: function (cfg) {

            var promise = new Promise(function (resolve, reject) {

                Portal.PageManager.openModule({
                    url: Router.action("WSCView", "FindObjectById"),
                    mode: 'window',
                    width: 350,
                    height: -1,
                    parentContainer: me.getContext('Module'),
                    params: {
                        entity: cfg.entity
                    },
                    customParams: {
                        endDialogFn: function (objectID) {

                            if (Ext.isString(objectID)) {
                                objectID = objectID.trim();
                            }

                            if (Ext.isEmpty(objectID)) {
                                reject();
                                return;
                            }

                            Portal.WSC.OperationManager.exists({
                                id: objectID,
                                entity: cfg.entity,
                                successFn: function () {
                                    resolve(objectID);
                                },
                                failureFn: function () {
                                    Portal.Util.Msg.showErrorMsg(Ext.String.format(translations['WSC_Msg_ObjectNotFound'], translations['WSC_' + cfg.entity]));

                                    reject();
                                }
                            });
                        }
                    }
                });

            });

            return promise;
        },

