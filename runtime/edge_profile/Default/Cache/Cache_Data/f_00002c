Ext.define('Portal.Controls.ObjectLinkExtended', {

    extend: 'Portal.Controls.CompositeFieldBase',

    alias: 'widget.objectlinkextended',

    fieldTypeCls: 'objectlink-extended-field',

    config: {

        name: null,

        entity: null,

        recordType: null,

        collectionType: null,

        detailUrl: null,

        dataResolutionUrl: null,

        searchUrl: null,

        searchFilters: null,

        immediateSearchUrl: null,

        immediateSearchOperator: null,

        immediateSearchField: null,

        detailOpeningMode: null,

        readOnly: false,

        allowBlank: true,

        previewTpl: null,

        previewTplExpressions: null,

        previewHeight: null,

        previewCollapsed: false,

        previewCollapsible: false,

        previewAutoCollapse: false,

        cls: null,

        emptyValue: Portal.Const.EMPTY_ID,

        emptyText: null,

        objectLinkFieldConfig: null

    },

    privates: {

        objectLinkField: null,

        selectedObject: null,

        previewContainer: null,

        previewProjectionExpressions: null,

        previewProjectionAliases: null,

        getTemplateData: function (objectID) {
            var me = this;

            var promise = new Promise(function (resolve, reject) {

                Portal.WSC.OperationManager.request({
                    url: Router.action('WSC', 'Projection'),
                    params: {
                        entity: me.getEntity(),
                        filter: Portal.Util.Json.encode([{ property: 'ID', op: 'eq', value: objectID }]),
                        columnNames: Portal.Util.Json.encode(me.previewProjectionAliases),
                        columnExpressions: Portal.Util.Json.encode(me.previewProjectionExpressions),
                        limit: 1
                    },
                    successFn: function (response) {
                        if(response.data && response.data.length == 1)
                            resolve(response.data[0]);

                        reject();
                    },
                    failureFn: function (response) {
                        reject(response);
                    }
                });
            });

            return promise;
        },

        onValueResolved: function (objLink, value, description, initialized) {
            var me = this;

            me.previewContainer.setLoading(true);

            this.selectedObject = this.objectLinkField.selectedObject;

            this.fireEvent('valueresolved', this, value, description, initialized);

            this.getTemplateData(value)
                .then(function (data) {
                    me.updatePreview(data);
                })
                .catch(function (errors) {
                    me.previewContainer.update(me.getErrorPlaceholder());
                })
                .finally(function () {
                    me.previewContainer.setLoading(false);
                    me.updateControlUI();
                });
        },

        onValueChange: function (objLink, newValue, oldValue) {
            if (this.isValueClear(newValue, oldValue)) {
                this.onValueClear();
            } else if (this.isValueSet(newValue, oldValue)) {
                this.onValueSet(newValue);
            }

            if (this.isRealValueChange(newValue, oldValue)) {
                this.fireEvent('change', this, newValue, oldValue);
            }
        },

        onValueClear: function () {
            this.previewContainer.update(this.getEmptyPlaceholder());
            
            this.updateControlUI();
        },

        onValueSet: function (value) {
            this.updateControlUI();
        },

        onValueResolutionError: function (objLink, errorCode, errorMessage) {
            this.previewContainer.update(this.getErrorPlaceholder(errorMessage));
        },

        onImmediateSearchError: function (objLink) {
            this.previewContainer.update(this.getNoResultsPlaceholder());
        },

        onValidityChange: function (objLink, isValid, eOpts) {
            if (isValid)
                this.clearInvalid();
            else
                this.markInvalid(this.getErrors());

            this.toggleInvalidCls(!isValid);

            this.fireEvent('validitychange', this, isValid, eOpts);
        },

        onObjectLinkTriggerClick: function (field, trigger, index, tag, e) {
            if (!this.objectLinkField.hideTrigger) {
                switch (tag) {

                    case 'preview':
                        this.togglePreview();
                        break;

                    default:
                        // let the object link field manage its default triggers
                }
            }
        },

        isRealValueChange: function (newValue, oldValue) {
            return (
                this.isValueClear(newValue, oldValue) ||
                this.isValueSet(newValue, oldValue) ||
                (
                    !this.isEmptyValue(newValue) &&
                    !this.isEmptyValue(oldValue) &&
                    newValue != oldValue
                )
            );
        },

        isEmptyValue: function (value) {
            return Portal.Util.isEmptyValue(value) || _.isArray(value);
        },

        isValueClear: function (newValue, oldValue) {
            return !this.isEmptyValue(oldValue) && this.isEmptyValue(newValue);
        },

        isValueSet: function (newValue, oldValue) {
            return (
                !this.isEmptyValue(newValue) &&
                this.isEmptyValue(oldValue)
            );
        },

        getEmptyPlaceholder: function () {
            return Portal.PageManager.generatePlaceholderHtml('', 'obj-link-extended-empty');
        },

        getErrorPlaceholder: function (errorMsg) {            
            return Portal.PageManager.generatePlaceholderHtml(errorMsg, 'obj-link-extended error');
        },

        getNoResultsPlaceholder: function () {
            return Portal.PageManager.generatePlaceholderHtml(translations.WSC_Msg_ObjectLinkSearchFailure, 'obj-link-extended no-results');
        },

        refreshCls: function () {
            if (this.previewContainer.hidden) {
                this.addCls('preview-collapsed');
                this.removeCls('preview-expanded');
            } else {
                this.addCls('preview-expanded');
                this.removeCls('preview-collapsed');
            }
        }

    },

    initCompositeField: function () {
        var objLinkConfig = this.getObjectLinkFieldConfig();

        Ext.apply(objLinkConfig, {
            allowBlank: this.getAllowBlank(),
            readOnly: this.getReadOnly(),
            isFormField: false
        });

        this.previewProjectionExpressions = _.pluck(this.getPreviewTplExpressions() || [], 'Expression');
        this.previewProjectionAliases = _.pluck(this.getPreviewTplExpressions() || [], 'Alias');

        Ext.apply(this, {
            contentLayout: { type: 'vbox', align: 'stretch' },
            contentItems: [
                objLinkConfig,
                {
                    xtype: 'container',
                    itemId: 'previewcontainer',
                    cls: 'preview-ct',
                    height: (this.getPreviewHeight() ? this.getPreviewHeight() : null),
                    flex: 1,
                    tpl: this.previewTpl,
                    margin: 0,
                    html: this.getEmptyPlaceholder(),
                    autoScroll: true,
                    hidden: this.getPreviewAutoCollapse() ? (this.value ? false : true) : this.getPreviewCollapsed()
                }]
        });

    },

    initInternalReferences: function () {
        // save child components references
        this.previewContainer = this.down('#previewcontainer');
        this.objectLinkField = this.down('#objlinkfield');

        if (this.value) this.objectLinkField.value = this.value;
    },

    onInitComplete: function () {
        // setup object link field

        // TODO - OBJLINKEXTENDED - MIGLIORARE - FARE IN MODO CHE TUTTI I TRIGGER DELL'OBJECT LINK ABBIANO QUESTO COMPORTAMENTO IN MODO TRASPARENTE
        var previewTrigger = this.objectLinkField.getTrigger('preview');
        if (previewTrigger)
            Ext.override(previewTrigger, { onCustomClick: this.objectLinkField.triggerOnCustomClick });

        this.objectLinkField.on(
            'triggerclick',
            this.onObjectLinkTriggerClick,
            this);

        this.objectLinkField.on(
            'valueresolved',
            this.onValueResolved,
            this);

        this.objectLinkField.on(
            'change',
            this.onValueChange,
            this);

        this.objectLinkField.on(
            'valueresolutionerror',
            this.onValueResolutionError,
            this);

        this.objectLinkField.on(
            'immediatesearcherror',
            this.onImmediateSearchError,
            this);

        this.objectLinkField.on(
            'focusenter',
            function () {
                this.addCls('x-field-focus');
            },
            this
        );

        this.objectLinkField.on(
            'focusleave',
            function () {
                this.removeCls('x-field-focus');
            },
            this
        );

        this.objectLinkField.on(
            'validitychange',
            this.onValidityChange,
            this
        );

        this.refreshCls();
    },

    updatePreview: function (data) {
        this.previewContainer.update(data);
    },

    showPreview: function () {
        this.previewContainer.show();
        this.refreshCls();
    },

    hidePreview: function () {
        this.previewContainer.hide();
        this.refreshCls();
    },

    togglePreview: function () {
        if (this.previewContainer.hidden)
            this.showPreview();
        else
            this.hidePreview();
    },

    setValue: function (value) {
        this.objectLinkField.setValue(value);
    },

    getValue: function () {
        return this.objectLinkField.getValue();
    },

    getDisplayValue: function () {
        return this.objectLinkField.getDisplayValue();
    },

    initValue: function () {

        // avoid initValue call with empty value, it causes issues on object link initialization when there are active dependencies

        if (this.value) {
            this.objectLinkField.initValue.apply(this.objectLinkField, arguments);
            this.onValueSet(this.value);
        }
    },

    isDirty: function () {
        return this.objectLinkField.isDirty();
    },

    resetOriginalValue: function () {
        this.mixins.field.resetOriginalValue.call(this);

        this.objectLinkField.resetOriginalValue();
    },

    resetDirty: function () {
        this.objectLinkField.resetDirty();
    },

    markInvalid: function (errors) {
        this.objectLinkField.markInvalid(errors);
        this.setActiveErrors(errors);
    },

    clearInvalid: function () {
        this.objectLinkField.clearInvalid();
        this.unsetActiveError();
    },

    isValid: function () {
        return this.objectLinkField.isValid();
    },

    getErrors: function () {
        return this.objectLinkField.getErrors();
    },

    setMandatory: function (isCompulsory) {
        this.callParent(arguments);

        this.objectLinkField.setMandatory(isCompulsory);
    },

    getSearchFilter: function () {
        return this.objectLinkField.searchFilters;
    },

    setSearchFilter: function (newFilter) {
        this.objectLinkField.setSearchFilter(newFilter);
    },

    resetSearchFilter: function () {
        this.objectLinkField.searchFilters = null;
    },

    getSelectedObject: function () {
        return this.selectedObject;
    },

    isLoadingMode: function () {
        return this.objectLinkField.isLoadingMode();
    },

    setLoadingMode: function (value) {
        return this.objectLinkField.setLoadingMode(value);
    },

    isInitializing: function () {
        return this.objectLinkField.isInitializing();
    },

    autoresolve: function () {
        this.objectLinkField.autoresolve.apply(this.objectLinkField, arguments);
    },

    collapse: function () { 
        this.hidePreview();
    },

    expand: function () {
        this.showPreview();
    },

    clearValue: function () {
        this.objectLinkField.clearValue();
        this.updateControlUI();
    },

    updateControlUI: function () {
        var me = this;

        if (!me.rendered) return;

        var isEmpty = me.isEmpty();
        var isReadOnly = me.readOnly;
        
        me.objectLinkField.setReadOnly(isReadOnly);

        var triggersVisibility = {
            'detail': !isEmpty,
            'objectLink': !isReadOnly && isEmpty,
            'clear': !isReadOnly && !isEmpty
        };

        _.each(triggersVisibility, function (visible, triggerName) {
            var trigger = me.objectLinkField.getTrigger(triggerName);
            if (trigger) trigger.setVisible(visible);
        });

        if (me.getPreviewAutoCollapse() && me.previewCollapsible) {
            if (isEmpty)
                me.hidePreview();
            else
                me.showPreview();
        }

    }

});
