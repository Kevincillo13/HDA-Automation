Ext.define('Portal.Navigation.History', {

    singleton: true,

    alternateClassName: ['Portal.History'],

    HISTORY_LEVEL_SEPARATOR: '@',

    HISTORY_PARAMS_SEPARATOR: '$',

    URL_PARAMS_SEPARATOR: '?',

    currentToken: null,

    back: function () {
        Ext.History.back();
    },

    add: function (hash, preventDup) {
        // save current token to internal token
        this.currentToken = hash;

        Ext.History.add(hash, preventDup);
    },

    addLevel: function (hash, level, preventDup) {

        var parsedToken = this.splitToken(this.getToken()),//this.parseCurrentToken(),
            token;

        parsedToken = parsedToken.slice(0, level);
        parsedToken.push(hash);

        token = parsedToken.join(this.HISTORY_LEVEL_SEPARATOR);

        // save current token to internal token
        this.currentToken = token;

        Ext.History.add(token, preventDup);
    },

    getToken: function (level) {
        var token = Ext.History.getToken();

        // woarkaround to avoid Ext.History.getToken empty result when history is not yet ready
        // if Ext.History token is empty (it could happen when Ext.History's internal task isn't ready or hasn't yet handled last Ext.History.add call) then use Portal.History internal token
        if (Ext.isEmpty(token)) token = this.currentToken;

        if (Ext.isEmpty(token)) return '';

        // no specific history level required, return token as is
        if (!Ext.isDefined(level)) return token;

        // extract the required history level from token
        var levels = token.split(this.HISTORY_LEVEL_SEPARATOR);

        if (levels.length <= level) return null;
        return levels[level];
    },

    onChange: function (mgr) {
        var me = this,
            observable = mgr.getHistorySource(),
            fn = mgr.onHistoryChange,
            level = mgr.getHistoryLevel(),
            prefix = mgr.getHistoryPrefix(),
            listener;

        if (!Ext.isDefined(level) && !Ext.isDefined(prefix)) {
            // no level specified
            // attach fn to history change
            listener = fn;

        } else {
            // if a specific history level is specified then
            // attach fn to history change passing the required level history token
            listener = function (token) {
                var parsedToken = me.parseToken(token);

                if (parsedToken && parsedToken.length > level) {
                    if (!Ext.isDefined(prefix) || Ext.String.startsWith(token, prefix)) {
                        fn.call(mgr, parsedToken[level]);

                        //mgr.fireEvent('historychange', parsedToken[level]);
                    }
                }
            };
        }

        // attach listener to history change event
        Ext.History.addListener('change', listener, me);

        // remove listener on observable destroy
        observable.addListener('destroy', function () {
            Ext.History.removeListener('change', listener, me);
        });
    },

    hashUrl: function (url) {

        /*
            History hash pattern: /{local url}${url-encoded params}@{2nd level history token}@...
        */

        if (Ext.String.startsWith(url, Portal.Const.Url.APP_VIRTUAL_PATH)) {
            url = url.substring(Portal.Const.Url.APP_VIRTUAL_PATH.length);
        }

        var idx = url.indexOf(this.URL_PARAMS_SEPARATOR);
        if (idx == -1) return url;

        var qs = url.substring(idx + 1);
        url = url.substring(0, idx);

        var tmp = Ext.Object.fromQueryString(qs);
        tmp = Ext.Object.toQueryString(tmp);

        return url + this.HISTORY_PARAMS_SEPARATOR + tmp;
    },

    currentTokenToUrl: function (level) {
        return this.tokenToUrl(this.getToken(), level);
    },

    tokenToUrl: function (token, level) {
        var parsedToken = this.parseToken(token, level) || [];
        return parsedToken;
    },

    parseCurrentToken: function (level) {
        return this.parseToken(this.getToken(), level);
    },

    parseToken: function (hash, level) {

        var me = this;

        if (!Ext.String.startsWith(hash, '/')) return null;

        var levels = hash.split(this.HISTORY_LEVEL_SEPARATOR) || [],
            parsedUrl,
            paramsIdx;

        if (levels.length == 0) return null;

        if (Ext.isDefined(level)) {
            if (level.length <= level) return null;
            hash = levels[level];
            return me.parseTokenLevel(hash);
        }

        var parsedToken = [];
        Ext.each(levels, function (l) {
            parsedToken.push(me.parseTokenLevel(l));
        });

        return parsedToken;
    },

    splitToken: function (hash, level) {

        var me = this;

        if (!Ext.String.startsWith(hash, '/')) return null;

        var levels = hash.split(this.HISTORY_LEVEL_SEPARATOR) || [],
            parsedUrl,
            paramsIdx;

        if (levels.length == 0) return null;

        if (Ext.isDefined(level)) {
            if (level.length <= level) return null;
            hash = levels[level];
            return hash;
        }

        return levels;
    },

    parseTokenLevel: function (hash) {

        var paramsIdx = hash.indexOf(this.HISTORY_PARAMS_SEPARATOR);

        if (paramsIdx == -1) return hash;

        var qs = hash.substring(paramsIdx + 1);
        hash = hash.substring(0, paramsIdx);

        qs = Ext.Object.fromQueryString(qs);
        qs = Ext.Object.toQueryString(qs);

        return hash + this.URL_PARAMS_SEPARATOR + qs;
    }
});

