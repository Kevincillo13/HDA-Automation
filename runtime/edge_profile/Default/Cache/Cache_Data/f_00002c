            if (cmp.inputType && cmp.inputType == "password") return false;

            var fn = (typeof (cmp.getText) == "function" ? cmp.getText :
                (typeof (cmp.getDisplayValue) == "function" ? cmp.getDisplayValue :
                    (typeof (cmp.getValue) == "function" ? cmp.getValue : null)));

