                '<tpl if="closable"><div class="notification-icon notification-dismiss icon-close" data-qtip="{closeTooltip:plainqtip}" data-action="close"></div></tpl>',
            '</div>',
            '<div class="notification-body">',
                '<div class="notification-content" data-action="click">',
                    '<tpl if="textContent">{textContent:htmlEncoded}<tpl else>{htmlContent}</tpl>',
                '</div>',
            '</div>',
            //'<div class="notification-actions">ACTIONS</div>',
        '</div>'
    ],

    getNotificationIconCls: function (notificationType) {
        switch (notificationType) {

            case this.NEGATIVE:
                return 'icon-error';

            case this.WARNING:
                return 'icon-warning';

            case this.POSITIVE:
                return 'icon-success';

            case this.INFO:
                return 'icon-info';

            default:
                return '';
        }
    },

    getNotificationItemCls: function (notificationType) {
        switch (notificationType) {

            case this.NEGATIVE:
            case this.WARNING:
            case this.POSITIVE:
            case this.INFO:
                return 'notification-type-' + notificationType;

            default:
                return 'notification-type-neutral';
        }
    },

    getNotificationTpl: function (notificationPanel) {
        var html = '';

        if (notificationPanel.title) {
            html = Portal.Notification.NotificationUtils.TPL_COMPLETE;
        } else {
            html = Portal.Notification.NotificationUtils.TPL_SIMPLE;
        }

        return Ext.create('Ext.net.XTemplate', {
            html: html,
            functions: {
                getNotificationCls: function () {
                    var cls = [''];

                    cls.push(Portal.Notification.NotificationUtils.getNotificationItemCls(notificationPanel.type.toLowerCase()));

                    if (notificationPanel.mode)
                        cls.push(notificationPanel.mode);

                    if (notificationPanel.clickable)
                        cls.push('is-clickable');

                    return cls.join(' ');
                },

                getNotificationIconCls: function () {
                    return Portal.Notification.NotificationUtils.getNotificationIconCls(notificationPanel.type.toLowerCase());
                }
            }
        });
    }

});
Ext.define('Portal.Notification.NotificationPanel', {

    extend: 'Ext.net.InfoPanel',

    alias: 'widget.notificationpanel',

    componentCls: 'notification-panel',

    statics: {

        performAction: function (notificationEl, action) {
            var cmp = Ext.Component.fromElement(Ext.fly(notificationEl));

            cmp.performAction(action);
        }

    },

    header: false,

    config: {

        type: 'neutral',

        mode: null, // toast, banner, ...

        title: null,

        textContent: null,

        htmlContent: null,

        closable: false,

        closeTooltip: null,

        clickable: false

    },

    privates: {

        clearNotificationCls: function () {
            this.removeCls('notification-type-' + this.type);
            this.removeCls('is-clickable');
        },

        applyNotificationCls: function () {
            this.addCls('notification-type-' + this.type);

            if (this.clickable)
                this.addCls('is-clickable');
        },

        setNotificationData: function (data) {

            if (!_.isUndefined(data.type))
                this.type = data.type;

            if (!_.isUndefined(data.title))
                this.title = data.title;

            if (!_.isUndefined(data.textContent)) {
                this.textContent = data.textContent;
                this.htmlContent = null;
            }

            if (!_.isUndefined(data.htmlContent)) {
                this.htmlContent = data.htmlContent;
                this.textContent = null;
            }

            if (!_.isUndefined(data.closable))
                this.closable = data.closable;

            if (!_.isUndefined(data.closeTooltip))
                this.closeTooltip = data.closeTooltip;

            if (!_.isUndefined(data.clickable))
                this.clickable = data.clickable;

        },

        buildNotificationHtml: function () {

            var me = this;

            var notificationTplData = {
                type: this.type,
                title: this.title,
                textContent: this.textContent,
                htmlContent: this.htmlContent,
                closable: this.closable,
                closeTooltip: this.closeTooltip,
                clickable: this.clickable
            };

            var tpl = Portal.Notification.NotificationUtils.getNotificationTpl(me);

            return tpl.apply(notificationTplData);
        },

        setupClickHandler: function () {

            var me = this;
            var el = me.el;
            if (!el) return;

            el.on('click', function (e, target) {
                var targetEl = Ext.get(target);
                var action = Portal.ExtUtil.Element.findAttributeValue(targetEl, "data-action");

                if (action) me.performAction(action);
            });
        }

    },

    initComponent: function () {

        // defaults

        this.type = this.type || 'neutral';

        this.html = this.buildNotificationHtml();

        this.applyNotificationCls();

        this.callParent(arguments);

    },

    performAction: function (action) {
        switch (action) {

            case 'close':
                if (this.closable) {
                    this.close();
                }

                break;

            case 'click':
                if (this.clickable) {
                    this.fireEvent('click', this);
                }
                break;

        }
    },

    updateContent: function (data) {
        this.clearNotificationCls();
        this.setNotificationData(data);
        this.update(this.buildNotificationHtml());
        this.applyNotificationCls();
    },

    onRender: function () {
        this.callParent();
        this.setupClickHandler();
    }

});
