Ext.define('Portal.HTMLPreviewParser', {

    singleton: true,

    privates: {

        initialized: false,

        unsafeItems: [],

        parsers: [],

        imageValidAttributes: ['src', 'alt', 'width', 'height'],

        inlineImageSrcRegex: new RegExp(/Image\/InlineImage\/([a-fA-F\d]{8}-[a-fA-F\d]{4}-[a-fA-F\d]{4}-[a-fA-F\d]{4}-[a-fA-F\d]{12})/i),

        initialize: function () {

            this.unsafeItems = [
                {
                    pattern: '<a\\s+[^>]*?href\\s*?=\\s*?["\']([^"\']*?)["\'][^>\\/]*?>',
                    replacement: '<a href="$1" target="_blank">'
                }, {
                    pattern: '<a\\s+[^>]*?href\\s*?=\\s*?["\']([^"\']*?)["\'][^>]*?\\/>',
                    replacement: '<a href="$1" target="_blank" />'
                }, {
                    pattern: '<a\\s+[^>]*?href\\s*?=\\s*?["\']Attachment\\/GetAttachmentBlob\\/([a-zA-Z\\d]{0,10})["\'][^>\\/]*?>',
                    replacement: '<a href="' + Portal.Const.Url.APP_VIRTUAL_PATH + '/Attachment/GetAttachmentBlob/$1" target="_blank">'
                }
            ];

            this.parsers = [
                this.parseTables,
                this.parseImages
            ];

            this.initialized = true;

        },

        /**
         * Images parsing
         * 
         * @param {Document} doc - The HTML document to parse.
         */
        parseImages: function (doc) {

            try {
                var images = doc.evaluate('//img', doc,
                    null, XPathResult.ORDERED_NODE_SNAPSHOT_TYPE, null);

                for (let i = 0, length = images.snapshotLength; i < length; ++i) {
                    this.parseImage(images.snapshotItem(i));
                }
            } catch (e) {
                Portal.Console.error(e);
            }

        },

        /**
         * <img> element parsing.
         * 
         * @param {Element} imageNode - The HTML <img> element to parse.
         */
        parseImage: function (imageNode) {
            var me = this;

            [...imageNode.attributes].forEach(function (attr) {


                if (!me.imageValidAttributes.includes(attr.name)) {
                    imageNode.removeAttribute(attr.name);
                } else {

                    if (attr.name === 'src') {

                        var match = me.inlineImageSrcRegex.exec(attr.value);

                        if (match) {
                            attr.value = `${Portal.Const.Url.APP_VIRTUAL_PATH}/Image/InlineImage/${match[1]}`;
                        }

                    }
                }

            });

        },

        /**
         * <table> element parsing.
         * 
         * @param {Document} doc - The HTML document to parse.
         */
        parseTables: function (doc) {

            try {

                var nodesQueue = Array.from(doc.body.childNodes);

                while (nodesQueue.length > 0) {
                    // dequeue next node
                    var n = nodesQueue.shift();

                    // limit wrapping to the outermost table in case of nested tables
                    if (n.nodeName === 'TABLE') {
                        this.wrapTable(doc, n);
                    } else {
                        // enqueue child nodes
                        if (n.childNodes.length > 0) {
                            n.childNodes.forEach(function (child) { nodesQueue.push(child); });
                        }
                    }
                }
            } catch (e) {
                Portal.Console.error(e);
            }

        },

        /**
         * Wraps a <table> element with a <div class="table-wrapper"> element (to guarantee the right table styling and overflow handling).
         * 
         * @param {Document} doc - The HTML document.
         * @param {Node} tableNode - The table DOM node.
         */
        wrapTable: function (doc, tableNode) {
            var wrapper = doc.createElement('div');
            wrapper.classList.add('table-wrapper');

            var parent = tableNode.parentNode;
            parent.replaceChild(wrapper, tableNode);

            wrapper.appendChild(tableNode);
        }
    },

    parse: function (htmlContent) {

        if (!this.initialized)
            this.initialize();

        var me = this;
        var regex = null;

        var regexItems = me.unsafeItems.filter(function (i) { return i.pattern; });
        if (regexItems.length > 0) {
            regexItems.forEach(function (unsafeItem) {
                regex = new RegExp(unsafeItem.pattern, "gi");
                htmlContent = htmlContent.replace(regex, unsafeItem.replacement);
            });
        }

        if (this.parsers.length > 0) {

            var dParser = new DOMParser();
            var doc = dParser.parseFromString(htmlContent, 'text/html');

            this.parsers.forEach(function (parser) { parser.call(me, doc); });

            htmlContent = doc.body.innerHTML;
        }

        return htmlContent;
    }
});
