        doSelectTemplate: function (templateId) {

            var contextParam = {};
            me.fireEvent('beforeGetTemplateDetailData', { entity: entity, id: templateId, contextParam: contextParam });

            Ext.Ajax.request({
                url: Router.action("WSCView", "GetTemplateDetailData"),
                method: 'POST',
                params: {
                    "ID": templateId,
                    "context": Portal.Util.Json.encode(contextParam)
                },
                success: function (response, opts) {
                    var json = Portal.Util.Json.decode(response.responseText, true);
                    if (json != null) {
                        if (json.success) {
                            applyTemplateInternal(json.id, json.template, json.fullTemplate, contextParam);
                        }
                        else {
                            Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION);
                        }
                    }
                },
                failure: function (response, opts) {
                    // failure code
                    Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION);
                }
            });
        },

        selectTemplate: function () {
            var parentEntity = "",
                parentID = "";
            var ctx = me.getContext("Detail");
            if (ctx != null) {
                parentEntity = ctx.contextStatus.recordType;
                parentID = ctx.contextStatus.id;
            }
            else {
                ctx = me.getContext("List");
                if (ctx != null) {
                    parentEntity = ctx.contextStatus.recordType;
                    parentID = ctx.getSelectedIdList();
                }
            }

            Portal.PageManager.openModule({
                url: Router.action("WSCView", "List", {
                    AllowedEntities: entity,
                    ParentEntity: parentEntity,
                    ParentID: parentID,
                    ShowPreview: true
                }),
                mode: 'objectLink',
                parentContainer: me.getContext('Module'),
                params: { 'entity': "Templates" },
                width: 1500,
                height: 750
            });

            var topic = 'Portal.Template.ObjectLink.ValueSelected';

            if (Ext.isEmptyObj(workingCtx.messageListeners)) workingCtx.messageListeners = [];

            //TODO: Inserire un lancio di un evento 

            if (workingCtx.messageListeners.indexOf(topic) == -1) {

                workingCtx.messageListeners.push(topic);

                me.listenToMessage({
                    topic: topic,
                    messageFilter: 'child',
                    listenerFn: function (msg) {
                        me.doSelectTemplate(msg.value);
                    }
                });
            }
        },

        /*
            Template publishing
        */

        publishTemplate: function () {
            me.setPublishedStatus(true);
        },

        unPublishTemplate: function () {
            me.setPublishedStatus(false);
        },

        setPublishedStatus: function (isPublic) {
