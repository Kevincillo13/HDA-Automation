                    xtype: 'container',
                    items: this.contentItems
                });
            }

            // --- field note container ---
            var noteCt = {
                xtype: 'component',
                id: this.id + '_note',
                itemId: 'fieldNoteContainer',
                cls: 'field-note-ct',
