    /****************************************************************************
    *                               PRIVATE METHODS
    ****************************************************************************/

    var _getStandardFiltersArray = function () {

        var filterForm = _getActiveArea().getForm(),
            filterItems = filterForm.getFields(),
            emptyFilter = true,
            filterArray = [],
            isExpanded = _isExpanded(),
            defaultFilter = _getDefaultFilter(),
            defaultFilterName = '',
            defaultFilterValue = null,
            defaultFilterOp = '',
            defaultFilterExtKey = null;

        if (defaultFilter) {
            defaultFilterName = defaultFilter.getName();
            defaultFilterValue = defaultFilter.getValue();
            defaultFilterOp = defaultFilter.filterOperator;
            defaultFilterExtKey = defaultFilter.filterExtensionKey;
        }

        // for each filter field build filter object
        filterItems.each(function (item, index, length) {
            emptyFilter = false;

            // should contain explicit name (not equal to id)
            var filterable = item.getName() !== item.id + "_Value";

            if (filterable) {
                var filter;

                if (!isExpanded && item.getName() === defaultFilterName) {
                    // take the default filter value instead of the form one when filter area is collapsed
                    filter = Portal.Filters.FilterAreaContext.Utils.buildFilterFromProperties(defaultFilterName, defaultFilterValue, defaultFilterOp, defaultFilterExtKey);
                } else {
                    filter = Portal.Filters.FilterAreaContext.Utils.buildFilterFromField(item);
                }

                // added?
                if (filter)
                    filterArray.push(filter);
            }
        });

        //return filterArray;
        if (emptyFilter && !me.initialFilters) return [];

        var filters = filterArray;
        if (me.initialFilters) filters = Portal.Util.mergeFilterArrays(filters, me.initialFilters, true);
        return filters;
    };

    var _buildFullFilterFromParts = function (standard, advanced) {
        return {
            type: "AND",
            conditions: standard ? standard : [],
            subfilters: advanced ? [advanced] : []
        };
    };

    var _getFilterPartsFromFullFilter = function (filter) {

        var stdFilter = null,
            advFilter = null;

        // simple std filter array
        if (filter.stdFilter && Ext.isArray(filter.stdFilter)) {
            stdFilter = filter.stdFilter;
        }
        // get legacy standard filters 
        else if (filter.stdFilter && filter.stdFilter.filters && filter.stdFilter.filters.length > 0) {
            stdFilter = filter.stdFilter.filters;
        }
        // get standard filters
        else if (filter.stdFilter && filter.stdFilter.conditions && filter.stdFilter.conditions.length > 0) {
            stdFilter = filter.stdFilter.conditions;
        }
        else {
            stdFilter = filter && filter.conditions ? filter.conditions : [];
            advFilter = filter && filter.subfilters ? filter.subfilters[0] : {};
        }

        return {
            standard: stdFilter,
            advanced: advFilter
        };
    };

    var _getDefaultFilter = function () {
        return areas[activeAreaID].defaultFilterCmp;
    };


    // Removes empty filters (value == null || value == '') from a standard filters array
    // or from a ComplexFilter object
    var _removeEmptyFilters = function (filter) {
        var resultFilter = _.clone(filter);

        // clean legacy standard filter Array...
        if (resultFilter.constructor === Array) {
            resultFilter = Portal.Util.mergeFilterArrays(resultFilter, [], false);
            return resultFilter;
        }

        // ...else clear advanced filter object recursively
        var removeEmptyFiltersRecursive = function (filter) {

            // clear empty filters in filter's conditions
            if (filter.conditions) {
                var conditionsWithValue = [];
                filter.conditions.forEach(function (item) {
                    //if (item.op == "nn" || item.op == "nl" || item.value != null && item.value != '') {
                    if (Portal.Util.filterConditionHasValue(item)) {
                        conditionsWithValue.push(item);
                    }
                });
                filter.conditions = conditionsWithValue;
            }

            // clear subfilters recursive
            if (filter.subfilters) {
                filter.subfilters.forEach(function (item) {
                    removeEmptyFiltersRecursive(item);
                });
            }
        };

        removeEmptyFiltersRecursive(resultFilter);
        return resultFilter;
    };

    /**
     * Apply a filter state configuration to current filter area.
     * 
     * @param {Object} state - filter state to apply
     * @param {Object} state.filter - filter to apply
     * @param {Object} state.parameters - mappings with ui countrols
     * @param {Object} state.filterName - filter.name,
     * @param {Object} state.filterDescription: filter.description,
     * @param {Object} state.filterId: filter.filterId,
     * @param {Boolean} state.canEdit: filter.canEdit,
     * @param {Object} state.published: filter.published,
     * @param {Object} state.areaFilterId: filter.areaFilterId
     * @param {Boolean} enableAnimation - show animation
     */
    var _setFilterState = function (state, enableAnimation) {

        Portal.Console.log('FilterAreaContext.SetFilterState');

        var activeArea = _getActiveArea(),
            filterForm = activeArea.getForm(),
            defaultFilter = _getDefaultFilter(),
            isExpanded = _isExpanded(),
            stdFilterUpdated = false,
            advFilterUpdated = false,
            stdFilter = null;

        // get standard and advanced part of filter
        var filter = state.filter ? state.filter : state;

        var filterParts = _getFilterPartsFromFullFilter(filter),
            standardFilters = filterParts.standard,
            advancedFilters = filterParts.advanced;

        _clearFilters(false, false, true);


        // set standard filters
        if (standardFilters) {

            if (_isStandardFilterWithControlID(standardFilters)) {
                _setStandardFiltersArrayWithControlID(standardFilters);
            } else {
                _setStandardFiltersArray(standardFilters);
            }

            stdFilterUpdated = true;
        }

        // if (warnings.length) _showMissingPropertiesWarning(warnings);

        // set advanced filters
        if (contextConfig.useAdvancedFilters && advancedFilters && state.parameters && advancedFiltersPanel) {
            var loader = advancedFiltersPanel.getLoader(),
                id = advancedFiltersPanel.id;

            // configure loader
            loader.success = function () {
                _advancedFilterAreaLoadComplete(advancedFilters, state.parameters);
            };

            loader.failure = function () {
            };

            loader.url = Router.action(
                'AdvancedFilterArea',
                'AdvancedFilter',
                {
                    filter: Portal.Util.Json.encode(advancedFilters),
                    parameters: Portal.Util.Json.encode(state.parameters),
                    containerId: id,
                    entity: me.recordType
                });

            advancedFiltersPanel.suspendEvents();

            loader.load();

            if (isExpanded)
                advancedFiltersPanel.show();

            advancedFiltersPanel.resumeEvents();

            advFilterUpdated = true;
        }

        // show filter infopanel
        if (!Ext.isEmpty(state.filterName)) { _showInfoPanel(state.filterName, state.filterDescription, !state.canEdit); }

        if (stdFilterUpdated) {
            // if adv filters changed wait for AdvancedFilterPanel reload to notify filter changes
            if (!advFilterUpdated) {
                //me.lastFilters = me.getFilter();
                me.filtersChanged(true, true);
            }
            _highlightFilters(standardFilters);
        }

        _fixedFilters = null;
    };

    var _clearFilters = function (fnParams, formOnly, blockMessage) {

        // Defaults
        var params = {
            immediate: false,
            formOnly: false,
            blockMessage: false,
            clearReadOnly: false
        };

        // Load Arguments
        if (Ext.isObject(fnParams)) {
            if (arguments.length > 1) throw new Error('If a parameters object is passed, no other arguments are allowed!');
            Ext.apply(params, fnParams);
        } else {
            params.immediate = fnParams;
            params.formOnly = formOnly;
            params.blockMessage = blockMessage;
        }

        var fields = _getActiveArea().getForm().getFields();

        if (!params.formOnly) {
            var defFilter = _getDefaultFilter();
            if (defFilter) defFilter.reset();
        }

        fields.each(function (item, index, length) {
            if (params.clearReadOnly || !item.readOnly) {
                item.suspendEvents();

                if (Ext.isDefined(item.portalDefaultValue)) {

                    var decodedValue = Portal.Util.Json.decode(item.portalDefaultValue);

                    if (item.xtype === "datefield" && !Ext.isEmpty(item.portalDefaultValue) && !Ext.isDate(item.portalDefaultValue)) {

                        item.setValue(Portal.Util.Json.getDateFromJson(decodedValue));
                    } else {
                        item.setValue(decodedValue);
                    }
                }
                else if (item.clearValue) item.clearValue();
                else if (item.clear) item.clear();
                else item.setValue('');
                item.resumeEvents();
            }
        });

        // hide advanced filter panel
        if (advancedFiltersPanel) { advancedFiltersPanel.hide(); }

        // hide information panels
        _hideInfoPanel();
        _hideWarningPanel();

        initialAdvancedFilter = null;
        initialParameters = null;

        // Send FilterChanged message
        if (!params.blockMessage) me.filtersChanged(params.immediate);
    };

    var _isExpanded = function () {
        return _getDefaultFilter() && !_getDefaultFilter().isVisible();
    };

    var _isValid = function () {
        return _getActiveArea().getForm().isValid();
    };

    var _isStandardFilterWithControlID = function (stdFilter) {
        if (!Ext.isEmpty(stdFilter) && stdFilter[0]) {
            return stdFilter[0].controlId;
        }

        return false;
    };

    var _getFixedFilters = function () {
        if (_fixedFilters === null) {
            var filterObj = me.getFilter();
            var filterForm = _getActiveArea().getForm();
            var filterItems = filterForm.getFields();

            _checkFixedFilters(filterObj, filterItems);

            _fixedFilters = filterObj;
        }

        return _fixedFilters;
    };

    var _checkFixedFilters = function (filterObj, filterItems) {
        
        filterObj.conditions = filterObj.conditions.filter(function (c) {
            return _isFilterFixed(c, filterItems);
        });

        if (filterObj.subfilters) {
            filterObj.subfilters.forEach(function (subfilter) {
                _checkFixedFilters(subfilter, filterItems);
            })
        }
    };

    var _isFilterFixed = function (filter, filterItems) {
        var filterControl = filterItems.findBy(function (f) {
            return _filterMatcher(f, filter);
        });

        var includeVisibleLocked = _filterIndicatorMode === 'removable_filters';

        // "implicit" filter or "hidden" filter or "locked" filter
        return !filterControl || filterControl.hidden || (includeVisibleLocked && filterControl.readOnly);
    };

    var _setupFilterIndicatorManagement = function () {

        if (_filterIndicatorMode === 'none') return;

        me.on('filtersinit', function (ctx, filters) {
            _checkFilterIndicator(filters);
        });

        me.on('filterschanged', function (ctx, filters) {
            _checkFilterIndicator(filters);
        });
    };

    var _checkFilterIndicator = function (filters) {
        var fixedFilters = _getFixedFilters();
        var currentIndicatorActive = Portal.Util.areFiltersDifferent(filters, fixedFilters);

        if (currentIndicatorActive !== _filterIndicatorActive) {
            _filterIndicatorActive = currentIndicatorActive;

            _updateFilterIndicatorUI();
        }
    };

    var _updateFilterIndicatorUI = function () {
        if(_filterToggleCmp)
            _filterToggleCmp[_filterIndicatorActive ? 'addCls' : 'removeCls']('filter-status-indicator');
    };


    //getDefaultField = function (filterState) {
    //    var defaultFltCmp = _getDefaultFilter();
    //    if (defaultFltCmp != null && defaultFltCmp.isVisible()) {
    //        var item;
    //        //Find filter value in the FilterArea
    //        Ext.each(filterState.data, function (o) { if (o.controlId == defaultFltCmp.getItemId()) item = o; });

    //        //If it has a value
    //        if (item) {
    //            if (defaultFltCmp.getValue() && defaultFltCmp.getValue() != '') {
    //                //If the default filter has a value, update the value
    //                item.value = defaultFltCmp.getValue();
    //            } else {
    //                //If the default filter has not a value, remove the filter
    //                filterState.data.remove(item);
    //            }
    //        } else {
    //            if (defaultFltCmp.getValue() && defaultFltCmp.getValue() != '') {
    //                filterState.data.push({ controlId: defaultFltCmp.getItemId(), value: defaultFltCmp.getValue() });
    //            }
    //        }
    //    }
    //},


    return {

        contextName: 'FilterArea',

        initialFilters: null,
        lastFilters: null,
        quickFilter: null,
        recordType: null,
        collectionType: null,
        filterSettings: null,

        // initialization methods
        init: _init,
        initFilterContainer: _initFilterContainer,

        // handlers
        backToOriginalFilter: _restoreOriginalFilter,
        clearFiltersHandler: _clearFiltersHandler,
        toggleFilterContainer: _toggleFilterContainer,
        collapseFilterContainer: _collapseFilterContainer,
        expandFilterContainer: _expandFilterContainer,
        openFilterEditor: _openFilterEditor,
        filtersChanged: _filtersChanged,

        //for backwards compatibility
        clearFilters: _clearFilters,


        // UI getters
        getToolbarContainer: _getToolbarContainer,
        getActiveArea: _getActiveArea, // DEPRECARE? usato esternamente solo per recuperare un controllo, sostituibile con  getFilterControl
        getFilterControl: _getFilterControl,

        // Data getters
        getFilter: _getFilter, // returns Wsc filter object

        // Data setters
        setStandardFiltersArray: _setStandardFiltersArray,
