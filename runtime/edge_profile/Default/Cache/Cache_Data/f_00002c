        /**
         * Standard RecordSave command record handler - Performs client validation and saves current object object data.
         * 
         * @param {Object} params - Command parameters.
         * @param {any} params.closePage - When set, the detail module closes after save operation completes.
         * @param {string} params.FullReload - When set to "true", the detail module fully reloads its content after save operation completes; otherwise only object data is refreshed.
         */
        saveRecord: function (params) {

            if (me.flagSavingInProgress) return;

            ensureWorkingContextType('Detail');

            var status = workingCtx.currentStatus(),
                currentParams,
                isNewRecord,
                successFn,
                failureFn;

            workingCtx.promises.validate()
                .then(function () {

                    params = params || {};
                    currentParams = Portal.Util.buildParams(params, status);

                    isNewRecord = (status.objectIDs == Portal.Const.EMPTY_ID || Ext.isEmpty(status.objectIDs));

                    myMask.show();

                    // BeforeSave Event
                    if (!me.fireEvent('beforesave', me, params, function () { myMask.hide(); me.saveRecord(params); }, function (error) { myMask.hide(); if (!Ext.isEmpty(error)) Portal.Util.Msg.showErrorToastMsg(error); })) {
                        myMask.hide();
                        return false;
                    }

                    Portal.Console.log(['SaveRecord', status.recordType, status.objectIDs, status, currentParams]);

                    // Success callback
                    successFn = function (responseObj) {

                        me.flagSavingInProgress = false;

                        // MessageBus Messages
                        var saveMsgTopic = 'Portal.' + status.recordType + '.' + (isNewRecord ? 'Insert' : 'Update'),
                            saveMsg = { ID: responseObj.data.ID, data: responseObj.data, status: Ext.apply({}, status) };

                        Portal.MessageBus.publish(saveMsgTopic, saveMsg, me);

                        if (status.recordType == "ObjectRelation") {

                            saveMsgTopic = saveMsgTopic.replace("ObjectRelation", "ObjectRelationDirection");

                            Portal.MessageBus.publish(saveMsgTopic, saveMsg, me);
                        }

                        // Manage Response
                        var objectNotVisible = (responseObj.result && responseObj.result.subcode == '2');

                        if (currentParams.closePage || objectNotVisible) {

                            workingCtx.resetDirty(true);
                            myMask.hide();
                            me.getContext('Module').close();

                        } else {

                            if (isNewRecord) {

                                if (responseObj.data == null || typeof responseObj.data == 'undefined') {

                                    Portal.Util.Msg.showErrorMsg({
                                        msg: Ext.String.format(getEntitySpecificMessage('WSC_Msg_SaveFailure', status.collectionType))
                                    });

                                    return;
                                }

                                workingCtx.fullReload(responseObj.data.ID);

                            } else {

                                workingCtx.resetDirty(true);

                                if (currentParams != null && currentParams.FullReload != null && currentParams.FullReload == "true") {

                                    workingCtx.fullReload(responseObj.data.ID);

                                } else {

                                    workingCtx.reloadData(responseObj.data, true);

                                    myMask.hide();
                                }

                            }

                            if (typeof params.successCb == 'function') {
                                params.successCb(responseObj);
                            }
                        }

                        // Save Success Toast Message
                        var msg = getEntitySpecificMessage('WSC_Msg_SaveSuccess', status.recordType);

                        if (objectNotVisible) msg += ' - ' + translations['WSC_Msg_ObjectNotVisible'];

                        Portal.Util.Msg.showSuccessToastMsg({ msg: msg, allowDN: false });
                    };

                    // Failure callback
                    failureFn = function (responseObj) {

                        myMask.hide();

                        me.flagSavingInProgress = false;

                        Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_OperationFailed'], responseObj);

                        if (typeof params.failureCb == 'function') {
                            params.failureCb(responseObj);
                        }
                    };

                    // Call WSC set operation
                    me.flagSavingInProgress = true;

                    Portal.Console.log('DEFAULT SET OPERATION');
                    
                    Portal.WSC.OperationManager.doObjectOperation({
                        objId: status.objectIDs,
                        objData: status.data,
                        objUrl: status.saveUrl,
                        objParams: currentParams,
                        successFn: successFn,
                        failureFn: failureFn
                    });
                })
                .catch(function (errors) { /* do nothing */ });
        },

