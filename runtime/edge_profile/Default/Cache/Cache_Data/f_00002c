Ext.define('Portal.TaskManager', function () {
    var _tasks = {};
        
    return {
        singleton: true,
        createTask: function(name, interval, run) 
        {    
            var task = Ext.create('Portal.Task', {
                name : name,
                interval: interval,
                run: run
            });

            return task;
        },
        start: function () {
            Ext.iterate(_tasks, function (key, task) {

                Ext.util.TaskManager.start({
                    run: task.run,
                    interval: task.interval,
                    fireOnStart: false
                });
                
                Portal.Console.log("Start task " + key);
            });
        },
        stop: function () { Ext.util.TaskManager.stopAll(); },
        add: function (task) {
            if (task.name==null) throw "Task name is missing.";
            if (_tasks[task.name]) throw "Task [" + task.name + '] is already present.';

            Portal.Console.log("Task " + task.name + " added");

            _tasks[task.name] = task;
        },
        constructor: function (cfg) {
            // do nothing
        }
    }
});


Ext.ns('Portal.WSC');

Ext.define('Portal.WSC.OperationManager', function () {
    var createSuccessFn = function (successCb, failureCb) {
        return function (response, opts) {
            var respObj = Portal.Util.Json.decode(response.responseText, true);
            if (respObj.success) {
                if(typeof successCb == 'function') successCb(respObj);
            } else {
                if(typeof failureCb == 'function') failureCb(respObj);
            }
        };
    },
    createFailureFn = function (failureCb) {
        return function (response, opts) {
            response.result = {
                code: response.status,
                desc: 'Server communication failure with status code ' + response.status
            };
            failureCb(response);
        };
    };

    return {
        singleton: true,
        
        /*
        * objId
        * objData
        * objUrl
        * objParams
        * successFn
        * failureFn
        */
        doObjectOperation: function (objCtx) {
            var opCfg = {
                method: objCtx.method || 'POST',
                url: Portal.Util.buildDetailUrl(objCtx.objUrl, objCtx.objId),
                success: createSuccessFn(objCtx.successFn, objCtx.failureFn),
                failure: createFailureFn(objCtx.failureFn),
                disableCaching: (objCtx.disableCaching === false ? objCtx.disableCaching : true)
            };

            opCfg.params = objCtx.objParams || {};

            if (objCtx.objData) {
                // passed in data
                opCfg.params.data = Portal.Util.Json.encode(objCtx.objData);
            }

            // call action
            return Ext.Ajax.request(opCfg);
        },

        /*
        * form
        * objId
        * objData
        * objUrl
        * uploadField
        * successFn
        * failureFn
        */
        doSetAndFileUpload: function (objCtx) {
            var params, url, submitCfg;

            params = objCtx.objParams || {};
            if (objCtx.objData) {
                params.data = Portal.Util.Json.encode(objCtx.objData);
            }

            Portal.Console.log('PRIMA DI FORM SUBMIT');

            submitCfg = {
                params: params,
                success: function (form, action) {
                    Portal.Console.log('submit success!');
                    Portal.Console.log(arguments);

                    if (action.result.success) {
                        if (typeof objCtx.successFn == 'function') objCtx.successFn(action.result);
                    } else {
                        if (typeof objCtx.failureFn == 'function') objCtx.failureFn(action.result);
                    }
                },
                failure: function (form, action) {
                    Portal.Console.log('submit failure!');
                    Portal.Console.log(arguments);
                    if (typeof objCtx.failureFn == 'function') objCtx.failureFn(action.result);
                }
            };

            // if an url is specified, then use that for submit action
            if (objCtx.objUrl != null) {
                if (objCtx.objId != null) {
                    submitCfg.url = Portal.Util.buildDetailUrl(objCtx.objUrl, objCtx.objId);
                } else {
                    submitCfg.url = objCtx.objUrl;
                }
            }

            objCtx.form.submit(submitCfg);

            Portal.Console.log('DOPO FORM SUBMIT');

        },

        /**
        * Generic Ajax request
        * 
        * url
        * params
        * successFn
        * failureFn
        */
        request: function (cfg) {
            var reqCfg = {
                method: cfg.method || 'POST',
                url: cfg.url,
                params: cfg.params,
                success: createSuccessFn(cfg.successFn, cfg.failureFn),
                failure: createFailureFn(cfg.failureFn)
            };

            if (cfg.disableCaching !== undefined) reqCfg.disableCaching = cfg.disableCaching;

            Ext.Ajax.request(reqCfg);
        },

        /**
        * Ajax POST request
        */
        post: function (cfg) {
            var reqCfg = {
                method: 'POST',
                url: cfg.url,
                jsonData: cfg.data,
                success: createSuccessFn(cfg.successFn, cfg.failureFn),
                failure: createFailureFn(cfg.failureFn)
            };
            Ext.Ajax.request(reqCfg);
        },

        jsonPost: function (cfg) {
            var reqCfg = {
                method: 'POST',
                url: cfg.url,
                rawData: cfg.data, //json-encoded
                headers: {'Content-Type': 'application/json'},
                success: createSuccessFn(cfg.successFn, cfg.failureFn),
                failure: createFailureFn(cfg.failureFn)
            };
            Ext.Ajax.request(reqCfg);
        },

        /**
        * Checks the existence of the specified object
        *
        * entity
        * id
        * successFn
        * failureFn
        */
        exists: function (cfg) {
            var existenceUrl = Portal.Const.Url.WSC_EXISTS_URL,
                reqCfg = {};

            // remove unwanted spaces            
            if (Ext.isString(cfg.id)) {
                cfg.id = (cfg.id || "").trim();
            }

            existenceUrl = Portal.Util.buildDetailUrl(existenceUrl, cfg.id);
            existenceUrl = existenceUrl.replace(Portal.Const.Url.ENTITY_PLACEHOLDER, cfg.entity);

            reqCfg = {
                method: 'POST',
                url: existenceUrl,
                params: { entity: cfg.entity },
                success: createSuccessFn(cfg.successFn, cfg.failureFn),
                failure: createFailureFn(cfg.failureFn)
            };

            Ext.Ajax.request(reqCfg);
        },

        /*
            getObjectById(cfg): Performs a "get" object given entity and its ID using the passed in configuration.

            cfg : {
                entity........: the entity to get data for eg. "Account", "Ticket",...
                id............: the ID of the object to get eg. "10C"
                successFn.....: Success callback.
                failureFn.....: Failure callback.
                diableCaching.: Optional. default is false. Set to true to enforce cache invalidation.
            }
        */
        getObjectById: function (cfg) {

            var ajaxCfg = {
                method: 'GET',
                url: Router.action("WSC", "Get", { entity: cfg.entity, id: cfg.id }),
                success: createSuccessFn(cfg.successFn, cfg.failureFn),
                failure: createFailureFn(cfg.failureFn),
                disableCaching: (cfg.disableCaching === false ? cfg.disableCaching : true)
            };

            Ext.Ajax.request(ajaxCfg);
        },

        // WSC operation result codes
        OK: '0',
        LogonFailed: '1',
        NotSupported: '2',
        NotSpecified: '3',
        MalformedOperation: '4',
        NotAllowed: '5',
        UpdateFailed: '6',
        ObjectNotFound: '7',
        ObjectNotDefined: '8',
        TooManyRecord: '9',
        SystemBusy: '10',
        TimeoutExpired: '11',
        OtherError: '99'
    };
});
