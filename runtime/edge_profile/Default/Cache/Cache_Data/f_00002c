        }
        if (me.shim || Ext.useShims) {
            el.enableShim(null, true);
        } else {
            el.disableShim();
        }
        ownerCt.disableTabbing();
        ownerCt.setMasked(true);

        el.restoreTabbableState();

        if (ownerCt.containsFocus) {
            me.focus();
        }
        me.sizeMask();
    }

