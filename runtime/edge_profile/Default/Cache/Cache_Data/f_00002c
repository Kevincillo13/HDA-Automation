Ext.define('Portal.Navigation.PortalHistoryManager', {

    extend: 'Portal.Navigation.HistoryManager',

    config: {

        /*
         * Tells if manager will open new page starting from the hash part of the url when no exising page matches it
         */
        autoLoadFromUrlHash: true,

        /*
         * Close current tab/page on browser "back"
         */
        closePageOnBack: false,

        /*
         * Closes the top level popup window on browser "back
         */
        closePopupOnBack: true

    },

    privates: {

        STATIC_PAGE_HISTORY_PREFIX: '/Page/',

        pageManager: null,

        currentHistory: null,

        initStaticPagesHistory: function () {
            var me = this;

            me.pageManager.getTabContainer().items.each(function (page) {
                me.trackHistoryToCmp(page, me.STATIC_PAGE_HISTORY_PREFIX + page.pageID);
            });
        },

        initDynamicPagesHistory: function () {
            var me = this;
            me.pageManager.getTabContainer().on('beforeadd', function (pagesContainer, pageCmp, index, eOpts) {
                var navData = { sourceCmp: pageCmp };

                if (pageCmp.getLoader())
                    navData.url = pageCmp.getLoader().url;

                me.updateHistory(navData);
            });
        },

        setupInitialActivePage: function () {
            var token = Portal.History.getToken();

            if (token) {
                this.onHistoryChange();
            } else {
                var firstTab = this.pageManager.getTabContainer().items.getAt(0);

                if (firstTab) {
                    this.pageManager.getTabContainer().setActiveTab(firstTab);
                    Portal.History.add(firstTab.history.hash, true);
                }
            }
        },

        getActiveWindow: function(){
            var windowOnFront;
            Ext.WindowManager.eachTopDown(function (cmp) {
                if (cmp.xtype == 'window' && cmp.portalWindow) {
                    windowOnFront = cmp;
                    return false;
                }
            });

            return windowOnFront;
        },

        mustClosePage: function (activePage, destinationPage, currentToken) {
            var destinationPageId = destinationPage ? destinationPage.id : '';

            if (activePage && activePage.id != destinationPageId && activePage.closable) {

                //// check if current history destination is really activePage previous one
                //var previousHistory = this.getCmpHistoryData(activePage.previousTab.card);

                //return (previousHistory && previousHistory.hash == currentToken);

                return true;
            }

            return false;
        },

        tryClosePageOnBack: function (destinationPage, currentToken) {
            var tabCt = this.pageManager.getTabContainer();
            var activePage = tabCt.getActiveTab();
            var mustClose = this.mustClosePage(activePage, destinationPage, currentToken);

            if (mustClose) {
                // try to close tab
                activePage.close();

                // tab closure was blocked, stop history change
                if (!activePage.isDestroyed)
                    Portal.History.add(activePage.history.hash);

                return false;
            }

            return true;
        },

        activateExistingPage: function (page) {
            var tabCt = this.pageManager.getTabContainer();

            // update tab history tracking info
            this.trackHistoryToCmp(page, Portal.History.getToken());

            // activate it if not yet active
            if (tabCt.getActiveTab().id != page.id) tabCt.setActiveTab(page);
        },

        openPageFromHistory: function () {
            if (this.getAutoLoadFromUrlHash()) {

                var historyToken = Portal.History.currentTokenToUrl(this.getHistoryLevel());

                if (this.isPortalPageHistory(historyToken)) {
                    this.openPortalPageFromHistoryToken(historyToken);
                } else {
                    this.openPortalModuleFromHistoryToken(historyToken);
                }

            }
        },

        isPortalPageHistory: function (token) {
            return token.indexOf(this.STATIC_PAGE_HISTORY_PREFIX) == 0;
        },

        openPortalPageFromHistoryToken: function (token) {
            var pageID = token.substring(this.STATIC_PAGE_HISTORY_PREFIX.length);
            Portal.PageManager.openPage(pageID);
        },

        openPortalModuleFromHistoryToken: function (token) {
            var url = Portal.Const.Url.APP_VIRTUAL_PATH + token,
                qsParams = Portal.Util.getQSParams(url),
                hasTitle = Ext.isDefined(qsParams.__title);

            Portal.PageManager.openModule({
                url: url,
                mode: 'tab',
                title: hasTitle ? qsParams.__title : null,
                collapseTitleToContainer: !hasTitle
            });
        },

        pageMatchesHistory: function (page, token) {
            var history = this.getCmpHistoryData(page);

            return (
                history &&
                history.tracking &&
                this.parseHistoryToken(history.hash).toLowerCase() == this.parseHistoryToken(token).toLowerCase()
            );
        },

        parseHistoryToken: function (token) {
            return Portal.History.parseToken(token, this.getHistoryLevel());
        },

        getPageFromToken: function (token) {
            var me = this;
            var pagesCt = this.pageManager.getTabContainer();
            var foundPage = null;

            if (pagesCt != null) {

                // find a page that is related to current history token
                pagesCt.items.each(function (page) {
                    if (me.pageMatchesHistory(page, token)) {
                        foundPage = page;
                        return false;
                    }
                });
            }

            return foundPage;
        },

        // injects history data to component in order to link it to a history hash value, 
        // on component activation its history hash value will be set as the new history value
        trackHistoryToCmp: function (cmp, hash, tracking) {
            if (!cmp.history) cmp.history = {};

            // inject to component history configuration
            if (!cmp.history.tracking) {

                // on component activation track history hash
                cmp.addManagedListener(cmp, 'activate', function () {
                    if (Portal.History.getToken() != this.history.hash)
                        Portal.History.add(this.history.hash, true);
                });

            }

            Ext.apply(cmp.history, {
                tracking: true,
                hash: hash
            });
        },

        getCmpHistoryData: function (cmp) {
            return cmp.history;
        }

    },

    constructor: function (config) {
        var me = this;

        this.callParent(arguments);

        this.pageManager = me.getHistorySource();
    },

    init: function () {
        this.initStaticPagesHistory();
        this.initDynamicPagesHistory();
        this.setupInitialActivePage();
    },

    onHistoryChange: function () {
        var me = this,
            token = Portal.History.getToken(),
            pagesCt = this.pageManager.getTabContainer(),
            destinationPage,
            previousHistory = this.currentHistory;

        // history hasn't changed
        if (previousHistory == token) return;

        // handle popups
        if (this.getClosePopupOnBack()) {
            var activeWindow = this.getActiveWindow();
            if (activeWindow && activeWindow.closeOnHistoryChange) {

                activeWindow.close();

                // remain on current history
                Portal.History.add(this.currentHistory);

                return;
            }
        }

        // track new history token
        this.currentHistory = token;

        if (!token || token.length == 0) return;

        destinationPage = this.getPageFromToken(token);

        if (this.getClosePageOnBack()) {
            // try to close current page, if page closure is blocked then stop and cancel further operations
            if (!this.tryClosePageOnBack(destinationPage, token)) return;
        }

        if (destinationPage)
            this.activateExistingPage(destinationPage);
        else
            this.openPageFromHistory();
    },

    updateHistory: function (navData) {
        var sourcePage = navData.sourceCmp,
            url = navData.url,
            token,
            isStaticPage = (Ext.isDefined(sourcePage.pageID) && sourcePage.pageID != ''),
            cmp;

        if (isStaticPage) {

            cmp = sourcePage;

            // static portal page tab
            // history url for static page is "/Page/PageID"
            token = this.STATIC_PAGE_HISTORY_PREFIX + cmp.pageID;

        } else {

            cmp = (sourcePage.portalTab ? sourcePage : sourcePage.up('[portalTab]'));

            // dynamic portal tab
            // history url for dynamic page corresponds to module url (including querystring parameters)
            if (cmp && url) {
                if (!Ext.isDefined(token)) {
                    // build token from page url
                    token = Portal.History.hashUrl(url);
                }
            }
        }

        if (cmp) {

            // get 1st level history token
            var currentHeadToken = this.getToken();

            // if current token root level equals to new token root level 
            // then keep entire current token in order to preserve any existing history sub levels
            if (currentHeadToken && currentHeadToken == Portal.History.parseToken(token, this.getHistoryLevel())) {
                token = Portal.History.getToken();
            }

            // update history only if it has changed
            if (!cmp.history || cmp.history.hash != token) {

                // track new token to the found component, in order to get it when component will be activated in the future
                this.trackHistoryToCmp(cmp, token);

                // if new token is different from current token then add it to history
                if (!isStaticPage && Portal.History.getToken() != cmp.history.hash) Portal.History.add(cmp.history.hash);
            }

            if (Ext.isEmpty(Portal.History.getToken())) Portal.History.add(token);
        }

    },

    getHistoryTokenFromModuleUrl: function (url) {
        url = url.replace(Portal.Const.Url.APP_VIRTUAL_PATH, '');
        url = url.replace(Portal.History.URL_PARAMS_SEPARATOR, Portal.History.HISTORY_PARAMS_SEPARATOR);
        return url
    }

});
