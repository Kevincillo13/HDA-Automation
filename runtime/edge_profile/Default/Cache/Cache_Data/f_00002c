Portal.PreviewContext = function () {

    var me = null,
        workingCtx = null;

    var REFRESH_DELAY = 500;

    var _init = function () {
        if (workingCtx.contextName !== 'List' && workingCtx.contextName !== 'Card') return;

        var panel = workingCtx.component.down('#PreviewModule');

        workingCtx.listenToMessage({
            topic: 'Portal.' + workingCtx.contextStatus.recordType + '.Selected',
            messageFilter: 'samemodule',
            listenerFn: function (msg) {

                var id = msg.objectIDs,
                    moduleParams = _cmp(msg.sourceCtx.componentId).getContext('Module').getModuleParams();

                // if ID is nothing or string.empty or null then return
                if (!id) {
                    // reload the preview panel with the initial confing to mantain EmptyImageType and EmptyMessageToken
                    panel.loadModule(panel.initialConfig.loader.url, null, REFRESH_DELAY);
                    return;
                }

                // reset id if not singleselection
                if (id.indexOf(Portal.Const.ARRAY_SEPARATOR) > -1) { id = Portal.Const.EMPTY_ID; }

                // build preview parameters
                var previewParams = {
                    id: id,
                    entity: workingCtx.contextStatus.recordType
                };

                if (moduleParams.listViewID) { previewParams.listViewID = moduleParams.ViewID; }
                if (moduleParams.listFilter) { previewParams.listFilter = moduleParams.filter; }
                if (moduleParams.OriginalEntity) { previewParams.originalEntity = moduleParams.OriginalEntity; }
                if (moduleParams.PreviewModule) { previewParams.previewModule = moduleParams.PreviewModule; }
                if (moduleParams.PreviewViewID) { previewParams.previewViewID = moduleParams.PreviewViewID; }

                // load preview
                panel.loadModule(
                    Router.action("WSCView", "Preview", previewParams),
                    null,
                    REFRESH_DELAY
                );
            }
        });

    };

    return {

        contextName: 'Preview',

        init: function (initCfg) {
            me = this;
        },

        setWorkingContext: function (ctx) {
            workingCtx = ctx;
            _init();
        },

        getWorkingContext: function () { return workingCtx; }

        // commands...

    };
};
