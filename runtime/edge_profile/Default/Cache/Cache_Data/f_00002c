Ext.define('Portal.UI.PageModuleActivator', {

    singleton: true,

    tabContainer: null,

    privates: {

        moduleMatches: function (moduleCtx, id) {
            var container = moduleCtx.getContainerCmp();

            return container.itemId === id;
        },

        isLastPathLevel: function (moduleIDs) {
            return moduleIDs.length === 1;
        },

        getRemainingPathLevels: function (moduleIDs) {
            return moduleIDs.slice(1);
        },

        navLoadedModules: function (moduleCtx, moduleIDs) {
            var me = this;

            var promise = new Promise(function (resolve, reject) {
                var moduleID = moduleIDs[0];
                var module = _.find(moduleCtx.getModules(), function (m) { return me.moduleMatches(m, moduleID); });

                if (module) {

                    if (me.isLastPathLevel(moduleIDs)) {
                        // we reached the requested module
                        resolve(module);

                    } else {
                        // still some sub-levels to navigate
                        me.navLoadedModules(module, me.getRemainingPathLevels(moduleIDs))
                            .then(resolve)
                            .catch(reject);
                    }
                } else {

                    reject();

                }
            });

            return promise;
        },

        navLoadingModules: function (moduleCtx, moduleIDs, timeout) {
            var me = this;

            var promise = new Promise(function (resolve, reject) {
                var moduleID = moduleIDs[0];

                var unsubScribeFn = moduleCtx.listenToMessage({
                    topic: 'Portal.Context.Ready',
                    messageFilter: 'child',
                    listenerFn: function (ctx) {
                        if (ctx.contextName === 'Module') {

                            if (me.moduleMatches(ctx, moduleID)) {

                                if (me.isLastPathLevel(moduleIDs)) {

                                    // we reached the requested module

                                    detachListener();
                                    detachTimeout();

                                    resolve(ctx);

                                } else {

                                    detachListener();
                                    detachTimeout();

                                    // still some sub-levels to navigate

                                    me.navLoadingModules(ctx, me.getRemainingPathLevels(moduleIDs), timeout)
                                        .then(function (ctx) {
                                            resolve(ctx);
                                        })
                                        .catch(function () {
                                            reject();
                                        });
                                }
                            }
                        }
                    }
                });

                var detachListener = function () {
                    if (unsubScribeFn) {
                        unsubScribeFn();
                        delete unsubScribeFn;
                    }
                };

                var timeoutId = setTimeout(function () {
                    detachListener();
                    reject();

                }, timeout);

                var detachTimeout = function () {
                    if (timeoutId) {
                        clearTimeout(timeoutId);
                        delete timeoutId;
                    }
                };
            });

            return promise;

        },

        activateNewPage: function (pageID, moduleIDs, timeout) {
            var me = this;
            var page = Portal.PageManager.openPage(pageID);
            
            return new Promise(function (resolve, reject) {

                page.loader.on('load', function () {

                    if (_.isEmpty(moduleIDs)) {
                        resolve();
                        return;
                    }

                    var pageCmp = page.down('portalpage');

                    me.navLoadingModules(pageCmp.getContext('Module'), moduleIDs, timeout)
                        .then(resolve)
                        .catch(reject);

                });
            });
        },

        activateExistingPage: function (page, moduleIDs, timeout) {
            var me = this;

            return new Promise(function (resolve, reject) {
                var pageTab = (page.portalTab ? page : page.up('[portalTab]'));
                var activeTab = me.tabContainer.getActiveTab();
                var activePage = (activeTab.xtype === 'portalpage' ? activeTab : activeTab.down('portalpage'));

                if (_.isEmpty(moduleIDs)) {
                    me.tabContainer.setActiveTab(pageTab);
                    resolve();

                    return;
                }

                if (page.rendered) {

                    if (activePage === page) {

                        me.navLoadedModules(page.getContext('Module'), moduleIDs)
                            .then(resolve)
                            .catch(reject);

                    } else {

                        pageTab.on(
                            'activate',
                            function () {
                                me.navLoadedModules(page.getContext('Module'), moduleIDs)
                                    .then(resolve)
                                    .catch(reject);
                            },
                            pageTab,
                            { single: true });
                    }

                } else {

                    page.on(
                        'beforerender',
                        function () {
                            me.navLoadingModules(page.getContext('Module'), moduleIDs, timeout)
                                .then(resolve)
                                .catch(reject);
                        },
                        page,
                        { single: true });
                }

                me.tabContainer.setActiveTab(pageTab);
            });
        }
    },

    /**
     * Activates the specified portal module.
     * @param {Object} params
     * @param {String} params.pageID - The page to activate
     * @param {String} params.path - The path to the requested module ("/moduleID1/moduleID2/...")
     * @param {Function} params.callback - The function to call once the requested module has been activated
     * @param {number} params.timeout - The operation timeout
     */
    activate: function (params) {
        var me = this;
        var pageID = params.pageID;
        var moduleIDs = (params.path ? params.path.substring(1).split('/') : []);
        var timeout = params.timeout || 30000;
        var page = me.tabContainer.down('portalpage[pageID=' + pageID + ']');

        return page ?
            me.activateExistingPage(page, moduleIDs, timeout) :
            me.activateNewPage(pageID, moduleIDs, timeout);

    },

    setTabContainer: function (cmp) {
        this.tabContainer = cmp;
    }


});
