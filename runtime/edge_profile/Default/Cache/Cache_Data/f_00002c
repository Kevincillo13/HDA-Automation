Portal.UIRules.RuleManagerContext_v1 = function () {

    var me = null;
    var _debugMode = false;

    var _detailCtx = null;
    var _entity = null;
    var _objectType = null;
    var _fieldsMapping = [];
    var _allFields = {};
    var _allSections = {};
    var _suspended = false;

    var _rules = {
        /*  Contains current Entity rules.
            Built on context loading 
        */
    };
    var _fieldDependencies = {
        /*  Represents source field => target fields/sections dependencies
            Built on context loading

            "SourceFieldName": {
                targets: [
                    {type: "section": id: "Section_ID"},
                    {type: "field": id: "Field_Name"},
                ]
            }
        */
    };

    /*******************************************************************************************************
     *                                      PRIVATE UTILITIES
     ******************************************************************************************************/

    var _ruleConditionValueFixers = {
        Date: function (condition) {
            var fixedCondition = _.clone(condition);

            var dateObject = new Date(fixedCondition.value);
            if (fixedCondition.op === "gt" || fixedCondition.op === "le") {
                dateObject = dateObject.addDays(1).addSeconds(-1);
            }
            fixedCondition.value = dateObject;

            return fixedCondition;
        }
    };

    var _fieldConditionEvaluators = {

        eq: function (field, valueToCheck) { return this.isEqual(field, valueToCheck); },
        ne: function (field, valueToCheck) { return !this.eq(field, valueToCheck); },

        nl: function (field) { return Portal.Util.isEmptyValue(field.getValue()); },
        nn: function (field) { return !this.nl(field); },

        nsw: function (field, valueToCheck) { return !this.sw(field, valueToCheck); },
        sw: function (field, valueToCheck) { return field.getValue().match("^" + valueToCheck) !== null; },
        ew: function (field, valueToCheck) { return field.getValue().match(valueToCheck + "$") !== null; },

        gt: function (field, valueToCheck) { return field.getValue() > valueToCheck; },
        lt: function (field, valueToCheck) { return field.getValue() < valueToCheck; },
        ge: function (field, valueToCheck) { return !this.lt(field, valueToCheck); },
        le: function (field, valueToCheck) { return !this.gt(field, valueToCheck); },

        isEqual: function (field, valueToCheck) {

            var fieldValue = field.getValue();

            // no value to make check -> good value
            if (!_.isBoolean(valueToCheck) && !valueToCheck) { return true; }

            // convert value to array and split "|" separated strings
            valueToCheck = valueToCheck.split ? valueToCheck.split("|") : valueToCheck;
            if (!_.isArray(valueToCheck)) valueToCheck = [valueToCheck];

            // Comparison function
            var comparerFn = function (value) { return value === fieldValue; };

            if (_.isString(fieldValue) && fieldValue.split && Portal.ExtUtil.Field.maySupportMultipleValuesPipeSeparated(field))
                comparerFn = function (value) { return fieldValue.split("|").includes(value); };

            // check if at least one value match
            return _.some(valueToCheck, comparerFn);
        }
    };

    var _suspendModuleLayouts = function () {
        me.component.suspendLayouts();
    };

    var _resumeModuleLayouts = function () {
        me.component.resumeLayouts();
        me.component.updateLayout();
    };

    /*******************************************************************************************************
     *                                              LOGS
     ******************************************************************************************************/

    var _writeWarning = function (message) {
        if (_debugMode) { console.warn(new Date().toLocaleString() + " - UIRulesManager: " + message); }
    };

    var _writeLog = function (message) {
        if (_debugMode) { console.log(new Date().toLocaleString() + " - UIRulesManager: " + message); }
    };

    var _writeLogWithObject = function (message, obj) {
        if (_debugMode) { console.log(new Date().toLocaleString() + " - UIRulesManager: " + message, obj); }
    };

    /*******************************************************************************************************
     *                                              INIT
     ******************************************************************************************************/

    /**
     * Setup context.
     */
    var _init = function () {

        _writeLog("Start initialization");

        _entity = _detailCtx.contextStatus.recordType;
        _objectType = _detailCtx.contextStatus.objectType;

        _rules = _getCurrentRules();
        _writeLogWithObject("Built current rules for entity '{entity}' of type '{objectType}'. Result engine rules: ".format({
            entity: _entity,
            objectType: _objectType
        }), _rules);

        _fieldDependencies = _buildDependencies(_rules);
        _writeLogWithObject("Built current rule dependencies. Result dependencies: ", _fieldDependencies);

        _buildFieldListeners(_fieldDependencies);
        _writeLog("Built listeners.");

        me.component.on('formload', function(){

            // we need to force dependency evaluation for fields having a defaultValue 
            // because they'll not fire initial change event if actual value is equal to defaultValue
            var defaultValueDependencies =
                _.chain(_fieldDependencies)
                    .map(function (dependency, fieldName) {
                        return { fieldName: fieldName, dependency: dependency, field: _getField(fieldName) };
                    })
                    .filter(function (dependencyInfo) {
                        return dependencyInfo.field && dependencyInfo.field.initialConfig && dependencyInfo.field.initialConfig.value;
                    })
                    .value();

            if (_.any(defaultValueDependencies)) {
                _writeLog("First load dependencies evaluation (fields with defaultValue).");

                _suspendModuleLayouts();

                _.each(defaultValueDependencies, function (dependencyInfo) {
                    _evaluateFieldDependencies(dependencyInfo.field, dependencyInfo.fieldName, true);
                });

                _resumeModuleLayouts();

                _writeLog("First load dependencies evaluation (fields with defaultValue) completed.");
            }

            _writeLog("Initialization completed.");

        });

    };

    /**
     * Build dependency listeners.
     * @param {Object} rules Rules to handle.
     * @return {Object} field dependencies.
     */
    var _buildDependencies = function (rules) {

        var dependencies = {};

        var fillArray = function (type, fieldID, fieldRules, targetArray) {

            if (!fieldRules || !fieldRules.conditions) { return; }

            var processingFields = [];
            _.each(fieldRules.conditions, function (itm) {
                processingFields.push(_.isString(itm) ? itm : itm.property);
            });

            _.each(processingFields, function (field) {
                if (!targetArray[field])
                    targetArray[field] = { targets: [] };

                targetArray[field].targets.push({ type: type, id: fieldID });
            });
        };

        _.each(rules.fields, function (rule, fieldID) {
            fillArray('field', fieldID, rule.enabledIf, dependencies);
            fillArray('field', fieldID, rule.mandatoryIf, dependencies);
            fillArray('field', fieldID, rule.visibleIf, dependencies);
            fillArray('field', fieldID, rule.readonlyIf, dependencies);
            fillArray('field', fieldID, rule.resetIf, dependencies);
        });

        _.each(rules.sections, function (rule, fieldID) {
            fillArray('section', fieldID, rule.enabledIf, dependencies);
            fillArray('section', fieldID, rule.resetIf, dependencies);
        });

        return dependencies;
    };

    var _buildFieldListeners = function (dependencyArray) {
        _.each(dependencyArray, function (dependency, fieldName) {
            var field = _getField(fieldName);
            if (field) {
                field.on('change', function () {
                    _evaluateFieldDependencies(field, fieldName);
                });
            }
        });
    };

    /**
     * Get rules for current Detail entity type. 
     * @returns {Object} Rules object
     */
    var _getCurrentRules = function () {

        var emptyRuleset = [],
            emptyRules = { sections: {}, fields: {} };

        var allRules = Portal.UIRules.Rules || emptyRules;

        // checks condition values and apply fixes for special value types 
        var fixConditionValues = function (conditions) {
            var fixedConditions = [];
            _.each(conditions, function (condition) {
                var getFixedValueFn = _ruleConditionValueFixers[condition.type];
                if (getFixedValueFn)
                    fixedConditions.push(getFixedValueFn(condition));
                else
                    fixedConditions.push(condition);
            });
            return fixedConditions;
        };

        // transforms "server" json format to format used from this engine
        var transform = function (rulesets, property) {
            var result = {};
            _.each(rulesets, function (rs) {
                _.each(rs[property], function (f) {
                    _.each(rs.rules, function (r) {
                        _.each(r.name, function (n) {
                            result[f] = result[f] || {};
                            result[f][n] = {
                                type: r.type || "AND",
                                conditions: fixConditionValues(r.conditions)
                            };
                        });
                    });
                });
            });
            return result;
        };

        // get entity type rules from complete entity rule object
        var getRules = function (rules, entityType) {
            var typeRules = _.find(rules, function (r) { return r.type === entityType; });
            var typeRules_sections = typeRules ? _.filter(typeRules.rulesets, function (r) { return !!r.sections; }) : emptyRuleset;
            var typeRules_fields = typeRules ? _.filter(typeRules.rulesets, function (r) { return !!r.fields; }) : emptyRuleset;

            return {
                sectionRules: transform(typeRules_sections, "sections"),
                fieldRules: transform(typeRules_fields, "fields")
            };
        };

        // get entity rules
        var entityRules = _.where(allRules.rules, { entity: _entity });

        // get default rules
        var defaultRules = getRules(entityRules, 'Default');
        var typeRules = getRules(entityRules, _objectType);

        // return merged results
        return {
            sections: Object.assign({}, defaultRules.sectionRules, typeRules.sectionRules),
            fields: Object.assign({}, defaultRules.fieldRules, typeRules.fieldRules)
        };
    };


    /*******************************************************************************************************
     *                                              EVALUATION
     ******************************************************************************************************/

    var _evaluateFieldDependencies = function (field, fieldName, skipSuspendLayouts) {

        if (!field) return;

        if (_suspended) return;

        var suspendLayouts = !skipSuspendLayouts;

        _writeLog("Evaluating dependencies for field '{fieldName}', current value: '{fieldValue}'...".format({
            fieldName: fieldName,
            fieldValue: field.getValue()
        }));

        var fieldRule = _fieldDependencies[fieldName];
        if (!fieldRule) return;

        if (suspendLayouts) {
            _suspendModuleLayouts();
        }

        if (!me.fireEvent('beforeapplyrule', me, field, fieldName, fieldRule))
            return;

        _.each(fieldRule.targets, function (target) {
            if (target.type === 'section') {
                var sectionID = target.id,
                    sectionRule = _rules.sections[target.id];
                _evaluateCondition(sectionID, sectionRule.enabledIf, _enableSection);
                _evaluateCondition(sectionID, sectionRule.resetIf, _resetSection);
            }

            if (target.type === 'field') {
                var fieldName = target.id,
                    fieldRule = _rules.fields[target.id];
                _evaluateCondition(fieldName, fieldRule.visibleIf, _showField);
                _evaluateCondition(fieldName, fieldRule.enabledIf, _enableField);
                _evaluateCondition(fieldName, fieldRule.mandatoryIf, _setFieldMandatory);
                _evaluateCondition(fieldName, fieldRule.readonlyIf, _setFieldReadonly);
                _evaluateCondition(fieldName, fieldRule.resetIf, _resetField);
            }
        });

        me.fireEvent('applyrule', me, field, fieldName, fieldRule);

        if (suspendLayouts) {
            _resumeModuleLayouts();
        }
    };

    var _evaluateCondition = function (fieldName, rules, applyFunction) {

        // consistency check
        if (_.isEmpty(rules)) return;

        // select rule behaviour
        var andConfiguration = {
            seed: true,
            evaluator: function (currentValue, fieldValue) { return currentValue && fieldValue; }
        };
        var orConfiguration = {
            seed: false,
            evaluator: function (currentValue, fieldValue) { return currentValue || fieldValue; }
        };
        var configuration = rules.type === "OR" ? orConfiguration : andConfiguration;

        // evaluate rule
        var validCondition = configuration.seed;
        _.each(rules.conditions, function (fieldCondition) {
            validCondition = configuration.evaluator(validCondition, _evaluateFieldCondition(fieldCondition));
        });

        // apply rule result
        _writeLogWithObject("...applying rule to '{fieldName}' -> {applyFunctionName}({validCondition}). Evaluated rule: ".format({
            fieldName: fieldName,
            applyFunctionName: applyFunction.name,
            validCondition: validCondition
        }), rules);
        
        applyFunction(fieldName, validCondition);
    };

    var _evaluateFieldCondition = function (expression) {

        var fieldName = null,
            fieldOperator = "eq",
            fieldValue = null;

        if (_.isString(expression)) {
            fieldName = expression;
        }
        else {
            fieldName = expression.property;
            fieldOperator = expression.op || fieldOperator;
            fieldValue = expression.value;
        }

        var field = _getField(fieldName);

        return _fieldConditionEvaluators[fieldOperator.toLowerCase()](field, fieldValue);
    };

    /*******************************************************************************************************
     *                                              GETTERS
     ******************************************************************************************************/

    var _getField = function (name) {
        var fieldID = _fieldsMapping[name] || name;
        if (!_allFields[fieldID])
            _allFields[fieldID] = _detailCtx.findField(fieldID);

        return _allFields[fieldID];
    };

    var _getSection = function (sectionID) {
        if (!_allSections[sectionID]) {
            _allSections[sectionID] = _detailCtx.component.down('#section_' + sectionID);
        }

        return _allSections[sectionID];
    };

    /*******************************************************************************************************
     *                                          SECTION HANDLING
     ******************************************************************************************************/

    var _enableSection = function (sectionID, enable) {
        var section = _getSection(sectionID);
        if (!section) return;

        enable ? section.show().expand() : section.hide();

        _.each(section.query('field'), function (sectionField) {
            _enableField(sectionField.name, enable);
        });
    };

    var _resetSection = function (sectionID, reset) {
        var section = _getSection(sectionID);
        if (!section || !reset) return;

        _.each(section.query('field'), function (sectionField) {
            _resetField(sectionField.name, true);
        });
    };

    /*******************************************************************************************************
     *                                          FIELD HANDLING
     ******************************************************************************************************/

    var _showField = function (fieldName, show) {
        var field = _getField(fieldName);
        if (!field) return;

        if (show) {
            field.show();
        }
        else {
            field.hide();
        }
    };

    var _enableField = function (fieldName, enable) {
        var field = _getField(fieldName);
        if (!field) return;

        if (field.initialConfig.allowBlank === false && !enable) {
            _writeWarning("......impossible to disable field '{fieldName}': server rule 'allowBlank' is set to 'false'!".format({ fieldName: fieldName }));
            return;
        }

        if (enable) { field.enable(); }
        else { field.disable(); }
    };

    var _resetField = function (fieldName, reset) {
        if (!reset) return;

        var field = _getField(fieldName);
        if (field) {
            if (field.clearValue) field.clearValue();
            else if (field.clear) field.clear();
            else field.reset();
        }
    };

    var _setFieldReadonly = function (fieldName, readonly) {
        var field = _getField(fieldName);
        if (field)
            field.setReadOnly(readonly);
    };

    var _setFieldMandatory = function (fieldName, mandatory) {
        var field = _getField(fieldName);

        if (!field) return;

        if (field.initialConfig.allowBlank === false && !mandatory) {
            _writeWarning("......impossible to remove mandatory from field '{fieldName}': server rule 'allowBlank' is set to 'false'!".format({ fieldName: fieldName }));
            return;
        }

        field.setMandatory(mandatory);
    };

    return {

        contextName: 'RuleManager_v1',

        init: function (initCfg) {
            me = this;
        },

        setWorkingContext: function (ctx) {
            _detailCtx = ctx;
            _init();
        },

        getWorkingContext: function () {
            return workingCtx;
        },

        suspendRules: function () {
            _suspended = true;
        },

        resumeRules: function (flush) {
            _suspended = false;

            if (flush)
                me.applyRules();
        },

        applyRules: function () {
            _suspendModuleLayouts();

            _.chain(_fieldDependencies)
                .map(function (dependency, fieldName) {
                    return { fieldName: fieldName, dependency: dependency, field: _getField(fieldName) };
                })
                .each(function (dependencyInfo) {
                    _evaluateFieldDependencies(dependencyInfo.field, dependencyInfo.fieldName, true);
                });

            _resumeModuleLayouts();
        }

    };
};
