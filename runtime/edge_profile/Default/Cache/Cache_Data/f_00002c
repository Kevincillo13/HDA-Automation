            } else {
                dockedItems = [].concat(me.dockedItems || []);
                dockedItems.push(tabBar);
                me.dockedItems = dockedItems;
            }
        }

        // we have to skip Ext.tab.Panel.initComponent, we want to call its parent class
        // this is done in order to avoid tabbar to be added as docked item or header item
        me.superclass.superclass.initComponent.apply(this, arguments);

        activeTab = me.activeTab = me.getComponent(activeTab);

        if (activeTab) {
            tabBar.setActiveTab(activeTab.tab, true);
        }

        // from Ext.Net override
        this.on("beforetabchange", function (el, newTab) {
            newTab = newTab || {};
            var field = this.getActiveTabField();

            if (field) {
                field.setValue(this.getTabId(newTab) + ':' + el.items.indexOf(newTab));
            }
        }, this);

        this.on("render", function () {
            var field = this.getActiveTabField();

            if (field && this.hasId()) {
                field.render(this.el.parent() || this.el);
            }
        }, this, { single: true });

    }

