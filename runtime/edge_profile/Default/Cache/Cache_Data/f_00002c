Ext.define('Portal.Controls.HyperlinkManager', {

    statics: {

        triggerClickHandler: function (item) {
            
            var href = item.getValue();

            // open URL
            if (href == "")
                return;

            if (href.match(new RegExp("{|<"))) {

                var contextParam = {};
                contextParam.Object = { entity: item.getContext('Detail').currentStatus().recordType, id: item.getContext('Detail').currentStatus().id };
                contextParam.User = { entity: 'User', id: Portal.Const.WSCUser.ID };

                Ext.Ajax.request({
                    url: Router.action("WSCView", "ParseString"),
                    method: 'POST',
                    params: {
                        "value": href,
                        "context": Portal.Util.Json.encode(contextParam)
                    },
                    success: function (response, opts) {
                        var json = Portal.Util.Json.decode(response.responseText, true);
                        if (json != null) {
                            if (json.success) {
                                window.open(json.value, "_blank");
                            }
                            else {
                                Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION);
                            }
                        }
                    },
                    failure: function (response, opts) {
                        // failure code
                        Portal.Util.Msg.showErrorMsg(translations.WSC_ERR_OPERATION);
                    }
                });

            } else {
                window.open(href, "_blank");
            }

        }
    }
});

