        var checkSizeBoundaries = function (paramToCheck, defaultSize, direction) {
            if (paramToCheck) {

                if (isNaN(paramToCheck) && paramToCheck.endsWith('%')) {

                    var percentage = Number(paramToCheck.substring(0, paramToCheck.indexOf("%")));

                    // percentage lower boundary
                    if (percentage <= 20) paramToCheck = "65%";

                    // percentage upper boundary
                    if (percentage > 98) paramToCheck = "98%";

                } else {

                    var pixels = Number(paramToCheck);

                    // pixels lower boundary
                    if (pixels < 210) paramToCheck = defaultSize;

                    // pixels upper boundary
                    var viewportSize = Portal.PageManager.getViewport().getSize();

                    if (pixels >= viewportSize[direction]) paramToCheck = "98%";
