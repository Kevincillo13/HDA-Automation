     */
    class CustomDayEventsView extends scheduler.views["modes/day/events"] {
        config() {
            var me = this;
            const ui = super.config();
            ui.onClick = {
                // click on event
                webix_scheduler_day_event: function (e) { return me.ShowEvent(e); },
                // click on empty space of a cell
                webix_scheduler_day_scale_item: function (e, h) { return me.ShowNew(h); }
