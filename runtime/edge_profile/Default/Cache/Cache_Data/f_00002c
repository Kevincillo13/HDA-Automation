                var map = {};
                Ext.each(data, function (item) { map[item.OperationID] = item; });

                // enable menu items (first level). 
                enableMenuItems(map, toolbar.items.getRange());

                var controls = me.component.query('buttoncontrol');
                Ext.Array.each(controls, function (ctl) {
