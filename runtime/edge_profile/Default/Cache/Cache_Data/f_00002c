        // >> WSCViewContext member
        reloadData: function (newData, reloadAllFields) {
            var formData = {};

            Portal.Util.Json.prepareObject(newData);

            // keep track of new record data
            me.contextStatus.initialData = newData;
            me.contextStatus.data = newData;

            var newDataFlat = Portal.Util.createFlatBaseObject(newData);

            if (reloadAllFields) {
                formData = newDataFlat;
            } else {
                formData = {};

                // lookups that need always value reload
                // if the lookup object was inserted we need to get its id and set it to the field as value
                var lookupFields = me.getFields('imagefield|htmlfield|attachmentfield');
                if (!Ext.isEmpty(lookupFields)) {
                    Ext.each(lookupFields, function (lookupField) {
                        var lookupName = lookupField.getName();
                        formData[lookupName] = newDataFlat[lookupName];
                    });
                }

                if (newData.LastUpdate) Ext.apply(formData, { LastUpdate: newDataFlat.LastUpdate });
            }

            if (!Ext.isEmpty(formData)) {
                loadData(formData);
            }

            me.resetDirty();
        },

        fullReload: function (id) {

            var filtersToSkip = ['templateid'];

            try {
                loadingMask.show();

                var status = me.currentStatus();

                id = id || status.objectIDs;

                var params = {};

                // Keep Specified RecordView
                if (me.contextStatus && me.contextStatus.recordViewID) {
                    params.RecordViewID = me.contextStatus.recordViewID;
                }

                // TODO - skip all filters?
                if (!Ext.isEmpty(me.contextStatus.filter)) {

                    // skip filters that must not be forwarded
                    var reloadFilters = [];
                    _.each(me.contextStatus.filter, function (f) {
                        if (f && f.property && !_.contains(filtersToSkip, f.property.toLowerCase())) reloadFilters.push(f);
                    });

                    // set new filters as reload params (overwrite existing ones)
                    params.filter = reloadFilters;
                }

                Portal.WSC.OperationManager.exists({
                    id: id,
                    entity: status.collectionType,
                    successFn: function () {

                        var moduleCtx = me.getContext('Module');

                        if (moduleCtx) {

                            var moduleParams = moduleCtx.getModuleParams();
                            var urlData = { id: id, entity: status.recordType };

                            // keep RecordViewID parameter
                            if (moduleParams.RecordViewID) {
                                urlData.RecordViewID = moduleParams.RecordViewID;
                            }

                            var detailUrl = Router.action("WSCView", "Detail", urlData);

                            if (Portal.PageManager.historyManager) {

                                const moduleToken = Portal.PageManager.historyManager.getHistoryTokenFromModuleUrl(moduleCtx.url());

                                if (Portal.PageManager.historyManager.getToken() === moduleToken)
                                    Portal.PageManager.historyManager.updateHistory({ sourceCmp: me.component, url: detailUrl });
                            }

                            moduleCtx.reload({ url: detailUrl, loadingMask: loadingMask, params: params });
                        }
                    },
                    failureFn: function () {
                        if (loadingMask && !loadingMask.isDestroyed) loadingMask.hide();
                        me.resetDirty(true);
                        me.getContext('Module').close();
                    }
                });


            } catch (err) {
