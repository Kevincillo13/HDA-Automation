            if (me.templateCtx) {
                me.templateCtx.on('beforeGetTemplateDetailData', function (args) {
                    //if (model.TemplateManagement) return; da verificare
                    var tplDict = args.contextParam,
                        status = me.currentStatus();

                    if (!Ext.isEmpty(status.objectIDs)) tplDict.Object = { entity: status.recordType, id: status.objectIDs };
                });
            }

            //Hide button
            var executeWork = function (elements) {
                var subMenu = [];
                var afterTbFill = true;
                Ext.each(elements.reverse(), function (node) {

                    if (node.getXType() == 'tbfill') afterTbFill = false;
                    if (afterTbFill && node && (node.getXType() == 'menuitem' || node.getXType() == 'button')) {
