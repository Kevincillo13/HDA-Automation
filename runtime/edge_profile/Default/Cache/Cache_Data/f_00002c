Ext.define('Portal.ContextManager', {
    singleton: true,
    constructor: function (cfg) {
        var me = this,
            activeCtxs = {},
            getContextName = function (ctxDef) {
                if (activeCtxs[ctxDef])
                    return activeCtxs[ctxDef];

                var ctxDefType = typeof ctxDef,
                    ctxConstructor = null;

                if (ctxDefType == 'string') {
                    ctxConstructor = eval(ctxDef);    
                }

                if (!Ext.isDefined(ctxConstructor)) return '';

                if (Ext.isFunction(ctxConstructor))
                    ctxConstructor = ctxConstructor();

                if (ctxDefType == 'string') {
                    activeCtxs[ctxDef] = ctxConstructor.contextName;
                }

                return ctxConstructor.contextName;
            };

        me.getContextName = getContextName;
    }
});

