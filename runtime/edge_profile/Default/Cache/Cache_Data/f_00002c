            //selectOnFocus: true,
            selectOnTab: true,
            typeAhead: false,
            forceSelection: true,
            immediateSearchOperator: me.immediateSearchOperator || 'in'
        });

        // // defaults for custom properties (only if not specified into constructor config)
        Ext.applyIf(me, {
            typing: false,
            pendingValue: null,
            loaded: false,
            initializing: true,
            hasFocus: false,
            selectedObject: null,
            objectLinkValid: true,
            loadingMode: false,
            searchViewOpened: false
        });

        me.callParent();

        // remove unwanted events that cause check change firing
        var allowedEvents = [];
        Ext.each(me.checkChangeEvents, function (event) {
            if (['keyup', 'textInput', 'input'].indexOf(event) == -1)
                allowedEvents.push(event);
        });
        me.checkChangeEvents = allowedEvents;

        // event listeners
        me.addManagedListener(me, 'triggerclick', eventHandlers.triggerClick);
        me.addManagedListener(me, 'writeablechange', eventHandlers.writeableChange);
        me.addManagedListener(me, 'formload', eventHandlers.formload);

        // immediate search listeners 
        // to handle search firing when user types something into the input field
        me.addManagedListener(me, 'blur', eventHandlers.blur);
        me.addManagedListener(me, 'focus', eventHandlers.focus);
        me.addManagedListener(me, 'beforeselect', eventHandlers.beforeSelect);


        me.addManagedListener(me, 'render', function () {
            me.getEl().addListener('keydown', eventHandlers.elKeydown, me);
        });

        // setup component
        me.addManagedListener(me, 'afterrender', function () {
            this.getPicker();
            initializeControl();
            this.updateControlUI();
        });

        // auto-resolve initial value
        if (!Ext.isEmpty(me.initialConfig.value) && me.initialConfig.value != Portal.Const.EMPTY_ID) {
            me.addManagedListener(me, 'render', function () { me.loadObjectData(me.initialConfig.value); }, me, { single: true });
        }
    },

    getClientConfig: function () {
        // return client configuration
        return {
            detailUrl: this.detailUrl,
            tableID: this.tableID,
            detailOpeningMode: this.detailOpeningMode,
            recordType: this.recordType,
            viewMode: this.viewMode
        };
    },

    applyClientConfig: function (cfg) {
        // applies a new client configuration
        Ext.apply(this, cfg);
    },

    searchCallback: function (value) {
        this.loaded = true; // marking that field has a value now
        this.typing = false; // marking that field has not a typed value now
        this.setValue(value);
        this.clearInvalid();

        // now valid.
        this.objectLinkValid = true;
    },

    setTriggerVisibility: function (name, visible) {

        if (!this.triggerEl) {

            if (!visible) {
                Ext.each(this.triggersConfig, function (triggerCfg) {
                    if (!triggerCfg.hidden && triggerCfg.tag === name) {
                        Ext.apply(triggerCfg, { style: "display:none", hidden: true });
                    }
                });
            }

        } else {

            var trigger = this.getTrigger(name);

            if (trigger) {
                if (!visible) {
                    //trigger.removeCls('trigger-visible');
                    trigger.hide();
                } else {
                    //trigger.addCls('trigger-visible');
                    trigger.show();
                }
            }

        }
    },

    setAsLoading: function (loading) {
        if (!this.inputEl) return;
        if (loading) {
            this.inputEl.setValue(translations['WSC_Loading']);
            this.removeCls('selectedObjectLink');
            this.addCls('loadingObjectLink');
        } else {
            this.inputEl.setValue('');
            this.typing = false;
            this.removeCls('loadingObjectLink');
        }
    },

    isLoadingMode: function () {
        return this.loadingMode;
    },
    setLoadingMode: function (newValue) {
        this.loadingMode = newValue;
    },

    openDetailView: function () {
        var value = this.getValue();

        // if field has no value or has a temporary typed value then skip
        if (!value || value == Portal.Const.EMPTY_ID /*|| this.typing*/) return;

        // open object detail view
        Portal.PageManager.openModule({
            mode: this.getDetailOpeningMode(),
            url: Router.action("WSCView", 'Detail', { entity: this.recordType, id: value }),
            parentContainer: this.getContext('Module')
        });
    },

    openSearchView: function (searchValue) {

        var me = this;

        if (this.searchViewOpened) return;

        this.searchViewOpened = true;
        this.setLoadingMode(true);

        var data = null;
        var ctx = me.getContext("Detail");

        var entity = null;
        if (ctx != null) {
            data = ctx.getData();
            entity = ctx.contextStatus.recordType;
        }
        else
            data = {};

        if (!this.fireEvent('sqllinkbeforesearch', this, data)) return;

        var urlParameter = Router.action("WSCView", "SQLLinkList", { tableID: this.tableID, entity: entity });
        var urlFilters = [];

        var searchText = "";
        if (this.typing) {
            searchText = searchValue || this.getTypedValue();
        }

        var encodedData = Portal.Util.Json.encode(data);
        var params = { data: encodedData, searchText: searchText };

        var filter = [];
        if (this.searchFilters) filter = [].concat(this.searchFilters);

        filter = Portal.Util.mergeFilterArrays(filter, urlFilters);

        params.objectLinkControl = this.getId();
        if (filter) params.filter = Portal.Util.Json.encode(filter);

        var win = Portal.PageManager.openModule({
            mode: 'objectLink',
            title: me.fieldLabel,
            url: urlParameter,
            parentContainer: this.getContext('Module'),
            params: params,
            callbackFn: function (cmp, ctx) {
                ctx.mon(ctx, 'moduleclose', function () {
                    me.searchViewOpened = false;
                    me.setLoadingMode(false);
                    me.focus();
                });
            }
        });

    },

    removeErrorStyles: function () {
        if (!this.inputEl) return;
        this.inputEl.removeCls('objectlink_object-not-found');
        this.inputEl.removeCls('objectlink_object-not-visible');
        this.inputEl.removeCls('objectlink_object-not-available');
    },

    /*** Set object, value and description of an objectlink, managing initialization state and valueresolved event. ***/
    setObjectLinkData: function (object, value, description, style) {

        this.removeErrorStyles();

        // sostituita chiamata a clearValue per evitare di scatenare evento change con valore vuoto prima di impostare l'effettivo valore.
        //this.clearValue();
        this.getStore().removeAll();
        this.lastQuery = '';
        this.pendingValue = null;

        // Set Data
        this.setTriggerVisibility('detail', object ? true : false);
        this.selectedObject = object;
        this.setRecord(value, description);
        this.setValue(value, null, true);

        // Set ObjectLink as Initialized
        var initialized = !this.initializing;
        if (this.initializing) {
            this.resetDirty();
            this.initializing = false;
        }

        // Configuration & Events
        if (style) this.inputEl.addCls(style);
        if (object) this.fireEvent('valueresolved', this, value, description, initialized);

        this.updateControlUI();
    },

    /*
     * Loads object description corresponding to the passed value. The function calls server action to get the decription,
     * adds a new item to the object link associated store and then calls the original setValue (of ComboBox) function.
     */
    loadObjectData: function (newValue, callbackFn) {
        var rec = {}, oldValue = this.getValue();

        this.pendingValue = newValue;

        // use Ext UrlEncode method (workaround passing "v" as querystring param since it uses only objects as param)
        var newValueEncoded = Ext.urlEncode({ v: newValue }).substring(2);

        var data = null;
        var ctx = this.getContext("Detail");
        var entity = null;
        if (ctx != null) {
            data = ctx.getData();
            entity = ctx.contextStatus.recordType;
        }
        Ext.Ajax.request({
            url: Router.action("WSCView", "GetSQLLinkDescription"),
            params: {
                id: newValue,
                tableID: this.tableID,
                data: Portal.Util.Json.encode(data),
                entity: entity
            },
            method: 'POST',
            scope: this,
            success: function (response, options) {
                // Ajax request OK
                var responseObj = Ext.decode(response.responseText),
                    store = this.getStore();

                if (!responseObj.success) {
                    Portal.Console.error('object link loading response ko: ' + responseObj.result.code + ' ' + responseObj.result.desc);

                    switch (responseObj.result.code) {

                        case Portal.WSC.OperationManager.ObjectNotFound:

                            switch (responseObj.result.subcode) {

                                case '2':
                                    this.setObjectLinkData(null, newValue, translations['WSC_Error_ObjectNotVisible'], 'objectlink_object-not-visible');
                                    break;

                                default:
                                    this.setObjectLinkData(null, '', translations['WSC_Error_ObjectNotFound'], 'objectlink_object-not-found');

                            }
                            break;

                        case Portal.WSC.OperationManager.OtherError:
                            this.setObjectLinkData(null, newValue, translations['WSC_Error_ObjectNotAvailable'], 'objectlink_object-not-available');
                            Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_ServerCommunicationError'] + '<br/>' + responseObj.result.desc);
                            break;

                        default:
                            this.setObjectLinkData(null, newValue, translations['WSC_Error_ObjectLoading'], 'objectlink_object-not-available');

                    }

                } else {
                    //Portal.Console.log('object link loading ok (value=' + newValue + ', desc=' + responseObj.data.ObjectDescription + ")");

                    var objDescription = '';
                    if (responseObj.data.ObjectDescription) objDescription = this.cleanupDescription(responseObj.data.ObjectDescription);
                    this.setObjectLinkData(responseObj.data, newValue, objDescription);

                }

            },
            failure: function (response, options) {
                // Ajax request KO
                Portal.Console.error(['object link', 'loading call ko', response.status, response.statusText]);
                this.setObjectLinkData(null, newValue, translations['WSC_Error_ObjectLoading'], 'objectlink_object-not-available');
            }
        });
    },

    immediateSearch: function () {
        var me = this;
        if (!me.typing) return;
        if (me.searchViewOpened) return;

        var searchValue = me.getTypedValue();

        me.setLoadingMode(true);

        var data = null;
        var ctx = this.getContext("Detail");
        var entity = null;
        if (ctx != null) {
            data = ctx.getData();
            entity = ctx.contextStatus.recordType;
        }

        Ext.Ajax.request({
            url: Router.action("WSCView", "SQLLinkSearch", { filter: searchValue, tableID: this.tableID, entity: entity }),
            params: { data: Portal.Util.Json.encode(data) },
            method: 'POST',
            success: function (response, options) {
                // Ajax request OK
                var responseObj = Ext.decode(response.responseText);

                if (!responseObj.success) {
                    Portal.Console.error('object link custom search response ko: ' + responseObj.result.code + ' ' + responseObj.result.desc);

                    me.setLoadingMode(false);
                    me.clearValue(true);
                    me.inputEl.setValue(searchValue);
                    me.markInvalid(translations['WSC_Msg_ObjectLinkSearchFailure']);

                    // now valid.
                    me.objectLinkValid = false;

                } else {

                    Portal.Console.log('object link custom search ok');

                    if (responseObj.total == 1) {
                        // one match, select this item

                        var objDescription = me.cleanupDescription(responseObj.data[0].Description);

                        me.setLoadingMode(false);
                        me.typing = false;
                        me.setRecord(responseObj.data[0].ID, objDescription);
                        me.setValue(responseObj.data[0].ID);
                        me.clearInvalid();

                        // now valid.
                        me.objectLinkValid = true;
                    } else {
                        // more than 1 item matches the search text, open search view                        
                        me.openSearchView(searchValue);
                    }

                }
            },
            failure: function (response, options) {
                // Ajax request KO
                Portal.Console.error('object link custom search call ko: ' + response.status + ' ' + response.statusText);
                Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_ServerCommunicationError'], +response.status + ' ' + response.statusText);
                me.setLoadingMode(false);
            }
        });
    },

    valueLoaded: function () {
        this.loaded = true;
        this.pendingValue = null;
        this.typing = false;

        if (!Portal.Util.isEmptyValue(this.getValue())) {
            this.isValid();
        }

        //this.setAsSelected(true);
    },

    setRecord: function (value, txt) {
        var store = this.getStore(), rec = {};
        store.removeAll();
        rec[this.valueField] = value;
        rec[this.displayField] = txt;
        store.add(rec);
    },

    // overrides

    // override of Ext.form.field.ComboBox initValue function (ExtJS override)
    //initValue: function () {
    //    if (this.value !== undefined) {
    //        this.setValue(this.value, null, true);
    //    } else if (!Ext.isEmpty(this.el.dom.value) && this.el.dom.value != this.emptyText) {
    //        this.setValue(this.el.dom.value, null, true);
    //    }
    //    this.originalValue = this.getValue();
    //},

    // override of Ext.form.field.ComboBox setValue function (ExtJS override)
    setValue: function (value, doSelect, skipResolve) {

        // value typed by user, skip setValue
        if (this.typing) {
            return;
        }

        if (Portal.Util.isEmptyValue(value)) {

            // empty value, set empty item+
            this.getStore().removeAll();
            this.setRecord(String(Portal.Const.EMPTY_ID), '');

            //this.callParent(arguments);
            Portal.Controls.ObjectLink.superclass.setValue.call(this, String(Portal.Const.EMPTY_ID), doSelect);

            // set control as initialized in case of empty value, we don't need to wait any value resolution to complete
            if (this.initializing) {
                this.initializing = false;
            }

            this.valueLoaded();

        } else {
            if (Ext.isObject(value) || Ext.isArray(value)) {
                this.callParent(arguments);
                return;
            }

            // not empty value
            if (skipResolve) {
                // skip description resolution and set value
                this.callParent(arguments);
                this.valueLoaded();

            } else {
                // load selected item description
                var oldValue = this.getValue();
                if (oldValue != value) {
                    this.loadObjectData(value);
                } else {
                    //this.setAsSelected(true);
                }
            }
        }
    },

    // override of Ext.form.field.ComboBox getValue function (ExtJS override)
    getValue: function () {
        if (this.pendingValue) {
            return this.pendingValue;
        }
        if (this.typing && this.getTypedValue() != this.getDisplayValue()) {
            return Portal.Const.EMPTY_ID;
        }
        return this.callParent() || Portal.Const.EMPTY_ID;
    },

    // override of Ext.form.field.ComboBox clearValue function (ExtJS override)
    clearValue: function (keepTypedValue) {
        this.selectedObject = null;
        this.callParent();
        this.getStore().removeAll();
        this.lastQuery = '';
        this.pendingValue = null;

        //this.setAsSelected(false);

        if (!Ext.isDefined(keepTypedValue) || !keepTypedValue) {
            if (this.rendered) this.inputEl.setValue('');
            this.typing = false;
            this.objectLinkValid = true;
        }

        this.updateControlUI();
    },

    // override of Ext.form.field.ComboBox isValid function (ExtJS override)
    //isValid: function () {
    //    var parentValid =  this.callParent();
    //    return (this.objectLinkValid && parentValid);
    //},

    getErrors: function (value) {
        var me = this,
            format = Ext.String.format,
            errors = me.callParent(arguments);

        if (!this.objectLinkValid) {
            errors.push(translations['WSC_Msg_ObjectLinkSearchFailure']);
        } else {

            if (this.loadingMode) {
                errors.push(translations['WSC_Msg_ObjectLinkValidationInProgress']);
            }
        }

        return errors;
    },

    // override of Ext.form.field.Picker onDownArray function (ExtJS override)
    onDownArrow: function (e) {
        // do nothing, cause we don't want to show combo list
    },

    // override of Ext.form.field.Picker expand function (ExtJS override)
    expand: function () {
        // do nothing, cause we don't want to show combo list
    },

    // override of Ext.form.field.Trigger onTriggerWrapClick function (Ext.Net override)
    onTriggerWrapClick: function () {
        var me = this,
            e = arguments[me.triggerRepeater ? 1 : 0],
            t = e && e.getTarget('.' + me.triggerBaseCls, null),
            match = t && t.className.match(me.triggerIndexRe),
            idx,
            special,
            tdefault,
            triggerClickMethod;

        //if (match && !me.readOnly && !me.disabled) {
        if (match) {
            idx = parseInt(match[1], 10);
            special = t.getAttribute("special");

            if (special) {
                triggerClickMethod = me['onTrigger' + (idx + 1) + 'Click'] || me.onTriggerClick;
                if (triggerClickMethod) {
                    triggerClickMethod.call(me, e);
                }
            } else {
                this.onCustomTriggerClick(e, {
                    index: idx,
                    tag: t.getAttribute("tid")
                });
            }
        }
    },

    // override of Ext.form.field.Trigger onCustomTriggerClick function (Ext.Net override)
    onCustomTriggerClick: function (o, evt) {
        this.fireEvent("triggerclick", this, this.getTrigger(o.index), o.index, o.tag, evt);
    },

    // override of Ext.form.field.Trigger afterRender function (Ext.Net override)
    afterRender: function () {
        Ext.form.field.Trigger.superclass.afterRender.call(this, arguments);

        this.triggerCell.each(function (item) {
            item.setVisibilityMode(Ext.Element.DISPLAY);
        });

        if (this.hideTrigger) {
            this.triggerCell.addCls("x-hide-display");
        }
    },

    getTypedValue: function () {
        //return this.getRawValue();
        if (this.inputEl) return this.inputEl.getValue();
        return null;
    },

    getDetailOpeningMode: function () {
        if (this.detailOpeningMode == null) {
            var modCtx = this.getContext('Module'),
                detailMode = null;
            while (modCtx && modCtx.openingMode() == 'childmodule') {
                modCtx = modCtx.getParentCtx();
            }

            if (modCtx && modCtx.openingMode() != 'childmodule') detailMode = modCtx.openingMode();

            this.detailOpeningMode = detailMode;
        }
        return this.detailOpeningMode;
    },

    cleanupDescription: function (description) {
        return description.replace(/\n|\r/g, '');
    },

    isInitializing: function () {
        return this.initializing;
    },

    getViewMode: function () {
        if (this.viewMode !== null) {
            switch (this.viewMode.toLowerCase()) {
                case "auto":

                    if (Portal.Const.Device.IsMobile)
                        return "hyperlink";
                    else
                        return "default";

                default:

                    return this.viewMode.toLowerCase();

            }
        }
        else return "default";
    },

    updateControlUI: function () {
        var me = this;
        var value = me.getValue();

        // object link trigger is visible when the field is not read-only and its value is not empty
        me.setTriggerVisibility("objectLink", !me.readOnly && Portal.Util.isEmptyValue(value));

        // clear trigger is visible when the field is not read-only and it has a not empty value
        me.setTriggerVisibility("clear", !me.readOnly && !Portal.Util.isEmptyValue(value));

        // disable key events when the field is read-only
        me.enableKeyEvents = !me.readOnly;

        me.setEditable(!me.readOnly && !Portal.Const.Device.IsMobile);

    }
});
