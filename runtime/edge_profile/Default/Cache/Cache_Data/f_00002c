                    //}
                    if (status.recordViewID)
                        currentParams.recordViewID = status.recordViewID;

                    // reload current module passing the new object type
                    me.getContext('Module').reload({
                        url: loadUrl,
                        params: currentParams
                    });

                };

            // force dirty.
            currentParams.setDirty = 1;

