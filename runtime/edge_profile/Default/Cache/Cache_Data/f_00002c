    var _toggleFilterContainer = function () {

        if (viewMode === 'window') {

            var win = me.component.down('#FilterAreaWindow');

            if (!win) return;

            var currSize = Portal.Util.getCurrentViewSize();
            if (currSize.width < 600) {
                // small devices - maximize window
                win.maxHeight = null;
                win.setWidth(currSize.width);
                win.setHeight(currSize.height);
            } else {
                // normal devices - adjust window width only
                win.setWidth(Portal.Util.getDefaultModalViewSize().width);
            }

            win.show();
            win.center();

        } else {

            var container = _getFiltersContainer();
            if (container) container.toggleCollapse(true);
        }

        if (Portal.AccessibilityNavigationManager) {
            Portal.AccessibilityNavigationManager.setDomElementsNavigation();
        }
    };

    var _collapseFilterContainer = function () { _expandOrCollapseFilterContainer("collapse"); };

    var _expandFilterContainer = function () { _expandOrCollapseFilterContainer("expand"); };

    var _expandOrCollapseFilterContainer = function (action) {
        var isExpand = action === "expand",
            isCollapse = action === "collapse";

        if (!toolbarContainer) { return; }
        if (!isExpand && !isCollapse) { return; }

        if (isCollapse) {
            toolbarContainer.removeCls('filter-area-expanded');
            if (_filterToggleCmp.pressed) _filterToggleCmp.toggle(false);
        }

        if (isExpand) {
            toolbarContainer.addCls('filter-area-expanded');
        }

        var defaultFilter = _getDefaultFilter();

        if (defaultFilter) {
            var areaFilter = _getActiveArea().getForm().findField(defaultFilter.getName());

            if (areaFilter) {

                if (isCollapse) {
                    if (areaFilter.getValue()) { defaultFilter.setValue(areaFilter.getValue()); }
                    defaultFilter.show();
                }

                if (isExpand) {
                    areaFilter.setValue(defaultFilter.getValue());
                    defaultFilter.hide();
                }
            }
        }
    };

