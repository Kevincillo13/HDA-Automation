Ext.define('Portal.Controls.ComboTriggerManager', {
    singleton: true,

    evaluateClearTriggerVisibility: function (combo) {

        if (!combo.triggerEl) return;
        if (combo.readOnly) return;

        if (!Portal.Util.isEmptyValue(combo.getValue())) {
            combo.getTrigger(0).show();
            let clearTriggerEl = combo.getTrigger(0).el.dom;

            if (clearTriggerEl.getAttribute("tabIndex") != "0") {
                clearTriggerEl.setAttribute("tabIndex", "0");
                clearTriggerEl.setAttribute("aria-label", translations.ACCESSIBILITY_ToolBar_Clear);
            }
        } else {
            combo.getTrigger(0).hide();
        }
    },

    afterRenderHandler: function (combo, eOpts) {

        Portal.Controls.ComboTriggerManager.evaluateClearTriggerVisibility(combo);
    },

    changeHandler: function (combo, record, index) {

        Portal.Controls.ComboTriggerManager.evaluateClearTriggerVisibility(combo);
    },

    focusLeaveHandler: function (combo, event, eOpts) {

        Portal.Controls.ComboTriggerManager.evaluateClearTriggerVisibility(combo);
    },

    beforeQueryHandler: function (queryPlan, eOpts) {

        if (!queryPlan.combo.triggerEl) return;

        queryPlan.combo.getTrigger(0)[queryPlan.combo.getRawValue().toString().length == 0 ? 'hide' : 'show']();
    },

    triggerClickHandler: function (combo, trigger, index, tag, e) {

        if (tag == 'clear') {
            
            if (combo.getXType() == 'datefield') {
                combo.clear();
            } else {
                combo.clearValue();
                combo.setValue(combo.triggerEmptyValue ? combo.triggerEmptyValue.toString() : Portal.Const.EMPTY_ID);
            }

            combo.getTrigger(0).hide();
        }
