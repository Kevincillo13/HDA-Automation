Ext.define('Portal.Controls.ActionLink', {

    extend: 'Ext.panel.Panel',

    alias: 'widget.portalactionlink',

    componentCls: 'panel action-link',

    contentLoaded: false,

    supportsHiddenCls: true,

    mixins: {
        moduleContainer: 'Portal.ModuleContainer'
    },

    config: {

        contentScrollMode: 'Auto'

    },

    initComponent: function () {
        var me = this;

        me.callParent();

        var onBeforeLoad = function (loader, options, eOpts) { me.contentLoaded = false; };

        onBeforeLoad = Ext.Function.createSequence(
            onBeforeLoad,
            Portal.ModuleContainer.buildOnModuleRemoteLoading({
                collapseTitleToContainer: false,
                parentContainer: function () { return me.getContext('Module'); }, // set the action link module context as parent context
                contentScrollMode: me.getContentScrollMode()
            }));

        // action link default listeners
        me.getLoader().addListener('beforeload', onBeforeLoad);

        me.getLoader().addListener('load', function (loader, response, options, eOpts) {
            me.contentLoaded = true;

            Portal.ModuleContainer.onContainerLoad.apply(this, arguments);
        });

        me.getLoader().addListener('exception', Portal.ModuleContainer.onContainerLoadException);

        me.addListener('beforeClose', Portal.ModuleContainer.onContainerBeforeClose);
        me.addListener('close', Portal.ModuleContainer.onContainerClose);
    },

    loadModule: function (url, params, delay) {
        var cfg = {
            url: url,
            params: params,
            delay: delay
        };

        if (Portal.Const.Device && Portal.Const.Device.IsMobile) {
            Ext.apply(cfg, { loadMask: { showMask: false } });
        }

        Portal.ModuleContainer.reload(this, cfg);
    }
});
