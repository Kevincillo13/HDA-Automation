                elements    : a collection of "menuitem" or "button" items. 
                
            Return:
                enabledItems: the list of items that have been ENABLED (first level only)

        */
        enableMenuItems: function (map, elements) {
            var enabledNodes = [];

            Ext.each(elements, function (node) {
                if (node && (node.getXType() == 'menuitem' || node.getXType() == 'button')) {
                    if (node.itemId && map[node.itemId]) {
                        var showNode = map[node.itemId].Enabled;

                        node.setVisible(showNode);

                        // add items that are enabled to output list.
                        if (showNode) {
                            enabledNodes.push(node);
                            if (node.menu && node.menu.items) {
                                // check sub nodes.
                                var subNodes = node.menu.items.getRange();

                                // enable menu items based on active OPERATIONS
                                var enabledSubNodes = me.enableMenuItems(map, subNodes);

                                // something to show as child nodes?
                                var visibleSubNodes = Ext.Array.filter(subNodes, function (node) { return !node.isHidden(); });

                                // show master node ONLY when SOME CHILD NODE available
                                node.setVisible(visibleSubNodes.length > 0);
                            }
