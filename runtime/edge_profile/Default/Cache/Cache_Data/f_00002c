Ext.define('Portal.Controls.DependencyManager', {
    
    singleton: true,

    methods: {},

    getMethod: function (fullName) {
        if(this.methods[fullName])
            return this.methods[fullName];
        return null;
    },

    setupControlDependency: function (sourceControl, targetControl) {
        // set source dependency infos
        if (!sourceControl.dependency) {
            Ext.apply(sourceControl, {
                dependency: {
                    isSource: false,
                    isTarget: false,
                    sources: [],
                    targets: []
                }
            });
        }
        with (sourceControl.dependency) {
            isSource = true;
            targets.push(targetControl);
        }

        // set target dependency infos
        if (!targetControl.dependency) {
            Ext.apply(targetControl, {
                dependency: {
                    isSource: false,
                    isTarget: false,
                    sources: [],
                    targets: []
                }
            });
        }
        with (targetControl.dependency) {
            isTarget = true;
            sources.push(sourceControl);
        }
    },
    
    setupDependencies: function (depArray) {
        var me = this, sourceID = '', targetID = '', sourceCmp, targetCmp, handlerFn;
        
        Ext.each(depArray, function (depCfg) {
            handlerFn = me.resolveMethod(depCfg.handler);
            if (!Ext.isFunction(handlerFn)) return;

            if(depCfg.sourceControlID != sourceID){
                sourceID = depCfg.sourceControlID
                sourceCmp = Ext.net.ResourceMgr.getCmp(sourceID);
            }

            if(depCfg.targetControlID != targetID){
                targetID = depCfg.targetControlID;
                targetCmp = Ext.net.ResourceMgr.getCmp(targetID);
            }
            
            if (sourceCmp && targetCmp) {
                handlerFn(sourceCmp, targetCmp, depCfg.params);
                me.setupControlDependency(sourceCmp, targetCmp);
            }

        });
    },

    resolveMethod: function (fullName) {
        var method = this.getMethod(fullName);
        if (!method){
            var parts = fullName.split('.'), obj = window;
            Ext.each(parts, function (part) {
                if (obj[part]) obj = obj[part];
            });
            method = obj;
            this.methods[fullName] = method;
        }
        return method;
    }

});
