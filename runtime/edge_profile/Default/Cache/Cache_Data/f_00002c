        saveBeforeExecutingCommand: function (fn, params) {

            var currentParams = Portal.CommandContext.Utils.prepareOperationParams(me.currentStatus(), params);
            var avoidAsking = null;
            var forceValidation = (params && params.forceValidation) ? true : false;

            /*
                check for "AutoSaveBeforeExecutingCommand" params existence
                AutoSaveBeforeExecutingCommand = '1', 'true', 'True' means that we've to skip asking for user confirmation and immediately save pending changes (if exists) before executing command
            */
            if (params != null && Ext.isDefined(params.avoidAsking)) {
                if (Ext.isNumeric(params.avoidAsking)) {
                    avoidAsking = (new Boolean(params.avoidAsking * 1)).valueOf();
                } else {
                    avoidAsking = (params.avoidAsking.toLowerCase() == 'true');
                }
            }
            if (Ext.isDefined(currentParams.AutoSaveBeforeExecutingCommand)) {
                if (Ext.isNumeric(currentParams.AutoSaveBeforeExecutingCommand)) {
                    avoidAsking = (new Boolean(currentParams.AutoSaveBeforeExecutingCommand * 1)).valueOf();
                } else {
                    avoidAsking = (currentParams.AutoSaveBeforeExecutingCommand.toLowerCase() == 'true');
                }
            }

            if ((me.isDirty() || (forceValidation && !me.isValid())) && !me.getContext('Command').flagSavingInProgress && !isTemplateManagement) {

                me.saveBeforeExecutingOperation(
                    translations['WSC_Msg_SaveBeforeExecute'],
                    function () {
                        var functionParams = { successCb: function () { fn.call(me, params); } };
                        me.getContext('Command').saveRecord(functionParams);
                    },
                    function () { },
                    function () { fn.call(me, params); },
                    {
                        avoidAsking: avoidAsking,
                        forceValidation: forceValidation
                    }
                );

            } else {
                fn.call(me, params);
            }
        },

        saveBeforeExecutingCommandPromise: function (params) {
            return new Promise(function (resolve, reject) {

                var currentParams = Portal.CommandContext.Utils.prepareOperationParams(me.currentStatus(), params);
                var avoidAsking = null;
                var forceValidation = (params && params.forceValidation) ? true : false;

                /*
                    check for "AutoSaveBeforeExecutingCommand" params existence
                    AutoSaveBeforeExecutingCommand = '1', 'true', 'True' means that we've to skip asking for user confirmation and immediately save pending changes (if exists) before executing command
                */
                if (params != null && Ext.isDefined(params.avoidAsking)) {
                    if (Ext.isNumeric(params.avoidAsking)) {
                        avoidAsking = (new Boolean(params.avoidAsking * 1)).valueOf();
                    } else {
                        avoidAsking = (params.avoidAsking.toLowerCase() == 'true');
                    }
                }
                if (Ext.isDefined(currentParams.AutoSaveBeforeExecutingCommand)) {
                    if (Ext.isNumeric(currentParams.AutoSaveBeforeExecutingCommand)) {
                        avoidAsking = (new Boolean(currentParams.AutoSaveBeforeExecutingCommand * 1)).valueOf();
                    } else {
                        avoidAsking = (currentParams.AutoSaveBeforeExecutingCommand.toLowerCase() == 'true');
                    }
                }

                if ((me.isDirty() || (forceValidation && !me.isValid())) && !me.getContext('Command').flagSavingInProgress && !isTemplateManagement) {

                    me.saveBeforeExecutingOperation(
                        translations['WSC_Msg_SaveBeforeExecute'],
                        function () {
                            var functionParams = {
                                successCb: function () { resolve(params); },
                                failureCb: function () { reject(params); }
                            };
                            me.getContext('Command').saveRecord(functionParams);
                        },
                        function () {
                            reject(Portal.Const.RefuseConfirmError);
                        },
                        function () { resolve(params); },
                        {
                            avoidAsking: avoidAsking,
                            forceValidation: forceValidation
                        }
                    );

                } else {
                    resolve(params);
                }

            });
        },


        saveBeforeExecutingOperation: function (message, scFunction, failFunction, commandFunction, params) {

            var doSaveBeforeExecutingOperation = function () {

                if (me.isDirty() && !isTemplateManagement) {

                    //Ask if save or not
                    var askBeforeSave = function () {

                        if (params && params.avoidAsking === true) {

                            if (scFunction) scFunction();

                        } else {

                            Portal.Util.Msg.confirm(
                                translations['WSC_Detail'], message || translations['WSC_Msg_SaveWhenClosing'],
                                function (ans) {

                                    if (ans == 'cancel') { return; }

                                    if (ans == 'yes' && scFunction) { scFunction(); }

                                    if (ans == 'no' && failFunction) { failFunction(); }
                                }
                            );

                        }
                    };

                    var callback = function (data) {
                        if (!data) return;
                        var map = {};
                        Ext.each(data, function (item) { map[item.OperationID] = item; });

                        if ((map['RecordSaveAndClose'] && map['RecordSaveAndClose'].Enabled) || (map['RecordSave'] && map['RecordSave'].Enabled)) {
                            askBeforeSave();
                        } else {
                            if (commandFunction) commandFunction();
                        }
                    };

                    //if (!Portal.PageManager.applicationClosing()) {
                    var commandContext = me.getContext('Command');
                    if (commandContext && commandContext.component === me.component) {
                        commandContext.getAvailableOperations(callback, me.contextStatus.availableOperations);
                    } else {
                        return true;
                    }

                    //}

                    return false;
                }
            };

            if (params && params.forceValidation) {

                me.promises.validate()
                    .then(function () {
                        doSaveBeforeExecutingOperation();
                    })
                    .catch(function (errors) {
                        // do nothing
                    });

                return false;
            }

            return doSaveBeforeExecutingOperation();
        },

