Ext.define('Portal.Controls.Module', {

    extend: 'Ext.panel.Panel',

    alias: 'widget.portalmodule',

    requires: ['Portal.MessageBus'],

    componentCls: 'module',

    statics: {
        resizeModule: function (moduleCmp) {
            try{
                var moduleCt = moduleCmp.up(),
                    moduleColumn = moduleCt.up('portalcolumn', 1),
                    modulePortal,
                    moduleHeight;

                // check if current module is the only one into its column
                if (moduleColumn && moduleColumn.items && moduleColumn.items.getCount() == 1) {
                    modulePortal = moduleColumn.up('portalpanel');
                    if (modulePortal) {
                        moduleHeight = modulePortal.getHeight();
                        moduleCt.setHeight(moduleHeight);
                    }
                }
            } catch (e) { }

        }
    },

    config: {

        contentScrollMode: 'Auto',

        isContentArea: true

    },

    setIsContentArea: function (isContentArea) {
        this.isContentArea = isContentArea;

        if (this.rendered)
            this.updateContentAreaClasses();
    },

    updateContentAreaClasses: function () {
        if (this.isContentArea)
            this.addCls('content-area');
        else
            this.removeCls('content-area');
    },

    setContentScrollMode: function (value) {
        this.callParent(arguments);
        
        switch (value) {
            case 'Scroll':
                this.setAutoScroll(true);
                break;

            case 'None':
                this.setAutoScroll(false);
                break;
        }
    },

    initComponent: function () {
        var me = this;

        me.callParent();

        me.moduleLoadMode = me.moduleLoadMode || 'local';
        
        // module default listeners
        me.addListener('added', me.initModule, me, { single: true });
        me.addListener('afterlayout', function () {
            Portal.MessageBus.publish('Portal.InlineManual.StateChanged');
            if (Portal.AccessibilityNavigationManager) {
                Portal.AccessibilityNavigationManager.setDomElementsNavigation();
            }
        }, me, { single: true });
    },

    beforeRender: function () {
        this.callParent(arguments);

        this.updateContentAreaClasses();
    },

    initModule: function () {

        //Ext.suspendLayouts();

        // create new module context instance and connect it to current component
       try {
            Portal.ModuleContext.createInstance(this);
            if (this.moduleLoadMode == 'remote') {
                this.addListener('beforerender', function () { Portal.Controls.Module.resizeModule(this); });
           }
        } catch (e) {
            Portal.Console.error('Portal Exception >> Error on initModule call!');
            if (this.id) Portal.Console.error('Module target component is "' + this.id + '"');
            if (e.message) Portal.Console.error(e.message);
            if (e.stack) Portal.Console.error(e.stack);
        }
    }
});
