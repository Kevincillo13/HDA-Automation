Ext.define("Portal.Analysis.TreeMapBehaviour", {
    extend: "Portal.Analysis.AnalysisBehaviourBase",
    constructor: function () {
        var me = this,
            _page = null,
            _dataSource = [],
            _container = null,
            _color = null,
            _counter = 0;

        var _consts = {
            ROOT_ID: "root"
        };

        me.callParent(arguments);

        var _translateLabel = function (text) {
            return translations[text] ? translations[text] : text;
        }

        var _getTemplateFromParam = function (container, templateName, templateObject) {
            if (container.templateParameters && container.templateParameters[templateName]) {
                var tpl = new Ext.XTemplate(container.templateParameters[templateName]);
                return tpl.apply(templateObject);
            }

            return "";
        };

        var _buildDataSource = function (container) {

            var index = 1;
            var maps = _.map(container.data, d => ({
                id: _consts.ROOT_ID + "." + index++,
                value: d.Value,
                label: "<span class='" + d.IconCls + "'></span>" + _translateLabel(d.LabelCode),
                description: _translateLabel(d.LabelCode),
                source: d
            }));

            return { id: _consts.ROOT_ID, data: maps };
        };

        var _getColorPattern = function (item) {
            var color = null,
                r = 0,
                g = 0,
                b = 0;

            if (item.id === _consts.ROOT_ID) return;

            if (_color.startsWith("rgb")) {
                var rgb = _color.substring(4, _color.length - 1)
                    .replace(/ /g, '')
                    .split(',');
                r = rgb[0];
                g = rgb[1];
                b = rgb[2];
            } else if (_color.startsWith("#")) {
                var result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(_color);
                r = parseInt(result[1], 16);
                g = parseInt(result[2], 16);
                b = parseInt(result[3], 16);
            } else {
                return;
            }

            var _newR = Math.floor((10 + _counter) * r / 10) <= 255 ? Math.floor((10 + _counter) * r / 10) : 255;
            var _newG = Math.floor((10 + _counter) * g / 10) <= 255 ? Math.floor((10 + _counter) * g / 10) : 255;
            var _newB = Math.floor((10 + _counter) * b / 10) <= 255 ? Math.floor((10 + _counter) * b / 10) : 255;

            color = "rgb(" + _newR + "," + _newG + "," + _newB + ")";
            _counter++;

            return { background: color };
        }

        var _initializeAnalysis = function (container) {
            _updateAnalysis(container);
        };

        var _updateAnalysis = function (container) {
            if (_page) {
                _page.destructor();
            }

            var panel = container.component.down('#TemplatePanel'),
                body = panel.getBody();

            _color = container.templateParameters["Color"];

            _container = document.getElementById(body.id);


            var isEmptyTreeMap = !container.data.find(d => d.Value > 0);

            if (isEmptyTreeMap) {

                webix.ready(function () {
                    _page = webix.ui({
                        container: _container,
                        view: "template",
                        type: "clean",
                        borderless: true,
                        padding: 0,
                        template: _getTemplateFromParam(container, 'EmptyTemplate', {})
                    });
                });

            } else {

                _dataSource = _buildDataSource(container);

                webix.ready(function () {
                    _page = webix.ui({
                        view: "treemap",
                        container: _container,
                        type: {
                            cssClass: me.getColorPattern
                        },
                        tooltip: function (obj) {
                            var templateObject = {
                                Object: {
                                    value: obj.value,
                                    label: obj.label
                                }
                            };
                            var template = _getTemplateFromParam(container, 'TooltipTemplate', templateObject)
                            return template;
                        },
                        css: "TreeMap",
                        width: parseInt(_container.style.width) - 15,
                        height: parseInt(_container.style.height) - 10,
                        select: false,
                        borderless: true,
                        template: function (item) {
                            return item.label || "";
                        },
                        value: "#value#",
                        data: _dataSource
                    });
                });
            }
        };

        // public (overrides)
        me.initializeAnalysis = _initializeAnalysis;
        me.updateAnalysis = _updateAnalysis;
        me.getColorPattern = _getColorPattern;
    },
})
