Ext.define("Portal.Controls.ObjectLinkMulti", {

    extend: 'Ext.form.field.Text',

    alias: 'widget.objectlinkmulti',

    loading: false,

    pendingValue: null,

    initializing: true,

    selectedObjects: null,

    emptyText: translations.WSC_ObjectLinkMulti_NoElementSelectedPlaceholder,

    fieldTypeCls: 'objectlink-multi-field',

    config: {

        entity: "",

        searchFilters: [],

        searchFiltersJson: "",

        searchViewID: "Default",

        selectionViewID: "Default",

        dataResolutionUrl: "",

        maxVisibleDescriptions: 3,

        maxSelectableItems: 50
    },

    privates: {

        updateButtonsVisibility: function (forcedVisibility) {
            if (!this.rendered) return;

            _.each(this.rightButtons, function (btn) {
                var visible =
                    _.isUndefined(forcedVisibility) ?
                        btn.visibilityFn && btn.visibilityFn() :
                        forcedVisibility;

                btn[visible ? 'show' : 'hide']();
            });
        },

        buildInputDisplayValue: function (value) {
            if (!value) return '';

            var count = value.split(Portal.Const.ARRAY_SEPARATOR).length;

            if (count <= this.getMaxVisibleDescriptions() && this.selectedObjects && this.selectedObjects.length > 0) {

                return this.buildObjectDescriptions();

            } else {

                if (count === 1) {
                    return translations.WSC_ObjectLinkMulti_1ElementSelected;
                } else {
                    return translations.WSC_ObjectLinkMulti_MoreElementsSelected.replace("{0}", count);
                }
            }

        },

        getViewableObjectDescriptions: function () {
            return _
                .chain(this.selectedObjects)
                .sortBy('ObjectDescription')
                .map('ObjectDescription')
                .first(this.getMaxVisibleDescriptions())
                .value();
        },

        buildObjectDescriptions: function () {
            var objDescriptions =
                _.reduce(
                    this.getViewableObjectDescriptions(),
                    function (fullDesc, objDesc) { return fullDesc + ', ' + objDesc; });

            return objDescriptions;
        },

        loadObjectData: function (value) {
            var me = this;

            var promise = new Promise(function (resolve, reject) {
               
                Portal.WSC.OperationManager.request({
                    method: 'GET',
                    url: me.getDataResolutionUrl(),
                    params: {
                        ids: value,
                        entity: me.getEntity()
                    },
                    successFn: function (response) {
                        resolve(response.data);
                    },
                    failureFn: function (response) {
                        reject(response);
                    }
                });

            });

            return promise;
        },

        checkControlInitialization: function () {
            if (this.initializing) {
                this.resetDirty();
                this.initializing = false;
            }
        },

        setupOnClick: function () {
            var me = this;

            if (me.inputEl) {
                me.inputEl.on('click', function (e, target) {
                    me.expand();
                });
            }
        },

        clearInternal: function () {
            this.pendingValue = null;
            this.loading = false;
            this.isInitializing = false;
            this.selectedObjects = null;

            this.superclass.clear.call(this);
        },

        checkEmptyCls: function () {
            if (!this.isEmpty())
                this.removeCls(this.emptyCls);
            else
                this.addCls(this.emptyCls);
        }
    },

    /* --------------------- OVERRIDES --------------------- */

    initComponent: function (cfg) {
        var me = this;

        if (this.getSearchFiltersJson()) {
            this.setSearchFilters(Portal.Util.Json.decode(me.searchFiltersJson));
        }

        me.clearButton = {
            handler: function () {
                me.clear();
            },
            xtype: 'button',
            itemId: 'clearbutton',
            iconCls: 'icon-clear',
            id: me.id + '_clearButton',
            cls: 'clear-btn',
            tooltip: translations.WSC_ObjectLinkMulti_RightButtons_Clear,
            visibilityFn: function () {
                return !me.readOnly && !me.isEmpty();
            }
        };

        me.expandButton = {
            handler: function () {
                me.expand();
            },
            xtype: 'button',
            itemId: 'expandButton',
            iconCls: 'icon-open',
            id: me.id + '_expandButton',
            cls: 'expandButton-btn',
            tooltip: translations.WSC_ObjectLinkMulti_RightButtons_Expand,
            visibilityFn: function () {
                return !(me.readOnly && me.isEmpty());
            }
        };

        Ext.apply(me, {
            rightButtons: [me.clearButton, me.expandButton]
        });

        me.on('afterrender', function () {
            me.setupOnClick(me);

            Ext.each(me.rightButtons,
                function (item) {
                    switch (item.itemId) {
                        case 'expandButton':
                            me.expandButton = item;
                            break;
                        case 'clearbutton':
                            me.clearButton = item;
                    }
                }
            );

            this.updateButtonsVisibility();
        });

        me.callParent();

        this.checkEmptyCls();

    },

    // retrieves data to be applied to the input html tpl (initial markup rendering)
    getSubTplData: function (fieldData) {
       
        var subTplData = this.callParent(arguments);

        // we want the input element to be readonly
        subTplData.readOnly = true;

        // we want to write the display value inside the input element (not the selected ids array)
        subTplData.value = this.buildInputDisplayValue(this.getRawValue());

        return subTplData;
    },

    setValue: function (value) {

        var me = this;
        
        if (value) {

            // distinct and sort applied to IDs to avoid unwanted 'change'
            var IDs = Portal.Util.Array.uniqueAndSorted(value.split(Portal.Const.ARRAY_SEPARATOR));

            // validate IDs
            if (IDs.length > this.getMaxSelectableItems()) {
                var msg = translations['Portal_ObjectLinkMulti_NotAllowed_MaxSelectableItems'];

                msg = msg || 'It\'s not allowed to select more than { MaxSelectableItems } items.';

                Portal.Util.Msg.showErrorToastMsg(msg.format({ MaxSelectableItems: this.getMaxSelectableItems() }));

                return;
            }

            value = IDs.join(Portal.Const.ARRAY_SEPARATOR);
            me.loading = true;
            me.pendingValue = value;

            this.loadObjectData(value)
                .then(function (objects) {
                    
                    me.loading = false;
                    me.pendingValue = null;
                    me.selectedObjects = objects;

                    // TODO - OBJLINK MULTI - ID RESOLUTION - HANDLE OBJECT NOT VISIBLE
                    var selectedObjectIDs = _.map(objects, function (obj) { return obj.ID; });

                    value = selectedObjectIDs.join(Portal.Const.ARRAY_SEPARATOR);

                    me.superclass.setValue.call(me, value);

                    var initialized = !me.initializing;

                    me.checkControlInitialization();

                    me.fireEvent('valueresolved', me, value, me.selectedObjects, initialized);

                })
                .catch(function (response) {
                    
                    me.loading = false;
                    me.pendingValue = null;
                    me.selectedObjects = null;

                    me.superclass.setValue.call(me, value);

                    me.checkControlInitialization();

                    var errorCode = '';
                    var errorDesc = '';

                    if (response.result) {
                        errorCode = response.result.code;
                        errorDesc = response.result.desc;
                    }

                    me.fireEvent('valueresolutionerror', me, errorCode, errorDesc);

                    Portal.Console.error([
                        'ObjectLinkMulti',
                        me.getName(), 
                        me.getEntity(), 
                        'Load object data error [Value=' + value + '|ErrorCode=' + errorCode + '|ErrorDesc=' + errorDesc + ']'
                    ]);

                });

        } else {

            this.callParent([value]);

            this.selectedObjects = null;

            this.checkControlInitialization();
        }
    },

    // Implementation from:
    // https://docs.sencha.com/extjs/5.1.1/api/src/Base.js.html#Ext.form.field.Base-method-setRawValue
    setRawValue: function (value) {
        var me = this,
            rawValue = me.rawValue;

        if (!me.transformRawValue.$nullFn) {
            value = me.transformRawValue(value);
        }

        value = Ext.valueFrom(value, '');

        // We always need to go ahead with the set if valueContainsPlaceholder 
        // TODO: Remobve this when IE8 retires and we can use HTML5 placeholder everywhere. 

        // ORIGINAL CODE
        //if (rawValue === undefined || rawValue !== value || me.valueContainsPlaceholder) {
        if (rawValue === undefined || rawValue !== value || me.valueContainsPlaceholder || me.initializing) {
            me.rawValue = value;

            // Some Field subclasses may not render an inputEl 
            if (me.inputEl) {
                me.bindChangeEvents(false);

                // ORIGINAL CODE
                //me.inputEl.dom.value = value;
                me.inputEl.dom.value = me.buildInputDisplayValue(value);

                me.bindChangeEvents(true);
            }

            if (me.rendered && me.reference) {
                me.publishState('rawValue', value);
            }
        }

        return value;
    },

    getValue: function () {
        if (this.pendingValue !== null)
            return this.pendingValue;

        return this.callParent();
    },

    getRawValue: function () {
        var me = this,
            v = Ext.valueFrom(me.rawValue || me.value, '');
        me.rawValue = v;
        return v;
    },

    setReadOnly: function (readOnly) {
        this.callParent(arguments);

        // we want the input element always to be readonly
        if (this.rendered) this.setReadOnlyAttr(true);

        this.updateButtonsVisibility();
    },

    clear: function () {
        var me = this;
        var value = this.getValue();
        
        if (!Portal.Util.isEmptyValue(value)) {

            if (value.split(Portal.Const.ARRAY_SEPARATOR).length > 1) {

                Portal.Util.Msg.confirmPromise(
                    translations['Portal_ObjectLinkMulti_ChangesConfirmTitle'],
                    translations['Portal_ObjectLinkMulti_ClearAllConfirm'])
                    .then(function () { me.clearInternal(); })
                    .catch(function () { /* do nothing */ });
            } else {
                me.clearInternal();
            }    
        }

    },

    onChange: function () {
        this.callParent(arguments);

        this.checkEmptyCls();

        this.updateButtonsVisibility();
    },


    /* --------------------- CUSTOM METHODS --------------------- */

    expand: function () {

        if (this.readOnly && this.isEmpty()) return;

        var filters = this.getSearchFilters() || [];
        
        Portal.PageManager.openModule({
            url: Router.action("ObjectLinkMulti", "SelectionView", {
                entity: this.getEntity(),
                originalSelectedID: this.getValue(),
                isReadOnly: this.readOnly,
                ctrlId: this.id,
                selectionViewID: this.getSelectionViewID(),
                searchViewID: this.getSearchViewID(),
                searchFilters: Portal.Util.Json.encode(filters),
                maxSelectableItems: this.getMaxSelectableItems()
            }),
            mode: 'window',
            parentContainer: this.getContext('Module')
        });

    },

    /*
   * Set the object link search filter.
   * The passed in filter will be merged with existing filters and passed to field value search.
   */
    setSearchFilter: function (newFilter) {
        Portal.Console.log(['ObjectLinkMulti', 'Set search filter', this.id, newFilter]);

        var filter = [];
        if (this.getSearchFilters()) filter = [].concat(this.getSearchFilters());

        if (!Ext.isArray(newFilter)) newFilter = [newFilter];

        filter = Portal.Util.mergeFilterArrays(newFilter, filter);

        if (filter) {
            this.setSearchFilters(filter);
        } 
    },

    isInitializing: function () {
        return this.initializing;
    },

    getDisplayValue: function () {
        var value = this.getValue();

        if (Portal.Util.isEmptyValue(value) || this.loading) return '';

        var viewableDescriptions =
            _.map(this.getViewableObjectDescriptions(),
                  function (objDesc) { return objDesc + ';'; });

        var hiddenDescriptionsCount = (this.selectedObjects.length - viewableDescriptions.length);

        if (hiddenDescriptionsCount > 0) {

            var msg = translations['Portal_ObjectLinkMulti_OtherItems'];
            msg = msg || 'Other {OtherItemsCount}';
            
            viewableDescriptions.push('... ' + msg.format({ OtherItemsCount: hiddenDescriptionsCount}));
        }

        return _.reduce(viewableDescriptions,
                        function (fullDesc, objDesc) { return fullDesc + '\n' + objDesc; });
    },

    isEmpty: function () {
        return Portal.Util.isEmptyValue(this.getValue());
    }
});
