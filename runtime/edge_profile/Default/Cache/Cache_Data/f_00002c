        // TODO - PAGE MANAGER - TRY TO MERGE MODULE CREATION AND PAGE CREATION LOGICS (THEY SHOULD BE THE SAME APART THE URL GENERATION)

        /********************************* TAB MODULE CONTAINER *********************************/

        var tabModuleContainerFactory = {

            /* module container factory interface */

            onBeforeCreate: function (cfg) {

