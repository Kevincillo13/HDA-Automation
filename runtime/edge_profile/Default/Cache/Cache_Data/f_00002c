        Show(node) {
            if (this.getRoot() && node) {

                //node.attributes["webix_e_id"] -> concat of event type and record id split by _
                //in futuro e da sistemare meglio
                var thisRoot = this.getRoot();
                var elementIDAttribute = node.attributes["webix_e_id"] || node.parentNode.attributes["webix_item_id"] || node.parentNode.attributes["webix_l_id"];

                if (!elementIDAttribute) {
                    thisRoot.show(node);
                    return;
                }

                // TODO MauroB: l'id dell'evento in HDA corrisponde all'objectID, mentre nel CRM 
                // corrisponde ad EntityTypeID_ObjectID. Standardizzare la cosa sfruttando l'informazione
                // contenuta nella property EntityType del modello ricevuto dal server rimuovendo la
                // concatenazione di id
                var elementID =
                    elementIDAttribute.value.indexOf("_") >= 0 ?
                        elementIDAttribute.value.split(/_(.*)/s)[1] :
                        elementIDAttribute.value;

                if (_getEntityData(_getEventEntity(elementID)).readonly) {
                    return;
                }

                var success = function (data) {
                    if (data.allowSync) {

                        $$(_itemIdPrefix + "SyncEventBtn").show();

                        var syncButton = $$(_itemIdPrefix + "SyncEventBtn"),
                            syncButtonView = syncButton.$view,
                            removeCls = data.synced ? "webix_scheduler_warning" : "webix_primary",
                            addCls = data.synced ? "webix_primary" : "webix_scheduler_warning",
                            tooltip = data.synced ? translations.WSC_SyncEventCalendar : translations.WSC_NotYetSyncEventCalendar;

                        webix.html.removeCss(syncButtonView, removeCls)
                        webix.html.addCss(syncButtonView, addCls);
                        syncButton.define("tooltip", tooltip)
                        syncButton.refresh();

                    } else {
                        $$(_itemIdPrefix + "SyncEventBtn").hide();
                    }

                    thisRoot.show(node);
                };

                var failure = function (error) {
                    Portal.Util.Msg.showErrorToastMsg(error);
                };

                if (_configuration.externalCalendarProviderConfigured) {
                    var url = Router.action("ExternalProviderServices", "CheckEventSync"),
                        params = { ElementID: elementID };

                    Portal.Util.Promises.ajaxPostPromise(url, params)
                        .then(success)
                        .catch(failure);

                } else {

                    success({ allowSync: false });
                }

            }
        };

