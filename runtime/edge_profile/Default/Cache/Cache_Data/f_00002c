        save: function (params) {
            if (params == null || params.templateID == null || params.templateID.Value == null || params.templateID.Value == "" || params.templateID.Value == "-1") {
                if (params != null && params.parentTemplateID != null && params.parentTemplateID.Value != null)
                    me.templateNew(params.parentTemplateID.Value);
                else
                    me.templateNew(null);

                me.listenToMessage({
                    topic: 'Portal.Template.Insert',
                    messageFilter: 'child',
                    listenerFn: function (msg) {
                        me.templateSave(msg.ID, true, true);
                    }
                });
