Ext.define('Portal.Controls.FlagComboBox', {

    extend: 'Ext.form.field.ComboBox',

    alias: 'widget.flagcombobox',

    fieldTypeCls: 'flagcombo-field',

    setValue: function (value) {

        var valueToSet = value;
        
        if (Ext.isString(value)) {
            valueToSet = this.parseStringValue(value.toLowerCase());

        } else if (Ext.isNumber(value)) {
            valueToSet = this.parseNumericValue(value * 1);
        }

        this.callParent([valueToSet]);
    },

    parseStringValue: function (value) {
        if (Ext.isNumeric(value)) {
            return this.parseNumericValue(value * 1);
        }

        var valueToSet;

        if (value == 'true') {
            valueToSet = true;
        } else if (value == 'false') {
            valueToSet = false;
        }

        return valueToSet;
    },

    parseNumericValue: function (value) {
        var valueToSet;

        if (value == 1) {
            valueToSet = true;
        } else if (value == 0) {
            valueToSet = false;
        }

        return valueToSet;
    }

});
