Ext.define('Portal.Controls.PowerFinderDataView', {
    extend: 'Ext.view.View',
    alias: 'widget.powerfinderdataview',

    /* Properties */
    entity: null,
    detailMode: 'none',
    anchorMode: 'window',

    constructor: function (config) { var me = this; me.callParent(arguments); },

    /* Component Initialization */
    initComponent: function () {
        var me = this;
        me.callParent(arguments);

        me.entity = me.initialConfig.entity;
        me.detailMode = me.initialConfig.detailMode;

        me.anchorMode = me.detailMode === 'window' ? 'window' : me.initialConfig.anchorMode;

        me.configureDetailMode(me.detailMode);

        me.on('select', function (view, record, index, eOpts) {
            if (me.selectHandler) me.selectHandler(record);
        });
        me.on('deselect', function (view, record, eOpts) {
            if (me.deselectHandler) me.deselectHandler(record);
        });
    },

    configureDetailMode: function (detailMode) {
        var me = this;

        switch (detailMode) {

            case 'none':
                break;

            case 'inline':
                var cmpView = me.getPlugin('HTMLPreview');
                cmpView.on('beforecomponentbind', function () { me.componentView.onBeforeComponentBind.apply(me, arguments); });
                cmpView.on('componentbind', function () { me.componentView.onComponentBind.apply(me, arguments); });

                me.selectHandler = function (record) {

                    var cmp = record.get('pfModel');

                    if (cmp.collapsed) {
                        cmp.expand();
                    } else {
                        cmp.collapse();
                        me.updateLayout();
                    }

                    if (Portal.AccessibilityNavigationManager) {
                        const links = cmp.el.dom.querySelectorAll("a");
                        links.forEach(x => {
                            if (!x.getAttribute("tabIndex") || x.getAttribute("tabIndex") == '-1') {
                                x.setAttribute("tabIndex", 0);
                            }
                        })

                        Portal.AccessibilityNavigationManager.setDomElementsNavigation();
                    }
                };
                break;

            case 'window':
            case 'tab':
                me.selectHandler = function (record) {

                    var entity = record.data.Object,
                        id = record.data.ObjectID;

                    Portal.PageManager.openModule({
                        url: Router.action("WSCView", "HTMLPreview"),
                        mode: detailMode,
                        params: { entity: entity, id: id, anchorMode: me.anchorMode },
                        title: translations['WSC_Detail']
                    });

                };
                break;

            default:
                break;
        }
    },

    selectHandler: null,
    
    componentView: {

        onBeforeComponentBind: function (plugin, item, component, record, node, target, index, view) {

            var me = this;

            switch (item.boundField) {

                case 'HTMLAbstract':

                    var entity = record.data.Object,
                        id = record.data.ObjectID;

                    var loaderCfg = {
                        url: Router.action("WSCView", "HTMLPreview", { entity: entity, id: id, anchorMode: me.anchorMode })
                    };

                    Ext.apply(component.loader, loaderCfg);
                    
                    break;
            }
            
        },

        onComponentBind: function (plugin, item, component, record, node, index, view) {
            record.set('pfModel', component, { silent: true, dirty: false });
        }
        
    },

    deselectHandler: function (record) {
        var cmp = record.get('pfModel');
        if (cmp && !cmp.collapsed) {
            cmp.collapse();
            this.updateLayout();
        }
    }

});
