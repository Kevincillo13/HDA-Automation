Ext.define('Portal.Controls.SlidingGroupsManager', {

    singleton: true,

    slidingGroups: {},

    privates: {

        createSlidingGroup: function (groupName) {
            return new Ext.util.Collection({
                filters: {
                    filterFn: function (item) {
                        return item.visibilityStatus === 'visible';
                    }
                }
            });
        }

    },

    register: function (slidingPanel, groupName) {

        if (!this.slidingGroups[groupName]) {
            this.slidingGroups[groupName] = this.createSlidingGroup(groupName);
        }

        this.slidingGroups[groupName].add(slidingPanel);

        slidingPanel.on(
            'beforeshow',
            function () {

                var visiblePanel = this.getVisibleItem(groupName);
                    
                if (!visiblePanel || visiblePanel.alwaysOnTop) return true;

                // there is an active panel on the specified group
                // close the active panel and wait it is closing before showing the new panel
                visiblePanel.on(
                    'beforeVisibilityOut',
                    function () {
                        slidingPanel.show();
                    },
                    this,
                    { single: true });

                visiblePanel.groupTopmost = false;
                visiblePanel.close();

                return false;
            },
            this);

        slidingPanel.on(
            'visibilityIn',
            function () { 
                slidingPanel.groupTopmost = true;
                this.slidingGroups[groupName].itemChanged(slidingPanel); 
            },
            this);

        slidingPanel.on(
            'beforeVisibilityOut',
            function () { 
                this.slidingGroups[groupName].itemChanged(slidingPanel); 
            },
            this);

        slidingPanel.on(
            'visibilityOut',
            function () {
                slidingPanel.groupTopmost = false;
            },
            this);

        slidingPanel.on(
            'destroy',
            function () { 
                this.unregister(slidingPanel, groupName); 
            },
            this);

    },
    
    unregister: function (slidingPanel, groupName) {
        this.slidingGroups[groupName].remove(slidingPanel);
    },

    getVisibleItem: function (groupName) {
        return this.slidingGroups[groupName] && this.slidingGroups[groupName].last();
    }
    
});
Ext.ns('Portal.Controls');

