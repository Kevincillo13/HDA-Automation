        if (!params.pagingToolbar) return;

        var tb = params.pagingToolbar;

        if (params.infiniteScrollingEnabled) {

            // hide page navigation buttons, labels, inputs, ...
            var itemsToHide = ['first', 'prev', 'next', 'last', 'inputItem', 'afterTextItem', 'lblPageSize', 'ComboPageSize'];
            _.each(itemsToHide, function (itemID) {
                var item = tb.down('#' + itemID);
                if (item) item.hide();
            });

            // hide remaining labels (except the total one)
            var extraLabelsToHide = _.filter(tb.query('tbtext'), function (item) { return Ext.isEmpty(item.itemId); });
            if (!Ext.isEmpty(extraLabelsToHide)) {
                _.each(extraLabelsToHide, function (extraLabelToHide) {
                    extraLabelToHide.hide();
                });
            }

            // setup a new tpl for the total message
            var displayMsg = '({2})';
            if (params.collectionName)
                displayMsg = params.collectionName + ' ' + displayMsg;

            tb.displayMsg = displayMsg;
        }


    }

