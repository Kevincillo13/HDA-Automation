/* RuleManager, manage rule firing */
Portal.RuleManager = function (ctx) {

    var ruleSets = {},
        actionObject = {},
        disabledRules = [];

    loadRules = function (data) {

        _.each(data.Actions, function (action) {

            var actionConstructor = Portal.RuleImplementationFactory.getAction(action.ActionType);

            if (actionConstructor) {

                actionObject[action.ID] = action;

                if (!Ext.isEmpty(action.Action)) action.Action = Ext.util.JSON.decode(action.Action);
                action.handler = actionConstructor.apply(this, [action.Action, ctx, action]);

                if (action.handler) actionObject[action.ID] = action;
                else Portal.Console.log('ActionHandler ' + action.ActionType + ' bad configured');

            } else Portal.Console.log('ActionType ' + action.ActionType + ' Not found, load implementation detail');

        });

        ruleSets = _.chain(data.RuleSets)
                    .map(function (item) { item.rules = []; return item; })
                    .indexBy('ID')
                    .value();

        _.chain(data.Rules)
         .sortBy(function (rule) { return -rule.Salience; }) // Descending Order
         .each(function (rule) {

             // Evaluate Condition Implementation
             var conditionConstructor = Portal.RuleImplementationFactory.getCondition(rule.ConditionType);

             if (!_.isEmpty(rule.Condition)) rule.Condition = Ext.util.JSON.decode(rule.Condition);

             if (conditionConstructor) {
                 rule.handler = conditionConstructor.apply(this, [rule, ctx]);
             }

             // Evaluate Action Implementation
             rule.action = actionObject[rule.RuleActionID];

             if (!_.isUndefined(rule.action) && !_.isUndefined(rule.handler)) {
                 // Add to List
                 ruleSets[rule.RuleSetID].rules.push(rule);
             } else {
                 disabledRules.push(rule);
             }

         });

    };

    function applyData(ruleset, data) {
        var currentActions = [];

        //Single Rule Condition Evaluation
        function evaluateSingleCondition(rule) {

            var promise = new RSVP.Promise(function (resolve, reject) {

                var conditionResult = null;

                if (!_.contains(currentActions, rule.RuleActionID)) {

                    var rejectHelper = function (e) {
                        reject({ rule: rule, e: e, data: data });
                    },
                    resolveHelper = function (conditionResult) {
                        resolve({ rule: rule, value: conditionResult, data: data });
                    };

                    try {                        
                        rule.handler(data, resolveHelper, rejectHelper);
                    } catch (e) {
                        Portal.Console.error(['Rule', 'RuleID:' + rule.ID, 'Error while evaluating Condition', e.message, e.stack, rule, data]);
                        rejectHelper(e);
                    }
                }

            });
            return promise;
        }

        function evaluateAction(action) {

            var promise = new RSVP.Promise(function (resolve, reject) {

                var rejectHelper = function (e) {
                    reject({ action: action, e: e, data: data });
                },
                resolveHelper = function () {
                    resolve({ action: action, data: data });
                };

                try {                                               
                        action.handler(data, resolveHelper, rejectHelper);
                    } catch (e) {
                        //Portal.Console.error(['Rule', 'RuleID:' + rule.ID, 'Error while evaluating Condition', e.message, e.stack, rule, data]);
                        rejectHelper(e);
                    }               
            });
            return promise;
        }

        //RuleSet Condition Strategy
        var rules = _.sortBy(ruleset.rules, function (rule) { return -rule.Salience; });        

        //var subscription = Rx.Observable.from(rules).flatMap(evaluateSingleCondition)
        //    .filter(function (item) { return item.value; })
        //    .distinctUntilChanged(function (item) { return item.rule.ActionID; })
        //    .subscribe(
        //    function (x) {
        //        console.log('Next: ' + x);
        //    },
        //    function (err) { console.log('Error: ' + err); },
        //    function () { console.log('Completed'); });
        //return;

        var source = Rx.Observable.from(rules).flatMap(evaluateSingleCondition)
          .filter(function (item) {
              return item.value;
          })
          .distinctUntilChanged(function (item) {
              return item.rule.RuleActionID;
          });

        switch (ruleset.MatchType) {
            case 'FirstMatch':              
                source = source.first();
                break;
        }

        //source.subscribe(
        //function (x) {
        //    console.log('Next: ' + x);
        //},
        //function (err) { console.log('Error: ' + err); },
        //function () { console.log('Completed'); });

        source = source
                .map(function (item) { return item.rule.action; })
                .flatMap(evaluateAction);

        var subscription = source.subscribe(
          function (x) {                            
              Portal.Console.log(['RuleAction', x.action.ActionType, x.action.ID].concat(_.values(x)));
          },
          function (e) {
              Portal.Console.error(['Rule'].concat(_.values(e)));
          },
          function () {              
              //console.log('onCompleted');
          });

    }

    function evaluateRules(data) {

        _.chain(ruleSets)
         .filter(function (item) { return !_.isEmpty(item.rules); })
         .each(function (ruleset) {
             applyData(ruleset, data);
         });
    }

    function performActions(actions, data) {

        if (_.isEmpty(actions)) return;
        if (!_.isArray(actions)) actions = [actions];

        _.each(actions, function (action) {
            try {
                action.handler(data);
            } catch (e) {
                Portal.Console.error(['Rule','Error while evaluating RuleActionID:' + action.ID, e.message, e.stack, data]);
            }
        });

    }


    return {
        loadRules: loadRules,
        evaluateRules: evaluateRules,
        performActions: performActions,
        getDisabledRule: function () { return disabledRules; }
    }
};


