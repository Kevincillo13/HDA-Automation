Ext.define('Portal.Controls.LoadMask', {

    extend: 'Ext.LoadMask',

    componentCls: 'load-mask',

    config: {

        msg: '',

        contentCls: 'loading',

        buttons: [],

        autoDismiss: false,

        autoDismissTimeout: 0,

        alwaysOnTop: true
    },

    statics: {

        messageTpl: new Ext.XTemplate(
            '<div class="mask-content {contentCls}">',
                '<div class="mask-icon"></div>',
                '<div class="mask-message">{msg}</div>',
                '<tpl if="buttons.length &gt; 0">',
                    '<div class="mask-buttons toolbar">',
                        '<tpl for="buttons">',
                            '<div class="btn {cls}" data-action="{action}" onClick="Portal.Controls.LoadMask.handleButtonAction(this);">',
                                '{text}',
                                '<tpl if="values.default && parent.autoDismissRemainingSeconds">',
                                    '&nbsp;',
                                    '<span class="auto-dismiss-ct">(<span class="auto-dismiss-count">{parent.autoDismissRemainingSeconds}</span>)</span>',
                                '</tpl>',
                            '</div> ',
                        '</tpl>',
                    '</div>',
                '</tpl>',
            '</div>'
        ),

        handleButtonAction: function (el) {
            var mask = Ext.fly(el).up('.load-mask');
            if (!mask || !mask.component) return;

            mask.component.handleButtonAction(el.dataset.action);
        },

        DEFAULT_AUTODISMISS_TIMEOUT: 5000
    },

    privates: {

        getMsgHtml: function () {

            return this.statics().messageTpl.apply({
                msg: this.msg,
                contentCls: this.getContentCls(),
                buttons: this.getButtons(),
                autoDismissRemainingSeconds: this.autoDismissRemainingSeconds
            });
        },

        refresh: function () {
            if (this.isVisible())
                this.afterShow();
        },

        ensureOnTop: function () {
            if (Ext.WindowManager.getActive()) {
                this.el.setZIndex(Ext.WindowManager.getActive().el.getZIndex() + 1);
            }
        },

        startAutoDismissCountdown: function () {
            this.autoDismissCountdownTask = Ext.util.TaskManager.start({
                interval: 1000,
                fireOnStart: false,
                scope: this,
                run: function () {

                    this.autoDismissRemainingSeconds--;

                    if (this.autoDismissRemainingSeconds === 0) {

                        this.callDefaultAction();
                        this.stopAutoDismissCountdown();

                    } else {
                        this.el.down('.auto-dismiss-count').setHtml(this.autoDismissRemainingSeconds);
                    }
                }
            });
        },

        stopAutoDismissCountdown: function () {
            if (this.autoDismissCountdownTask) {
                this.autoDismissRemainingSeconds = 0;
                this.autoDismissCountdownTask.stopForced = true;
                Ext.util.TaskManager.stop(this.autoDismissCountdownTask);
            }
        },

        callDefaultAction: function () {
            var defaultButton = _.findWhere(this.buttons, { default: true });

            if (defaultButton) {
                this.handleButtonAction(defaultButton.action);
            }
        },

        hideTask: null,

        autoDismissCountdownTask: null,

        autoDismissRemainingSeconds: 0,

    },

    initComponent: function () {

        this.hideTask = new Ext.util.DelayedTask(function () {
            this.superclass.hide.call(this);
        });

        this.callParent(arguments);
    },

    setAutoDismissTimeout: function (timeout) {

        this.stopAutoDismissCountdown();

        this.autoDismissTimeout = timeout;
        this.autoDismissRemainingSeconds = Math.floor(timeout / 1000);

        if (timeout > 0) {
            this.startAutoDismissCountdown();
        }
    },

    setButtons: function (buttons) {
