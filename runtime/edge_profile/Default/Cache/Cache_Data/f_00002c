        // Create a delayed task that delays signalR notifications to a maximum of 'maxWaitTime' and then shows them.
        // delayIfNotElapsed: start/delay the task.
        // refreshIfPending: refresh the list if a refresh is pending.
        newSignalRRefreshTask: function (moduleContext, type, id, showNotif, entityDescription) {
            var thisTsk = null;
            return {

                moduleCtx: moduleContext,
                refreshPending: false,
                taskDelay: 30000,
                maxWaitTime: 90000,
                startDate: null,

                task: new Ext.util.DelayedTask(function (type, id, showNotif) {

                    var tabActive = (thisTsk.moduleCtx && thisTsk.moduleCtx.isTabActive()) ? true : false;

                    if (tabActive) {
                        me.refreshList();
                        thisTsk.refreshPending = false;
                    } else {
                        thisTsk.refreshPending = true;
                    }

                    if (showNotif)
                        Portal.Util.Msg.showToastMsg({
                            msg: Ext.String.format(translations['WSC_NewObjectOnInbox'], entityDescription, id),
                            queue: "rightbottom",
                            delay: 5000
                        });

                    thisTsk.startDate = null;

                }),

                delayIfNotElapsed: function (params) {
                    if (!thisTsk)
                        thisTsk = this;
                    if (!thisTsk.startDate)
                        thisTsk.startDate = new Date();
                    if ((new Date() - thisTsk.startDate) < thisTsk.maxWaitTime)
                        thisTsk.task.delay(thisTsk.taskDelay, null, null, params);
                },

                refreshIfPending: function () {
                    if (thisTsk && thisTsk.refreshPending) {
                        me.refreshList();
                        thisTsk.refreshPending = false;
                        thisTsk.startDate = null;
                    }
                }

            }

