        activatePage: function (pageID) {

            var navTree = me.component.down('#PagesTree');
            var pinnedPages = me.component.down('#PinnedPages');

            if (navTree) {

                var record = navTree.store.getById(pageID);
                var model = navTree.getSelectionModel();
                model.select(record);

            } else if (pinnedPages) {

                var tab = pinnedPages.items.findBy(function (a) { return a.itemId === pageID });
                pinnedPages.setActiveTab(tab);

            } else {

                me.component.down("[id$='DetailPagesCard']").getLayout().setActiveItem(pageID);
            }
        },

        promises: {

            validate: function () {

                return new Promise(function (resolve, reject) {

                    var data = me.currentStatus();

                    _promiseValidator
                        .validate(data)
                        .then(function () {
                            resolve();
                        })
                        .catch(function (errors) {
                            _formErrorsViewer.showErrors(errors);

                            // get first error field
                            var error = errors ? errors[0] : null,
                                field = error ? error.config.field : null,
                                fieldPage = me.getComponentMainDetailPage(field),
                                focusElement = field ? field.getFocusEl() : null;

                            // move to field page
                            if (fieldPage) {
                                me.activatePage(fieldPage.pageID);
                            }

                            // focus on error field
                            if (focusElement) {
                                focusElement.dom.focus();
                            }

                            reject(errors);
                        });
                });
            }
        }

    };
};
