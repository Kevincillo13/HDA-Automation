Ext.define('Portal.Controls.UploadHelper', {

    singleton: true,

    fileExtensionFilterTypes: {
        Include: 'Include',
        Exclude: 'Exclude',
        None: 'None'
    },

    getUploadErrorMessage: function (uploaderControl, err) {
        var uploader = uploaderControl.uploader;
        var fileName = err.file ? err.file.name : '';
        var errorMsg = translations['Msg_Attachments_GenericError'];

        switch (err.code) {

            case plupload.FILE_SIZE_ERROR:
                errorMsg = Ext.String.format(translations['Msg_Attachments_WrongFileSize'], uploader.getOption('filters').max_file_size);
                break;

            case plupload.FILE_EXTENSION_ERROR:
                errorMsg = translations['Msg_Attachments_WrongFileType'];
                break;

            default:

                if (err.status == 400) {

                    switch (err.response) {

                        case 'ERR_UPLOAD_BAD_FILENAME':
                            errorMsg = translations['Msg_Attachments_WrongFileName'];
                            break;

                        case 'ERR_UPLOAD_BAD_EXTENSION':
                            errorMsg = translations['Msg_Attachments_WrongFileType'];
                            break;

                        case 'ERR_UPLOAD_BAD_SIZE':
                            //IE9 File size server side check
                            errorMsg = Ext.String.format(translations['Msg_Attachments_WrongFileSize'], uploader.getOption('filters').max_file_size);
                            break;
                    }
                }
        }

        if (fileName !== '')
            errorMsg = [
                '<b>',
                Portal.Util.htmlEncode(fileName),
                '</b>',
                '<br>',
                errorMsg
            ].join('');

        return errorMsg;
    },

    buildFileFilters: function (uploadControl) {
        // Create File Filters
        var fileFilters = {};

        // Configure File Size Filter
        fileFilters.max_file_size = uploadControl.maxFileSize;

        // Configure File Extension Filter
        if (uploadControl.fileExtensionFilter) {

            var filterValue = uploadControl.fileExtensionFilter.replace(/\|/g, ',');

            switch (uploadControl.fileExtensionFilterType) {

                case this.fileExtensionFilterTypes.Include:
                    fileFilters.mime_types = [{ title: "Files", extensions: filterValue }];
                    break;

                case this.fileExtensionFilterTypes.Exclude:
                    fileFilters.mime_types_exclude = filterValue;
                    break;

            }

        }

        return fileFilters;
    }
});
