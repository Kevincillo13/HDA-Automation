Ext.apply(Portal.Filters.FilterAreaContext.Utils, {

    /* Privates */

    _filterMatcher: null,

    _matchFiltersByPropertyOperator: function (filterField, filterObj) {
        return (
            filterField.getName() === filterObj.property &&
            filterField.filterOperator === filterObj.op
        );
    },

    _matchFiltersByPropertyOperatorFEK: function (filterField, filterObj) {
        return (
            this._matchFiltersByPropertyOperator(filterField, filterObj) &&
            /*MauroB : compare extKey with == to match null and undefined... refactor to check value existance before.. */
            filterField.filterExtensionKey == filterObj.extKey
        );
    },

    /* Public */

    setFieldValueFromFilter: function (field, filter) {

        var value = filter.value;

        if (field.xtype === "datefield") {
            value = Ext.isDate(value) ? value : Portal.Util.Json.getDateFromJson(value);
        }

        if (field.xtype !== "displayfield") {

            field.setValue(value);

            if (!Portal.Util.isEmptyValue(value) && field.triggers && field.triggers.clear) {
                field.triggers.clear.show();
            }
        }
    },

    buildFilterFromField: function (field) {
        return Portal.FiltersUtil.buildFilterFromField(field);
    },

    buildFilterFromProperties: function (name, value, op, extKey) {
        return Portal.FiltersUtil.buildFilterFromProperties(name, value, op, extKey);
    },

    getFilterMatcher: function () {
        var me = this;

        if (!me._filterMatcher) {
            var fn =
                me.filterExtensionKeyMatching() ?
                    me._matchFiltersByPropertyOperatorFEK :
                    me._matchFiltersByPropertyOperator;

            me._filterMatcher = function () { return fn.apply(me, arguments); };
        }

        return me._filterMatcher;
    },

    /* Overridables */

    canSetFilterExtensionKey: function (filter, control) {
        return false;
    },

    filterExtensionKeyMatching: function () {
        // include filter extension key when matching filters
        return true;
    },

    getFilterIndicatorMode: function () {
        return (Portal.Const.Device.IsMobile ? 'removable_filters' : 'none');
    }

});
