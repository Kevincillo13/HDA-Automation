    * - SourceFilter: the filter object to use to resolve source control once target has been selected
    * - SkipOnFirstLoad: do not apply dependency on first value load;
    * - AutoResolve {TwoWay|Source|Target|None[Default]}: auto-select target after source value changed when target search returns only one item;
    * - TargetWithRelationOnly {True[Default]|False}: if True makes target control be ALWAYS filtered by ObjectRelationTypeID, otherwise the filter by relation will be applied only if source control has value;
    */
    filterObjectLinkRelationed: function (sourceControl, targetControl, params) {
        var context = {
            sourceControl: sourceControl,
            targetControl: targetControl
        },

            sourceFieldName = sourceControl.name,

            targetFieldName = targetControl.name,

            objectRelationTypeID = (Ext.isDefined(params.ObjectRelationTypeID) && Ext.isDefined(params.ObjectRelationTypeID.Value) ? params.ObjectRelationTypeID.Value : ''),

            autoResolve = (Ext.isDefined(params.AutoResolve) && Ext.isDefined(params.AutoResolve.Value) ? params.AutoResolve.Value.toLowerCase() : 'none'),

            isSourceAutoResolve = (autoResolve == 'twoway' || autoResolve == 'source'),

            isTargetAutoResolve = (autoResolve == 'twoway' || autoResolve == 'target'),

            targetWithRelationOnly = (Ext.isDefined(params.TargetWithRelationOnly) && Ext.isDefined(params.TargetWithRelationOnly.Value) ? params.TargetWithRelationOnly.Value.toLowerCase() == 'true' : true),

            ensureObjectRelationFilter = function (filter) {
                if (!objectRelationTypeID) return;

                var objRelationFilter = _.findWhere(filter, { property: 'Relations.ObjectRelationTypeID' });
                if (!objRelationFilter) {
                    filter.push({ property: 'Relations.ObjectRelationTypeID', op: 'eq', value: objectRelationTypeID });
                }
            },

            prepareTargetFilter = function (filter, params) {
                if (Portal.Util.isEmptyValue(sourceControl.getValue())) {

                    // empty source value, check if we've to maintain filter on ObjectRelationType or not

                    if (!targetWithRelationOnly) {
                        // remove ObjectRelationTypeID filter
                        var objRelationFilter = _.findWhere(filter, { property: 'Relations.ObjectRelationTypeID' });
                        if (objRelationFilter) {
                            objRelationFilter.value = '';
                        }
                    }
                } else {
                    ensureObjectRelationFilter(filter);
                }
            },

            prepareSourceFilter = function (filter, params) {
                ensureObjectRelationFilter(filter);
            },

            // calculates the filter value and applies it to the target control
            applyTargetFilter = function () {
                var parsedParams = Portal.Util.buildParams(params, context);
                //Use this param (parsedParams.SourceFieldName) if sourceControlName is differend from the filtered field
                if (parsedParams.SourceFieldName) { sourceFieldName = parsedParams.SourceFieldName; }

                var filter = parsedParams.Filter || parsedParams.TargetFilter;

                if (!filter) return;

                prepareTargetFilter(filter, parsedParams);

                targetControl.setSearchFilter(filter);
            },

            performTargetAutoResolve = function (newValue, oldValue) {

                if (!isTargetAutoResolve && !targetControl.isMandatory()) return;

                // auto-resolve target only if source control is initialized and its value is not empty
                if (sourceControl.isInitializing() || Portal.Util.isEmptyValue(sourceControl.getValue())) return;

                // auto-resolve target only if source is not auto-resolving
                //if (sourceControl.isAutoResolving()) return;
                oldValue = (
                    (Ext.isArray(oldValue) && !Ext.isEmpty(oldValue)) ?
                        oldValue[0].get(this.valueField) :
                        Ext.isEmpty(oldValue) ?
                            Portal.Const.EMPTY_ID :
                            oldValue
                );

                newValue = (Ext.isEmpty(newValue) ? Portal.Const.EMPTY_ID : newValue);

                // auto-resolve target only if source value changed
                if (oldValue != newValue) targetControl.autoResolve();
                //}
            };

        // add a change listener to source control in order to manage source value change and apply filter to target control
        sourceControl.addListener('change', function (field, newValue, oldValue) {

            if (this.readOnly) return;

            // apply filter to targer control
            applyTargetFilter();

            performTargetAutoResolve(newValue, oldValue);
        });

        // apply target filter on form load event
        sourceControl.addListener('formload', function () {
            applyTargetFilter();
        }, null, { single: true });

        if (isSourceAutoResolve) {

            // add a listener to target control change event to apply related source control value if this is different from the current one
            targetControl.addListener('valueresolved', function (control, newValue, objDescription, initialized) {

                if (initialized) {

                    var parsedParams = Portal.Util.buildParams(params, context);

                    // apply source value
                    if (parsedParams.SourceFilter) {
                        prepareSourceFilter(parsedParams.SourceFilter, parsedParams);
                        sourceControl.autoResolve(parsedParams.SourceFilter);
                    }
                }

            });
        }

    },

    /**
    * Handles DateTime fields dependencies
    * Available parameters:
    *   - AllowEquals: allows target control value to be equal to starting control value
    *   - KeepDeltaTime: when changing the source value sets the target value while preserving the time difference
    *                    (delta time is stored in target control to allow multiple targets on one source control)
    */
    dateTimeRange: function (sourceControl, targetControl, params) {

        targetControl.validator = function (value) {
            return Portal.Date.rangeCheck(sourceControl, targetControl, params) ? true : translations['WSC_Msg_InvalidDateRange'];
        }

        if (params && params.KeepDeltaTime) {

            // set source control "change" event handler to apply filter to the target combo
            sourceControl.addListener('change', function () {

                // HACK MauroB: DateTimeField has not a beforeChange event nor a oldValue exposed in change event so delta
                // time is calculated for the first time using control's original values difference
                var totalOriginalTargetTime = Date.parse(targetControl.dateField.originalValue) + Date.parse(targetControl.timeField.originalValue),
                    totalOriginalSourceTime = Date.parse(sourceControl.dateField.originalValue) + Date.parse(sourceControl.timeField.originalValue),
                    newTargetDate;

                if (!totalOriginalTargetTime && targetControl.dateField.getValue() && targetControl.dateField.getValue() && targetControl.timeField.getValue()) {
                    totalOriginalTargetTime = Date.parse(targetControl.dateField.getValue()) + Date.parse(targetControl.timeField.getValue());
                }

                if (!totalOriginalSourceTime && sourceControl.dateField.getValue() && sourceControl.dateField.getValue() && sourceControl.timeField.getValue()) {
                    totalOriginalSourceTime = Date.parse(sourceControl.dateField.getValue()) + Date.parse(sourceControl.timeField.getValue());
                }

                if (!targetControl.deltaMillisecondsFromSource && totalOriginalSourceTime) {
                    if (totalOriginalTargetTime) {
                        targetControl.deltaMillisecondsFromSource = totalOriginalTargetTime - totalOriginalSourceTime;
                    }
                    else {
                        targetControl.deltaMillisecondsFromSource = 0;
                    }
                }

                if (sourceControl.getValue() && totalOriginalSourceTime) {
                    newTargetDate = new Date(sourceControl.getValue().setMilliseconds(targetControl.deltaMillisecondsFromSource));
                    targetControl.setValue(newTargetDate);
                }
            });

            // set target control "change" event handler to update delta time between controls
            targetControl.addListener('change', function () {
                if (sourceControl.getValue()) {
                    targetControl.deltaMillisecondsFromSource = targetControl.getValue() - sourceControl.getValue();
                }
            });
        }
    },

    // sets the target object value with the ObjectRelationTypeID value specified as parameter
    // when the source object has a not empty value
    updateObjectRelationType: function (sourceControl, targetControl, params) {

        var context = {
            sourceControl: sourceControl,
            targetControl: targetControl
        },
            parsedParams = Portal.Util.buildParams(params, context);

        sourceControl.addListener('change', function () {
            if (Ext.isEmpty(this.getValue())) {
                targetControl.setValue('');
            } else {
                targetControl.setValue(parsedParams.ObjectRelationTypeID);
            }
        });
    },

    // TODO - VERIFICARE SE UNIFICARE CON filterObjectLink - Riportata per retro-compatibilità
    // Rispetto a filterObjectLink quando si seleziona il target imposta il source solo se questo è vuoto
    accountToCostCenterDependency: function (sourceControl, targetControl, params) {

        var context = {
            sourceControl: sourceControl,
            targetControl: targetControl
        },

            sourceFieldName = sourceControl.name,

            targetFieldName = targetControl.name,

            autoResolve = (Ext.isDefined(params.AutoResolve) && Ext.isDefined(params.AutoResolve.Value) ? params.AutoResolve.Value.toLowerCase() : 'source'),

            isSourceAutoResolve = (autoResolve == 'twoway' || autoResolve == 'source'),

            isTargetAutoResolve = (autoResolve == 'twoway' || autoResolve == 'target'),

            // calculates the filter value and applies it to the target control
            applyTargetFilter = function () {
                var parsedParams = Portal.Util.buildParams(params, context);
                //Use this param (parsedParams.SourceFieldName) if sourceControlName is differend from the filtered field
                if (parsedParams.SourceFieldName) { sourceFieldName = parsedParams.SourceFieldName; }

                if (!parsedParams.Filter) { return; }

                targetControl.setSearchFilter(parsedParams.Filter);
            },

            // applies the specified value to the source control if it is different from the current one
            // and then applies the target filter according to the source control new value
            applySourceValue = function (v) {
                if (!sourceControl.getValue() || sourceControl.getValue() == "") {
                    sourceControl.setValue(v);
                }
            },

            getRealSourceFileName = function () {
                var realSourceFieldName = sourceFieldName;
                if (params != null && params.SourceFieldNameOnTargetObject && params.SourceFieldNameOnTargetObject.Value != "")
                    realSourceFieldName = params.SourceFieldNameOnTargetObject.Value;
                if (realSourceFieldName == null || realSourceFieldName == "")
                    realSourceFieldName = sourceFieldName;
                return realSourceFieldName;
            },

            performTargetAutoResolve = function (newValue, oldValue) {

                if (!isTargetAutoResolve && !targetControl.isMandatory()) return;

                // auto-resolve target only if source control is initialized and its value is not empty
                if (sourceControl.isInitializing() || Portal.Util.isEmptyValue(sourceControl.getValue())) return;

                oldValue = (
                    (Ext.isArray(oldValue) && !Ext.isEmpty(oldValue)) ?
                        oldValue[0].get(this.valueField) :
                        !Ext.isDefined(oldValue) || Ext.isEmpty(oldValue) ?
                            Portal.Const.EMPTY_ID :
                            oldValue
                );

                newValue = (!Ext.isDefined(newValue) || Ext.isEmpty(newValue) ? Portal.Const.EMPTY_ID : newValue);

                // auto-resolve target only if source value changed
                if (oldValue != newValue) targetControl.autoResolve();

            };

        // add a change listener to source control in order to manage source value change and apply filter to target control
        sourceControl.addListener('change', function (field, newValue, oldValue) {

            if (this.readOnly) return;

            var doReset = true;

            // apply filter to targer control
            applyTargetFilter();

            // if target control has a selected object having the same value for the source field property as the source control value
            // then do not reset target control value
            var realSourceFieldName = getRealSourceFileName();
            if (targetControl.selectedObject && targetControl.selectedObject[realSourceFieldName]) {
                if (targetControl.selectedObject[realSourceFieldName] == sourceControl.getValue()) {
                    doReset = false;
                }
            }

            if (doReset) {
                // skip target reset if "SkipOnFirstLoad" dependency parameter is set and we're still initializing the control
                var skip = params.SkipOnFirstLoad && params.SkipOnFirstLoad.Value && sourceControl.isInitializing() ? true : false;
                if (!skip) {
                    // reset target value
                    targetControl.selectedObject = null;
                    targetControl.setValue(String(Portal.Const.EMPTY_ID));
                }
            }

            performTargetAutoResolve(newValue, oldValue);
        });

        // apply target filter on form load event
        sourceControl.addListener('formload', function () {
            applyTargetFilter();
        }, null, { single: true });


        if (isSourceAutoResolve) {

            // add a listener to target control change event to apply related source control value if this is different from the current one
            targetControl.addListener('valueresolved', function (control, newValue, objDescription, initialized) {

                if (this.debugMode) {
                    Portal.Console.log('DependencyMethod filterObjectLink > targetControl valueresolved');
                    Portal.Console.log(arguments);
                }

                var skip = params.SkipOnFirstLoad && params.SkipOnFirstLoad.Value && !initialized ? true : false;
                if (!skip) {
                    var realSourceFieldName = getRealSourceFileName();
                    if (targetControl.selectedObject && targetControl.selectedObject[realSourceFieldName]) {
                        applySourceValue(targetControl.selectedObject[realSourceFieldName]);
                    } else {
                        if (this.debugMode)
                            Portal.Console.log("targetControl.selectedObject not valid!");
                    }
                }

            });
        }
    }

};
