            switch (winCfg.title) {

                case 'Cell properties':
                    fields = winCfg.body.items[0].items;
                    hideAllFieldsBut = ['type'];
                    break;

                case 'Row properties':
                    fields = winCfg.body.items;
                    hideAllFieldsBut = ['type'];
                    break;
