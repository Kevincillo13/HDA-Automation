// requires: ['Portal.MessageBusHelper'],

Ext.define('Portal.MessageBus', {
    requires: ['Portal.MessageBusHelper'],
    singleton: true,
    constructor: function (cfg) {
        var me = this;
        cfg = cfg || {};
        Ext.apply(me, cfg);

        me.publish = function (topic, data, sourceCtx) {
            if (sourceCtx) Ext.apply(data, {
                sourceCtx: {
                    path: sourceCtx.path(),
                    contextName: sourceCtx.contextName,
                    componentId: sourceCtx.component.id
                }
            });

            Ext.net.Bus.publish(topic, data);
            Portal.Console.log(['MESSAGE BUS','message sent', topic, data]);
        };
        
        me.subscribe = function (topic, fn, config) {
            return Ext.net.Bus.subscribe(topic, fn, config);
        };

        me.unsubscribe = function (topic, fn) {
            Ext.net.Bus.unsubscribe(topic, fn);
        };

        me.using = function (msg, ctx) {
            var handler = Ext.create('Portal.MessageBusHelper', { data: msg, ctx: ctx });
            return handler;
        };
    }
});

