/*
    TextAreaButtons Plugin.

    Provides generic features to the textareas such as:
    - zoom in/out (expanding the textarea - Icon + F2 key)
    - spell checking (button and automatic spell checker)
*/
Ext.define('Portal.Plugins.TextAreaButtons', {
    alias: 'portal.plugins.textareabuttons',

    emojiMenu: null,

    /*
        Plugin configuration
    */
    init: function (instance) {

        if (instance.spellCheckValidationEnabled) {
            instance.spellCheckEnabled = instance.spellCheckValidationEnabled && typeof $Spelling !== "undefined";
        }
        else {
            instance.spellCheckEnabled = false;
        }

        if (instance.emojiPickerEnabled) {
            instance.emojiPickerEnabled = instance.emojiPickerEnabled;
        }
        else {
            instance.emojiPickerEnabled = false;
        }

        if (instance.allowTranslations) {
            if (!instance.translationKey) {
                instance.translationKey = null;
            }
        }
        else {
            instance.allowTranslations = false;
        }


        this.initSpellChecker(instance);

        instance.mon(instance, 'added', this.onAdded, this);
        instance.mon(instance, 'afterrender', this.onAfterRender, this);
        instance.mon(instance, 'destroy', this.onDestroy, this);
        instance.mon(instance, 'keyup', this.onKeyUp, this);
    },

    /*
        RegEx used to clean up requests to spell checker
    */
    spellCheckerRegEx: function () {
        var _getSeparators = function () {
            var re = '', i, str = '\\s!"#$%&()*+,-./:;<=>?@[\]^_{|}§©«®±¶·¸»¼½¾¿×÷¤\u201d\u201c';

            // Build word separator regexp
            for (i = 0; i < str.length; i++)
                re += '\\' + str.charAt(i);

            return re;
        };

        return new RegExp('([0-9]|[' + _getSeparators() + '])', 'g');
    }(),

    /*
        Spell checker initialization.
    */
    initSpellChecker: function (instance) {
        if (!instance.spellCheckEnabled) return;

        var me = this;

        instance.spellCheckIsValid = true;
        instance.spellCheckerRegEx = me.spellCheckerRegEx;

        instance.spellCheckingTask = new Ext.util.DelayedTask(function () {
            me.doSpellChecking(instance, false);
        });

        instance.doSpellChecking = function (isInteractive) {
            me.doSpellChecking(instance, isInteractive);
        }

        instance.enqueueSpellCheck = function () {
            instance.spellCheckingTask.delay(500);
        }

        // track change for spellchecker (NOT INTERACTIVE)
        instance.mon(instance, 'change', function () { instance.enqueueSpellCheck(); });
    },

    /*
        Performs the spell checking logic (using "Suggest" logic to retrieve results and understand possible issues).
    */
    doSpellChecking: function (instance, isInteractive) {

        var text = instance.getValue();

        var getWords = function (tx) {
            tx = tx.replace(instance.spellCheckerRegEx, ' ');

            var rawWords = Ext.String.splitWords(tx);

            // take only short words otherwise there are issues on the spellcheker.
            return Ext.Array.filter(rawWords, function (o) { return (o != null && o.length < 30); });
        }

        var checkingResult = $Spelling.SpellCheckSuggest(getWords(text));

        var hasError = Ext.isArray(checkingResult) ? Ext.Array.filter(checkingResult, function (item) { return Ext.isArray(item) && item.length > 0; }).length > 0 : !checkingResult;

        // check whether is valid or not.
        instance.spellCheckIsValid = (!hasError || instance.readOnly);

        if (isInteractive) {
            if (instance.spellCheckIsValid) {

                Portal.Util.Msg.showToastMsg({
                    msg: translations['WSC_SPELLCK_NoError']
                });

            } else {

                var o = $Spelling.SpellCheckInWindow(instance.inputEl.dom);

                // Workaround for "There are some errors in the field XXX, continue?" on detail save when the user changes language in the SpellCheck UI
                o.onChangeLanguage = function (language) {

                    var prevLang = $Spelling.DefaultDictionary;
                    if ($Spelling) {
                        $Spelling.DefaultDictionary = language;
                    }

                    var text = instance.getValue();
                    var checkingResult = $Spelling.SpellCheckSuggest(getWords(text));
                    var hasError = Ext.isArray(checkingResult) ? Ext.Array.filter(checkingResult, function (item) { return Ext.isArray(item) && item.length > 0; }).length > 0 : !checkingResult;

                    instance.spellCheckIsValid = (!hasError || instance.readOnly);

                    if (instance.spellCheckIsValid) {
                        Portal.Util.Msg.showToastMsg({
                            msg: translations['WSC_SPELLCK_NoError']
                        });
                    }

                    if ($Spelling) {
                        $Spelling.DefaultDictionary = prevLang;
                    }
                };
            }
        }
    },

    onAdded: function (instance, ownerCt, index) {
        var me = this;

        if (Ext.isEmpty(instance.rightButtons)) instance.rightButtons = [];

        // spellcheck button
        if (instance.spellCheckEnabled && !instance.readOnly) {
            instance.rightButtons.push({
                cls: "float-button textarea-right-button",
                iconCls: "icon-spellcheck",
                itemId: 'spell',
                listeners: {
                    click: function () {
                        instance.doSpellChecking(true);
                    }
                }
            });
        }

        // zoom button
        instance.rightButtons.push({
            cls: "float-button textarea-right-button",
            iconCls: "icon-expand",
