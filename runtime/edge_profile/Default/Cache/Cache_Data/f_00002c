        getComponentMainDetailPage: function (cmp) {

            if (!cmp) return null;

            var parentPage = cmp.up("[pageID][cls*='js-page-container']");

            if (!parentPage) return null;

            var moduleCtx = parentPage.getContext('Module');
            var detailCtx = moduleCtx.getSiblingContext('Detail');

            if (detailCtx !== me) {

                return me.getComponentMainDetailPage(parentPage);

            } else {

                return parentPage;
            }
