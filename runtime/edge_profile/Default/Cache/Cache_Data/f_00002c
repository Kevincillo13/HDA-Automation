    var _getFilter = function () {
        var stdFilter = _getStandardFiltersArray(),
            fields = _getAdvancedFilterFields();

        // remove empty standard filters 
        if (stdFilter) {
            stdFilter = _removeEmptyFilters(stdFilter);
        }

        // build advanced filter and remove empty filters 
        var advFilter = null;
        if (initialAdvancedFilter) {
            advFilter = _getFilterWithParameters(initialAdvancedFilter, fields, 'wsc');
            advFilter = _removeEmptyFilters(advFilter);
        }

        var complexFilter = _buildFullFilterFromParts(stdFilter, advFilter);

        return complexFilter;
    };

    var _getFilterFields = function () {

        var state = _getFilterState();

        // filter state contains all filters including empty ones
        var stdFilterArray = Portal.Util.removeEmptyFilters(state.stdFilter);

        // return complete filter
        return {
            id: activeAreaID,
            entity: me.recordType,
            filter: _buildFullFilterFromParts(stdFilterArray, state.advFilter),
            parameters: state.parameters
        };
    };

    var _getFilterState = function () {

        var stdFilterArray = _getStandardFiltersArray(),
            advFilter = null,
            fields = _getAdvancedFilterFields(),
            controlParameterValues = [];

        // get advanced filter's control values
        fields.forEach(function (field) {
            controlParameterValues.push({ controlId: field.itemId, value: field.value });
        });

        if (initialAdvancedFilter) {
            advFilter = _getFilterWithParameters(initialAdvancedFilter, fields, 'std');
        }

        var state = {
            stdFilter: stdFilterArray,
            advFilter: advFilter,
            parameters: initialParameters
        };
        return state;
    };

    /**
     * Apply parameter values to filter and build it.
     * @param {any} inputFilter starting filter to elaborate
     * @param {any} fields      array of fields to apply to filter
     * @param {any} filterType return filter type, available options:
     *                              - std (returns input filter with only values updated)
     *                              - wsc (returns wsc filter)
     * @returns {Object} filter
     */
    var _getFilterWithParameters = function (inputFilter, fields, filterType) {

        if (!fields) return inputFilter;

        var getFilterRecursive = function (filter, fields, filterType) {

            var outputFilter = { type: filter.type, conditions: [], subfilters: [] };

            var conditions = filter.conditions || [],
                subfilters = filter.subfilters || [];

            conditions.forEach(function (item) {

                var field = fields.find(function (c) { return c.itemId === item.parameterControlId; });

                var condition = null;
                switch (filterType.toLowerCase()) {
                    case 'std':
                        condition = item;
                        if (condition.op === "nn" || condition.op === "nl")
                            condition.value = null;
                        else {
                            if (field) {
                                condition.value = field.getFilterValue ? field.getFilterValue() : field.getValue();
                            } else {
                                condition.value = item.value;
                            }
                        }
                        outputFilter.conditions.push(condition);
                        break;
                    case 'wsc':
                        if (field) {
                            // advanced filter's fields have all a default op = 'eq', we must overwrite it with correct filter operator
                            field.filterOperator = item.op;
                            condition = Portal.Filters.FilterAreaContext.Utils.buildFilterFromField(field);
                            condition.property = item.property;
                            outputFilter.conditions.push(condition);
                        } else {
                            condition = Portal.Filters.FilterAreaContext.Utils.buildFilterFromProperties(item.property, item.value, item.op, item.extKey);
                            outputFilter.conditions.push(condition);
                        }
                        break;
                }
            });

            // check all subfilters
            subfilters.forEach(function (item) {
                outputFilter.subfilters.push(
                    getFilterRecursive(item, fields, filterType)
                );
            });

            return outputFilter;
        };

        // build filter
        var filter = getFilterRecursive(inputFilter, fields, filterType);

        // return updated filter
        return filter;
    };

    /****************************************************************************
    *                          PRIVATE DATA SETTERS
    ****************************************************************************/

    var _setStandardFiltersArray = function (filters) {
        var filterObj = {},
            filterRecord = null,
            filterAreaForm = _getActiveArea().getForm(),
            filterItems = filterAreaForm.getFields(),
            mgr,
            df,
            f,
            unfoundFilters = [];

        if (filters && !Array.isArray(filters) && filters.conditions && filters.conditions.length > 0) {
            filters = filters.conditions;
        }

        filters = filters || [];
        if (filters.length === 0) { return; }

        _clearWarningPanel();

        for (var i = 0; i < filters.length; i++) {

            var fi = filters[i];
            var fd = filterItems.findBy(function (f) {
                return _filterMatcher(f, fi);
            });

            var initialFilter = null;
            if (me.initialFilters) {
                initialFilter = me.initialFilters.find(function (f) {
                    return f.property === fi.property && f.op === fi.op;
                });
            }

            if (!fd && !initialFilter) {
                unfoundFilters.push(fi);
            }

            if (fd && !Ext.isEmptyObj(fd)) {

                fd.suspendEvents();

                Portal.Filters.FilterAreaContext.Utils.setFieldValueFromFilter(fd, fi);

                //if (fd.xtype == 'datefield' && !Ext.isDate(fi.value)) {
                //    fd.setValue(Portal.Util.Json.getDateFromJson(fi.value));
                //} else
                //    fd.setValue(fi.value);
                //fd.setValue(fi.value);
                //filterObj[fd.getItemId()] = fi.value;

                if (Ext.isDefined(fi.lock)) {
                    if (fd) fd.setReadOnly(fi.lock);
                }

                if (fi.extKey) {
                    if (fd.filterExtensionKey && fd.filterExtensionKey !== fi.extKey && !Portal.Filters.FilterAreaContext.Utils.canSetFilterExtensionKey(fi, fd)) {
                        throw new Error('FilterExtensionKey defined both on control and filter, please remove one!');
                    } else {
                        fd.filterExtensionKey = fi.extKey;
                    }
                }

                fd.resumeEvents();
            }

        }
        //filterAreaForm.setValues(filterObj);

        // some filters not found -> show warnings
        if (unfoundFilters.length) {
            _showMissingPropertiesWarning(unfoundFilters);
        }

        _updateDefaultFilterValue();
    };

    var _setStandardFiltersArrayWithControlID = function (filters) {
        var filterObj = {},
            filterRecord = null,
            filterAreaForm = _getActiveArea().getForm(),
            mgr,
            df,
            f,
            unfoundFilters = [];

        filters = filters || [];
        if (filters.length === 0) return;

        _clearWarningPanel();

        for (var i = 0; i < filters.length; i++) {

            var fi = filters[i];
            var fd = filterAreaForm.findField(fi.controlId);

            if (fd && !Ext.isEmptyObj(fd)) {

                fd.suspendEvents();
                Portal.Filters.FilterAreaContext.Utils.setFieldValueFromFilter(fd, fi);
                fd.resumeEvents();
            }

        }

        _updateDefaultFilterValue();
    };

    var _updateDefaultFilterValue = function () {
        var df = _getDefaultFilter(),
            filterAreaForm = _getActiveArea().getForm();

        if (!df) return;

        // copy value from filter area control to toolbar control
        var f = filterAreaForm.findField(df.getName());
        if (f && f.getValue()) df.setValue(f.getValue());
