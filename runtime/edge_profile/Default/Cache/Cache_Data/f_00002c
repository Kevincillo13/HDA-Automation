Ext.define('Portal.ModuleContext', {
    requires: ['Portal.ContextBase', 'Portal.ModuleContainer', 'Portal.MessageBus'],
    extend: 'Portal.ContextBase',
    contextName: 'Module',
    mixins: {
        moduleContainer: 'Portal.ModuleContainer'
    },
    statics: {

        REFRESH_DELAY: 500,

        listeners: {

            onBeforeDestroy: function (cmp, opts) {
                Portal.Console.log('MODULE BEFORE DESTROY EVENT [ModuleID=' + cmp.id + ']');

                // de-register module ref from parent module container
                // parent module container is parent module in case of child modules
                // parent module container is PageManager in case of root modules
                var moduleCtx = cmp.getContext('Module'),
                    modulecontainer = moduleCtx.moduleContainer();
                if (modulecontainer)
                    modulecontainer.deregisterModule(moduleCtx.id);
                else
                    Portal.PageManager.deregisterModule(moduleCtx.id);
            },

            onDestroy: function (cmp, opts) {
                Portal.Console.log('MODULE DESTROY EVENT [ModuleID=' + cmp.id + ']');
                // do nothing
            },

            contextInitComplete: function () {
                var moduleCmp = this;
                var scrollingCtxs = moduleCmp.getContext('Module').findCtxsHavingFunction('setupContentScrollMode');

                if (scrollingCtxs.length > 1) {
                    throw new Error('Multiple "setupContentScrollMode" implementations found! Ensure at most ONE implementation of the function among all contexts. [ModuleID=' + moduleCmp.id + ']');
                } else if (scrollingCtxs.length === 1) {
                    scrollingCtxs[0].setupContentScrollMode(moduleCmp.getContentScrollMode());
                }
            }
        },
        createInstance: function (cmp) {
            if (cmp.initialConfig && cmp.initialConfig.portalContextType) {
                // create the specific context instance that the component declares (it ensures Module Context creation)
                Portal.ContextFactory.createInstance(cmp.initialConfig.portalContextType, cmp, cmp.initialConfig);
            } else {
                // create the default module context instance
                Portal.ContextFactory.ensureModuleContext(cmp, cmp.initialConfig);
            }
        }
    },

    privates: {

        hideHeader: function () {
            var me = this;
            var header = me.getHeader();

            if (header && typeof header.hide == 'function') header.hide();
        },

        collapseTitleToContainer: function (title) {
            var me = this;

            me.onComponentReady(function () {
                var containerCmp = me.getContainerCmp();
                var header = me.getHeader();

                if (!containerCmp) return;

                if (typeof containerCmp.setTitle == 'function')
                    containerCmp.setTitle(title);

                if (header) {

                    var iconCls = (header.getIconCls ? header.getIconCls() : '');
                    if (iconCls && typeof containerCmp.setIconCls == 'function')
                        containerCmp.setIconCls(iconCls);

                    me.hideHeader();
                }
            });
        },

        findCtxsHavingFunction: function (functionName) {
            var module = this.component;
            var ctxs = [];

            // collect all context instances (except ModuleContext)
            _.each(module.Context, function (ctx) { if (ctx.contextName !== 'Module') ctxs.push(ctx); });

            // keep only contexts having the requested function
            var matchingCtxs = [];
            _.filter(ctxs, function (ctx) {
                var hasFunction =
                    _
                        .chain(ctx)
                        .functions(ctx)
                        .some(function (fnName) { return fnName === functionName; })
                        .value();

                if (hasFunction) {
                    matchingCtxs.push(ctx);
                }
            });

            return matchingCtxs;
        }

    },

    constructor: function (config) {
        var me = this,

            // private members

            containerId = null,

            parentModuleCmp = null,

            moduleContainer = null,

            url = null,

            openerParams = null,

            openingMode = null,

            loadMode = null,

            _path = null,

            dialogResult = null,

            autoRefreshTask = null;

        // default module listeners
        config.component.addListener('beforedestroy', Portal.ModuleContext.listeners.onBeforeDestroy);
        config.component.addListener('destroy', Portal.ModuleContext.listeners.onDestroy);
        config.component.addListener('contextinitcomplete', Portal.ModuleContext.listeners.contextInitComplete);

        // Copy configured listeners into *this* object so that the base class's
        // constructor will add them.
        me.listeners = null;
        if (config) me.listeners = config.listeners;

        me.superclass.constructor.call(me, config);

        /*
        me.addEvents('modulebeforeclose', 'moduleclose');
        */

        me.mixins.moduleContainer.constructor.call(me, config);

        // public members
        
        /*
           Represents the component container for current module context.
           In case of remote (server side) loading the container component is the panel that holds the loader configuration and phisically loads the module.
           In case of client loading the container component is the module component itself
        */
        me.containerId = function (_) {
            if (!arguments.length) return containerId;
            containerId = _;
            return _;
        };

        /*
            The parent Module component (if exists)
        */
        me.parentModuleCmp = function (_) {
            if (!arguments.length) return parentModuleCmp;
            parentModuleCmp = _;
            return _;
        };

        /*
            The parent ModuleContainer instance.
            Root ModuleContainer is the PageManager singleton.
        */
        me.moduleContainer = function (_) {
            if (!arguments.length) return moduleContainer;
            moduleContainer = _;
            return _;
        };

        /*
            The url of the server side action that generated current context.
            Used only with remote load mode.
        */
        me.url = function (_) {
            if (!arguments.length) return url;
            url = _;
            return _;
        };

        /*
            The params sent by current module opener
        */
        me.openerParams = function (_) {
            if (!arguments.length) return openerParams;
            openerParams = _;
            return _;
        };

        /*
            The opening mode for current context. Valid values:
            - tab
            - window
            - childmodule
        */
        me.openingMode = function (_) {
            if (!arguments.length) return openingMode;
            openingMode = _;
            return _;
        };

        /*
            The module load mode. It can be:
            - remote: module loaded using a component loader that calls a server-side action;
            - local: module loaded completely client-side;
        */
        me.loadMode = function(_){
            if(!arguments.length) return loadMode;
            loadMode = _;
            return _;
        };

        /*
            The path of current module context.
            It represents the hierarchy path of the module contexts from root one to current one.
            It's a '/' separated string built from modules' id.
        */
        me.path = function (_) {
            if (!arguments.length) return _path;
            _path = _;
            return _;
        };

        me.getLogicalPath = function () {
            var path = '/', pathArr = [];
            var ctx = me;

            while (ctx) {
                if (ctx.component.logicalName) {
                    pathArr.push(ctx.component.logicalName);
                }
                ctx = ctx.getParentCtx();
            }

            if (pathArr.length > 0) {
                path += pathArr.reverse().join('/');
            }
            return path;
        };

        /*
            Current module pageID: module context gets it searching for the first ancestor component having the pageID attribute
        */
        me.pageID = function () {
            var pageCmp = me.pageComponent();
            if (pageCmp) return pageCmp.pageID;
            return null;
        };

        me.pageComponent = function () {
            return me.component.up('[pageID]');
        };

        me.init = function (initCfg) {
            
            var parentCmp = me.component.up(),
                openerCfg = (parentCmp && parentCmp.moduleOpenerConfig) ? parentCmp.moduleOpenerConfig : {};
            
            if (me.component.moduleLoadMode == 'remote') {
                // REMOTE load mode: module has been created and loaded server side
                me.loadMode('remote');

            } else {
                // CLIENT load mode: module has been created and loaded client side
                me.loadMode('local');
            }

            me.setup(initCfg, openerCfg);

            //Ext.resumeLayouts(true);
        };

        me.onTabDeactivate = function (handler) {
            var tab = me.component.up('[portalTab]');

            if (tab) {
                tab.on("deactivate", () => {
                    handler.call();
                })
            }
        };

        me.onTabActivate = function (handler) {
            var tab = me.component.up('[portalTab]');

            if (tab) {
                tab.on("activate", () => {
                    handler.call();
                })
            }
        };

        me.center = function () {

            var containerCmp = me.getContainerCmp();

            if (containerCmp && containerCmp.xtype == 'window') {
                var win = containerCmp;

                win.center();

                // TODO - ATTENZIONE
                // window.show() chiamato qui fa in modo che anche il componente del modulo venga renderizzato in questo momento.
                // Questo potrebbe cambiare il comportamento di onComponentReady quando richiamato all'interno dell'init del contesto:
                // component.rendered sarà 'true' e quindi onComponentReady verrà eseguito subito;
                // se invece lo show non viene chiamato qui, allora component.rendered sarà 'false' e onComponentReady
                // aggiungerà un listener all'evento 'afterrender' per eseguire la funzione richiesta.

                // Per garantire retro-compatibilità con tutti i contesti viene mantenuta la chiamata a window.show()
                if (win.autoShowOnModuleLoad) win.show();
                
            }
        };

        me.setup = function (initCfg, openerCfg) {
            Portal.Console.log('module setup');
            Portal.Console.log(initCfg);
            Portal.Console.log(openerCfg);

            // setup module container instance for current module
            var path = '', moduleContainerInstance = null;

            if (openerCfg.parentContainer) {
                me.parentModuleCmp(openerCfg.parentContainer.component);
                moduleContainerInstance = openerCfg.parentContainer;
            }
            
            // if no parent module container exists then take modules root container a default container for current module
            if (Ext.isEmptyObj(moduleContainerInstance)) moduleContainerInstance = Portal.ModuleContainer.getRootContainer();

            me.moduleContainer(moduleContainerInstance);

            if (typeof moduleContainerInstance.path == 'function') {
                path = moduleContainerInstance.path();
            }

            Ext.apply(openerCfg, {
                path: path
            });

            // setup current module properties
            url = openerCfg.url;
            openingMode = openerCfg.openingMode;
            me.path(openerCfg.path + '/' + me.id);

            var parentCmp = me.component.up();

            me.containerId(parentCmp ? parentCmp.id : null);
            me.openerParams(openerCfg.params);

            me.setTitle(me.component.moduleTitle || '');

            //if (!Ext.isEmpty(openingMode) && (openingMode == "window" || openingMode == "objectlink")) {
            //    me.component.addBodyCls('supportscrollbar');
            //}

            // register to module container
            moduleContainerInstance.registerModule(me);
            
            me.center();

            // if required, invoke callback fn when module context is ready
            if (typeof openerCfg.callbackFn == 'function') {
                me.component.onContextReady('Module', function (ctx) {
                    openerCfg.callbackFn(me.component, ctx);
                });
            }
        };

        // helper function to get contanet component instance
        me.getContainerCmp = function () {
            return me.component.up();
        };

        me.getTitle = function () {
            //return me.component.title ? me.component.title : '';
            return me.component.moduleTitle ? me.component.moduleTitle : '';
        };

        me.getModuleParams = function () {
            if (me.component.moduleParams) return Portal.Util.Json.decode(me.component.moduleParams);
            return {};
        };

        me.getModuleOpenerConfig = function () {
            var parentCmp = me.component.up(),
                openerCfg = (parentCmp && parentCmp.moduleOpenerConfig) ? parentCmp.moduleOpenerConfig : {};

            return openerCfg;
        };

        me.getCustomModuleParams = function () {
            var par = me.getModuleOpenerConfig();
            if (par) return par.customParams;
            return null;
        };

        me.setTitle = function (title) {

            var openerCfg = me.getModuleOpenerConfig(),
                header = me.getHeader();

            if (!title) return;

            // check module opener config to see if title header has to be hidden and container cmp has to be updated
            if (openerCfg.collapseTitleToContainer) {
                me.collapseTitleToContainer(title);
                return;
            }

            if (openerCfg.showInnerTitle) {
                me.component.setTitle(title);
            } else {
                me.hideHeader();
            }
        };

        me.setDirty = function (isDirty) {

            var me = this;
            
            me.onComponentReady(function () {

                var setComponentDirty = function (cmp, isDirty) {
                    cmp[isDirty ? 'addCls' : 'removeCls']('dirty');
                };

                // Module
                setComponentDirty(me.component, isDirty);

                // Container (ModuleContainer, TabPanel, Window, SlidingWindow)
                var containerCmp = me.getContainerCmp();

                if (!containerCmp) return;

                setComponentDirty(containerCmp, isDirty);

                // Tab (TabPanel linked tab)
                if (containerCmp.tab) {

                    setComponentDirty(containerCmp.tab, isDirty);

                    containerCmp.tab.updateLayout();
                }
            });
        };

        me.setBadge = function (text) {
            var tabPanel = me.component.up('[portalTab]');

            if (tabPanel) {
                Portal.PageManager.setBadge(text, tabPanel.tab);
            }
        };

        me.getHeader = function () {
            return (Ext.isFunction(me.component.getHeader) ? me.component.getHeader() : null);
        };

        me.getParentCtx = function () {
            var cmp = me.parentModuleCmp();
            if (cmp) {
                // an explicit parent module component has been set for this module context, get the reference of the module context which is attached to
                if (cmp.Context)
                    return cmp.Context['Module'];
                else
                    return cmp.getContext('Module');
            }
            return null;
        };

        // makes this module context to close
        me.close = function () {
            // close module container (ext component)
            var containerCmp = me.getContainerCmp();
            if (containerCmp) containerCmp.close();
        };
        
        me.endDialog = function (data) {
            dialogResult = data;
            me.close();
        };

        /**
         * Refreshes a module content, by reloading it using the actual url and parameters.
         */
        me.refresh = function () {
            me.reload({ delay: Portal.ModuleContext.REFRESH_DELAY });
        };

        /**
         * Reloads a module content.
         * 
         * @param {Object} cfg - The reload configuration.
         * @param {string} cfg.url - The url to use to load module content.
         * @param {Object} cfg.params - The parameters to attach to the load request.
         * @param {number} cfg.delay - The delay (milliseconds) to wait before sending the request.
         *                             Reload requests within this period will be buffered.
         * @param {Object} cfg.loadingMask - The loading mask object to be shown during the load request.
         * @param {Object} cfg.loadMask - The load mask configuration (to show/hide the load mask during the request).
         */
        me.reload = function (cfg) {
            if (me.loadMode() == 'remote') {

                // re-configure container loader and reload current module
                cfg = cfg || {};

                // encode filter param (supposed to be an array)
                if (cfg.params && cfg.params.filter && Ext.isArray(cfg.params.filter)) {
                    cfg.params.filter = Portal.Util.Json.encode(cfg.params.filter);
                }

                Portal.ModuleContainer.reload(me.getContainerCmp(), cfg);

            } else {
                if (cfg.loadingMask && cfg.loadingMask.hide && !cfg.loadingMask.isDestroyed)
                    cfg.loadingMask.hide();
            }
        };

        /**
         * Reloads the module content using the specified parameters.
         * 
         * @param {Object} params - The new parameters to attach to the reload request.
         * @param {boolean} replaceAllParams - true, if we want "params" to be the only parameters attached to the reload request;
         *                                     false, if we want "params" to be merged with existing module load parameters.
         * @param {number} delay - The delay (milliseconds) to wait before sending the request.
         *                         Reload requests within this period will be buffered.
         */
        me.reloadWithParams = function (params, replaceAllParams, delay) {
            var url = me.url();
            var urlParts = url.split('?');
            var path = urlParts[0];
            var qsParams = (urlParts.length == 2 ? urlParts[1] : '');

            if (!replaceAllParams) {
                var urlParams = Ext.Object.fromQueryString(qsParams);

                Ext.apply(urlParams, params);

                qsParams = Ext.Object.toQueryString(urlParams);

            } else {
                qsParams = Ext.Object.toQueryString(params);
            }
            
            url = path;

            if (!Ext.isEmpty(qsParams))
                url += '?' + qsParams;

            me.reload({ url: url, delay: delay });
        };


        me.is = function (ctxName) {
            return (me.getContext(ctxName) != null);
        };

        me.isTabActive = function () {

            var tabPanel = me.component.up('[portalTab]');

            if (tabPanel)
                return tabPanel.tab.active;
            else
                return false;

        };

        me.setAutoRefresh = function (interval, runFn, fireOnStart) {

            fireOnStart = fireOnStart || false;

            if (interval > 0) {

                if (autoRefreshTask) {
                    me.destroyAutoRefresh();
                }

                autoRefreshTask = Ext.util.TaskManager.start({
                    run: runFn,
                    interval: (1000 * interval),
                    fireOnStart: fireOnStart
                });

                var activationCmp = me.component.up('[portalTab]');

                if (activationCmp) {
                    activationCmp.mon(
                        activationCmp,
                        'deactivate',
                        function () {
                            if(me.isAutoRefreshRunning())
                                me.suspendAutoRefresh();
                        }
                    );
                    activationCmp.mon(
                        activationCmp,
                        'activate',
                        function () {
                            // force fire on start in order to refresh module content on module re-activation
                            if(me.isAutoRefreshSuspended())
                                me.restartAutoRefresh(true);
                        }
                    );
                }

                me.component.on('destroy', function () {
                    me.stopAutoRefresh();
                    me.destroyAutoRefresh();
                });
            }
        };

        me.hasAutoRefresh = function () {
            return (autoRefreshTask !== null);
        };

        me.stopAutoRefresh = function () {
            Ext.util.TaskManager.stop(autoRefreshTask);
            autoRefreshTask.suspended = false;
        };

        me.suspendAutoRefresh = function () {
            Ext.util.TaskManager.stop(autoRefreshTask);
            autoRefreshTask.suspended = true;
        },

        me.destroyAutoRefresh = function () {
            delete autoRefreshTask;
        };

        me.restartAutoRefresh = function (immediate) {
            autoRefreshTask.fireOnStart = immediate;
            autoRefreshTask.suspended = false;
            Ext.util.TaskManager.start(autoRefreshTask);
        };

        me.resetAutoRefresh = function () {
            autoRefreshTask.taskRunTime = new Date().getTime();
        };

        me.isAutoRefreshRunning = function () {
            return (autoRefreshTask ? !autoRefreshTask.stopped && !autoRefreshTask.suspended : false);
        };

        me.isAutoRefreshSuspended = function () {
            return (autoRefreshTask ? autoRefreshTask.suspended : false);
        };

        me.isAutoRefreshStopped = function () {
            return (autoRefreshTask ? autoRefreshTask.stopped && !autoRefreshTask.suspended : false);
        };

        /**
         * Returns the scrolling component for current module.
         * By default the scrolling component is the module itself, except for modules having a custom scroll management (eg: Detail, Analysis).
         */
        me.getScrollableCmp = function () {

            var scrollingCtxs = me.findCtxsHavingFunction('getScrollableCmp');

            if (scrollingCtxs.length > 1) {
                throw new Error('Multiple "getScrollableCmp" implementations found! Ensure at most ONE implementation of the function among all contexts. [ModuleID=' + me.component.id + ']');
            } else if (scrollingCtxs.length === 1) {
                return scrollingCtxs[0].getScrollableCmp();
            } else {
                return me.component;
            }
        };

        me.on('modulebeforeclose', function (callback) {
            Portal.Console.log('MODULE CONTEXT BEFORE CLOSE ['+me.id+']');
            return true;
        });

        me.on('moduleclose', function () {
            Portal.Console.log('MODULE CONTEXT CLOSE [' + me.id + ']');

            // dialog result close callback
            var par = me.getCustomModuleParams();

            if (par && Ext.isFunction(par.endDialogFn)) {
                par.endDialogFn(dialogResult);
            }

        });

    }
});


