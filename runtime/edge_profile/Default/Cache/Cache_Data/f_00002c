Portal.DetailViewTemplateContext = function () {

    var me = null,
        workingCtx = null,
        templateState = null,
        entity = null,

        getState = function () {

            var fields = workingCtx.getFieldValues(),
                data = [];

            Ext.iterate(fields, function (item) {
                var value = fields[item];
                if (!Ext.isEmpty(value) && value != Portal.Const.EMPTY_ID) data.push({ 'field': item, 'value': value });
            });

            return data;
        },

        getFieldMetadata = function () {

            var fieldMetadata = {};

            var fields = workingCtx.getFields() || [];

            fields.forEach(function (f) {

                if (typeof f.getMetadata == 'function') {

                    var meta = f.getMetadata();

                    if (meta) fieldMetadata[f.getName()] = meta;
                }
            });

            return fieldMetadata;
        },

        setState = function (data, enableAnimation, fullTemplate, templateId) {
            if (workingCtx.contextName == "Detail" && workingCtx.findField('ObjectTypeID') && data && data.length && templateId) {

                // Get previous and new ObjectTypeID
                var oldType, newType;
                oldType = workingCtx.findField('ObjectTypeID').getValue();
                for (var i = 0; i < data.length; i++) {
                    if (data[i].field == 'ObjectTypeID') {
                        newType = data[i].value;
                        break;
                    }
                }

                // If a change type is required
                if (newType && newType != oldType) {

                    // Prepare reload callback
                    var callback = function (data, fullTemplate) {
                        var id = workingCtx.contextStatus.id || '';
                        var recordType = workingCtx.contextStatus.recordType;

                        var config = {
                            url: Router.action("WSCView", "Detail", { entity: recordType, id: id }),
                            params: {
                                filter: [
                                    { "property": "TemplateId", "value": templateId, "op": "eq" }
                                ],
                                setDirty: 1
                            },
                            loadingMask: Portal.Util.Msg.getLoadMask(me.component, { msg: translations['WSC_Msg_Wait'] })
                        };
                        if (!fullTemplate) {
                            var dirtyData = workingCtx.getData(true);
                            Ext.each(data, function (item, index, all) {
                                if (dirtyData[item.field] != undefined)
                                    delete dirtyData[item.field];
                            });

                            config.callback = function (container) {
                                try {
                                    var detailCmp = container.target.down('portalmodule');

                                    if (detailCmp) {
                                        var ctx = detailCmp.getContext('Detail');
                                        if (ctx.isLoading()) {
                                            detailCmp.on('formload', function (component, detailCtx) {
                                                Ext.Function.createDelayed(function () { ctx.setFieldValues(dirtyData); }, 300)();
                                            });
                                        } else {
                                            ctx.setFieldValues(dirtyData);
                                        }
                                    }
                                }
                                catch (e) {
                                    Portal.Console.log('ERROR ON FORMLOAD TEMPLATE CALLBACK');
                                    Portal.Console.log(e);
                                }
                            }
                        }
                        me.getContext('Module').reload(config);
                    }

                    // Check if form is dirty and warn the user to prevent unwanted data loss
                    /*
                    if (workingCtx.isDirty()) {

                        Portal.Util.Msg.confirm(
                            translations['WSC_Detail'],
                            translations['HDA_Confirm_PerformOperationOverDirtyForm'],
                            function (ans) {
                                if (ans == 'yes') {
                                    if (callback) callback();
                                } else {
                                    return;
                                }
                            });

                    } else {
                        callback();
                    }
                    */
                    callback(data, fullTemplate);
                    return;
                }

            }

            var fields = workingCtx.getFieldValues();
            if (fullTemplate) {
                Ext.iterate(fields, function (item) {
                    var control = workingCtx.findField(item);
                    if (control && Ext.isDefined(control.disabled) && control.disabled == false) {
                        control.suspendEvents();
                        control.setValue("");
                        control.resumeEvents();
                    }
                    if (control && !Ext.isDefined(control.disabled)) {
                        control.setValue("");
                    }
                });
            }

            if (data && data.length) {
                var controlUpdated = false;

                Ext.each(data, function (item, index, all) {

                    var control = workingCtx.findField(item.field);

                    if (control) {
                        var doStdUpdate = me.fireEvent('beforeUpdateTemplateControlValue', me, {
                            control: control,
                            item: item,
                            data: data
                        });
                        if (!doStdUpdate) return;
                    }

                    if (control && Ext.isDefined(control.disabled) && control.disabled == false) {
                        controlUpdated = true;
                        control.suspendEvents();
                        if (Portal.Const.ICRM) {
                            if (control.xtype === "nettagfield") {
                                var itemToAdd = control.getRawValue() !== "" ? control.getRawValue().filter(x => (!x.fromTemplate)) : "";
                                if (itemToAdd === "")
                                    itemToAdd = (item.value || "").split(";").map(function (x) { return { text: x, value: x, fromTemplate: true }; });
                                else {
                                    (item.value || "").split(";")
                                        .map(function (x) { return { text: x, value: x, fromTemplate: true }; })
                                        .forEach((v, i, a) => itemToAdd.push(v));
                                }
                                control.setValue(itemToAdd);
                            } else if (control.xtype == "combobox" || control.xtype == "treefield") {
                                control.setValue(item.value);
                            } else {
                                control.setValue(control.getValue() + " " + item.value);
                            }
                        }
                        else {
                            control.setValue(item.value);
                        }
                        control.resumeEvents();
                        if (enableAnimation && !control.hidden && control.getEl())
                            control.getEl().frame();
                    }
                    if (control && !Ext.isDefined(control.disabled)) {
                        control.setValue(item.value);
                    }
                });
            }
        },

