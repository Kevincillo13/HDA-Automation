Ext.define("Portal.Controls.GeographyField", {

    extend: 'Portal.Controls.CompositeFieldBase',

    alias: 'widget.geographyfield',

    fieldTypeCls: 'geography-field',

    mapFieldID: null,
    mapContainerEl: null,
    wktValue: null,
    raster: null,
    vector: null,
    view: null,
    overlay: null,

    divWrapFieldID: null,
    divInputSearchID: null,
    divCoordinatesID: null,
    divAddressID: null,

    geoCodeURL: Router.action("Map", "Geocode"),
    geoCodeReverseURL: Router.action("Map", "ReverseGeocode"),
    mapDefaultZoom: 9,
    mapCenterLongitude: 12.503,
    mapCenterLatitude: 41.8813,
    loaded: false,
    allowBlank: true,
    searchEnabled: false,
    parentControlDetailID: null,

    coordinateContainer: null,

    config: {

        mapHeight: 250,

        minHeight: 200

    },

    initComponent: function () {
        var me = this;

        if (!Portal.MapUtil.isOpenLayersSupported()) {

            Ext.apply(me, {
                contentTpl: '<div class="map-placeholder geography-wrapper"><div class="map-text">{text}</div><div class="map-value">{value}</div></div>',
                contentData: { text: translations['Portal_Map_Not_Supported'], value: '' }
            });

            return me.callParent();
        }

        me.divWrapFieldID = Ext.String.format('{0}_{1}', me.id, 'divWrapField');
        me.divInputSearchID = Ext.String.format('{0}_{1}', me.id, 'divSearch');
        me.divCoordinatesID = Ext.String.format('{0}_{1}', me.id, 'divCoordinates');
        me.divAddressID = Ext.String.format('{0}_{1}', me.id, 'divAddress');
        me.mapDefaultZoom = me.initialConfig.mapDefaultZoom ? me.initialConfig.mapDefaultZoom : me.mapDefaultZoom;
        me.mapCenterLongitude = me.initialConfig.mapCenterLongitude ? me.initialConfig.mapCenterLongitude : me.mapCenterLongitude;
        me.mapCenterLatitude = me.initialConfig.mapCenterLatitude ? me.initialConfig.mapCenterLatitude : me.mapCenterLatitude;

        if (!me.contentHeight && me.initialConfig.mapHeight) {
            me.contentHeight = me.initialConfig.mapHeight;
        }

        //TODO?
        //If I activate this, the center animantion e moving map don't work anymore
        //me.setUserCoordinateToCenter();

        me.contentTpl = [
            '<div class="geography-wrapper">',
                '<div class="geography-search-wrapper">',
                    Ext.String.format('<input class="geography-search-input field-content-wrapper" id="{0}" type="text" placeholder="{1}.."/>', me.divInputSearchID, translations['Portal_Geography_Search']),
                    Ext.String.format('<div class="geography-tool search-btn icon-ico-057" onclick="Ext.getCmp(\'{0}\').searchPoint();" data-qtip="{1}"></div>', me.id, translations['Portal_Geography_Search']),
                    Ext.String.format('<div class="geography-tool clear-btn icon-ico-037" onclick="Ext.getCmp(\'{0}\').clearMap();" data-qtip="{1}"></div>', me.id, translations['Portal_Geography_Clear']),
                '</div>',
                '<div class="map-buttons-wrapper" >',
                    Ext.String.format('<div class="geography-tool search-btn icon-ico-057" onclick="Ext.getCmp(\'{0}\').expandMapAndSelectPoint();" data-qtip="{1}"></div>', me.id, translations['Portal_Geography_ExpandMapAndSearch']),
                    Ext.String.format('<div class="geography-tool expand-btn icon-ico-114" onclick="Ext.getCmp(\'{0}\').expandMapAndSelectPoint();" data-qtip="{1}"></div>', me.id, translations['Portal_Geography_ExpandMap']),
                    Ext.String.format('<div class="geography-tool clear-btn icon-ico-037" onclick="Ext.getCmp(\'{0}\').clearMap();" data-qtip="{1}"></div>', me.id, translations['Portal_Geography_Clear']),
                '</div>',
                Ext.String.format('<div id="{0}" class="map"></div>', me.divWrapFieldID),
                Ext.String.format('<div id="{0}" class="info-coordinates"></div>', me.divCoordinatesID),
                Ext.String.format('<div id="{0}" class="info-address"></div>', me.divAddressID),
            '</div>'
        ];

        me.callParent();

        me.setSearchEnabled(me.searchEnabled);

    },

    onAfterRender: function () {

        if (!Portal.MapUtil.isOpenLayersSupported()) return;

        var me = this;

        me.renderMap(me.divWrapFieldID);

        if (me.value) {
            me.loaded = true;
            me.originalValue = me.value;
            me.setMarkerFromPoint(me.value);
        }

        if (me.contentHeight === 0) {
            me.contentContainer.setHeight('100%');
        } else {
            me.contentContainer.setHeight(me.contentHeight);
        }

        var inputSearch = Ext.get(me.divInputSearchID);

        inputSearch.on('keyup', function (e) {
            if (e.keyCode === 13) {
                e.preventDefault();
                me.searchPoint();
            }
        });
    },

    onAfterLayout: function () {
        if(this.map) this.map.updateSize();
    },

    getValue: function () {
        return this.value;
    },

    //value :  example "POINT(12 45)"
    setValue: function (value) {

        var me = this;
        me.value = value;

        if (me.map) {
            me.setMarkerFromPoint(me.value);
        } else {
            me.updateMapPlaceholder(me.value);
        }

        me.checkChange();
    },

    setMapHeight: function (mapHeight) {
        this.mapHeight = mapHeight;
        this.setContentHeight(mapHeight);
    },

    updateMapPlaceholder: function (value) {
        var valueToDisplay = translations['Portal_Geography_NoSelection'];

        if (value) {
            valueToDisplay = this.getLabelCoordinates(value);
        }

        this.contentContainer.update({ text: translations['Portal_Map_Not_Supported'], value: valueToDisplay });
    },

    setSearchEnabled: function (enabled) {
        this[enabled ? 'addCls' : 'removeCls']('is-search-mode');
    },

    renderMap: function (containerID) {

        var me = this;

        // extract the actual mapContainer <div> where map should be placed
        //if (!me.mapContainer) me.mapContainer = document.getElementById(containerID);
        
        if (!me.mapContainerEl) me.mapContainerEl = me.el.down('#' + containerID);

        var mapContainerDom = me.mapContainerEl.dom;

        mapContainerDom.innerHTML = '';

        me.raster = new ol.layer.Tile({
            source: new ol.source.OSM()
        });

        me.view = new ol.View({
            center: ol.proj.fromLonLat([me.mapCenterLongitude, me.mapCenterLatitude]),
            zoom: me.mapDefaultZoom
        });

        me.map = new ol.Map({
            layers: [me.raster],
            target: containerID,
            view: me.view
        });

        me.clearInfo();

        var container = document.getElementById(me.divCoordinatesID);
       
        me.overlay = new ol.Overlay({
            element: container,
            positioning: 'bottom-center',
            stopEvent: false,
            offset: [0, 0]
        });

        me.map.addOverlay(me.overlay);

        me.map.on('singleclick', function (event) {

            var ft = me.map.forEachFeatureAtPixel(event.pixel, function (feature) {
                return feature;
            });

            if (ft) {
                var coordinates = ft.getGeometry().getCoordinates();
               
                var divCoord = me.overlay.getPosition();

                if (divCoord && divCoord[0] == coordinates[0] && divCoord[1] == coordinates[1]) {
                    me.overlay.setPosition(undefined);
                }
                else {
                    me.overlay.setPosition(coordinates);
                }

            } else {
                me.overlay.setPosition(undefined);
               
                if (!me.readOnly && me.searchEnabled) {
                    var clickedPoint = ol.proj.transform(event.coordinate, 'EPSG:3857', 'EPSG:4326');
                    var wktClickedPoint = Ext.String.format("POINT({0} {1})", clickedPoint[0], clickedPoint[1]);
                    me.setValue(wktClickedPoint);
                }
            }
           
        });

        /* For sizing map correctly */
        setTimeout(function () { me.map.updateSize(); }, 200);

    },

    clearMap: function () {
       
        var me = this;
        if (!me.readOnly) {
            me.setValue(null);
        }
    },

    expandMapAndSelectPoint: function () {
        
        var me = this;
        var portalModuleId = me.id + '_popup_portalmodule';
        var popupId = me.id + '_popup';

        if (this.readOnly) {
            Portal.PageManager.openLocalModule({
                mode: 'window',
                module: {
                    xtype: 'portalmodule',
                    id: portalModuleId,
                    layout: { type: 'fit' },
                    cls: 'module map-popup-module',
                    autoScroll: true,
                    items: [{
                        itemId: popupId,
                        id: popupId,
                        xtype: 'geographyfield',
                        value: this.getValue(),
                        mapHeight:0, // auto-height
                        searchEnabled: false,
                        parentControlDetailID: this.id,
                        readOnly: this.readOnly,
                        mapDefaultZoom: this.mapDefaultZoom,
                        mapCenterLongitude: this.mapCenterLongitude,
                        mapCenterLatitude: this.mapCenterLatitude
                    }]
                },
                title: translations['Msg_Geography_Popup_Title']
            });

        }
        else {
            
            Portal.PageManager.openLocalModule({
                mode: 'window',
                module: {
                    xtype: 'portalmodule',
                    layout: { type: 'vbox', align: 'stretch' },
                    cls: 'module map-popup-module',
                    autoScroll: true,
                    items: [
                    {
                        xtype: 'label',
                        cls: 'map-note-label',
                        itemId: 'popup_map-note-label',
                        text: translations['Msg_Geography_Popup_Note']
                    },
                        {
                        flex:1,
                        itemId: popupId,
                        id: popupId,
                        xtype: 'geographyfield',
                        value: me.getValue(),
                        searchEnabled: true,
                        mapHeight: 0, // auto-height
                        originalValue: me.originalValue,
                        parentControlDetailID: me.id,
                        readOnly: me.readOnly,
                        mapDefaultZoom: this.mapDefaultZoom,
                        mapCenterLongitude: this.mapCenterLongitude,
                        mapCenterLatitude: this.mapCenterLatitude
                    },
                    {
                        xtype: 'toolbar',
                        cls: 'toolbar toolbar-right toolbar-pos-bottom',
                        layout: 'anchor',
                        items: [
                            {
                                xtype: 'button',
                                text: translations['Msg_Geography_Popup_Confirm'],
                                itemId: 'acceptbutton',
                                cls: 'map-popup-accept-btn btn btn-primary',
                                tooltip: translations['Msg_Geography_Popup_Confirm_Tooltip'],
                                listeners: {
                                    click: function () {
                                        me.confirmPopupSelectionAndClose(this.getContext());
                                    }
                                }
                            },
                            {
                                xtype: 'button',
                                text: translations['Msg_Geography_Popup_Cancel'],
                                itemId: 'cancelbutton',
                                cls: 'map-popup-cancel-btn btn btn-secondary',
                                tooltip: translations['Msg_Geography_Popup_Cancel_Tooltip'],
                                listeners: {
                                    click: function () {
                                        me.cancelPopupSelectionAndClose(this.getContext());
                                    }
                                }
                            }]
                        }
                    ]
                },
                title: translations['Msg_Geography_Popup_Title']
            });
        }
      
    },

    searchPoint: function () {
        
        var me = this;
        var addressQuery = document.getElementById(this.divInputSearchID).value;

        if (addressQuery) { 

            me.setLoading(true);

            Ext.Ajax.request({
                url: this.geoCodeURL,
                method: 'POST',
                params: {
                    query: addressQuery
                },
                success: function (response, opts) {

                    me.setLoading(false);
               
                    var data = Portal.Util.Json.decode(response.responseText, true);

                    // display first occourrence
                    if (data && data.length > 0) {
                        var item = data[0];
                        var wktSearchedValue = me.getWKTFromCoordinate(item.lon, item.lat);
                        me.setValue(wktSearchedValue);
                    }
                    else {
                        Portal.Util.Msg.showErrorToastMsg(translations['Msg_Geography_Search_NoCoordinate']);
                    }
                },
                failure: function (response, opts) {
                    // do nothing...

                    me.setLoading(false);

                }
                });
        }
    },


    getPositionVectorFromCoordinate: function (longitute, latitude) {

        var me = this;
        var wktValue = me.getWKTFromCoordinate(longitute, latitude);
        return me.getPositionVector(wktValue);
    },

    getWKTFromCoordinate: function (longitute, latitude) {

        var wktValue = Ext.String.format('POINT({0} {1})', longitute, latitude);
        return wktValue;
    },

    getPositionVector: function (wktValue) {

        var format = new ol.format.WKT();

        var feature = format.readFeature(wktValue, {
            dataProjection: 'EPSG:4326',
            featureProjection: 'EPSG:3857'
        });

        feature.name = wktValue;

        var imgUrl = Portal.Const.Url.APP_VIRTUAL_PATH + '\\Client\\Resources\\Img\\base\\mini-location.png';
        //var imgUrl = 'http://dev.openlayers.org/img/marker-blue.png';

        var vector = new ol.layer.Vector({
            source: new ol.source.Vector({
                features: [feature]
            }),
            style: new ol.style.Style({
                image: new ol.style.Icon({
                    anchor: [0.5, 1],
                    imgSize: [30, 30],
                    src: imgUrl
                })
            })
        });

        return vector;
    },

    getNewCenterFromPoint: function (wktString) {

        var coordFinder = /\(\s?(\S+)\s+(\S+)\s?\)/g;
        var allMatches = coordFinder.exec(wktString);
        var lon = parseFloat(allMatches[1]);
        var lat = parseFloat(allMatches[2]);

        return ol.proj.fromLonLat([lon, lat]);

    },

    getLabelCoordinates: function (wktString) {

        var coordFinder = /\(\s?(\S+)\s+(\S+)\s?\)/g;
        var allMatches = coordFinder.exec(wktString);
        var lon = parseFloat(allMatches[1]);
        var lat = parseFloat(allMatches[2]);

        return Ext.String.format('<table><tr><td><b>{0}</b></td><td>{1}</td></tr><tr><td><b>{2}</b></td><td>{3}</td></tr></table>', translations['Portal_Latitude'], lat, translations['Portal_Longitude'], lon);
    },

    getLatitudeCoordinate: function (wktString) {

        var coordFinder = /\(\s?(\S+)\s+(\S+)\s?\)/g;
        var allMatches = coordFinder.exec(wktString);
        var lat = parseFloat(allMatches[2]);

        return lat;

    },

    getLongitudeCoordinate: function (wktString) {

        var coordFinder = /\(\s?(\S+)\s+(\S+)\s?\)/g;
        var allMatches = coordFinder.exec(wktString);
        var lon = parseFloat(allMatches[1]);
      
        return lon;

    },

    setLabelAddress: function (wktString) {
    
        var me = this;
        var lat = me.getLatitudeCoordinate(wktString);
        var lon = me.getLongitudeCoordinate(wktString);
        var addressDiv = document.getElementById(me.divAddressID);
        addressDiv.innerHTML = "&nbsp;";

        Ext.Ajax.request({
            url: this.geoCodeReverseURL,
            method: 'POST',
            params: {
                latitude: lat,
                longitude: lon
            },
            success: function (response, opts) {
                
                var data = Portal.Util.Json.decode(response.responseText, true);

                // display first occourrence
                if (data && data.display_name) {
                    var addressDisplayName = Portal.Util.htmlEncode(data.display_name);

                    addressDiv.innerHTML = addressDisplayName;
                    addressDiv.dataset.qtip = addressDisplayName;
                }
                else {
                    Portal.Util.Msg.showErrorToastMsg(translations['Msg_Geography_NoAddress']);
                }
            },
            failure: function (response, opts) {
                // do nothing...
            }
        });
    },

    setLabelCoordinates: function (wktString) {
        var me = this;
        var coordinateDiv = document.getElementById(me.divCoordinatesID);
