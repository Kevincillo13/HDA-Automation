Portal.Filters.QuickFilterHelper = function (ctx, config) {

    var me = this;

    var _filterEditorModes = {
        FilterEditor: 0,
        FilterEditorWithGrid: 1,
        ExportReport: 2
    };

    var filterBaseData,
        areaFilterId = config.getFilterAreaID(),
        entity = config.getFilterEntity(),
        entityCollection = config.getFilterEntityCollection(),

        /* ======= Private Methods ======= */

        getEmptyFilterBaseData = function () {
            return {
                filterId: Portal.Const.EMPTY_ID,
                name: '',
                description: '',
                entity: '',
                published: false,
                canEdit: true,
                type: config.type || null,
                areaFilterId: ''
            };
        },

        setCurrentFilterBaseData = function (state) {
            filterBaseData = getEmptyFilterBaseData();
            Ext.apply(filterBaseData, state);
        },

        getCurrentFilterBaseData = function () {
            return filterBaseData || getEmptyFilterBaseData();
        },

        clearCurrentFilterBaseData = function () {
            setCurrentFilterBaseData({});
        },

        getFullFilterState = function () {
            var base = getCurrentFilterBaseData();
            var data = config.getFilterState();

            return Ext.apply(base, data);
        },

        updateCurrentFilterData = function (data) {

            var state = getCurrentFilterBaseData();

            Ext.apply(state, {
                filterId: data.ID,
                entity: data.Entity,
                areaFilterId: data.AreaFilterID,
                name: data.Name,
                description: data.Description,
                published: data.Published,
                type: data.Type
                //ownerUserID: data.OwnerUserID,
                //fields: data.Fields
            });

            setCurrentFilterBaseData(state);

        },

        openManagementView = function () {

            var filter = [
                { property: 'entity', op: 'eq', value: entity + '|' + entityCollection, lock: true },
                { property: 'areaFilterId', op: 'eq', value: areaFilterId, lock: true }
            ];

            var viewDim = Ext.getBody().getViewSize();

            Portal.PageManager.openModule({
                url: Router.action("WSCView", "List"),
                parentContainer: ctx.getContext('Module'),
                title: translations['Module_QuickFilterList'],
                mode: 'window',
                height: viewDim.height * 0.9,
                params: {
                    entity: 'PortalFilters',
                    filter: JSON.stringify(filter)
                }
            });

        },

        openAdvancedFilterEditor = function () {
            if (!advancedFiltersEnabled()) return;

            var state = getFullFilterState(),
                filter = (state && state.advFilter) ? state.advFilter : {},
                parameters = (state && state.parameters) ? state.parameters : [];

            if (!state.canEdit) {
                Portal.Console.log('QuickFilterHelper > User cannot edit current filter ' + state.filterId + ' ' + state.filterName);
                return;
            }

            var viewDim = Ext.getBody().getViewSize();

            Portal.PageManager.openModule({
                mode: 'window',
                url: Router.action('Filter', 'FilterEditor'),
                params: {
                    filterID: state.filterId,
                    entity: entity,
                    filter: Portal.Util.Json.encode(filter),
                    parameters: Portal.Util.Json.encode(parameters),
                    filterName: state.name,
                    viewMode: _filterEditorModes.FilterEditorWithGrid
                },
                customParams: {
                    endDialogFn: function (data) {
                        if (data && config.reloadAdvancedFilterArea) {

                            var state = getCurrentFilterBaseData();

                            Ext.apply(state, data);

                            config.reloadAdvancedFilterArea(state);
                        }
                    }
                },
                width: viewDim.width * 0.9,//1200,
                height: viewDim.height * 0.9,//700,
                parentContainer: ctx.getContext('Module')
            });
        },

        loadFilter = function (item) {
            var filter = {
                filterId: item.filterId,
                filter: item.filter,
                name: item.text,
                description: item.qtip,
                canEdit: item.canEdit,
                published: item.published,
                areaFilterId: item.areaFilterId,
                type: item.type,
                fields: Portal.Util.Json.decode(item.fields, true),
                entity: item.entity
            };

            setCurrentFilterBaseData({
                filterId: filter.filterId,
                name: filter.name,
                description: filter.description,
                canEdit: filter.canEdit,
                published: filter.published,
                type: filter.type,
                areaFilterId: filter.areaFilterId
            });

            config.loadFilterButtonHandler(filter);
        },

        canSaveFilter = function (state) {
            return (state && state.filterId && state.filterId !== Portal.Const.EMPTY_ID && state.canEdit);
        },

        canManageFilters = function () {
            return filterSavingEnabled() || filterPublishingEnabled();
        },

        canOpenAdvancedFilterEditor = function (buttonConfig) {
            return advancedFiltersEnabled();
        },

        buildFilterMenuItems = function (items) {
            var menuItems = [];

            Ext.each(items, function (itm) {
                itm.iconCls = itm.published ? '' : 'icon-private';
                itm.handler = function (item, e) { loadFilter(item); };

                menuItems.push(itm);
            });

            return menuItems;
        },

        buildFiltersLoadButton = function (filterItems) {
            return {
                text: translations['Filters_Load'],
                //iconCls: "icon-load",
                menu: { xtype: 'menu', items: filterItems },
                hideOnClick: false,
                listeners: {
                    activate: function () { this.expandMenu(); }
                },
                disabled: (!filterItems.length)
            };
        },

        buildSaveButton = function () {
            //var currentFilterState = getFullFilterState();
            var currentFilterBaseData = getCurrentFilterBaseData();

            return {
                itemId: 'btn-save',
                //iconCls: 'icon icon-ico-032',
                iconCls: 'icon-save',
                text: translations['Filters_Save'],
                handler: function (item, e) {
                    currentFilterBaseData = getCurrentFilterBaseData();
                    quickFilterSave(currentFilterBaseData.filterId, false, currentFilterBaseData.name, currentFilterBaseData.description);
                },
                disabled: !canSaveFilter(currentFilterBaseData)
            };
        },

        buildSaveAsButton = function () {
            return {
                itemId: 'btn-saveas',
                //iconCls: 'icon icon-ico-032',
                iconCls: 'icon-save',
                text: translations['Filters_SaveAs'],
                handler: function (item, e) {

                    var filterIdSnapshot = getCurrentFilterBaseData().filterId,
                        type = getCurrentFilterBaseData().type;

                    var filter = [
                        { property: 'Entity', op: 'eq', value: entity },
                        { property: 'AreaFilterID', op: 'eq', value: areaFilterId },
                        { property: 'Name', op: 'eq', value: null },
                        { property: 'Description', op: 'eq', value: null },
                        { property: 'Fields', op: 'eq', value: Portal.Util.Json.encode(config.getFilterFields()) },
                        { property: 'Published', op: 'eq', value: null },
                        { property: 'Type', op: 'eq', value: type },
                        { property: 'OwnerUserID', op: 'eq', value: Portal.Const.WSCUser.ID }
                    ];

                    Portal.PageManager.openModule({
                        url: Router.action("WSCView", "Detail", { entity: "PortalFilter", id: "" }),
                        parentContainer: ctx.getContext('Module'),
                        //title: translations['Module_QuickFilter'],
                        mode: 'window',
                        width: 700,
                        height: 500,
                        params: { filter: JSON.stringify(filter) },
                        customParams: {
                            endDialogFn: function () {

                                if (config.saveFilterHandler) {
                                    var state = getCurrentFilterBaseData();
                                    config.saveFilterHandler(filterIdSnapshot !== state.filterId, state.name, state.description, state.filterId);
                                }

                            }
                        }
                    });

                }
            };
        },

        buildManageButton = function (items) {
            return {
                iconCls: "icon-settings",
                text: translations['Filters_Manage'],
                handler: function () { openManagementView(); },
                disabled: (!items.length && !editAllFiltersEnabled())
            };
        },

        buildAdvancedFilterButton = function () {
            var currentFilterBaseData = getCurrentFilterBaseData();

            return {
                iconCls: "icon-settings",
                text: translations['Filters_Editor'],
                handler: function () { openAdvancedFilterEditor(); },
                disabled: !currentFilterBaseData.canEdit
            };
        },

        addSeparator = function (btn) {
            btn.menu.add('-');
        },

        buildUserInteface = function (responseObj, splitbutton, buttonConfig) {
            var me = this,
                state = filterBaseData;

            // buttonConfig: load, save, load-save

            splitbutton.menu.removeAll();

            // existing filters load buttons
            if (buttonConfig === 'load' || buttonConfig === 'load-save') {

                var loadMenuItems = buildFilterMenuItems(responseObj.data);

                if (buttonConfig === 'load-save') {
                    splitbutton.menu.add(buildFiltersLoadButton(loadMenuItems));
                } else {
                    splitbutton.menu.add(loadMenuItems);
                }
            }

            // save/saveas buttons
            if (buttonConfig === 'save' || buttonConfig === 'load-save') {

                if (buttonConfig === 'load-save') addSeparator(splitbutton);

                splitbutton.menu.add(buildSaveButton());
                splitbutton.menu.add(buildSaveAsButton());
            }

            if (canManageFilters() || canOpenAdvancedFilterEditor()) {
                addSeparator(splitbutton);

                //Manage QuickFilter Button
                if (canManageFilters()) splitbutton.menu.add(buildManageButton(responseObj.data));

                // if 'load-save' (= filter area) add Editor button
                if (canOpenAdvancedFilterEditor(buttonConfig)) {
                    splitbutton.menu.add(buildAdvancedFilterButton());
                }
            }
        },

        /* Save Quick Filter Fields */
        quickFilterSave = function (id, isNewFilter, filterName, filterDescription) {
            var url = Router.action('QuickFilter', 'SaveFields'),
                data = config.getFilterFields();

            var doSave = function () {
                Portal.WSC.OperationManager.doObjectOperation({
                    objUrl: url,
                    objParams: {
                        'id': id,
                        'data': Portal.Util.Json.encode(data)
                    },
                    successFn: function () {

                        Portal.Util.Msg.showToastMsg({ msg: translations["Msg_OperationSuccessfully"], allowDN: false });

                        var state = getCurrentFilterBaseData();

                        Ext.apply(state, {
                            filterId: id,
                            name: filterName,
                            description: filterDescription
                        });

                        setCurrentFilterBaseData(state);

                        if (config.saveFilterHandler) {
                            state = getCurrentFilterBaseData();
                            config.saveFilterHandler(true, state.name, state.description, id);
                        }

                    },
                    failureFn: function (responseObj) {
                        Portal.Util.Msg.showErrorToastMsg(translations['Msg_OperationError'], responseObj);
                    }
                });
            };

            if (isNewFilter) {
                // save new filter fields
                doSave();
            } else {
                // confirm overwrite?
                Portal.Util.Msg.confirm(
                    translations["WSC_Confirm"],
                    translations["WSC_Msg_OverwriteTemplateConfirm"],
                    function (buttonId) {
                        // exit?
                        if (buttonId !== "yes") return;
                        doSave();
                    });
            }
        },

        /* Populate splitbutton with filters */
        quickFilterMenuPopulate = function (splitbutton, buttonConfig, callback) {

            Portal.WSC.OperationManager.doObjectOperation({

                objUrl: Router.action('QuickFilter', 'Button'),

                objParams: {
                    areaFilterId: areaFilterId,
                    entity: entity,
                    entityCollection: entityCollection
                },

                successFn: function (responseObj) {
                    buildUserInteface(responseObj, splitbutton, buttonConfig);
                    if (callback) callback();
                },

                failureFn: function (responseObj) {
                    Portal.Util.Msg.showErrorMsg(translations['Msg_OperationError'], responseObj);
                }

            });

        },

        advancedFiltersEnabled = function () {
            return config.getFilterSettings().AdvancedFiltersEnabled;
        },

        filterSavingEnabled = function () {
            return config.getFilterSettings().FilterSavingEnabled;
        },

        filterPublishingEnabled = function () {
            return config.getFilterSettings().FilterPublishingEnabled;
        },

        editAllFiltersEnabled = function () {
            return config.getFilterSettings().EditAllFiltersEnabled;
        }
        ;

    /* ======= Initialization Methods ======= */

    ctx.listenToMessage({
        topic: 'Portal.PortalFilter.Insert',
        messageFilter: 'public',
        listenerFn: function (msg) {
            if (msg.data.Entity === entity && msg.data.AreaFilterID === areaFilterId) {
                updateCurrentFilterData(msg.data);
            }
        }
    });

    ctx.listenToMessage({
        topic: 'Portal.PortalFilter.Update',
        messageFilter: 'public',
        listenerFn: function (msg) {
            var state = getCurrentFilterBaseData();
            if (msg.data.ID === state.filterId) {
                updateCurrentFilterData(msg.data);
            }
        }
    });

    /* ======= Public Methods ======= */
    return {

        quickFilterMenuPopulate: quickFilterMenuPopulate,

        openAdvancedFilterEditor: openAdvancedFilterEditor,

        clearSelection: clearCurrentFilterBaseData,

        buildSaveButton: buildSaveButton,

        buildSaveAsButton: buildSaveAsButton,

        loadFilter: loadFilter

    };
};
