Ext.define('Portal.Controls.ObjectLink', {

    extend: 'Ext.form.field.ComboBox',

    alias: 'widget.objectlink',

    fieldTypeCls: 'objectlink-field',

    privates: {

        editableDenyForced: false,

        canSetAsEditable: function () {
            return !Portal.Const.Device.IsMobile && !this.editableDenyForced;
        }

    },

    initComponent: function () {

        // private
        var me = this,

            initializeControl = function () {
                //var isMobile = Portal.Const.Device.IsMobile;
                // detail trigger is visible when a not empty value is selected (even if the field is read-only)
                if (me.getViewMode() == 'hyperlink') {

                    if (Portal.Const.Device.IsMobile) {
                        me.setEditable(false);
                    }

                    me.inputEl.addListener("click", function () {

                        var value = me.getValue();

                        if (!Portal.Util.isEmptyValue(value))
                            me.openDetailView();
                        else if (!me.readOnly && (Portal.Const.Device.IsMobile || !me.editable))
                            me.openSearchView();
                    });
                }

                me.inputEl.addListener("keydown", function (e) {
                    if (e.keyCode == 13) {
                        e.preventDefault();

                        let value = me.getValue();

                        if (!Portal.Util.isEmptyValue(value))
                            me.openDetailView();
                        else if (!me.readOnly && (Portal.Const.Device.IsMobile || !me.editable))
                            me.openSearchView();
                    }
                })
            },

            /* This method updates control UI (triggers, input etc... based on control status) */
            updateControlUI = function () {
                var value = me.getValue();
                var isMobile = Portal.Const.Device.IsMobile;
                // trigger visibility depends on platform 
                if (me.getViewMode() == 'hyperlink') {
                    me.setTriggerVisibility("objectLink", !me.readOnly && Portal.Util.isEmptyValue(value));
                    me.setTriggerVisibility("detail", false);

                    configureTextAsHyperlink(!Portal.Util.isEmptyValue(value) && !me.typing);
                } else {
                    me.setTriggerVisibility("objectLink", !me.readOnly && Portal.Util.isEmptyValue(value));
                    me.setTriggerVisibility("detail", !Portal.Util.isEmptyValue(value));
                }

                // clear trigger is visible when the field is not read-only and it has a not empty value
                me.setTriggerVisibility("clear", !me.readOnly && !Portal.Util.isEmptyValue(value));


                // disable key events when the field is read-only
                me.enableKeyEvents = !me.readOnly;

                // editable ONLY when possible
                me.setEditable(!isMobile && !me.readOnly && me.canSetAsEditable(), true);
            },

            configureTextAsHyperlink = function (hyperlinkEnabled) {

                if (hyperlinkEnabled)
                    me.addCls("hyperLink");
                else
                    me.removeCls("hyperLink");

            },

            eventHandlers = {

                elKeydown: function (e) {

                    if (this.readOnly || this.isInitializing()) return;

                    // ignore TAB, ALT, CTRL, SHIFT keys
                    if (e.keyCode == e.TAB || e.keyCode == e.ALT || e.keyCode == e.CTRL || e.keyCode == e.SHIFT) return;

                    // ignore arrow keys, home, end
                    if (e.keyCode >= 35 && e.keyCode <= 40) return;

                    var wasTyping = this.typing;

                    this.removeErrorStyles();

                    this.typing = true;

                    if (!wasTyping) this.updateControlUI();
                },

                blur: function (field) {

                    Portal.Console.log(['ObjectLink blur', field.id]);

                    if (field.readOnly || field.isInitializing()) return;
                    field.hasFocus = false;

                    if (field.getTypedValue() === '') {
                        field.typing = false;
                        field.clearValue();
                        return;
                    }

                    if (field.typing) {
                        if (field.getTypedValue() != field.getDisplayValue()) {
