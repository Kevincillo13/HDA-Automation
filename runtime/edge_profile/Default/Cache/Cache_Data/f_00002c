                .then(function (objectID) {
                    var detailUrl = Router.action("WSCView", "Detail", { id: objectID, entity: cfg.entity });
                    var params = {};

                    if (!Ext.isEmpty(cfg.recordViewID)) params['recordViewID'] = cfg.recordViewID;

