        editTemplate: function (params) {
            if (!workingCtx.ensureSingleSelection()) return;
            Ext.Ajax.request({
                url: Router.action("WSCView", "GetTemplateDetailData"),
                method: 'POST',
                params: {
                    ID: workingCtx.getSingleID()
                },
                success: function (response, opts) {
                    var json = Portal.Util.Json.decode(response.responseText, true);
                    if (json != null) {
                        if (json.success) {
                            var params = {
                                filter: {
                                    Mode: "value",
                                    Value: JSON.stringify({
                                        property: "TemplateId",
                                        value: json.id,
                                        op: "eq"
                                    })
                                }
                            };
                            var currentParams = Portal.Util.buildParams(params, workingCtx);
                            Portal.PageManager.openModule({
                                url: Portal.Util.buildDetailUrl(json.detailURL, Portal.Const.EMPTY_ID),
                                params: currentParams,
                                mode: workingCtx.currentStatus().detailMode,
                                parentContainer: me.getContext('Module')
