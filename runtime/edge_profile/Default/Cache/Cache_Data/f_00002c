        defaultCommandHandler: function (view, record, htmlItem, index, e, cmdClassName, cmdMethodName, params) {
            if (e.type === 'keydown') {
                // 13 --> ENTER
                if (e.keyCode === 13) {
                    this.onKeyDownDefaultCommandHandler(view, record, htmlItem, index, e, cmdClassName, cmdMethodName, params);
