                    Portal.Console.log(['SQLLink focus', field.id]);
                    field.hasFocus = true;
                    setTimeout(function () { if (!field.isDestroyed) field.selectText(); }, 100);
                },

                beforeSelect: function (field, record, index, eOpts) {
                    field.typing = false;
                },

                writeableChange: function (field, read, eOpts) {
                    this.updateControlUI();
                },

                formload: function () {
                    if (me.pendingValue) {
                        //me.addManagedListener(this, 'valueresolved', function () { me.resetDirty(); }, this, { single: true });
                    } else {
                        me.resetDirty();
                    }
                },

                triggerClick: function (field, trigger, index, tag, e) {
                    if (!this.hideTrigger) {
                        switch (tag) {

                            case 'clear':
                                me.clearValue();
                                me.validate();
                                break;

                            case 'objectLink':
                                me.openSearchView();
                                field.typing = false;
                                break;

                            default:
                            // do nothing
                        }
                    }
                }
            };

        var triggers = me.getTriggers();
        //Ext.applyIf(triggers, {
        //    clear: { tag: 'clear', cls: Ext.form.trigger.Trigger.getIcon("Clear")},
        //    detail: { tag: 'detail', cls: Ext.form.trigger.Trigger.getIcon("Ellipsis"), hideOnReadOnly: false },
        //    objectLink: {tag: 'search', cls: Ext.form.trigger.Trigger.getIcon("Search")}
        //});

        me.setTriggers(triggers);

        // workaround to make combo picker always hidden even when field writable status changes (readonly/editable)
        triggers = me.getTriggers();
        if (triggers.picker) triggers.picker.hideOnReadOnly = false;
        // apply default configs 
        Ext.apply(me, {
            submitValue: false,
            validateOnBlur: false,
            enableKeyEvents: true,
            hideBaseTrigger: true,
            minChars: 2,
