                    var objLink = Ext.net.ResourceMgr.getCmp(moduleParams.objectLinkControl);
                    if (objLink)
                        _moduleCtx.mon(_moduleCtx, 'moduleclose', function () {
                            objLink.setLoadingMode(false);
                            objLink.focus();
                        });
                }
            }

            if (me.contextStatus.controlDependencies) {
                Portal.Controls.DependencyManager.setupDependencies(me.contextStatus.controlDependencies);
            }

            me.component.addListener('destroy', function () {
                if (_availableOperations.task) _availableOperations.task.cancel();
            });

            // setup badge synchronization (if specified by containing page)
            setupBadgeSync();

