Portal.DetailUtil = {

    setupContentScrollMode: function (ctx, contentScrollMode) {
        var pagesContainer = ctx.component.down('#DetailPagesCard');

        if (!pagesContainer) return;

        var doScroll = (contentScrollMode !== 'None');

        // clear autoscroll from module component
        ctx.component.setAutoScroll(false);

        // let the scrolling be handled by each detail "page" component
        // so that only page content will be scrollable and detail toolbar and other detail components will remain "fixed"
        pagesContainer.items.each(function (pageCmp) {
            pageCmp.setAutoScroll(doScroll);
        });
    },

    getScrollableCmp: function (ctx) {
        var pagesContainer = ctx.component.down('#DetailPagesCard');

        if (pagesContainer) return pagesContainer.getLayout().getActiveItem();

        return null;
    }

};
Ext.ns('Portal');

Portal.DetailContext = function () {

    var me = null,

        isLoading = true,

        dirtyStatus = null,

        isTemplateManagement = false,

        loadingMask = null,

        entityRefreshLockIntervalID = null,

        _formValidators = [],

        _formErrorsViewer = null,

        _promiseValidator = null,

        _dirtyStatusEvaluators = [],

        initViewFilter = function (encodedFilter) {
            // decoding filter passed in, removing ObjectTypeID if specified
            if (!encodedFilter) return null;

            //var filter = Ext.decode(encodedFilter, true);
            var filter = Portal.Util.Json.decode(encodedFilter, true);
            for (var i = 0; i < filter.length; i++) {
                // TODO - usare Portal.Const.OBJECT_TYPE_FIELD
                if (filter[i].property == 'ObjectTypeID') {
                    filter.splice(i, 1);
                    break;
                }
            }

            return filter;
        },

        loadData = function (data) {

            me.setFieldValues(data);

            /*
             * FormLoad Event
             * ==============
             * Event fired after each form load, both from reloadData and fullReload.
             * Fields values have already been loaded in the form when fired.
             * 
             * WARNING:
             * ReloadData can happen more than once during detail life cycle (record save without full reload, save before operation, etc.),
             * so to initialize fields only once (events/listeners, etc.) add { single: true }, for ex:
             * me.component.on('formload', setup, null, { single: true });
             * */
            me.component.fireEvent('formload', me.component, me);
            Portal.Console.log(['Detail', 'Form Load Event']);

