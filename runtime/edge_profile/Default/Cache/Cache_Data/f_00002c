Ext.define('Portal.Analysis.AnalysisBehaviourBase', {

    // must-override
    initializeAnalysis: function (container) { throw 'Function not implemented "initializeAnalysis"!'; },

    // must-override
    updateAnalysis: function (container) { throw 'Function not implemented "updateAnalysis"!'; },

    /* add listeners
     * obj -> topics Array (es. Portal.Cost.Insert)
     *     -> validatorFn (function needed because the listenToMessage.messageFilter = 'public')
     *     -> listenerFn (optional callback function. Default listenerFn call the updateAnalysis)
     * container -> container to apply the listenToMessage functions
     */
    createAnalysisListeners: function (obj, container) {
        for (var i = 0; i < obj.topics.length; i++) {
            container.listenToMessage({
                topic: obj.topics[i],
                messageFilter: 'public',
                listenerFn: function (msg) {
                    var validate = obj.validatorFn(msg);
                    if (validate) {
                        if (obj.listenerFn)
                            obj.listenerFn();
                        else
                            container.component.getContext().Analysis.update();
                    }
                }
            });
        }
    }

});

