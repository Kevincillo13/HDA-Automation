    var _loadFilter = function (filterData) {
        var fields = filterData.fields,
            filter = null;
        parameters = null;

        if (!fields.filterAreas && fields.constructor === Array) {
            // legacy standard filters: old filters saved on DB like plain array [{property,value,op},..]
            filter = _buildFullFilterFromParts(fields, null);
        }
        else if (fields.filterAreas) {
            // current complex filters (standard + advanced)
            var standard = null,
                advanced = null;
            fields.filterAreas.forEach(function (item) {
                switch (item.type) {
                    case STD_FILTER_TYPE:
                        standard = item.filter;
                        break;
                    case ADV_FILTER_TYPE:
                        advanced = item.filter;
                        break;
                    default:
                        break;
                }
            });
            filter = _buildFullFilterFromParts(standard, advanced);
            parameters = fields.parameters;
        }
        else {
            // new unique filter format
            filter = fields.filter;
            parameters = fields.parameters;

            if (viewMode === 'window') {
                // In case of Mobile device, when loading and advandced filter,
                // the filter area view has to be shown before loading the filter fields.
                _toggleFilterContainer();
            }

        }

        _setDefaultField();

        me.setFilterState({
            filter: filter,
            parameters: parameters,
            filterName: filterData.name,
            filterDescription: filterData.description,
            filterId: filterData.filterId,
            canEdit: filterData.canEdit,
            published: filterData.published,
            areaFilterId: filterData.areaFilterId
        },
            _isExpanded());

        _saveLocalStoredFilter();
    };

    var _setDefaultField = function (fields) {
        var defaultFltCmp = _getDefaultFilter();

        Ext.each(fields, function (field) {
            if (defaultFltCmp && defaultFltCmp.getItemId() === field.controlId) {
                var oldValue = defaultFltCmp.getValue();
                defaultFltCmp.setValue(field.value);

                if (!_isExpanded()) {
                    defaultFltCmp.getEl().frame();
                }

                // fire filter change
                me.filtersChanged();
            }
        });
    };

