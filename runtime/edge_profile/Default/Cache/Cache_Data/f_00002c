                    if (Portal.Util.isEmptyValue(newValue) && Portal.Util.isEmptyValue(oldValue)) return;

                    this.updateControlUI();
                }
            };

        me.updateControlUI = updateControlUI;

        var triggers = me.getTriggers();
        //Ext.applyIf(triggers, {
        //    clear: { tag: 'clear', cls: Ext.form.trigger.Trigger.getIcon("Clear")},
        //    detail: { tag: 'detail', cls: Ext.form.trigger.Trigger.getIcon("Ellipsis"), hideOnReadOnly: false },
        //    objectLink: {tag: 'search', cls: Ext.form.trigger.Trigger.getIcon("Search")}
        //});

