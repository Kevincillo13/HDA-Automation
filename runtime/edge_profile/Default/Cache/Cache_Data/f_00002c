Portal.SortList = function () {
    var workingCtx = null,
        me = null,
        _webix,
        _container;

    var _lastValidSize = { height: 0, width: 0 };

    /** @type {SortListItem[]} */
    var _configuration = [];

    var getSize = function () {
        var size = me.component.up().getSize();

        _lastValidSize.height = size.height;
        _lastValidSize.width = size.width;

        return _lastValidSize;
    };

    var _buildView = function () {
        _webix = webix.ui({
            container: _container.id,
            height: 400,
            rows: [
                {
                    id: "order-list",
                    view: "list",
                    drag: "order",
                    template: "<div class='webix-dnd-item'><div>#description#</div></div>",
                    dragscroll: true,
                    css: { "border-radius": "5px" },
                    scroll: false,
                    type: {
                        height: 40
                    },
                    data: _configuration,
                    on: {
                        onAfterDrop: function (context) {
                            let idx_start = _configuration.findIndex(x => ("" + x.id) === context.source[0]);
                            let idx_end = context.index;
                            if (idx_start === -1 || idx_end === -1) return;

                            if (idx_end < idx_start) {
                                let _temp = _configuration[idx_start];

                                for (let index = idx_end; index < idx_start + 1; index++) {
                                    let a = _configuration[index];
                                    _configuration[index] = _temp;
                                    _temp = a;
                                }

                            } else {
                                let _temp = _configuration[idx_start];

                                for (let index = idx_end; index > idx_start - 1; index--) {
                                    let a = _configuration[index];
                                    _configuration[index] = _temp;
                                    _temp = a;
                                }
                            }
                        }
                    }
                },
                {
                    view: "toolbar",
                    borderless: true,
                    cols: [
                        {},
                        { view: "button", label: translations.WSC_Confirm, align: "right", width: 100, click: onConfirmClick }
                    ]
                }
            ]
        });
        setTimeout(() => _webix.adjust(), 100);
    };

    var onConfirmClick = function () {
        var parentCtx = me.getContext("Module").getParentCtx();
        var result = []
        _configuration.forEach((element, i) => {
            result.push({ ...element, levelID: i });
        });
        parentCtx.getContext("SortList").setResults(result);
        me.component.up().close();
    };

    var _setResults = function (result) {
        ICRM.Util.Promises.ajaxPostPromise(Router.action("SortList", "SaveSortList"), { EntityCollection: workingCtx.contextStatus.collectionType, Items: Portal.Util.Json.encode(result) })
            .catch(r => Portal.Util.Msg.showErrorToastMsg(translations['WSC_ERR_OPERATION']))
            .then(() => workingCtx.refresh());
    };

    var openSortList = function (params) {
        if (workingCtx.contextName === "List") {
            var status = workingCtx.contextStatus;
            var _collectionName = status.collectionType;
            var _filter = status.filter;

            var descriptionField = null;
            if (params && params.DescriptionField && params.DescriptionField.Value) {
                descriptionField = params.DescriptionField.Value
            } else {
                descriptionField = "Description"
            }

            ICRM.Util.Promises.getProjectionPromise({
                entity: _collectionName,
                filter: _filter,
                columnNames: ["ID", "Description", "LevelID"],
                columnExpressions: ["ID", descriptionField, "LevelID"],
                limit: 20000
            }).then(data => {
                return Portal.PageManager.openModule({
                    url: Router.action("SortList", "SortList"),
                    mode: "window",
                    width: 350,
                    height: 500,
                    title: translations.WSC_Ordering,
                    parentContainer: me.getContext("Module"),
                    params: {
                        Items: Portal.Util.Json.encode(data.map(x => {
                            if (!x.LevelID) {
                                x.LevelID = 0;
                            }

                            return {
                                levelID: x.LevelID,
                                objectId: x.ID,
                                description: x.Description
                            }
                        }))
                    }
                })
            })

        };
    }

    var _init = function (initCfg) {
        me = this;
        if (initCfg.portalContextType === "Portal.ListContext" || initCfg.portalContextType === "Portal.DetailContext") return;
        me.component.on("afterrender", function () {
            _container = me.component
                .down("#Container")
                .contentEl.el.down(".container");

            getSize();
            debugger;

            _configuration = me.getConfiguration("model");
            _configuration = _configuration.sort((a, b) => a.levelID - b.levelID);
            _buildView();
        });
        me.component.up().on("beforeclose", function () {
            if (_webix) _webix.destructor();
        })
    };

    var _setWorkingContext = function (ctx) {
        workingCtx = ctx;
        Portal.Console.log("SetWorkingContext " + ctx);
    };

    var _getWorkingContext = function () {
        return workingCtx;
    };

    return {
        contextName: "SortList",
        init: _init,
        setWorkingContext: _setWorkingContext,
        getWorkingContext: _getWorkingContext,
        openSortList: openSortList,
        setResults: _setResults
    }
}
