    const _getRequestParameters = function () {
        var entityType = comboboxEl.getValue();

        if (!entityType) { return null; }

        return {
            entity: _configuration.entity,
            field: _configuration.statusField,
            kanbanName: _moduleParams.KanbanName,
            parentObject: _moduleParams._Context ? _moduleParams._Context.ContextObject : null,
            parentObjectID: _moduleParams._Context ? _moduleParams._Context.ContextObjectID : null,
            entityType: entityType
        };
    };

    /**
     * Get Request parameters and execute method
     * @param {Function} fn Function to execute
     * @param {Object} defaultResponse 
     * @returns
     */
    const _getParamsAndExecute = function (fn, defaultResponse) {
        // get params
        var params = _getRequestParameters();
        if (!params) {
            // if no valid parameters -> return default response
            return defaultResponse;
        }

        // execute ajax call
        return fn.call(this, params);
    };

    /**
     * Get kanban columns
     * @returns {Array} List of kanban column configurations
     */
    const _getColumns = function () {

        const getColumns = function (params) {
            return Portal.Util.Promises.ajaxGetPromise(_configuration.columnsUrl, params);
        };

        return _getParamsAndExecute(getColumns, {});

    };

    /**
     * Get kanban drop-only columns
     * @returns {Array} List of kanban drop-only column configurations
     */
    const _getDropOnlyColumns = function () {

        const getDropOnlyColumns = function (params) {
            return Portal.Util.Promises.ajaxGetPromise(_configuration.dropOnlyColumnsUrl, params);
        };

        return _getParamsAndExecute(getDropOnlyColumns, {});
    };

    /**
     * Get data for kanban filling
     * @return {Object} GetData response object
     */
    const _getData = function () {

        const getData = function (params) {
            // inject current filters
            params.filter = Portal.Util.Json.encode(_currentFilter);

            return Portal.Util.Promises.ajaxGetPromise(_configuration.dataUrl, params);
        }

        return _getParamsAndExecute(getData, {});
    };

    /*************************************************************************
     *                             Size helpers                              *
     ************************************************************************/

    /**
     * Get ViewPort size
     * @returns {Object} View size object
     */
    const _getPopupSize = function () {
        var viewDim = Ext.getBody().getViewSize();
        return {
            height: viewDim.height * 0.9,
            width: viewDim.width * 0.9,
        };
    };

    /**
     * Get Kanban available size
     * @return {Object} size object
     */
    const _getKanbanSize = function () {
        var size = me.component.down("#kanbanContainer").getSize();

        return {
            height: size.height - 10, // magic number, to make kanban's internal horizontal scrollbar visible
            width: size.width,
        };
    };

    /**
     * Resize kanban to fill all available space
     */
    const _adjustKanbanSize = function () {
        if (!wxKanbanScroller) return;

        var size = me.component.down("#kanbanContainer").getSize();

        wxKanbanScroller.config.height = size.height - 10; // magic number, to make kanban's internal horizontal scrollbar visible
        wxKanbanScroller.config.width = size.width;
        wxKanbanScroller.resize();
    };

    /*************************************************************************
     *                           Template helpers                            *
     ************************************************************************/

    /**
     * Initialize card template using XTemplate or default Webix template
     */
    const _initTemplate = function () {
        if (!_configuration.useXTemplates) {
            // WebIX templates
            typeConfiguration = {
                name: "PATCards",
                template: _configuration.templates.template,
                templateAvatar: _configuration.templates.avatar,
                templateBody: _configuration.templates.body,
                templateFooter: _configuration.templates.footer,
                //templateAttachments: function (obj) { return ""; },
                //templateCopy: function (obj) { return ""; },
                //templateIcons: function (obj) { return ""; },
                //templateStart: function (obj) { return ""; },
                //templateEnd: function (obj) { return ""; },
                //templateTags: function (obj) { return ""; }
            };
        } else {
            // XTemplates
            typeConfiguration = {
                name: "PATCards",
            };

            if (_configuration.templates.template) {
                var xtpl = new Ext.XTemplate(_configuration.templates.template);
                Ext.apply(typeConfiguration, {
                    template: function (data) {
                        return xtpl.apply(data);
                    },
                });
            }

            // TODO: apply other templates here.
        }
    };

    const _addStatisticsTemplate = function (res) {
        if (_configuration.templates.statisticsTemplate) {
            var xtpl = new Ext.XTemplate(_configuration.templates.statisticsTemplate);
            var xtplStatistics = xtpl.apply({ statisticsResult: res });
            Ext.apply(typeConfiguration, {
                statisticsTemplate: xtplStatistics,
            });
        }
    };

    /*************************************************************************
     *                             Webix Kanban                              *
     ************************************************************************/

    /**
     * Refresh current kanban reloading data
     */
    const _refreshKanban = function () {
        wxKanban.clearAll();

        // reload data parsing get data result
        _updateKanban();
    };

    /**
     * Updates kanban configuration reloading all control and redrawing it
     */
    const _updateKanban = function () {

        var updateUI = function (data) {
            return new Promise(function (resolve, reject) {
                // remove old kanban
                if (wxKanban) wxKanban.destructor();
                if (wxKanbanScroller) wxKanbanScroller.destructor();
                _drawKanban(_kanbanData);
                //_adjustKanbanSize();
                resolve();
            });
        };

        var showHideErrorMessage = function (data) {
            if (!data || _.isEmpty(data)) {
                kanbanEl.addCls("empty icon-problem");
                kanbanEl.setHtml(translations.Portal_Err_InvalidPage);
            } else {
                kanbanEl.removeCls("empty icon-problem");
                kanbanEl.setHtml("");
            }
        };

        _getColumns()
            .then(function (data) {
                _kanbanData.cols = data;
                _kanbanData.cols.forEach(c => {
                    c.Description = Portal.Util.htmlEncode(c.Description);
                    c.OriginalDescription = c.Description;
                });
                showHideErrorMessage(data);
            })
            .then(_getDropOnlyColumns)
            .then(function (data) {
                _kanbanData.dropOnlyCols = data;
            })
            .then(_getData)
            .then(function (result) {
                _getDataAppliedFilters = result.filter;
                _kanbanData.data = result.data.map(function (e) {
                    return Ext.apply(e, { isValidating: false });
                });
            })
            .then(_initTemplate)
            .then(_setStatistics)
            .then(updateUI)
            .catch(function (error) {

            });
    };

    /**
     * Draw kanban with passed parameters
     * @param {Object} params kanban configuration
     * @param {Array} params.cols array of working columns
     * @param {Array} params.dropOnlyCols array of drop only columns
     * @param {Array} params.data array of cards to display in cols
     */
    const _drawKanban = function (params) {
        webix.extend(webix.ui.kanban, webix.ProgressBar);

        // register type
        webix.type(webix.ui.kanbanlist, typeConfiguration);

        var createUI = function (columns, dropOnlyColumns) {
            var kanbanRows = [];

            // first row: standard columns
            if (columns) {
                kanbanRows[0] = {
                    borderless: true,
                    cols: columns.map(function (v) {
                        return {
                            patColumnId: v.ID,
                            paddingX: 6,
                            margin: 0,
                            width: 300,
                            css: "standard-column",
                            rows: [
                                {
                                    view: "kanbanheader",
                                    type: "sub",
                                    label: v.Description,
                                    tooltip: { template: v.Description },
                                    icon: v.Icon
                                },
                                {
                                    view: "kanbanlist",
                                    status: v.ID,
                                    type: "PATCards"
                                }
                            ]
                        };
                    })
                };
            }

            // second row: drop only columns
            if (dropOnlyColumns) {
                // fake row to show when drop-only is hidden
                // webix batch management always shows a batch
                //kanbanRows[1] = {
                //    view: "spacer",
                //    batch: "batch0",
                //    hidden: true,
                //    borderless: true,
                //    height: 1
                //};
                kanbanRows[1] = {
                    batch: "batch1",
                    hidden: true,
                    borderless: true,
                    height: 120,
                    cols: dropOnlyColumns.map(function (v) {
                        return {
                            patColumnId: v.ID,
                            css: "drop-only-column",
                            paddingX: 5,
                            rows: [
                                { view: "kanbanheader", type: "sub", label: v.Description },
                                { view: "kanbanlist", status: v.ID, type: "PATCards" },
                            ],
                        };
                    }),
                };
            }

            return kanbanRows;
        };

        var handleItemDrop = function (itemId, status, list) {
            wxKanban.showProgress();

            var originalStatus = this.getItem(itemId).status;

            var getSaveParameters = function () {
                var params = _getRequestParameters();
                params.objectID = itemId;
                params.newStatus = status;
                return params;
            };

            var validate = function () {
                var params = getSaveParameters();
                return Portal.Util.Promises.ajaxGetPromise(_configuration.validateUrl, params);
            };

            var saveItem = function (result) {
                var params = getSaveParameters();
                return Portal.Util.Promises.ajaxGetPromise(_configuration.saveUrl, params);
            };

            var updateKanbanItem = function () {
                if (
                    !_.find(_kanbanData.dropOnlyCols, function (i) {
                        return i.ID === status;
                    })
                ) {
                    wxKanban.updateItem(itemId, { status: status, isValidating: false });
                } else {
                    _refreshKanban();
                }
            };

            var rollbackKanbanItem = function (error) {
                Portal.Util.Msg.showErrorToastMsg(error);
                wxKanban.updateItem(itemId, {
                    status: originalStatus,
                    isValidating: false,
                });
            };

            var cleanup = function () {
                wxKanban.hideProgress();
            };

            wxKanban.showProgress();
            validate()
                .then(saveItem)
                .then(updateKanbanItem)
                .catch(rollbackKanbanItem)
                .finally(cleanup);

            return true;
        };

        var handleStoreUpdate = function () {
            _setStatistics();
            _kanbanData.cols.forEach(col => {

                if (wxKanban) {
                    var kanbanCol = wxKanban.queryView({ patColumnId: col.ID });

                    if (kanbanCol) {
                        var kanbanColHeader = kanbanCol.getChildViews()[0];

                        if (kanbanColHeader && kanbanColHeader.config.label !== col.Description) {
                            kanbanColHeader.define("label", col.Description);
                            kanbanColHeader.refresh();
                        }
                    }

                }

            });
        }

        var openDetail = function (itemId, ev, node, list) {
            if (!_configuration.allowEdit) {
                return;
            }

            var popupSize = _getPopupSize();

            Portal.PageManager.openModule({
                mode: (_configuration.openMode && _configuration.openMode !== "" ? _configuration.openMode : "window"),
                url: Router.action("WSCView", "Detail", {
                    entity: _configuration.entity,
                    id: itemId,
                }),
                params: {},
                height: popupSize.height,
                width: popupSize.width,
                customParams: {
                    endDialogFn: function () {
                        _refreshKanban();
                    },
                },
            });
        };

        /*
         * findParentElement checking for class given class...
         *
         * since class can be applied to a parent (any)
         */
        var findParentElementByClass = function (el, cls) {
            var elRoot = me.component.getEl().dom;

            while (el != elRoot && el != null) {
                if (el.classList.contains(cls)) return el;

                el = el.parentElement;
            }

            // not found.
            return null;
        };

        var handleItemClick = function (itemId, ev, node, list) {
            if (findParentElementByClass(ev.target, "opener") != null) {
                openDetail(itemId, ev, node, list);
            }
        };

        webix.CustomScroll.init();

        wxKanbanScroller = webix.ui({
            id: kanbanScrollbarID,
            container: kanbanEl,
            scroll: "x",
            view: "scrollview",
            borderless: true,
            height: _getKanbanSize().height,
            width: _getKanbanSize().width,
            padding: 5,
            body: {
                editor: false,
                view: "kanban",
                borderless: false,
                margin: 0,
                rows: createUI(params.cols, params.dropOnlyCols),
                data: params.data,
                save: function (id, operation, params) { },
                on: {
                    onListItemClick: handleItemClick,
                    onListBeforeDrag: function () {
                        if (!_configuration.allowEdit) {
                            return false;
                        }
                        wxKanban.showBatch("batch1", true);
                    },
                    onListAfterDrop: function () {
                        wxKanban.showBatch("batch1", false);
                    },
                    onListBeforeDragIn(context, e, list) {
                        CustomAutoScroll.call(this);
                    },
                    onListDragOut() {
                        CustomAutoScroll.call(this);
                    },
                    onBeforeStatusChange: handleItemDrop,
                    "data->onStoreUpdated": handleStoreUpdate
                },
            },
        });

        wxKanban = wxKanbanScroller.getChildViews()[0];
    };

    const CustomAutoScroll = () => {
        const context = webix.DragControl.getContext(),
            node = webix.DragControl.getNode(),
            scrollView = $$(kanbanScrollbarID);

        if (node) {
            const nodePos = webix.html.offset(node),
                viewPos = webix.html.offset(scrollView.$view);

            const rightNodePos = nodePos.x + nodePos.width,
                rightViewPos = viewPos.x + viewPos.width,
                contentWidth = scrollView.getBody().$width,
                scrollPosX = scrollView.getScrollState().x;

            if (this._scrollDelay) {
                clearTimeout(this._scrollDelay)
            };

            if ((rightNodePos > rightViewPos) && (viewPos.width + scrollPosX < contentWidth)) {
                scrollView.scrollTo(scrollPosX + 20);
                this._scrollDelay = setTimeout(() => CustomAutoScroll(), 50);
            } else if ((nodePos.x < viewPos.x) && (scrollPosX > 0)) {
                scrollView.scrollTo(scrollPosX > 20 ? scrollPosX - 20 : 0);
                this._scrollDelay = setTimeout(() => CustomAutoScroll(), 50);
            }
        };
    }

    /**
     * Calculate Statistics and write on columns header
     * Possible type of statistics: count, sum, avg, min, max, custom
     */
    const _setStatistics = function () {
        return new Promise(function (resolve, reject) {
            if (!_configuration.statistics) { return resolve(); }

            var statisticsMethods = {
                count: function (data) {
                    return data.length;
                },
                sum: function (data) {
                    return _.reduce(data, (memo, el) => memo + el, 0)
                },
                avg: function (data) {
                    return statisticsMethods.sum(data) / data.length || 1;
                },
                min: function (data) {
                    var min = _.chain(data).min();
                    return min.isFinite().value() ? min.value() : 0;
                },
                max: function (data) {
                    var max = _.chain(data).max();
                    return max.isFinite().value() ? max.value() : 0;
                }
            }

            // custom statistics
            if (_configuration.statisticsType === "custom") {
                var params = _getRequestParameters();
                Portal.Util.Promises.ajaxGetPromise(_configuration.statisticsUrl, params)
                    .then(function (data) {
                        _kanbanData.cols.forEach(c => {
                            if (!data) return;
                            _addStatisticsTemplate(data[c.ID]);
                            c.Description = c.OriginalDescription + typeConfiguration.statisticsTemplate;
                        })
                        return resolve();
                    }).catch(function (e) { return reject(e); });

                return;
            };

            // no available standard statistics method
            if (!statisticsMethods[_configuration.statisticsType]) { return resolve(); }

            // no available statistic property
            if (_configuration.statisticsType !== "count" && !_configuration.statisticsProperty) { return resolve(); }

            // standard statistics
            _kanbanData.cols.forEach(function (col) {

                // get all property values of current column
                var columnData = _.chain(_kanbanData.data).filter((el) => el.status === col.ID).pluck(_configuration.statisticsProperty).value();
                // calculate statistics
                var result = statisticsMethods[_configuration.statisticsType].call(null, columnData);
                // update template with new statistics value
                _addStatisticsTemplate(result);
                // update column header description
                col.Description = col.OriginalDescription + typeConfiguration.statisticsTemplate

                return resolve();
            });
        });
    };

    /*************************************************************************
     *                               Commands                                *
     ************************************************************************/

    /**
     * Open a new kanban item detail popup
     */
    var _addNew = function () {

        var params = { detailMode: { Value: 'window', Mode: 'value' } };

        this.getContext("Command").createNew(params);
    };

    /**
     * Open kanban fullscreen
     */
    var _openFullScreen = function () {
        var actionLink = me.component,
            fullscreenButton = actionLink.down("#btnFullscreen");
        Portal.Util.Module.openModuleFullScreen(actionLink, fullscreenButton);
    };

    /*************************************************************************
     *                         System initialization                         *
     ************************************************************************/

    /**
     * Initialize context
     * @param {Object} initCfg starting configuration
     */
    const _init = function (initCfg) {

        // get module configuration parameters
        var params = Portal.Util.Json.decode(initCfg.moduleParams);
        params._Context = Portal.Util.Json.decode(params._Context);
        params.Filter = Portal.Util.Json.decode(params.Filter);
        _moduleParams = params;

        // get client configuration
        _clientCfg = initCfg.kanbanConfig;
        _clientCfg.filter = Portal.Util.Json.decode(_clientCfg.filter);

        // set working context for current component context(s)
        for (var ctxName in me.component.Context) {
            if (Ext.isFunction(me.component.Context[ctxName].setWorkingContext)) {
                me.component.Context[ctxName].setWorkingContext(me);
            }
        }

        me.component.on("afterrender", function () {

            // get components
            kanbanEl = me.component
                .down("#kanbanContainer")
                .contentEl.el.down(".kanban-container");
            comboboxEl = me.component.down("#entityTypes");

            // handle combo listeners
            me.mon(comboboxEl, "change", _updateKanban);
            comboboxEl
                .getStore()
                .on("load", function (store, records, successful, operation, eOpts) {
                    comboboxEl.setValue(store.getAt(0).data.ID);
                });

            // handle resize
            me.component.down("#kanbanContainer").on("resize", function () {
                _adjustKanbanSize();
            });

            // get control configuration
            _configuration = me.getConfiguration("model");
            if (_configuration) {
                Ext.apply(me.contextStatus, _configuration);
                me.contextStatus.recordType = _configuration.entity;
            }

            _initFilter();
            _updateKanban();
        });
    };

    const _initFilter = function () {

        _filterAreaCtx = me.getSiblingContext('FilterArea');

        me.onComponentReady(function () {

            initialFilter = [];
            _currentFilter = [];

            // bind filter values
            var filters = initialFilter.concat(_clientCfg.filter || []);

            if (_filterAreaCtx) {

                _filterAreaCtx.enableAdvancedFilters = false;

                _filterAreaCtx.setStandardFiltersArray(filters);
                _currentFilter = filters;

                me.component.onContextReady('FilterArea', function (ctx) {

                    // sync list filters with filter area ones
                    var areaFilters = Portal.Util.removeEmptyFilters(ctx.getFilter());
                    filters = Portal.Util.mergeFilterArrays(_currentFilter, areaFilters.conditions, true);
                    _currentFilter = filters;

                    ctx.filterSettings = _clientCfg.filterSettings;
                });

            } else if (filters && filters.length > 0) {
                _currentFilter = Ext.JSON.decode(filters);
            }


            // listen to filter change messages sent from filter area
            me.listenToMessage({
                topic: 'Portal.FilterArea.FilterChanged',
                messageFilter: 'samemodule',
                listenerFn: function (msg) {

                    var filters = msg.filters.conditions;

                    const filterChanged = Portal.Util.areFilterArraysDifferent(filters, _currentFilter);
                    if (!filterChanged) {
                        return;
                    }

                    _currentFilter = filters;
                    _updateKanban();

                },
                contextName: 'FilterArea'
            });

        });
    };

    /*************************************************************************
     *                         WSCViewContext member                         *
     ************************************************************************/

    const _removeDuplicatedValuesFromFilter = function (array) {
        return array.filter((value, index, self) =>
            index === self.findIndex(f => f.property === value.property &&
                f.op === value.op &&
                f.value === value.value &&
                f.extKey === value.extKey
            )
        )
    };

    // >> WSCViewContext member
    const _currentStatus = function () {
        const status = Portal.Util.cloneObj(me.contextStatus),
            objectTypeID = status.defaultObjectTypeID || comboboxEl.getValue(),
            typeFilter = [{ property: "ObjectTypeID", op: "eq", value: objectTypeID }];

        const detailFilter = _removeDuplicatedValuesFromFilter(_.union(_getDataAppliedFilters, typeFilter));

        Ext.apply(status, { filter: detailFilter });

        return status;
    };

    /*************************************************************************
     *                        WorkingContext Interface                       *
     ************************************************************************/

    /* [WorkingContext Interface] */
    /* Get Selection */
    const _getSelectedIDs = function () {
        return [];
    };

    /* [WorkingContext Interface] */
    /* Get Single ID */
    const _getSingleID = function () {
        var Ids = me.getSelectedIDs();
        if (Ids.length > 0) return Ids[0];
    };

    /* [WorkingContext Interface] */
    /* Check Selection Existance */
    const _ensureSelection = function () {
        if (me.getSelectedIDs().length == 0) {
            Portal.Util.Msg.showApplicationToastMsg({ msg: translations['WSC_SelectObjectFirst'], delay: 3000 });
            return false;
        }
        return true;
    };

    /* [WorkingContext Interface] */
    /* Check if Single Selection */
    const _ensureSingleSelection = function () {

        // Check Selection Existance
        if (!me.ensureSelection()) return false;

        // Check if Single Selection
        if (me.getSelectedIDs().length > 1) {
            Portal.Util.Msg.showApplicationToastMsg({ msg: translations['WSC_Msg_MultipleRecordNotAllowed'], delay: 3000 });
            return false;
        }

        return true;
    };

    /* [WorkingContext Interface] */
    /* Check Dirty and Execute Callback */
    const _checkDirty = function (fn, params) {
        fn(params);
    };

    /* [WorkingContext Interface] */
    /* Refresh Current WorkingContext */
    const _refresh = function () {
        _refreshKanban();
    };

    /*************************************************************************
     *                            Public Interface                           *
     ************************************************************************/

    return {
        contextName: "Kanban",
        dependencies: ["Portal.CommandContext"],
        init: function (initCfg) {
            me = this;
            initCfg = initCfg || {};

            Portal.Console.log("KANBAN INITIALIZATION");
            Portal.Console.log(initCfg);
            _init(initCfg);
        },

        // public properties
        contextStatus: {},

        // WSCViewContext member
        currentStatus: _currentStatus,

        // WorkingContext Interface
        getSelectedIDs: _getSelectedIDs,
        getSingleID: _getSingleID,
        ensureSelection: _ensureSelection,
        ensureSingleSelection: _ensureSingleSelection,
        checkDirty: _checkDirty,
        refresh: _refresh,

        // public methods
        addNew: _addNew,
        refresh: _refreshKanban,
        openFullScreen: _openFullScreen
    };
};


