Ext.define('Portal.ContextBase', {
    requires: ['Portal.ContextFactory'],
    mixins: {
        observable: 'Ext.util.Observable'
    },

    id: null,

    ready: false,

    //me: null,

    /* Ext.Component which this context is related to */
    component: null,

    /* Context name, a property with the same name will be created under component's Context property. Default context has no name. */
    contextName: null,

    /* Empty container for all promise functions */
    promises: {},

    /* Constructor for base context class */
    constructor: function (config) {
        var me = this;

        if (config.mixins) {
            Ext.Object.merge(this.mixins, config.mixins);
            delete config.mixins;
        }

        Ext.apply(this, config || {});

        me.id = me.component.id + '_' + me.contextName;

        me.mixins.observable.constructor.call(me, config);

        me.component.addListener('beforedestroy', me.onContextBeforeDestroy, me);
        me.component.addListener('destroy', me.onContextDestroy, me);
    },

    init: function (initCfg) {
        // do nothing
    },

    callFn: function (fnName, args) {
        if (Ext.isFunction(this[fnName])) {
            this[fnName].apply(this, args);
        }
    },

    onComponentReady: function (callback) {
        var me = this;
        if (me.component.rendered) {
            callback.apply(me);
        } else {
            me.component.addListener(
                'afterRender',
                function () {
                    callback.apply(me);
                },
                me,
                { single: true }
            );
        }
    },

    path: function () {
        var moduleCtx = this.component.getContext('Module');
        return moduleCtx.path() + '/' + this.id;
    },

    // helper function to get a Context object from current Context
    getContext: function (name, recursive) {
        var ctx = this.component.getContext(name);
        if (!recursive || !Ext.isEmptyObj(ctx)) return ctx;

    },

    // checks if current context has a sibling context having the specified name
    hasSiblingContext: function (name) {
        return this.component.hasOwnContext(name);
    },

    // gets a sibling context having the specified name (not recursive)
    getSiblingContext: function (name) {
        if (this.hasSiblingContext(name)) return this.component.getOwnContext(name);
        return null;
    },

    /* Finds a descendant component by its id */
    getCmp: function (id, xtype) {

        xtype = xtype || '';

        // search using "ends with" operator, otherwise use "equal to"
        var cmp = (this.component.down(xtype + '[id$=_' + id + ']') || this.component.down(xtype + '[id=' + id + ']'));
        return cmp;
    },

    buildUniqueId: function (id) {
        return this.component.id + '_' + id;
    },

    /*
        Adds a MessageBus subscription evaluating the given conditions:
        - topic: the topic the listener is interested to;
        - messageFilter: 
            . public (default): all messages sent with the given topic;
            . private: messages coming from the same context path of current module only;
        - listenerFn: the function that will be called when message is received;
        - contextName (optional): type of the message sender context the listener is interested to;
    */
    listenToMessage: function (cfg) {
        var ctx = this,
            portalTab = null,
            fn;

        if (ctx.component) portalTab = ctx.component.up('[portalTab]');

        Ext.applyIf(cfg, {
            messageFilter: 'public',
            portalTab: portalTab
        });

        fn = function (topic, data, config) {
            Portal.MessageBus.using(data, ctx).isValidMessage(cfg);
        };

        var subscribeFn = Portal.MessageBus.subscribe(cfg.topic, fn);

        var unsubscribeFn = function () {
            Portal.MessageBus.unsubscribe(cfg.topic, subscribeFn);
        };

        // add an unsubscription call on component destroy
        ctx.component.addListener('destroy', unsubscribeFn);

        return unsubscribeFn;
    },

    getStatus: function () { },

    setStatus: function () { },

    safeDelayedTask: function (delayFn) {
        var me = this;

        return new Ext.util.DelayedTask(function () {

            // if component doesn't exist or is destroyed then exit
            if (!me.component || me.component.isDestroyed) {
                return;
            }

            delayFn.apply(me, arguments);
        });
    },

    getConfigurationHolder: function () {
        var holder = _.findWhere(this.component.bin, { ConfigurationHolder: true });
        return holder;
    },

    getConfiguration: function (key) {
        var holder = this.getConfigurationHolder(),
            config = holder[key];

        return Portal.Util.Json.decode(config, true);
    },

    onContextBeforeDestroy: function () {
        return this.fireEvent('beforedestroy', this);
    },

    onContextDestroy: function () {
        this.fireEvent('destroy', this);
        this.destroy();
    }
});
Ext.ns('Portal');

Ext.define('Portal.ModuleContainer', {

    statics: {

        getRootContainer: function () {
            return Portal.PageManager;
        },

        hasContainerId: function (params) {
            return Ext.isDefined(params.containerId);
        },

        isContainerIdDifferentFromLoaderTarget: function (params, target) {
            return (params.containerId.indexOf(target.id) < 0);
        },

        ensureRightContainerId: function (params, target) {
            if (!Portal.ModuleContainer.hasContainerId(params) ||
                    Portal.ModuleContainer.isContainerIdDifferentFromLoaderTarget(params, target)) {

                // this usually happens when loader containerId param is computed server-side 
                // and Ext.Net has not yet built the real ClientID for the loader target component
                // or if the loader target component has an empty ID

                params.containerId = target.id;
            }
        },

        /*
         * Forwards to current module loader all parent module parameters that are named with a special convention 
         * following the "ActionLinkItemID.ParameterName" pattern.
         * 
         * For example: assuming current loader target itemId is "ActionLinkItemID"
         * and that parent module is passing a parameter named "ActionLinkItemID.ParameterName" with value "ParameterValue",
         * then this function will inject into current loader parameters a new parameter having name "ParameterName" and value "ParameterValue".
         */
        mergeParentModuleParams: function (loader, target, options) {
            var parentModuleCtx = target.getContext('Module');

            if (parentModuleCtx) {

                var paramNamePrefix = target.itemId + '.';

                var myModuleParams =
                    _.pick(
                        parentModuleCtx.getModuleParams(),
                        function (value, key) {
                            return Ext.String.startsWith(key, paramNamePrefix);
                        });

                var loaderExtraParams = {};
                _.each(myModuleParams, function (value, key) {
                    loaderExtraParams[key.substring(paramNamePrefix.length)] = value;
                });

                if (!_.isEmpty(loaderExtraParams)) {
                    var currentParams = options.params || {};
                    Ext.applyIf(currentParams, loaderExtraParams);

                    options.params = currentParams;
                }

            }
        },

        /*
            containerCfg
            - openingMode: module opening mode [window, tab, childmodule];
            - collapseTitleToContainer: true to collapse module title to container title;
            - parentContainer (context object or function):
              The module context thah will be the parent module for the new loaded module; otherwise the function that returns the context that will be the parent of the newly created module;
              if no parent is specified than the new module will be created as child of the root module container (PageManager);
            - callbackFn: function(moduleComponent, moduleContext) callback fn that will be called when module context is loaded and ready;
        */
        buildOnModuleRemoteLoading: function (containerCfg) {
            containerCfg = containerCfg || {};

            Ext.applyIf(containerCfg, {collapseTitleToContainer: true});

            return function (loader, options, eOpts) {

                Portal.Console.log(['MODULE_CONTAINER', 'Loading remote module', 'Url: ' + loader.url]);
                
                var containerCmp = loader.target;

                loader.target.loadStatus = 'loading';

                Portal.ModuleContainer.ensureRightContainerId(options.params, loader.target);

                Portal.ModuleContainer.mergeParentModuleParams(loader, loader.target, options);

                // prepare container configuration that will be used from module when it's loaded to setup module hierarchy
                Ext.apply(containerCmp, {
                    moduleOpenerConfig: {
                        containerId: containerCmp.id,
                        url: loader.url,
                        params: loader.params,
                        openingMode: containerCfg.openingMode || 'childmodule',
                        parentContainer: (typeof containerCfg.parentContainer == 'function' ? containerCfg.parentContainer() : containerCfg.parentContainer),
                        callbackFn: containerCfg.callbackFn,
                        collapseTitleToContainer: containerCfg.collapseTitleToContainer,
                        showInnerTitle: containerCfg.showInnerTitle,
                        customParams: containerCfg.customParams
                    }
                });

                if (containerCfg.contentScrollMode !== 'Auto') {

                    // forward contentScrollMode config to child module

                    loader.target.on('beforeadd', function (actionLink, module, position) {
                        if (module && module.getContentScrollMode() === 'Auto') {
                            module.setContentScrollMode(containerCfg.contentScrollMode);
                        }
                    });
                }
            };
        },

        onContainerBeforeClose: function (cmp, opts) {
            var moduleCtx = Portal.ModuleContainer.getContainerClosingTarget(this);
            if (moduleCtx) return moduleCtx.fireEvent('modulebeforeclose', function () { moduleCtx.close(); });

            return true;
        },

        onContainerClose: function (cmp, opts) {
            var moduleCtx = Portal.ModuleContainer.getContainerClosingTarget(this);
            if (moduleCtx) moduleCtx.fireEvent('moduleclose');
        },

        onContainerLoad: function (loader, response, options, eOpts) {
            Portal.Console.log(['MODULE_CONTAINER', 'Loaded', 'Url:' + loader.url, loader.params]);

            if (loader.target) {
                loader.target.loadStatus = 'ready';
            }
        },

        onContainerLoadException: function (loader, response, options) {

            var errData = ['MODULE_CONTAINER'];

            if (response.aborted) {
                errData.push('REQUEST CANCELED');
            } else if (response.timedout) {
                errData.push('REQUEST TIMEOUT');
            } else {
                errData.push('ERROR');
            }

            errData.push('Status:' + response.status);

            if (response.statusText) {
                errData.push('StatusText:' + response.statusText);
            }

            if(!response.__exceptionHandled) Portal.Error.traceResponse('MODULE LOAD ERROR', response);

            if (loader) errData.push('Url:' + loader.url);

            Portal.Console.error(errData);

            if (loader.target) {

                loader.target.loadStatus = 'error';

                // when response is aborted (canceled), 
                // then avoid to update the target content with the error placeholder 
                // because a new load request has started and will update the content when it completes
                if (!response.aborted) {
                    loader.target.addCls('load-error');
                    loader.target.removeAll();
                    loader.target.update(Portal.PageManager.generatePlaceholderHtml(translations['Portal_ModuleLoadError']));
                }
            }
        },

        getContainerClosingTarget: function (cmp) {
            var targetCmp;

            if (Portal.ModuleContainer.isModule(cmp))
                targetCmp = cmp;
            else
                targetCmp = Portal.ModuleContainer.getSingleChildModule(cmp); // current cmp is a container for a single module

            if (targetCmp)
                return targetCmp.getContext('Module');

            return null;
        },

        isModule: function (cmp) {
            return cmp.hasOwnContext('Module');
        },

        getSingleChildModule: function (cmp) {
            return cmp.items.getAt(0);
        },

        doReload: function (cmp, cfg) {
            var loader = cmp.getLoader();
            var url = cfg.url || loader.url;

            // if module loader request is still running, cancel it
            if (Portal.ModuleContainer.isLoading(cmp))
                Portal.ModuleContainer.cancelLoading(cmp);

            loader.url = url;

            // update opener config url
            if (cmp.moduleOpenerConfig) {
                if (cmp.moduleOpenerConfig.params && cmp.moduleOpenerConfig.params.filter) {
                    var filtersToSkip = ['templateid'];
                    var reloadFilters = [];

                    var filters = Portal.Util.Json.decode(cmp.moduleOpenerConfig.params.filter);
                    if (Ext.isArray(filters)) {
                        _.each(filters, function (f) {
                            if (f && f.property && !_.contains(filtersToSkip, f.property.toLowerCase())) reloadFilters.push(f);
                        });

                        // set new filters as reload params (overwrite existing ones)
                        cmp.moduleOpenerConfig.params.filter = Portal.Util.Json.encode(reloadFilters);
                    }
                }
                Ext.apply(cmp.moduleOpenerConfig, { url: url });
            }

            if (cfg.loadingMask)
                loader.loadMask = cfg.loadingMask;

            loader.load(cfg);
        },

        reload: function (cmp, cfg) {
            if (!cmp.moduleContainerReloadTask) {
                cmp.moduleContainerReloadTask = new Ext.util.DelayedTask(Portal.ModuleContainer.doReload);
            }

            cmp.moduleContainerReloadTask.delay(cfg.delay || 0, null, cmp, [cmp, cfg]);
        },

        isLoading: function (cmp) {
            var loader = cmp.getLoader();

            return (loader && loader.getTarget() && loader.getTarget().loadStatus === 'loading');
        },

        cancelLoading: function (cmp) {
            var loader = cmp.getLoader();

            Portal.Console.log(['MODULE_CONTAINER', 'Cancelling load request', 'Url:' + loader.url, loader.params]);

            loader.abort();
        }
    },

    constructor: function (ctorCfg) {
        var me = this;

        // public props and methods

        Ext.apply(me, {

            isModuleContainer: true,

            modules: {},

            getModule: function (id) {
                return me.modules[id];
            },

            getModules: function () {
                var arr = [];
                if (me.modules) {
                    for (var moduleID in me.modules) {
                        arr.push(me.modules[moduleID]);
                    }
                }
                return arr;
            },

            /*
                Search a module by part of its name.
                Deep search is supported (deep : true|false)
            */
            findModules: function (searchfor, deep) {
                var arr = [];
                var deep = deep || false;

                if (me.modules) {
                    for (var moduleID in me.modules) {
                        var thisModule = me.modules[moduleID]
                        if (moduleID.indexOf(searchfor) >= 0)
                            arr.push(thisModule);

                        if (deep && typeof (thisModule.findModule) == "function") {
                            arr = arr.concat(thisModule.findModule(searchfor, deep));                            
                        }
                    }
                }

                return arr;
            },

            registerModule: function (moduleCtx) {
                if (me.modules) me.modules[moduleCtx.id] = moduleCtx;
            },

            deregisterModule: function (id) {
                if(me.modules) delete me.modules[id];
            },

            openModule: function (cfg) {
                // do nothing
            },

            closeModule: function (moduleId) {
                Portal.Console.log('MODULE CONTAINER CLOSE [' + moduleId + ']');
                Portal.Console.log(me.modules);

                if (me.modules[moduleId]) {
                    me.modules[moduleId].close();
                }
            }
        });

        // listeners

        me.on('modulebeforeclose', function (callback) {
            //Portal.Console.log('MODULE CONTAINER NOTIFY CLOSE REQUEST');
            //Portal.Console.log(me.modules);

            //chiede a tutti i figli
            for (var moduleCtxId in me.modules) {
                if(!me.modules[moduleCtxId].fireEvent('modulebeforeclose', callback))
                    return false;
            }
            return true;
        });

        me.on('moduleclose', function () {
            //Portal.Console.log('MODULE CONTAINER NOTIFY CLOSE');
            //Portal.Console.log(me.modules);

            for (var moduleCtxId in me.modules) {
                me.modules[moduleCtxId].fireEvent('moduleclose');
            }
            delete me.modules;
        });

    }
});
