    openDetailView: function () {

        var detailMode = this.getDetailOpeningMode();
        if (detailMode === 'none') return;

        var value = this.getValue();

        // if field has no value or has a temporary typed value then skip
        if (!value || value == Portal.Const.EMPTY_ID /*|| this.typing*/) return;

        var url;

        if (this.detailUrl)
            url = this.detailUrl.replace(Portal.Const.Url.ID_PLACEHOLDER, value);
        else
            url = Router.action("WSCView", 'Detail', { entity: this.recordType, id: value });

        // open object detail view
        Portal.PageManager.openModule({
            mode: this.getDetailOpeningMode(),
            url: url,
            parentContainer: this.getContext('Module')
        });
    },
    openSearchView: function (searchValue) {
        var me = this;

        if (this.searchViewOpened) return;

        this.searchViewOpened = true;
        this.setLoadingMode(true);

        // extract query string parameters from url
        var urlTokenized = /([^?]*\??)(.*)/.exec(this.searchUrl);
        var urlParameter = this.searchUrl;
        var paramsObj = Ext.urlDecode(urlTokenized[2]);
        var urlFilters = [];
        var params = {};

        if (paramsObj.filter) {
            urlFilters = Ext.decode(paramsObj.filter);
            //field.searchFilter = Portal.Util.mergeFilterArrays(field.searchFilter, Ext.decode(paramsObj.filter));
            delete paramsObj.filter
            urlParameter = urlTokenized[1] + Ext.urlEncode(paramsObj);
        }

        var typedFilter = [];

        if (this.typing) {
            typedFilter.push({
                property: this.immediateSearchField,
                value: searchValue || this.getTypedValue(),
                op: this.immediateSearchOperator
            });
        }

        var filter = [];
        if (this.searchFilters) filter = [].concat(this.searchFilters);

        filter = Portal.Util.mergeFilterArrays(filter, urlFilters);
        filter = Portal.Util.mergeFilterArrays(filter, typedFilter);

        params.objectLinkControl = this.getId();
        if (filter) params.filter = Portal.Util.Json.encode(filter);

        // open object detail view
        var win = Portal.PageManager.openModule({
            mode: 'objectLink',
            url: urlParameter,
            parentContainer: this.getContext('Module'),
            params: params,
            callbackFn: function (cmp, ctx) {
                ctx.mon(ctx, 'moduleclose', function () {
                    me.onSearchViewClose();
                })
            }
        });

        win.on('close', function () {
            // ensure to call search close callback even in case of errors, when no 'moduleclose' event will be fired
            if (me.searchViewOpened)
                me.onSearchViewClose();
        });

    },

    onSearchViewClose: function () {
        this.searchViewOpened = false;
        this.setLoadingMode(false);
        this.focus();
    },

    removeErrorStyles: function () {
        if (!this.inputEl) return;
        this.inputEl.removeCls('objectlink_object-not-found');
        this.inputEl.removeCls('objectlink_object-not-visible');
        this.inputEl.removeCls('objectlink_object-not-available');
    },

    /*** Set object, value and description of an objectlink, managing initialization state and valueresolved event. ***/
    setObjectLinkData: function (object, value, description, style) {

        this.removeErrorStyles();

        // sostituita chiamata a clearValue per evitare di scatenare evento change con valore vuoto prima di impostare l'effettivo valore.
        //this.clearValue();
        var store = this.getStore();
        if (store) { store.removeAll(); }
        this.lastQuery = '';
        this.pendingValue = null;

        // Set Data        
        this.selectedObject = object;
        this.setRecord(value, description);
        this.setValue(value, null, true);        

        // Set ObjectLink as Initialized
        var initialized = !this.initializing;
        if (this.initializing) {
            this.resetDirty();
            this.initializing = false;
            this.fireEvent('initialized', this);
        }

        // Configuration & Events
        this.checkValidationEvaluation();
        if (this.inputEl && style) this.inputEl.addCls(style);
        if (object) this.fireEvent('valueresolved', this, value, description, initialized);

    },

    /*
     * Loads object description corresponding to the passed value. The function calls server action to get the decription,
     * adds a new item to the object link associated store and then calls the original setValue (of ComboBox) function.
     */
    loadObjectData: function (newValue, callbackFn) {
        var rec = {};
        var oldValue = this.getValue();
        var errorCode;
        var errorMsg;
        var errorValue;
        var errorCls;

        this.pendingValue = newValue;

        // use Ext UrlEncode method (workaround passing "v" as querystring param since it uses only objects as param)
        var newValueEncoded = Ext.urlEncode({ v: newValue }).substring(2);

        //return;

        Ext.Ajax.request({
            url: this.dataResolutionUrl.replace(Portal.Const.Url.ID_PLACEHOLDER, newValueEncoded),
            method: 'GET',
            scope: this,
            success: function (response, options) {
                var responseObj = Ext.decode(response.responseText),
                    store = this.getStore();

                if (!responseObj.success) {
                    Portal.Console.error('object link loading response ko: ' + responseObj.result.code + ' ' + responseObj.result.desc);

                    switch (responseObj.result.code) {

                        case Portal.WSC.OperationManager.ObjectNotFound:

                            switch (responseObj.result.subcode) {

                                case '2':

                                    errorCode = 'Error_ObjectNotVisible';
                                    errorValue = newValue;
                                    errorMsg = translations['WSC_Error_ObjectNotVisible'];
                                    errorCls = 'objectlink_object-not-visible';

                                    break;

                                default:

                                    errorCode = 'Error_ObjectNotFound';
                                    errorValue = '';
                                    errorMsg = translations['WSC_Error_ObjectNotFound'];
                                    errorCls = 'objectlink_object-not-found';
                            }

                            break;

                        case Portal.WSC.OperationManager.OtherError:

                            errorCode = 'Error_ObjectNotAvailable';
                            errorValue = newValue;
                            errorMsg = translations['WSC_Error_ObjectNotAvailable'];
                            errorCls = 'objectlink_object-not-available';

                            Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_ServerCommunicationError'] + '<br/>' + responseObj.result.desc);

                            break;

                        default:

                            errorCode = 'Error_ObjectLoading';
                            errorValue = newValue;
                            errorMsg = translations['WSC_Error_ObjectLoading'];
                            errorCls = 'objectlink_object-not-available';
                    }

                    this.setObjectLinkData(null, errorValue, errorMsg, errorCls);

                    this.fireEvent('valueresolutionerror', this, errorCode, errorMsg);

                } else {
                    //Portal.Console.log('object link loading ok (value=' + newValue + ', desc=' + responseObj.data.ObjectDescription + ")");

                    var objDescription = '';
                    if (responseObj.data) {
                        if (responseObj.data.ObjectDescription) objDescription = this.cleanupDescription(responseObj.data.ObjectDescription);
                        this.setObjectLinkData(responseObj.data, newValue, objDescription);
                    }
                }

            },
            failure: function (response, options) {

                // Ajax request KO

                errorCode = 'Error_ObjectLoading';
                errorMsg = translations['WSC_Error_ObjectLoading'];

                Portal.Console.error(['object link', 'loading call ko', response.status, response.statusText]);

                this.setObjectLinkData(null, newValue, errorMsg, 'objectlink_object-not-available');

                this.fireEvent('valueresolutionerror', this, errorCode, errorMsg);
            }
        });
    },

    immediateSearch: function () {
        var me = this;
        if (!me.typing) return;
        if (me.searchViewOpened) return;

        var searchValue = me.getTypedValue(),
            filter = [];

        if (me.searchFilters) {
            filter = filter.concat(me.searchFilters);
        }

        // add custom search filter to general search filter
        filter = Portal.Util.mergeFilterArrays(
            [{ property: me.immediateSearchField, value: searchValue, op: me.immediateSearchOperator }],
            filter
        );

        me.executeSearch(filter, 2)
            .then(function (response) {
                Portal.Console.log('object link custom search ok');

                if (response.total == 1) {
                    // one match, select this item

                    var objDescription = me.cleanupDescription(response.data[0].Description);

                    me.typing = false;
                    me.setRecord(response.data[0].ID, objDescription);
                    me.setValue(response.data[0].ID);
                    me.clearInvalid();

                    // now valid.
                    me.objectLinkValid = true;
                } else {
                    // more than 1 item match the search text, open search view                        
                    me.openSearchView(searchValue);
                }
            })
            .catch(function (response) {

                if (!response) {

                    // Ajax request KO

                    Portal.Console.error('object link custom search call ko: ' + response.status + ' ' + response.statusText);

                    Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_ServerCommunicationError'], +response.status + ' ' + response.statusText);

                    me.fireEvent('immediatesearchexception', me);

                    return;
                }

                Portal.Console.error('object link custom search response ko: ' + response.result.code + ' ' + response.result.desc);
                Portal.Console.error('name: ' + me.immediateSearchField + ', value: ' + me.getTypedValue());

                me.clearValue(true);
                me.inputEl.setValue(searchValue);
                me.markInvalid(translations['WSC_Msg_ObjectLinkSearchFailure']);

                // invalid.
                me.objectLinkValid = false;

                me.fireEvent('immediatesearcherror', me);
            });
    },

    executeSearch: function (filter, limit) {
        var me = this;

        var promise = new Promise(function (resolve, reject) {

            me.setLoadingMode(true);

            Portal.Console.log(['Immediate Search starting', me.getName()]);

            Ext.Ajax.request({
                url: me.immediateSearchUrl,
                method: 'GET',
                params: {
                    filter: Portal.Util.Json.encode(filter),
                    searchFieldName: me.immediateSearchField,
                    limit: limit || '20'
                },
                success: function (response, options) {

                    me.setLoadingMode(false);

                    // Ajax request OK
                    var responseObj = Ext.decode(response.responseText);

                    Portal.Console.log(['Immediate Search result', me.getName(), 'success']);

                    if (!responseObj.success) {
                        Portal.Console.error('object link custom search response ko: ' + responseObj.result.code + ' ' + responseObj.result.desc);
                        Portal.Console.error('name: ' + me.immediateSearchField + ', value: ' + me.getTypedValue());

                        reject(responseObj);

                    } else {
                        Portal.Console.log('object link custom search ok');

                        resolve(responseObj);

                    }
                },
                failure: function (response, options) {

                    me.setLoadingMode(false);

                    // Ajax request KO
                    Portal.Console.error('object link custom search call ko: ' + response.status + ' ' + response.statusText);
                    Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_ServerCommunicationError'], +response.status + ' ' + response.statusText);

                    reject();
                }
            });
        });

        return promise;
    },

    autoResolve: function (filter) {
        var me = this;

        filter = filter || [];
        if (me.searchFilters) {
            filter = Portal.Util.mergeFilterArrays(filter, me.searchFilters);
        }

        //  execute search without search filter and if result contains a single item then auto-select it
        this.executeSearch(filter, 2)
            .then(function (response) {
                if (response.total == 1) {

                    if (me.getValue() != response.data[0].ID) {

                        // one match, select this item
                        var objDescription = me.cleanupDescription(response.data[0].Description);

                        me.typing = false;
                        me.setRecord(response.data[0].ID, objDescription);
                        me.setValue(response.data[0].ID);
                        me.clearInvalid();

                        // now valid.
                        me.objectLinkValid = true;
                    }

                    me.checkValidationEvaluation();
                }
            })
            .catch(function (response) {
                // do nothing
            });
    },


