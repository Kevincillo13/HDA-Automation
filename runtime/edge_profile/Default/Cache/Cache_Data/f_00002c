                    window.globalSpeechRecognition.abort();
                    window.globalSpeechRecognition.onresult = function (event) {
                        if (event.results.length > 0) {
                            var current = event.results[event.results.length - 1][0];
                            instance.setValue(instance.getValue() + current.transcript);
