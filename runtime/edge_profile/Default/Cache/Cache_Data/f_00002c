        /**
         * Standard RecordClone command handler - Opens a new detail module, loading data by cloning the specified object.
         * NOTE: the original object is cloned but not yet saved when detail module is loaded.
         *
         * @param {Object} params The parameters for record clone command.
         * @param {string} params.RecordViewID The ID of the record view we want to open.
         * @param {string} params.detailMode the edit record view opening mode.
         *                 Supported values: {tab [DEFAULT], window}
         */
        cloneRecord: function (params) {

            // cloning a record means passing the "ID" as filter
            var status = workingCtx.currentStatus(),
                selectedObjectIDs = getSelectedobjectIDs(),
                currentParams = null,
                operationFilter = null,
                filterArr = [],
                loadUrl = Portal.Util.buildDetailUrl(status.detailUrl, Portal.Const.EMPTY_ID),
                data = null;

            var doCloneRecord = function () {
                Portal.Util.Msg.confirm(
                    translations['WSC_Detail'],
                    translations['WSC_Msg_CloneRecordConfirm'],
                    function (ans) {
                        var entityID = null;

                        if (ans == 'yes') {

                            currentParams = Portal.CommandContext.Utils.prepareOperationParams(status, params, true);
                            var modePage = currentParams.detailMode || status.detailMode;
                            entityID = selectedObjectIDs[0];
                            params = {
                                filter: {
                                    Mode: "value",
                                    Value: JSON.stringify({
                                        property: "ID",
                                        value: entityID,
                                        op: "eq",
                                        extKey: 'CLONERECORD'
                                    })
                                }
                            };
                            if (currentParams.RecordViewID)
                                params.RecordViewID = { Mode: "value", Value: currentParams.RecordViewID };

                            currentParams = Portal.CommandContext.Utils.prepareOperationParams(status, params, true);

                            Portal.PageManager.openModule({
                                mode: modePage,
                                url: loadUrl,
                                params: currentParams
                            });
                        }
                    });
            };

            Portal.Console.log('cloneRecord');
            Portal.Console.log(status);
            Portal.Console.log(params);

            if (workingCtx.contextName == 'Detail' || workingCtx.contextName == 'DetailView') {
                if (!workingCtx.isDirty()) {
                    // form data not changed, do change type operation
                    doCloneRecord();
                    return;
                }

                workingCtx.promises.validate()
                    .then(function () {
                        data = status.data;

                        myMask.show();

                        // execute save operation
                        Portal.WSC.OperationManager.doObjectOperation({
                            objId: selectedObjectIDs[0],
                            objData: data,
                            objUrl: status.saveUrl,
                            successFn: function (responseObj) {
                                // in case of successful result do change type operation
                                myMask.hide();
                                doCloneRecord();
                            },
                            failureFn: function (responseObj) {
                                myMask.hide();
                                Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_OperationFailed'], responseObj);
                            }
                        });
                    })
                    .catch(function (errors) { /* do nothing */ });

            }
            else if (workingCtx.contextName == 'List') {
                if (selectedObjectIDs.length == 0)
                    return;
                if (selectedObjectIDs.length != 1)
                    Portal.Util.Msg.showErrorMsg(translations['WSC_Msg_MultipleRecordNotAllowed']);
                else
                    doCloneRecord();
            }
        },

