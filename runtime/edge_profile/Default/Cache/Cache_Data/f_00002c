Ext.define('Portal.Navigation.HistoryManager', {

    config: {

        /*
            Tells which level of history the history manager instance is interested to. 0 = root.
        */
        historyLevel: 0,

        /*
            If a level > 0 is specified, the history prefix is used to check if a history change has to be communicated to current history manager instance.
            If historyPrefix is specified and historyLevel > 0, history change fn will be called only if the new history token has the specified prefix.
        */
        historyPrefix: undefined,

        /*
            Observable object current history manager will be attached to.
        */
        historySource: null
    },

    constructor: function (ctorCfg) {
        var me = this;

        me.initConfig(ctorCfg);

        if (Ext.isFunction(me.onHistoryChange))
            Portal.History.onChange(me);
    },

    /*
     * History manager initialization
     */
    init: Ext.emptyFn,

    /*
     * Actions to do when history changes (if a historyLevel was specified, then history change will be linked to the specific history level required)
     */
    onHistoryChange: Ext.emptyFn,

    /*
     * Updates component history and navigate to location
     */
    updateHistory: function (navData) {

    },
    
    /*
     * Updates current history token (for the specific level)
     */
    addHistoryLevel: function (hash) {
        Portal.History.addLevel(hash, this.getHistoryLevel());
    },

    /*
     * Returns current history token (according to manager history "level")
     */
    getToken: function () {
        return Portal.History.getToken(this.getHistoryLevel());
    }
    
});
