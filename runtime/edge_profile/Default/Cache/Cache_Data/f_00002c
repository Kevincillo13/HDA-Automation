                        Portal.Console.error('remote loading wsc response ko: ' + responseObj.result.code + ' ' + responseObj.result.desc);
                        Ext.MessageBox.alert('Server communication error', responseObj.result.desc);
                    } else {
                        Portal.Console.log(logPrefix + 'remote loading ok');

                        // setting values to form
                        loadData(response.data);
                    }
                },
                failure: function (response, options) {
                    // Ajax request KO
                    Portal.Console.error(['Detail', 'remote loading call ko', response.status, response.statusText]);
