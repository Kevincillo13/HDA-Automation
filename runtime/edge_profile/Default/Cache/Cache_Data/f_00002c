            }

            return paramToCheck;
        };

        var buildEmptyWindowConfig = function (cfg) {
            Ext.applyIf(cfg, { openingMode: cfg.mode || 'window' });

            var defaultViewSize;
            var winCfg = {
                title: cfg.title || '...',
                modal: true,
                autoScroll: (Ext.isDefined(cfg.autoScroll) ? cfg.autoScroll : false),
                closable: (Ext.isDefined(cfg.closable) ? cfg.closable : true),
                resizable: (Ext.isDefined(cfg.resizable) ? cfg.resizable : true),
                hidden: true,
                constrainHeader: true,
                closeAction: cfg.closeAction || 'destroy',
                layout: 'fit',
                border: false,
                titleAlign: 'left',
                cls: cfg.cls,
                ready: false,

                // custom attribute, to mark this component as a module container
                moduleContainer: true,

                // custom attribute, to mark this component as a portal window
                portalWindow: true,

                // custom attribute, to mark if we must show window on module load
                autoShowOnModuleLoad: (Ext.isDefined(cfg.autoShowOnModuleLoad) ? cfg.autoShowOnModuleLoad : true),
                closeOnHistoryChange: (Ext.isDefined(cfg.closeOnHistoryChange) ? cfg.closeOnHistoryChange : true),

                listeners: {
                    'beforeclose': Portal.ModuleContainer.onContainerBeforeClose,
                    'close': Portal.ModuleContainer.onContainerClose,
                    'show': {
                        fn: function () {
                            this.ready = true;
                            this.fireEvent('ready', this);
                        },
                        single: true
                    }
                }
            };

            if (Portal.Const.Device.IsMobile) {

                // IMPORTANT - We must set width/height to 100% instead of "maximized=true"
                //             because list modules (with infinite scrolling view) have issues when opened as maximixed windows
                //             (it seems that in that case window's layout isn't able to calc the available height the grid view uses
                //             to setup infinite scrolling).
                //             We force maximization by setting width/height to 100% and attaching a handler to 'move' event.

                // mobile devices - popup in full screen mode by default
                Ext.apply(winCfg, {
                    width: "100%",
                    height: "100%",
                    maximizable: false,
                    draggable: false,
                    resizable: false
                });

                winCfg.listeners = winCfg.listeners || {};

                Ext.apply(winCfg.listeners, {
                    'move': {
                        fn: function (win, x, y) {

                            const winBox = this.getBox();
                            const bodyBox = Ext.getBody().getBox();

                            if (this.isVisible()) {

                                // force maximization when window component box differs from the body one
                                if (winBox.width !== bodyBox.width || winBox.height !== bodyBox.height || winBox.top !== bodyBox.top || winBox.left !== bodyBox.left) {
                                    this.maximize();
                                }
                            }
                        },
                        buffer: 300
                    }
                });

            } else {

                // desktop devices - popup size calculated
                defaultViewSize = Portal.Util.getDefaultModalViewSize();

                var size = null;
                if (cfg.size) {
                    switch (cfg.size) {
                        case "fullsize":
                            size = "98%";
                            break;
                        case "large":
                            size = "80%";
                            break;
                        case "medium":
                            size = "65%";
                            break;
                        case "small":
                            size = "50%";
                            break;
                    }
                }

                if (cfg.width) cfg.width = checkSizeBoundaries(cfg.width, defaultViewSize.width, 'width');

                if (cfg.height && cfg.height != -1) cfg.height = checkSizeBoundaries(cfg.height, defaultViewSize.height, 'height');

                Ext.apply(winCfg, {
                    width: cfg.width || size || defaultViewSize.width,
                    height: (cfg.height != -1 ? (cfg.height || size || defaultViewSize.height) : null),
                    maximizable: false,
                    maximized: false
                });
            }

            return winCfg;
        };

