    var reloadCalendars = function () {
        if (!wxScheduler) {
            return;
        }

        _loadingData = true;
        me.component.setLoading(translations['WSC_Loading']);
        var localService = wxScheduler.getService("local");
        var ops = wxScheduler.getService("operations");
        var origCals = localService.cals.serialize();

        localService.calendars(false, true).
            then(function (data) {
                // Reset previous colors and status for existings calendars.
                var newCals = null;
                if (data) {
                    newCals = data.serialize();
                }

                if (newCals && origCals) {
                    newCals.forEach(function (nCal) {
                        var calExists = false;

                        origCals.forEach(function (oCal) {
                            if (nCal.id === oCal.id) {
                                ops.updateCalendar(nCal.id, oCal);
                                calExists = true;

                                calendarColors.forEach(function (cl) {
                                    if (cl.color === nCal.color) {
                                        cl.used = true;
                                    }
                                });
                            }
                        });

                        if (!calExists) {
                            _assignCalendarColor(nCal);
                        }

                    });
                }

                reloadEvents();
            }).
            then(function () {
                wxScheduler.$app.refresh();
            }).
            then(function () {
                me.component.setLoading(false);
                _loadingData = false;
            }).
            then(function () {
                if (_configuration.availableModes.timeline) {
                    localService.sections(false, true);
                }
            });

    };

    var _assignCalendarColor = function (calendar) {

        if (calendar.color) return;

        var firstUnassignedColor = _(calendarColors).find(c => !c.used);

        if (!firstUnassignedColor) { firstUnassignedColor = calendarColors[0]; }

        calendar.color = firstUnassignedColor.color;
        firstUnassignedColor.used = true;
    };

    var reloadEvents = function () {

        if (!wxScheduler) { return; }

        _loadingData = true;

        var ops = wxScheduler.getService("operations");
        ops.Events.clearAll();

        var localServices = wxScheduler.getService("local");
        localServices.
            events(false, true).
            then(function () { wxScheduler.$app.refresh(); }).
            then(function () { me.component.setLoading(false); _loadingData = false; }).
            catch(function (error) { debugger; });
    };

    var _getFilterValue = function () {
        var filterValue = "";

        if (_filterAreaCtx) {
            filterValue = _filterAreaCtx.getFilter();
        } else {
            filterValue = prepareStdFilter(_currentFilter);
        }

        return filterValue;
    };

    var prepareStdFilter = function (filterValue) {
        var filterValue = {
            type: "AND",
            conditions: filterValue,
            subfilters: []
        }

        return filterValue
    };

    var _addFilterValue = function (fieldName, value) {

        // get field to set
        if (!_filterAreaCtx) return;
        var field = _filterAreaCtx.getActiveArea().getForm().findField(fieldName);

        // get current value
        var currentValue = field.getValue(),
            valueArray = currentValue ? currentValue.split(Portal.Const.ARRAY_SEPARATOR) : [];

        // if current value does not contain value -> add value
        if (!valueArray.includes(value)) {
            // add value to array
            valueArray.push(value);
            // stringify array and update filter
            var newValue = valueArray.join(Portal.Const.ARRAY_SEPARATOR);
            field.setValue(newValue);
        }
    };

    var _getFilterValueJson = function () {
        var filter = _getFilterValue();
        var jsonFilter = "";


        if (filter) {
            jsonFilter = Portal.Util.Json.encode(filter);
        }

        return jsonFilter;
    };

    var _initFilter = function () {

        _filterAreaCtx = me.getSiblingContext('FilterArea');

        me.onComponentReady(function () {

            var injectObjectLinkSearchFilters = function (field, filterString) {

                if (!field || !filterString) { return; }

                field.searchFilters = _.union(
                    field.searchFilters,
                    Portal.Util.Json.decode(filterString)
                );

            };

            var initialFilter = [];
            _currentFilter = [];

            // bind filter values
            var filters;
            if (_clientCfg.filter) {
                var clientFilter = Ext.isArray(_clientCfg.filter) ?
                    _clientCfg.filter :
                    Portal.Util.Json.decode(_clientCfg.filter);
                filters = initialFilter.concat(clientFilter);
            }
            else {
                filters = initialFilter;
            }

            if (_filterAreaCtx) {

                _filterAreaCtx.filterSettings = _clientCfg.filterSettings;

                var activeFArea = _filterAreaCtx.getActiveArea();
                _filterAreaCtx.enableAdvancedFilters = false;

                _filterAreaCtx.setStandardFiltersArray(filters);
                _currentFilter = filters;

                me.component.onContextReady('FilterArea', function (ctx) {

                    // sync list filters with filter area ones
                    var areaFilters = Portal.Util.removeEmptyFilters(ctx.getFilter());
                    filters = Portal.Util.mergeFilterArrays(_currentFilter, areaFilters.conditions, true);

                    var userFilterField = activeFArea.getForm().findField("AssignedUserID");
                    var groupFilterField = activeFArea.getForm().findField("AssignedGroupID");

                    // inject object link searchFilters
                    injectObjectLinkSearchFilters(userFilterField, _configuration.assignedUserIDFilters);
                    injectObjectLinkSearchFilters(groupFilterField, _configuration.assignedGroupIDFilters);

                    if (userFilterField && userFilterField.store) {
                        userFilterField.store.on('load', function () {
                            filters.filter(x => x.property === "AssignedUserID").forEach(function (jFilter) {
                                if (userFilterField.store.data.items
                                    .map(function (i) { return i.id; })
                                    .some(function (i) { return i === jFilter.value; })) {
                                    userFilterField.setValue(jFilter.value);
                                }
                            });
                        });
                    }

                });

            } else if (filters && filters.length > 0) {
                _currentFilter = Ext.JSON.decode(filters);

            } else {
                _currentFilter = [];
            }

        });

        // checks max number of selectable users corresponding to max number of visible calendar groups
        var checkSelectionFn = function (filter, record, index) {
            var totCals = 0;
            if (filter && filter.value) {
                if (filter.value.indexOf('|') > 0) {
                    var cals = filter.value.split('|');
                    totCals = cals.length;
                } else {
                    totCals = filter.value.length;
                }
            }

            if (totCals >= _clientCfg.agenda_max_calendars) {
                // selecting a new record is not allowed when the maximum number of selectable records has been reached

                Portal.Util.Msg.showMsg({
                    msg: translations['WSC_Cal_MaxNumberReached'],
                    fn: function () {
                        // re-open combo list
                        filter.onTriggerClick();
                    }
                });
                return false;
            }
        };

        // set listeners for filter area user filter (used to check max selectable users)
        var filterForm = null;
        if (_filterAreaCtx) {
            _filterAreaCtx.getActiveArea().getForm();
        }

        if (filterForm && filterForm.findField('AssignedUserID')) {
            var userFilterField = filterForm.findField('AssignedUserID');
            if (userFilterField) {
                userFilterField.addListener('beforeselect', checkSelectionFn);
            }
        }

        // listen to filter change messages sent from filter area
        me.listenToMessage({
            topic: 'Portal.FilterArea.FilterChanged',
            messageFilter: 'samemodule',
            listenerFn: function (msg) {
                //var filters = Portal.Util.mergeFilterArrays(msg.filters, initialFilter, false);
                var filters = msg.filters.conditions;

                if (!Portal.Util.areFilterArraysDifferent(filters, _currentFilter)) return;

                var userFilter = null;
                Ext.each(filters, function (f) {
                    if (f.property === 'AssignedUserID') {
                        userFilter = f.value;
                        return false; // break each loop
                    }
                });

                _currentFilter = filters;
                me.reloadCalendars();
            },
            contextName: 'FilterArea'
        });

    };

    /**
     * Create and configure the WebIX Scheduler.
     */
    var _initWxScheduler = function () {

        // get components            
        schedulerEl = me.component.down("#SchedulerContainer").contentEl.el.down(".scheduler-container");

        webix.ready(function () {
            // use custom slim scrolls
            if (!webix.env.touch && webix.env.scrollSize) {
                webix.CustomScroll.init();
            }

            webix.Date.startOnMonday = true;

            var customTranslationsName = Portal.WebixTranslationsManager.setSchedulerLocalizations();
            var overrides = new Map([
                [scheduler.services.Backend, CustomBackend],
                [scheduler.views.main, CustomMainView],
                [scheduler.views.JetView, InfoPopup],
                [scheduler.views["bars"], CustomTopBarView],
                [scheduler.views["bars/add"], CustomAddBar],
                [scheduler.views["bars/nav"], CustomNavBarView],
                [scheduler.views["bars/navpopup"], CustomNavBarPopupView],
                [scheduler.views["event/info"], CustomInfo],
                [scheduler.views["side"], CustomSide],
                [scheduler.views["side/popup"], CustomSidePopup],
                [scheduler.views["modes/week"], CustomScrollWeek],
                [scheduler.views["modes/day"], CustomScrollDay],
                [scheduler.views["modes/day/events"], CustomDayEventsView],
                [scheduler.views["modes/month/events"], CustomMonthEventsView],
                [scheduler.views["modes/common/hourscale"], CustomHourscaleView],
                [scheduler.views["modes/timeline"], CustomTimelineView],
                [scheduler.views["modes/timeline/chart"], CustomChartView],
                [scheduler.views["modes/month/more"], CustomMonthMoreWindowView],
                [scheduler.views["modes/timeline/more"], CustomTimeLineMoreWindowView]
            ]);

            wxScheduler = webix.ui({
                container: schedulerEl,
                view: "scheduler",
                readonly: _configuration.readonly,
                date: new Date(),
                debug: false, // to avoid red popup errors being shown to the user
                mode: (_configuration.selectedMode || _clientCfg.mode || "month"),
                url: "",
                css: "event-scheduler scheduler_v2",
                override: overrides,
                timeline: (!!_configuration.availableModes.timeline),
                locale: {
                    lang: customTranslationsName
                }
            });

            wxScheduler.attachEvent("onBeforeEventDrag", (ctx, e) => {
                var elementID = ctx.id.indexOf("_") >= 0 ? ctx.id.split(/_(.*)/s)[1] : ctx.id;

                if (_getEventEntity(elementID).readonly) {
                    return false;
                }
            });

            wxScheduler.getState().$observe("date", function (date) {

                var firstreloadEvents = false;

                if (!_dateReloadEvents.from) {
                    firstreloadEvents = true;
                }
                var start = webix.Date.add(webix.Date.monthStart(date), -15, 'day', true);
                var end = webix.Date.add(start, 2, "month", true);

                _dateReloadEvents.from = start;
                _dateReloadEvents.to = end;

                if (!firstreloadEvents) {
                    reloadEvents();
                }
            });

            _adjustSchedulerSize();

        });

        // handle resize
        me.component.on('resize', function () { _adjustSchedulerSize(); });
    };

    /**
     * Initialize context
     * @param {Object} initCfg starting configuration
     */
    var _init = function (initCfg) {

        // get control configuration
        _configuration = me.getConfiguration("model");
        _itemIdPrefix = webix.uid().toString();
        _eventConfiguration = me.getConfiguration("eventmodel");
        _rangeContextMenu = me.component.getBinComponent('RangeContextMenu');

        calendarColors = _configuration.calendarColorPalette;

        if (initCfg.schedulerConfig) {
            _clientCfg = initCfg.schedulerConfig;
        }

        // set working context for current component context(s)
        for (var ctxName in me.component.Context) {
            if (Ext.isFunction(me.component.Context[ctxName].setWorkingContext)) {
                me.component.Context[ctxName].setWorkingContext(me);
            }
        }

        _initFilter();

        me.component.on('afterrender', function () {
            _initWxScheduler();
        });

        me.listenToMessage({
            topic: 'Portal.' + _configuration.entity + '.*',
            //messageFilter: 'private',
            listenerFn: function (msg) {
                me.reloadEvents();
            }
        });
    };

    var _getEventEntity = function (id) {
        var entity = wxScheduler.$app.getService('local').store.getItem(id);
        return entity;
    };

    var _openEntity = function (entity) {
        var entityData = _getEntityData(entity);

        var doOpenFn = function () {
            Portal.PageManager.openModule({
                mode: 'window',
                url: Router.action('WSCView', 'Detail', { id: entityData.objectID, entity: entityData.entityTypeName }),
                parentContainer: me.getContext('Module'),
                params: { detailMode: "window" },
                customParams: {
                    endDialogFn: function () {
                        reloadEvents();
                    }
                }
            });
        };

        var doFailureFn = function () {
            Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_ObjectNotFound']);
        };

        if (entityData.entityTypeName === "") return;

        Portal.WSC.OperationManager.exists({
            id: entityData.objectID,
            entity: entityData.entityTypeName,
            successFn: doOpenFn,
            failureFn: doFailureFn
        });
    };

    var _moveEntity = function (entity, startDate, endDate) {
        var allowed = false;
        var entityData = _getEntityData(entity);

        if (entityData.editable) {
            _modifyAppointment(entity, startDate, endDate);
            allowed = true;
        }
        else {
            Portal.Util.Msg.showErrorMsg(translations['WSC_Msg_OperationNotAllowed']);
            allowed = false;
        }

        return allowed;
    };

    var _deleteEntity = function (entity) {
        var entityData = _getEntityData(entity);

        if (entityData.editable) {
            _deleteAppointment(entity);
        }
        else {
            Portal.Util.Msg.showErrorMsg(translations['WSC_Msg_OperationNotAllowed']);
        }
    };

    var createAppointment = function (item, dates, callback) {
        _selectedRange.dates = dates;
        _selectedRange.callback = callback;
        _showNewAppointmentMenu(Ext.EventObject.getXY());
    };

    var _showNewAppointmentMenu = function (pos) {
        if (_rangeContextMenu && _rangeContextMenu.items && _rangeContextMenu.items.getCount() > 0) {
            _rangeContextMenu.showAt(pos);
        }
    };

    var hideRangeContextMenu = function (menu, item, e, eOpts) {
        if (Ext.isFunction(_selectedRange.callback)) {
            _selectedRange.callback();
        }
    };

    var setDateRange = function (start, end) {
        var startDate, endDate;

        if (start) {
            var isMonthView = (wxScheduler.$app.getState().mode === 'month');

            if (isMonthView) {
                // day click on a month view calendar, set default start hour to 8.30 am
                startDate = Ext.Date.add(Ext.Date.add(start, Ext.Date.HOUR, 8), Ext.Date.MINUTE, 30);
            } else {
                // day click on a week view or day view calendar, read the selected date-time
                startDate = start;
            }
        } else {
            startDate = new Date();
        }

        // default appointment duration set to 30 min
        endDate = end || Ext.Date.add(startDate, Ext.Date.MINUTE, 30);

        // set date range and show context menu for appointment creation
        _selectedRange.dates = { StartDate: startDate, EndDate: endDate };

    };

    var _dayClick = function (ev) {
        if (_loadingData) {
            return;
        }

        var date = ev.date instanceof Date ? ev.date : new Date(ev.date),
            end_date = ev.end_date || null;

        setDateRange(date, end_date);
        _showNewAppointmentMenu(Ext.EventObject.getXY());
    };

    var addNewEvent = function () {
        setDateRange();
        _showNewAppointmentMenu(Ext.EventObject.getXY());
    };

    var _modifyAppointment = function (entity, startDate, endDate) {
        var entityData = _getEntityData(entity);

        var data = {};
        data[_configuration.startDateField] = startDate;
        data[_configuration.endDateField] = endDate;

        var origStartDate = moment(entity.start_date).format('YYYY-MM-DD hh:mm:ss');

        var doModifyFn = function () {

            // do appointment update operation
            Portal.WSC.OperationManager.doObjectOperation({
                objId: entityData.objectID,
                objData: data,
                objUrl: Router.action('WSCView', 'Save', { id: Portal.Const.Url.ID_PLACEHOLDER, entity: entityData.entityTypeName }),
                successFn: function (responseObj) {

                    me.reloadEvents();

                    Portal.Util.Msg.showToastMsg({
                        msg: translations['Calendar_Appointment_Resized']
                    });


                },
                failureFn: function (responseObj) {
                    me.reloadEvents();

                    me.component.setLoading(false);
                    Portal.Util.Msg.showErrorToastMsg('Operation failed', responseObj);
                }
            });
        };

        var doExistsFailureFn = function () {
            reloadEvents();
            me.component.setLoading(false);
            Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_ObjectNotFound']);
        };

        me.component.setLoading(translations['WSC_Loading']);

        // check object existence
        Portal.WSC.OperationManager.exists({
            id: entityData.objectID,
            entity: entityData.entityTypeName,
            successFn: doModifyFn,
            failureFn: doExistsFailureFn
        });

    };

    var _deleteAppointment = function (entity) {
        var entityData = _getEntityData(entity);

        var doDeleteFn = function () {

            // do appointment update operation
            Portal.WSC.OperationManager.doObjectOperation({
                objId: entityData.objectID,
                objUrl: Router.action('WSCView', 'Delete', { id: Portal.Const.Url.ID_PLACEHOLDER, entity: entityData.entityTypeName }),
                successFn: function (responseObj) {

                    me.reloadEvents();

                    Portal.Util.Msg.showToastMsg({
                        msg: translations['Calendar_Appointment_Deleted']
                    });
                },
                failureFn: function (responseObj) {
                    me.reloadEvents();

                    me.component.setLoading(false);
                    Portal.Util.Msg.showErrorToastMsg('Operation failed', responseObj);
                }
            });
        };

        var doExistsFailureFn = function () {
            reloadEvents();
            me.component.setLoading(false);
            Portal.Util.Msg.showErrorToastMsg(translations['WSC_Msg_ObjectNotFound']);
        };

        me.component.setLoading(translations['WSC_Loading']);

        // check object existence
        Portal.WSC.OperationManager.exists({
            id: entityData.objectID,
            entity: entityData.entityTypeName,
            successFn: doDeleteFn,
            failureFn: doExistsFailureFn
        });

    };

    var currentStatus = function () {

        var status = {
            detailMode: 'window',
            recordType: _configuration.entity,
            detailUrl: Router.action('WSCView', 'Detail', { entity: _configuration.entity, id: Portal.Const.Url.ID_PLACEHOLDER })
        };

        // if a date range is selected then add filter array with range dates: [{property:'DateFrom', value:..., op:'eq},{property:'DateTo', value:..., op:'eq}]
        var filter = [];
        if (_getdtSelecteds()) {
            filter = filter.concat(_buildSelectedRangeFilter());
        }

        // 19/12/2017 MauroB: spostato controllo su calendarSummaryStore perché in IE non veniva rimosso 
        // il calendario di default e quindi risultavano sempre 2+ calendari attivi
        // get active calendar user IDs
        var activeCalendarUserIDs = [];
        //Object.keys(calendarMap).forEach(function (k) { if (calendarMap[k] != null) activeCalendarUserIDs.push(k); });
        //calendarSummaryStore.getAllRange().forEach(function (k) { activeCalendarUserIDs.push(k.id); });

        // no active calendar: set loggedUser as assigned user of new Todo
        // only one calendar: set calendar user as todo assigned user
        // more than one active calendar: set blank assigned user
        if (activeCalendarUserIDs.length === 1) {
            filter.push({ property: 'AssignedUserID', value: activeCalendarUserIDs[0], op: 'eq' });
        } else if (activeCalendarUserIDs.length > 1) {
            filter.push({ property: 'AssignedUserID', value: activeCalendarUserIDs.join("|"), op: 'eq' });
        } else if (_defaultUserFilter) {
            filter.push(_defaultUserFilter);
        }

        var filterAreaFiltersValue = _getFilterValue()
        var filterAreaFilters = Portal.Util.removeEmptyFilters(filterAreaFiltersValue ? filterAreaFiltersValue.conditions : []);
        var completeFilters = Portal.CommandContext.Utils.mergeOperationFilters(filter, filterAreaFilters)

        Ext.apply(status, {
            filter: completeFilters
        });

        return status;
    };

    var _getdtSelecteds = function () {
        return _selectedRange.dates;
    };

    var _buildSelectedRangeFilter = function () {
        var dateFilter = [{
            property: _configuration.startDateField,
            value: _selectedRange.dates.StartDate,
            op: 'eq'
        }, {
            property: _configuration.endDateField,
            value: _selectedRange.dates.EndDate,
            op: 'eq'
        }];

        return dateFilter;
    };

    var _getEntityData = function (entity) {
        var data = {
            objectID: -1,
            entityType: "",
            entityTypeName: "",
            editable: 0,
            readonly: 0
        };

        if (entity) {
            data.objectID = entity.object_id;
            data.entityTypeName = entity.entity_type;
            data.editable = entity.editable;
            data.readonly = entity.readonly;
        }

        return data;
    };

    /******************************************************************************
     *                          Sidebar ADD buttons
     *****************************************************************************/

    var _openLookupSearchGrid = function (entityName, fieldName, filter) {

        // track lookup entity for searchCallback
        _currentObjectLinkSearchEntityName = entityName;

        // exclude already selected values
        var currentValue = _getFilterFieldValue(fieldName);
        if (currentValue) {
            var currentValuesFilter = [{ property: "ID", op: "ne", value: currentValue }];
            filter = filter ?
                _.union(Portal.Util.Json.decode(filter), currentValuesFilter) :
                currentValuesFilter;

            filter = Portal.Util.Json.encode(filter);
        }

        // open lookup
        Portal.PageManager.openModule({
            mode: 'objectLink',
            url: Router.action('WSCView', 'List', { entity: _currentObjectLinkSearchEntityName, filter: filter }),
            parentContainer: me.getContext('Module'),
            params: { detailMode: "window", contextName: "Scheduler_v2" }
        });
    };

    /**
     * Open Users lookup's search grid
     */
    var _openUsersLookupSearchGrid = function () {

        var filter = _configuration.assignedUserIDFilters ? _configuration.assignedUserIDFilters : "";

        _openLookupSearchGrid(OBJECT_LINK_ENTITIES.USERS, "AssignedUserID", filter);
    };

    /**
     * Open UserGroups lookup's search grid
     */
    var _openUserGroupsLookupSearchGrid = function () {

        var filter = _configuration.assignedGroupIDFilters ? _configuration.assignedGroupIDFilters : "";

        _openLookupSearchGrid(OBJECT_LINK_ENTITIES.USER_GROUPS, "AssignedGroupID", filter);
    };

    /**
     * Callback for the user/group search
     * @param {string} id of the selected entity id
     * 
     */
    var searchCallback = function (id) {
        if (_currentObjectLinkSearchEntityName === OBJECT_LINK_ENTITIES.USERS)
            _addUserCalendar(id);

        if (_currentObjectLinkSearchEntityName === OBJECT_LINK_ENTITIES.USER_GROUPS)
            _addGroupCalendar(id);

        // reset status
        _currentObjectLinkSearchEntityName = null;
    };

    /*****************************************************************************/

    var _getFilterField = function (fieldName) {
        if (!_filterAreaCtx) return;

        var activeArea = _filterAreaCtx.getActiveArea(),
            filterField = activeArea.getForm().findField(fieldName);
        return filterField;
    };

    var _getFilterFieldValue = function (fieldName) {

        var field = _getFilterField(fieldName),
            filterValue = "";

        if (field) {
            filterValue = field.getValue();
        } else {
            var filters = _getFilterValue();
            if (filters && filters.conditions) {
                filters.conditions.forEach(function (f) {
                    if (f.property === fieldName) {
                        filterValue = f.value;
                    }
                });
            }
        }

        return filterValue;
    }

    var _addGroupCalendar = function (groupID) {
        _addFilterValue("AssignedGroupID", groupID)
    };

    var _addUserCalendar = function (userID) {
        _addFilterValue("AssignedUserID", userID)
    };

    var _removeCalendar = function (filterFieldName, calendarID) {

        var field = _getFilterField(filterFieldName);
        if (!field) { return; }

        var filterValue = _getFilterFieldValue(filterFieldName),
            filterValueChanged = false,
            newFilterValue = [];

        if (filterValue) {
            var oldIDs = filterValue.split(Portal.Const.ARRAY_SEPARATOR);
            var newIDs = _.without(oldIDs, calendarID);
            filterValueChanged = oldIDs.length !== newIDs.length;
            newFilterValue = newIDs.join(Portal.Const.ARRAY_SEPARATOR);
        }

        if (filterValueChanged) {
            field.setValue(newFilterValue);
            // NOTE: The calendars and event are reloaded by the FilterChange event.
        }
    };

    var showWindowFromID = function (windowID) {
        var win = me.component.down('#' + windowID);
        if (!win) return;
        win.show();
        win.center();
    };

    var checkBoxChanges = function (item, newValue, oldValue) {
        me.component.setLoading(translations['WSC_Loading']);
        me.reloadEvents();
    };

    var getSelectedSection = function () {
        var s = wxScheduler.$app.getState().selected;
        return s.section;
    };

    return {

        contextName: 'Scheduler_v2',
        dependencies: ['Portal.CommandContext'],
        init: function (initCfg) {
            me = this;
            initCfg = initCfg || {};

            Portal.Console.log('Scheduler_v2 INITIALIZATION');
            Portal.Console.log(initCfg);
            _init(initCfg);
        },

        reloadEvents: reloadEvents,
        hideRangeContextMenu: hideRangeContextMenu,
        currentStatus: currentStatus,
        createAppointment: createAppointment,
        addNewEvent: addNewEvent,
        reloadCalendars: reloadCalendars,
        searchCallback: searchCallback,
        showWindowFromID: showWindowFromID,
        checkBoxChanges: checkBoxChanges,
        getSelectedSection: getSelectedSection,
    };

};
