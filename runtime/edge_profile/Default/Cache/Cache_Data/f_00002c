Portal.ListContext = function () {

    var me = null, // closure var that keeps a ref to the context instance, it will be set during context init call

        listComponent = null,

        refreshTask = null,

        signalRRefreshTask = null,

        debugMode = false,

        objectLinkID = null,

        _lastSelectedIDs = null,

        _emptyTextTpl = new Ext.XTemplate('<div class="x-grid-empty">{EmptyText}</div>'),

        _defaultEmptyText = null,

        _moduleCtx = null,

        _availableOperations = {

            task: null,

            request: null,

            callbackQueue: [],

            lastEvaluatedIDs: null,

            lastResult: null
        },

        _createAvailableOperationsTask = function () {
            _availableOperations.task = new Ext.util.DelayedTask(function () {
                var selectedIDs = me.getSelectedIdList();

                // issue a new evaluation request for current IDs
                _requireAvailableOperations(selectedIDs);
            });
        },

        _availableOpsCallback = function (availableOpsResult) {
            _availableOperations.request = null;
            _availableOperations.lastResult = availableOpsResult;

            me.updateToolbar(availableOpsResult);
            me.updateContextMenu(availableOpsResult);

            _.each(_availableOperations.callbackQueue, function (cb) {
                cb(availableOpsResult);
            });

            _availableOperations.callbackQueue = [];
        },

        _requireAvailableOperations = function (IDs) {
            _availableOperations.lastResult = null;
            _availableOperations.lastEvaluatedIDs = IDs;

            _availableOperations.request = me.getSiblingContext('Command').getAvailableOperations(_availableOpsCallback);
        },

        _isAvailableOperationsRequestRunning = function () {
            return (_availableOperations.request);
        },

        _cancelAvailableOperationsRequest = function () {
            Ext.Ajax.abort(_availableOperations.request);
            _availableOperations.callbackQueue = [];
            _availableOperations.lastEvaluatedIDs = null;
        },

        _evaluateAvailableOperations = function (onAvailableOpsCallback, delay) {
            if (!_availableOperations.task) _createAvailableOperationsTask();

            // cancel current evaluation request
            if (_isAvailableOperationsRequestRunning()) _cancelAvailableOperationsRequest();

            // enqueue the specified callback, it will be executed when available operations evaluation completes
            if (onAvailableOpsCallback) _availableOperations.callbackQueue.push(onAvailableOpsCallback);

            // apply default delay if not specified
            delay = delay || 300;

            // call evaluation task with a delay
            _availableOperations.task.delay(delay);
        },

        afterEntityInsertOrUpdate = function (msg) {

            if (_moduleCtx.openingMode() === 'objectLink') {
                // save updated ObjectLinkID to set to lookup control
                objectLinkID = msg.ID;

                //when detail form close, set value to calling objectLink and close module
                var parentContainerID = Ext.getCmp(msg.sourceCtx.componentId).getContext('Module').containerId();
                Ext.getCmp(parentContainerID).on('close', function () {
                    if (objectLinkID) setObjectLinkValue(_moduleCtx, objectLinkID);
                    _moduleCtx.close();
                })

            }
            else
                me.refreshList();
        },

        setObjectLinkValue = function (moduleCtx, selectedIdList) {

            var moduleParams = moduleCtx.getModuleParams();

            if (moduleParams && moduleParams.objectLinkControl) {

                //return value to control
                var objLink = Ext.net.ResourceMgr.getCmp(moduleParams.objectLinkControl);
                if (objLink) {
                    objLink.searchCallback(selectedIdList);
                }
            }
            else if (moduleParams && moduleParams.contextName) {

                //return value to context
                var ctx = me.getContext(moduleParams.contextName);
                if (ctx) ctx.searchCallback(selectedIdList);
            }

            //----------------- MESSAGE BUS PUBLISH --------------
            Portal.MessageBus.publish('Portal.' + me.contextStatus.recordType + '.ObjectLink.ValueSelected', { value: selectedIdList, objectLinkControl: moduleParams.objectLinkControl }, me);
        },

        setupBadgeSync = function () {
            var containerCmp = _moduleCtx.getContainerCmp();

            if (containerCmp.pageID && containerCmp.pageShowBadge) {
                Portal.ContextFactory.createInstance('Portal.Badges.ListBadgeContext', me.component, { pageID: containerCmp.pageID });
            }
        },

        _infiniteScrollingEnabled = function () {
            return (me.contextStatus.usePagedList === false);
        },

        _setupGridForInfiniteScrolling = function () {
            var tb = me.component.down('pagingtoolbar');

            Portal.ListContext.Utils.setupPagingToolbar({
                pagingToolbar: tb,
                infiniteScrollingEnabled: true,
                collectionName: translations['WSC_' + me.contextStatus.collectionType]
            });

        },

        _setupStateManagement = function () {
            if (!listComponent.stateful) return;

            var detailCtx = me.getContext('Detail');

            var buildGenericListStateID = function (listContextStatus, listLogicalName) {
                // TODO - Si può usare Portal.Const.LoggedUser.Username
                return Ext.String.format('{0}_{1}', listContextStatus.loggedUsername, listLogicalName);
            };

            var buildObjectLinkStateID = function (listContextStatus, listLogicalName, openingMode) {
                // TODO - Si può usare Portal.Const.LoggedUser.Username
                return Ext.String.format('{0}_{1}_{2}', listContextStatus.loggedUsername, listLogicalName, openingMode);
            };

            var buildDetailListStateID = function (listContextStatus, listLogicalName, detailContext) {
                // TODO - Si può usare Portal.Const.LoggedUser.Username
                return Ext.String.format('{0}_{1}_{2}', listContextStatus.loggedUsername, listLogicalName, detailContext.component.logicalName);
            };

            var buildDetailSubtableStateID = function (listContextStatus, listLogicalName, detailContext, moduleParams) {
                // we can have 2 or more matrixes in same detail view so we need a more accurate stateId
                // or all matrixes will use same state configuration rising errors.
                // --> add matrix CustomFieldID to stateId
                var filters = Portal.Util.Json.decode(moduleParams.Filter),
                    cfItem = filters.find(function (item) { return item.property == 'CustomFieldID'; }) // matrix custom field filter

                // TODO - Si può usare Portal.Const.LoggedUser.Username
                return Ext.String.format('{0}_{1}_{2}_{3}', listContextStatus.loggedUsername, listLogicalName, detailContext.component.logicalName, cfItem.value);
            };

            var buildMobileStateID = function (stateID) {
                return Ext.String.format('Mobile_{0}', stateID);
            };

            var buildCustomerPortalStateID = function (stateID) {
                return Ext.String.format('CP_{0}', stateID);
            };

            if (listComponent.stateId == null || listComponent.stateId == "") {

                var cmpLogicalName = me.component.logicalName;

                if (_moduleCtx.openingMode() != 'objectLink') {

                    if (detailCtx) {

                        if (me.contextStatus.recordType == 'SubtableRecord') {

                            listComponent.stateId = buildDetailSubtableStateID(me.contextStatus,
                                cmpLogicalName,
                                detailCtx,
                                Portal.Util.Json.decode(me.component.moduleParams));

                        } else {

                            listComponent.stateId = buildDetailListStateID(me.contextStatus,
                                cmpLogicalName,
                                detailCtx);

                        }
                    } else {
                        listComponent.stateId = buildGenericListStateID(me.contextStatus,
                            cmpLogicalName);
                    }
                } else {
                    listComponent.stateId = buildObjectLinkStateID(me.contextStatus,
                        cmpLogicalName,
                        _moduleCtx.openingMode());
                }

                // force customer portal stateid to be different from standard one
                if (Portal.Const.Application && Portal.Const.Application.isTouchPortal)
                    listComponent.stateId = buildCustomerPortalStateID(listComponent.stateId);

                // force mobile stateid to be different from standard one
                if (Portal.Const.Device.IsMobile)
                    listComponent.stateId = buildMobileStateID(listComponent.stateId);
            }

            // do state initialization now that component has its right stateId

            /*
                There is a bug with AbstractStore that causes double load call on grid state init when store has remote sort/filter (even if it has autoLoad=false)
                https://wwww.sencha.com/forum/showthread.php?292941-Autoload-false-and-stateful-grid-store-always-loads
                    
                As a workaround to avoid double loading:
                - we use a flag tracking when grid is applying its state
                - while grid is applying its state we cancel any load operation
                - we reset the flag when grid state init has completed
            */

            var applyingState = true;
            var store = listComponent.getStore();

            if (store) {
                store.addListener('beforeload',
                    function (store, operation) {
                        return !applyingState;
                    });
            }

            //if the grid isn't modified, set the configuration state, so the "standard" state will not be saved to database
            if (!Ext.state.Manager.provider.state[listComponent.stateId])
                Ext.state.Manager.provider.state[listComponent.stateId] = listComponent.getState();

            listComponent.initState();

            applyingState = false;
        },

        _setupDetailOpeningMode = function (moduleCtx) {

            if (moduleCtx.openingMode() == 'objectLink') {
                me.contextStatus.detailMode = "window";
            } else if (!me.contextStatus.detailMode && moduleCtx.openingMode() === 'childmodule') {
                me.contextStatus.detailMode = Portal.PageManager.getModuleDetailMode(moduleCtx);
            }
        },

        _handleListDataLoadSuccess = function (records) {

            _updateListUIWithMessage(_defaultEmptyText || listComponent.initialConfig.emptyText);

            var isEmpty = (!records || records.length === 0);

            // force view refresh when empty data to ensure the right empty text is rendered    
            if (isEmpty) listComponent.getView().refresh();
        },

        _handleListDataLoadFailure = function (message) {
            _updateListUIWithMessage(message, 'error');
            _onUnsuccessfulLoad();
        },

        _handleListDataLoadWarning = function (message) {
            _updateListUIWithMessage(message, 'warning');
            _onUnsuccessfulLoad();
        },

        _onUnsuccessfulLoad = function (errorMessage) {
            var view = listComponent.getView();
            var store = listComponent.getStore();

            store.removeAll();
            view.refresh();
        },

        // TODO - AJAX OPERATION RESPONSE - COULD BE AN UTILITY FUNCTION (Util.js, AjaxUtil.js?)
        _parseAjaxOperation = function (operation) {
            var response = operation.getResponse();

            var parsedOperation = {
                status: (response ? response.status : null),
                jsonData: null,
                success: false,
                timedout: false,
                aborted: false
            };

            if (response && response.status === 200) {
                // [HTTP 200 + success=true/false]
                // we've got a response, fetch infos from response JSON data
                parsedOperation.jsonData = Portal.Util.Json.decode(response.responseText);
                parsedOperation.success = parsedOperation.jsonData.success;

                if (parsedOperation.jsonData.result) {
                    parsedOperation.timedout = (parsedOperation.jsonData.result.code === Portal.WSC.OperationManager.TimeoutExpired);
                }
            } else {
                // [HTTP 500, 400, ajax timeout]
                // something went wrong with the Ajax request
                var error = operation.getError();

                if (error && error.response) {
                    parsedOperation.timedout = error.response.timedout;
                    parsedOperation.aborted = error.response.aborted;
                }
            }

            return parsedOperation;
        },

        _getOperationErrorMessage = function (parsedOperation) {
            var message = null;

            if (parsedOperation.timedout) {

                message = translations.Portal_Err_ListData_TimeoutExpired;

            } else if (parsedOperation.aborted) {

                // request was canceled by client, we don't want to show an error message
                message = null;

            } else if (parsedOperation.jsonData && parsedOperation.jsonData.result) {

                var result = parsedOperation.jsonData.result;

                // result without a code is considered as a generic error,
                // use the result description as error message only for specified error codes
                if (result.code) message = result.desc;

            } else {

                message = translations.Portal_Err_ListData_GenericError;

            }

            return message;
        },

        _updateListUIWithMessage = function (errorMessage, cls) {
            _setEmptyText(errorMessage);

            _clearListLoadResultCls();

            if (cls) listComponent.addCls(cls);
        },

        _setEmptyText = function (emptyText) {
            var view = listComponent.getView();
            view.emptyText = _emptyTextTpl.apply({ EmptyText: emptyText });
        },

        _clearListLoadResultCls = function () {
            listComponent.removeCls(['error', 'warning']);
        },

        _updateFilters = function (filters) {
            filters = filters || [];
            me.filterProperties.currentFilters = filters;

            // set new filters as base filters
            me.setBaseFilter(me.filterProperties.currentFilters);

            Portal.MessageBus.publish('Portal.List.FiltersUpdated', { filters: filters }, me);
        },


        _isSelectedAll = function () {
            var grdCt = me.component.down('gridpanel');
            if (!(grdCt && grdCt.selModel && "checkboxmodel" === grdCt.selModel.selType)) return false;

            var headerCt = grdCt.down('headercontainer');
            if (!headerCt) return false;

            return $('#' + headerCt.id + ' .x-column-header-checkbox').attr("class").includes("x-grid-hd-checker-on");
        },


        _autoRefresh = {

            isEnabled: function () {
                return (me.autoRefreshInterval > 0);
            },

            setup: function () {
                if (!this.isEnabled()) return;

                _moduleCtx.setAutoRefresh(
                    me.autoRefreshInterval,
                    function () {
                        if (debugMode) Portal.Console.log('LIST CONTEXT REFRESH');

                        me.refreshList();
                    }, false);
            },

            stop: function () {
                if (!this.isEnabled()) return;

                if (_moduleCtx.isAutoRefreshRunning()) {
                    _moduleCtx.stopAutoRefresh();

                    Portal.Console.log(['List', 'Entity=' + me.contextStatus.recordType, 'Autorefresh stopped.']);
                }
            },

            restart: function () {
                if (!this.isEnabled()) return;

                if (!_moduleCtx.isAutoRefreshRunning() && !_moduleCtx.isAutoRefreshSuspended()) {
                    _moduleCtx.restartAutoRefresh(false);

                    Portal.Console.log(['List', 'Entity=' + me.contextStatus.recordType, 'Autorefresh restarted.']);
                }
            }
        },

        _getSelectedRecordModel = function () {

            var store = listComponent.getStore(),
                id = me.getSingleID(),
                record = store.getById(id);

            return record.getModel();
        };

    var _hideAllButtonsExcept = function (elements, buttonID) {

        Ext.each(elements, function (node) {
            if (node.getXType() === 'menuitem') {
                node.setVisible(node.itemId === buttonID);
            }
        });

    };


    return {

        contextName: 'List',

        dependencies: ['Portal.CommandContext'],

        contextStatus: {},

        autoload: false,

        refreshMode: 'Auto',

        autoRefreshInterval: 0,

        filterProperties: { currentFilters: [] },

        messageListeners: [],

        init: function (initCfg) {
            var listMgrType = null;
            me = this;
            initCfg = initCfg || {};

            Portal.Console.log('LISTCONTEXT INITIALIZATION');
            Portal.Console.log(initCfg);

            _moduleCtx = me.getContext('Module');

            var listCfg = me.getConfiguration('ListContextConfig');
            if (listCfg) {
                Ext.apply(me.contextStatus, listCfg);
                me.contextStatus.controlDependencies = (initCfg.controlDependencies ? Portal.Util.Json.decode(initCfg.controlDependencies) : []);
                me.autoload = me.contextStatus.autoload;
                me.refreshMode = me.contextStatus.refreshMode;

                if (!Ext.isEmpty(me.contextStatus.filter)) {
                    me.contextStatus.filter = Portal.Util.Json.decode(me.contextStatus.filter);
                } else {
                    me.contextStatus.filter = [];
                }

                // setting initial filters
                me.filterProperties.currentFilters = me.contextStatus.filter;
            }

            // by default take grid cmp as list component
            listComponent = me.component.down('grid') || me.component.down('dataview');

            var detailCtx = me.getContext('Detail');

            var moduleParams = _moduleCtx.getModuleParams();

            if (!Ext.isEmpty(moduleParams.AutoRefreshInterval)) {
                me.autoRefreshInterval = parseInt(moduleParams.AutoRefreshInterval);
            }
            
            if (!Ext.isEmpty(moduleParams.EmptyTextTpl)) {
                _emptyTextTpl = new Ext.XTemplate(moduleParams.EmptyTextTpl);
            }

            if (!Ext.isEmpty(moduleParams.EmptyText)) {
                _defaultEmptyText = moduleParams.EmptyText;
            }

            if (!Ext.isEmpty(moduleParams.EmptyTextTpl) && !Ext.isEmpty(_defaultEmptyText)) {
                listComponent.getView().emptyText = _emptyTextTpl.apply({ EmptyText: _defaultEmptyText });
            }
            else if (!Ext.isEmpty(_defaultEmptyText)) {
                listComponent.getView().emptyText = _defaultEmptyText;
            }

            _setupStateManagement();

            _setupDetailOpeningMode(_moduleCtx);

            if (_infiniteScrollingEnabled()) _setupGridForInfiniteScrolling();

            _autoRefresh.setup();

            // init filter area (if exists)
            if (me.component.Context.FilterArea) {

                me.component.onContextReady('FilterArea', function (ctx) {
                    // sync list filters with filter area ones
                    var areaFilters = Portal.Util.removeEmptyFilters(ctx.getFilter());

                    //Mantain empty filter if specified to ListContext and remove empty filter from "FilterArea"
                    me.filterProperties.currentFilters = Portal.Util.mergeFilterArrays(me.contextStatus.filter, areaFilters, true);

                    ctx.filterSettings = me.contextStatus.filterSettings;

                });
            }

            // init filter
            me.setBaseFilter(me.filterProperties.currentFilters);

            // listen to filter change messages sent from filter area
            me.listenToMessage({
                topic: 'Portal.FilterArea.FilterChanged',
                messageFilter: 'samemodule',
                listenerFn: function (msg) {

                    var filters = msg.filters;

                    if (me.refreshMode === 'Auto') {
                        me.loadList(filters);
                    } else {
                        _updateFilters(filters);
                    }


                },
                contextName: 'FilterArea'
            });

            me.listenToMessage({
                topic: 'Portal.' + me.contextStatus.recordType + '.Update',
                messageFilter: 'public',
                listenerFn: function (msg) {
                    afterEntityInsertOrUpdate(msg);
                }
            });

            me.listenToMessage({
                topic: 'Portal.' + me.contextStatus.recordType + '.Insert',
                messageFilter: 'public',
                listenerFn: function (msg) {
                    afterEntityInsertOrUpdate(msg);
                }
            });

            me.listenToMessage({
                topic: 'Portal.' + me.contextStatus.collectionType + '.Deleted',
                messageFilter: 'public',
                listenerFn: function (msg) {
                    me.refreshList();
                }
            });

            me.listenToMessage({
                topic: 'Portal.Job.Completed',
                filter: 'private',
                listenerFn: function (msg) {
                    (new Ext.util.DelayedTask(function () {
                        me.refreshList();
                    })).delay(1000);
                }
            });

            if (me.autoload) {

                me.loadList(me.filterProperties.currentFilters);

                // On SignalR ObjectChange: notify new objects to user and refresh the list
                SignalRClient.onObjectChanged(function (type, id, showNotif, entityDescription) {

                    // Configure SignalR Refresh Task
                    if (!signalRRefreshTask) {
                        signalRRefreshTask = me.newSignalRRefreshTask(_moduleCtx, type, id, showNotif, entityDescription);
                    }

                    // Buffer SignalR Refresh Requests
                    if (type == me.contextStatus.collectionType) {
                        signalRRefreshTask.delayIfNotElapsed([type, id, showNotif]);
                    }

                });

                // On Tab Activate: if any object changed/was added, refresh the list
                var portalTab = me.component.up('[portalTab]');
