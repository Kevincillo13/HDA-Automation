            if (hyperlinkEnabled)
                this.addCls("hyperLink");
            else
                this.removeCls("hyperLink");

        }
    },

    initComponent: function () {

        // private
        var me = this,

            moduleCmp = null,

            initializeControl = function () {

                if (me.getViewMode() == 'hyperlink') {
                    me.inputEl.addListener("click", function () {

                        var value = me.getValue();

                        if (Portal.Const.Device.IsMobile && Portal.Util.isEmptyValue(value))
                            me.openSearchView();
                    });
                }
            },

            eventHandlers = {

                elKeydown: function (e) {

                    if (this.readOnly || this.isInitializing()) return;

                    // ignore TAB, ALT, CTRL, SHIFT keys
                    if (e.keyCode == e.TAB || e.keyCode == e.ALT || e.keyCode == e.CTRL || e.keyCode == e.SHIFT) return;

                    // ignore arrow keys, home, end
                    if (e.keyCode >= 35 && e.keyCode <= 40) return;

                    //if (!this.typing) this.setAsSelected(false);

                    this.removeErrorStyles();

                    this.typing = true;
                },

                blur: function (field) {

                    Portal.Console.log(['SQLLink blur', field.id]);

                    if (field.readOnly || field.isInitializing()) return;
                    field.hasFocus = false;

                    if (field.getTypedValue() === '') {
                        field.typing = false;
                        field.clearValue();
                        return;
                    }

                    if (field.typing) {
                        if (field.getTypedValue() != field.getDisplayValue()) {
                            // reset store 
                            field.getStore().removeAll();

                            // immediate search only if user typed a value to search
                            this.immediateSearch();
                            if (field.hasFocus)
                                field.typing = false;
                        } else {
                            //field.setAsSelected(true);
                            field.typing = false;
                        }
                    }
                    field.hasFocus = false;
