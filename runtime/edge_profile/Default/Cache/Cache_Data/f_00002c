Ext.define('Portal.Controls.StaticObjectLinkBase', {
    singleton: true,
        init: function (cmp, mode) {
            Ext.apply(cmp, {
                objectLinkValue: '',
                pendingValue: false,
                listLoaded: false,
                originalValue: ''
            });

            if (!cmp.deferLoading) {

                if (!cmp.isFilter) {

                    // on "formload" event load combo store
                    cmp.on('formload', function (form) {
                        if (!cmp.listLoaded) {
                            cmp.getStore().load();
                        }
                    }, null, { single: true });

                } else {

                    // when this field is used as filter, then on "render" event load combo store
                    cmp.mon(cmp, 'render', function () {
                        if (!cmp.listLoaded) {
                            cmp.getStore().load();
                        }
                    });
                }
            }

            if (mode == 'single') {
                cmp.getStore().mon(cmp.getStore(), 'load', function (store, records, successful, options) {
                    
                    //Portal.Console.log('STATIC OBJECT LINK LOAD');
                    //Portal.Console.log('Name: ' + cmp.getName());

                    // if static object link in single selection mode then insert empty item into list
                    var emptyRecIdx = store.find(cmp.valueField, Portal.Const.EMPTY_ID);
                    if (emptyRecIdx < 0) {
                        var emptyRec = {};
                        emptyRec[cmp.valueField] = String(Portal.Const.EMPTY_ID);
                        emptyRec[cmp.displayField] = "";
                        //records = [emptyRec].concat(records);
                        //store.loadRawData(records);
                        store.insert(0, emptyRec);
                    }

                    cmp.listLoaded = true;
                    // set pending value
                    var oldValue = "";
                    if (cmp.pendingValue) {
                        //Portal.Console.log('PendingValue: ' + cmp.pendingValue);
                        oldValue = cmp.objectLinkValue;
                    } else {
                        //Portal.Console.log('GetValue: ' + cmp.getValue());
                        oldValue = cmp.getValue();
                    }

                    // check last value...
                    if (!oldValue || oldValue == '') {
                        //Portal.Console.log('LastValue: ' + cmp.lastValue);
                        oldValue = cmp.lastValue;
                    }

                    // check raw value...
                    if (!oldValue || oldValue == '') {
                        //Portal.Console.log('GetRawValue: ' + cmp.getRawValue());
                        oldValue = cmp.getRawValue();
                    }

                    if (!oldValue || oldValue == '') return;

                    var oldValueParts = [];

                    if (Ext.isArray(oldValue)) {
                        oldValueParts = oldValue;
                    } else if (Ext.isString(oldValue)) {
                        oldValueParts = oldValue.split('|');
                    } else {
                        oldValueParts = [oldValue];
                    }

                    //Portal.Console.log('OldValueParts: ' + oldValueParts.join('|'));

                    var foundParts = [];

                    Ext.each(oldValueParts, function (oldValuePart) {
                        //Portal.Console.log('Typeof OldValueParts: ' + typeof oldValuePart);
                        if (store.getById(oldValuePart) != null)
                            foundParts.push(oldValuePart);
                    });

                    //Portal.Console.log('FoundParts: ' + foundParts.join('|'));
                    //Portal.Console.log('remoteStoreReady: ' + cmp.remoteStoreReady);

                    /*
                    var _store = cmp.getStore();
                    if(_store){
                        Ext.each(_store.getRange(), function (rec) {
                            Portal.Console.log('Store Record: ' + rec.getId());
                        });
                    }
                    */
                    

                    if (foundParts.length > 0) {    
                        cmp.setValueAndFireSelect(foundParts.join('|'));
                    } else {
                        if (!!cmp.forceSelection) cmp.clearValue();
                        else cmp.setValue(oldValue);
                    }

                    if (!cmp.remoteStoreReady) {
                        cmp.remoteStoreReady = true;
                        cmp.resetDirty();
                    }
                    cmp.isValid();
                });

            } else {
                cmp.getStore().mon(cmp.getStore(), 'load', function (store, records, successful, options) {
                    cmp.listLoaded = true;
                    // set pending value
                    cmp.setValue(cmp.objectLinkValue);
                    cmp.isValid();
                });
            }
        },

        setValue: function (cmp, v, doSelect) {
            var internalValue = (!v && v != 0) || Ext.isArray(v) || Ext.isObject(v) ? Portal.Const.EMPTY_ID : ('' + v);
            
            // added to avoid value reset on store load by ExtJS ComboBox implementation (me.value is set on store load complete before 'load' event is called)
            cmp.value = internalValue;

            cmp.objectLinkValue = internalValue;

            // if list is ready, call original setValue fn
            if (cmp.listLoaded) {
                cmp.pendingValue = false;

                return cmp.superclass.setValue.call(cmp, internalValue, doSelect);
            }
            // if store is not ready the keep track of the value to set
            //Portal.Console.log('set value "' + v + '" skipped for ' + cmp.getName() + ', waiting for store loading');
            cmp.pendingValue = true;
        },

        getValue: function (cmp) {
            if (cmp.listLoaded) {
                return cmp.superclass.getValue.call(cmp);
            }
            return cmp.objectLinkValue;
        },

        clearValue: function (cmp) {
            cmp.objectLinkValue = Portal.Const.EMPTY_ID;
            cmp.pendingValue = false;
            cmp.superclass.clearValue.call(cmp);
    },

    autoResolve: function (cmp, filter) {
       
        if (cmp.store.data.length == 1 || cmp.store.data.length == 2) {
            //first record is Empty record
            var tt = cmp.store.data.items[cmp.store.data.length-1].data.ID;
            cmp.setValue(tt);
        } 
    }
});
