            if (_.isUndefined(buttons[0].default))
                buttons[0].default = true;
        }

        this.buttons = buttons;
    },

    updateMsg: function (msg) {
        this.setMsg(msg);

        this.refresh();
    },

    updateMask: function (cfg) {

        cfg = cfg || {};

        this.setMsg(cfg.msg);

        this.setContentCls(cfg.contentCls || 'loading');

        this.setAutoDismiss(!_.isUndefined(cfg.autoDismiss) ? cfg.autoDismiss : false);

        var buttons = cfg.buttons || [];

        if (this.autoDismiss && _.isEmpty(buttons)) {
            buttons.push({ cls: 'btn-secondary', text: translations['Portal_LoadMask_Dismiss'], action: 'Dismiss', default: true });
        }
        
        this.setButtons(buttons);

        if (!this.autoDismiss) {
            this.stopAutoDismissCountdown();
        } else {
            this.setAutoDismissTimeout(
                !_.isUndefined(cfg.autoDismissTimeout) ?
                    cfg.autoDismissTimeout :
                    this.statics().DEFAULT_AUTODISMISS_TIMEOUT
