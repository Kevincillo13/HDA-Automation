Ext.define("Portal.Analysis.KpiBehaviour", {
    extend: "Portal.Analysis.AnalysisBehaviourBase",
    constructor: function () {
        var me = this,
            _page = null,
            _dataSource = [],
            _container = null;

        me.callParent(arguments);

        var _getTemplateFromParam = function (container, templateName, templateObject) {
            if (container.templateParameters && container.templateParameters[templateName]) {
                var tpl = new Ext.XTemplate(container.templateParameters[templateName]);
                return tpl.apply(templateObject);
            }

            return "";
        };

        var initializeAnalysis = function (container) {
            updateAnalysis(container);
        };

        var updateAnalysis = function (container) {
            if (_page) {
                _page.destructor();
            }

            var defaultDay = container.data.length > 0
                ? moment(_.min(_.map(container.data, function (x) { return x.Day }))).subtract(1, "days").toDate()
                : moment();
            _dataSource.push({ id: "0", value: 0, day: defaultDay });
            for (var i = 1; i <= container.data.length; i++) {
                _dataSource.push({ id: i.toString(), value: container.data[i - 1].Total, day: container.data[i - 1].Day });
            }

            var templateObject = {
                Object: {}
            };
            if (_dataSource.length > 1) {
                templateObject.Object.current = {
                    value: _dataSource[_dataSource.length - 1].value,
                    date: _dataSource[_dataSource.length - 1].day
                };

                templateObject.Object.previous = {
                    value: _dataSource.length > 1 ? _dataSource[_dataSource.length - 2].value : 0,
                    date: _dataSource.length > 1 ? (_dataSource[_dataSource.length - 2].day == _dataSource[_dataSource.length - 1].day ? moment(templateObject.Object.current.date).subtract(1, 'days').toDate() : _dataSource[_dataSource.length - 2].day) : moment(templateObject.Object.current.date).subtract(1, 'days').toDate()
                };
            }

            if (container.baseParameters) {
                templateObject.Parameters = {};
                container.baseParameters.forEach(p => templateObject.Parameters[p.name] = p.value || p.defaultValue);
            }

            var titleTemplate = _getTemplateFromParam(container, 'TitleTemplate', templateObject),
                dateTemplate = _getTemplateFromParam(container, 'DateTemplate', templateObject),
                valueTemplate = _getTemplateFromParam(container, 'ValueTemplate', templateObject),
                subValueTemplate = _getTemplateFromParam(container, 'SubValueTemplate', templateObject);

            var panel = container.component.down('#TemplatePanel'),
                body = panel.getBody();

            _container = document.getElementById(body.id);
            _container.style["overflow"] = "hidden";
            _container.style["overflow-x"] = "hidden";
            _container.style["overflow-y"] = "hidden";

            var template = `                
                <div class="container">
                    <span class="title">{titleTemplate}</span>
                    <div>
                        <span class="date">{dateTemplate}</span>
                        <span class="value">{valueTemplate}</span>
                        <div class="sub-value">{subValueTemplate}</div>
                    </div>
                </div>`.format({
                titleTemplate: titleTemplate,
                dateTemplate: dateTemplate,
                valueTemplate: valueTemplate,
                subValueTemplate: subValueTemplate
            })

            webix.ready(function () {
                _page = webix.ui({
                    view: "gridlayout",
                    container: _container,
                    gridColumns: 1, gridRows: 1,
                    padding: 0,
                    margin: 0,
                    height: parseInt(_container.style.height),
                    borderless: true,
                    cells: [
                        {
                            view: "chart",
                            type: "area",
                            value: "#value#",
                            data: _dataSource,
                            x: 0, y: 0,
                            dx: 1, dy: 1,
                            item: { radius: 0 },
                            borderless: true,
                            offset: false,
                            padding: { left: 0, right: 0, bottom: 0 },
                            alpha: 0.2,
                            color: "#459DFE",
                        },
                        {
                            view: "template",
                            borderless: true,
                            template: template,
                            x: 0, y: 0,
                            dx: 1, dy: 1,
                            css: "HDA_KPI_Webix_Spline",
                            tooltip: function (obj) {
                                var template = _getTemplateFromParam(container, 'TooltipTemplate', templateObject)
                                return template;
                            }
                        }
                    ]
                });
            });
        };

        // public (overrides)
        me.initializeAnalysis = initializeAnalysis;
        me.updateAnalysis = updateAnalysis;
    },
});
